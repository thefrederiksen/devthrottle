<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Proof harness for issue #582: usage-telemetry toggle gate plus read-back.
    Standalone console (NOT part of cc-director.sln) referencing CcDirector.Core. Run with:
      dotnet run with this project as the target.
    It writes its output to the parent proof folder as telemetry-gate-output.txt, using an isolated
    CC_DIRECTOR_ROOT so it never touches the user's real config.json.
  -->
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>TelemetryGateHarness</AssemblyName>
    <RootNamespace>CcDirector.Proof.Issue582</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\..\..\src\CcDirector.Core\CcDirector.Core.csproj" />
  </ItemGroup>

</Project>
