<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <AssemblyName>cc-director-gateway</AssemblyName>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <RootNamespace>CcDirector.Gateway</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
    <!-- Lets the Gateway run as a first-class Windows service (SCM integration) without NSSM.
         A no-op when launched from a console, so dev `dotnet run` is unchanged. -->
    <PackageReference Include="Microsoft.Extensions.Hosting.WindowsServices" Version="10.0.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\CcDirector.Gateway.Contracts\CcDirector.Gateway.Contracts.csproj" />
    <ProjectReference Include="..\CcDirector.Core\CcDirector.Core.csproj" />
    <!-- Setup engine: the Cockpit supervisor auto-updates the Cockpit in place (CockpitUpdater). -->
    <ProjectReference Include="..\..\tools\cc-director-setup-engine\CcDirector.Setup.Engine.csproj" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="CcDirector.Gateway.Tests" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Web\manager.html" />
    <EmbeddedResource Include="Web\login.html" />
    <EmbeddedResource Include="Web\directory.html" />
    <EmbeddedResource Include="Web\api.html" />
    <EmbeddedResource Include="Web\transcripts.html" />
    <EmbeddedResource Include="Web\dictionary.html" />
    <EmbeddedResource Include="Web\exes.html" />
  </ItemGroup>

</Project>
