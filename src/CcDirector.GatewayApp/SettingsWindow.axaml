<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CcDirector.GatewayApp.SettingsWindow"
        Title="CC Director Gateway"
        Width="480" Height="600"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        RequestedThemeVariant="Dark"
        Background="#1E1E1E">

  <DockPanel Margin="20">

    <!-- Header -->
    <StackPanel DockPanel.Dock="Top" Spacing="2">
      <TextBlock Text="CC Director Gateway" FontSize="18" FontWeight="SemiBold" Foreground="#CCCCCC"/>
      <TextBlock x:Name="VersionText" Text="" FontSize="11" Foreground="#888888"/>
    </StackPanel>

    <!-- Footer buttons -->
    <DockPanel DockPanel.Dock="Bottom" Margin="0,16,0,0">
      <Button x:Name="CloseButton" DockPanel.Dock="Right" Content="Close"
              Background="#007ACC" Foreground="#FFFFFF" Padding="16,6" CornerRadius="2"/>
      <StackPanel Orientation="Horizontal" Spacing="8">
        <Button x:Name="OpenLogsButton" Content="Open Logs"
                Background="#3C3C3C" Foreground="#CCCCCC" Padding="12,6" CornerRadius="2"/>
        <Button x:Name="OpenConfigButton" Content="Open Config"
                Background="#3C3C3C" Foreground="#CCCCCC" Padding="12,6" CornerRadius="2"/>
      </StackPanel>
    </DockPanel>

    <!-- Body -->
    <StackPanel Spacing="16" Margin="0,18,0,0">

      <!-- Status panel: this window is now a pure status light. All configuration
           (API keys, brain, startup) lives in the Cockpit Settings page below. -->
      <Border Background="#252526" CornerRadius="3" Padding="14">
        <StackPanel Spacing="10">
          <TextBlock Text="STATUS" FontSize="11" FontWeight="SemiBold" Foreground="#888888"/>
          <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">
            <Grid.Styles>
              <Style Selector="TextBlock.label">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Foreground" Value="#AAAAAA"/>
                <Setter Property="Margin" Value="0,0,0,6"/>
              </Style>
              <Style Selector="TextBlock.value">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Foreground" Value="#CCCCCC"/>
                <Setter Property="Margin" Value="0,0,0,6"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
              </Style>
            </Grid.Styles>
            <TextBlock Grid.Row="0" Grid.Column="0" Classes="label" Text="State"/>
            <TextBlock Grid.Row="0" Grid.Column="1" Classes="value" x:Name="StateText" Text="..."/>
            <TextBlock Grid.Row="1" Grid.Column="0" Classes="label" Text="Port"/>
            <TextBlock Grid.Row="1" Grid.Column="1" Classes="value" x:Name="PortText" Text="..."/>
            <TextBlock Grid.Row="2" Grid.Column="0" Classes="label" Text="Uptime"/>
            <TextBlock Grid.Row="2" Grid.Column="1" Classes="value" x:Name="UptimeText" Text="..."/>
            <TextBlock Grid.Row="3" Grid.Column="0" Classes="label" Text="Directors"/>
            <TextBlock Grid.Row="3" Grid.Column="1" Classes="value" x:Name="DirectorsText" Text="..."/>
            <TextBlock Grid.Row="4" Grid.Column="0" Classes="label" Text="Cockpit"/>
            <TextBlock Grid.Row="4" Grid.Column="1" Classes="value" x:Name="CockpitText" Text="..."/>
            <TextBlock Grid.Row="5" Grid.Column="0" Classes="label" Text="Mode"/>
            <TextBlock Grid.Row="5" Grid.Column="1" Classes="value" x:Name="ModeText" Text="..."/>
            <TextBlock Grid.Row="6" Grid.Column="0" Classes="label" Text="Brain"/>
            <TextBlock Grid.Row="6" Grid.Column="1" Classes="value" x:Name="BrainLineText" Text="..."/>
          </Grid>
        </StackPanel>
      </Border>

      <!-- About / installed: what this Gateway box is running and the versions on disk. -->
      <Border Background="#252526" CornerRadius="3" Padding="14">
        <StackPanel Spacing="10">
          <TextBlock Text="ABOUT / INSTALLED" FontSize="11" FontWeight="SemiBold" Foreground="#888888"/>
          <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto,Auto">
            <Grid.Styles>
              <Style Selector="TextBlock.label">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Foreground" Value="#AAAAAA"/>
                <Setter Property="Margin" Value="0,0,0,6"/>
              </Style>
              <Style Selector="TextBlock.value">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Foreground" Value="#CCCCCC"/>
                <Setter Property="Margin" Value="0,0,0,6"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
              </Style>
            </Grid.Styles>
            <TextBlock Grid.Row="0" Grid.Column="0" Classes="label" Text="Build date"/>
            <TextBlock Grid.Row="0" Grid.Column="1" Classes="value" x:Name="BuildDateText" Text="..."/>
            <TextBlock Grid.Row="1" Grid.Column="0" Classes="label" Text="Cockpit URL"/>
            <TextBlock Grid.Row="1" Grid.Column="1" Classes="value" x:Name="CockpitUrlText" Text="resolving..."/>
            <TextBlock Grid.Row="2" Grid.Column="0" Classes="label" Text="Install root"/>
            <TextBlock Grid.Row="2" Grid.Column="1" Classes="value" x:Name="InstallRootText" Text="..."/>
            <TextBlock Grid.Row="3" Grid.Column="0" Classes="label" Text="Installed"/>
            <TextBlock Grid.Row="3" Grid.Column="1" Classes="value" x:Name="InstalledText" Text="..."/>
          </Grid>
        </StackPanel>
      </Border>

      <!-- The bridge to the one settings home (docs/architecture/gateway/SETTINGS_OWNERSHIP.md):
           configuration moved into the Cockpit, so this window points there instead of
           duplicating the controls. -->
      <StackPanel Spacing="8">
        <Button x:Name="OpenSettingsButton" Content="Open Settings in Cockpit"
                Background="#007ACC" Foreground="#FFFFFF" Padding="16,8" CornerRadius="2"
                HorizontalAlignment="Left"/>
        <TextBlock Text="API keys, the Brain (restart), and startup now live in the Cockpit. This window just shows whether the Gateway is alive."
                   FontSize="10" Foreground="#666666" TextWrapping="Wrap"/>
      </StackPanel>

    </StackPanel>
  </DockPanel>
</Window>
