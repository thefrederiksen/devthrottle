<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CcDirector.GatewayApp.PairingWindow"
        Title="Add a device"
        Width="400" Height="620"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        RequestedThemeVariant="Dark"
        Background="#1E1E1E">

  <DockPanel Margin="20">

    <StackPanel DockPanel.Dock="Top" Spacing="4">
      <TextBlock Text="ADD A DEVICE" FontSize="11" FontWeight="SemiBold" Foreground="#888888"/>
    </StackPanel>

    <!-- State 1: idle - account sign-in is the PRIMARY way to add a device; the 4-digit
         pairing code is offered below as a clearly secondary fallback. -->
    <ScrollViewer x:Name="IdlePanel" VerticalScrollBarVisibility="Auto" Margin="0,16,0,0">
      <StackPanel Spacing="14">

        <!-- Primary: sign in with your DevThrottle account -->
        <StackPanel Spacing="10">
          <TextBlock Text="Sign in with your DevThrottle account"
                     FontSize="16" FontWeight="SemiBold" Foreground="#FFFFFF" TextWrapping="Wrap"/>
          <TextBlock Text="On the new device, scan this code (or open the link below) and sign in to the same DevThrottle account. Signing into the same account is what joins the device here."
                     FontSize="13" Foreground="#CCCCCC" TextWrapping="Wrap"/>

          <Border Background="#FFFFFF" CornerRadius="3" Padding="12"
                  HorizontalAlignment="Center">
            <Panel Width="180" Height="180">
              <Image x:Name="QrImage" Width="180" Height="180"/>
              <TextBlock x:Name="QrFallbackText" Text="Preparing sign-in code..."
                         FontSize="12" Foreground="#666666"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Panel>
          </Border>

          <TextBlock Text="Or open this link on the new device:"
                     FontSize="11" Foreground="#888888"/>
          <SelectableTextBlock x:Name="SignInUrlText" Text=""
                               FontSize="12" FontFamily="Consolas,Courier New"
                               Foreground="#4FC1FF" TextWrapping="Wrap"/>
        </StackPanel>

        <Border Height="1" Background="#3C3C3C" Margin="0,4,0,4"/>

        <!-- Secondary fallback: the 4-digit pairing code (issue #469) -->
        <StackPanel Spacing="8">
          <TextBlock Text="NO ACCOUNT HANDY? USE A PAIRING CODE INSTEAD"
                     FontSize="11" FontWeight="SemiBold" Foreground="#888888" TextWrapping="Wrap"/>
          <TextBlock Text="Show a one-time pairing code on this screen, then type it into the new machine's Connect to Gateway dialog."
                     FontSize="12" Foreground="#AAAAAA" TextWrapping="Wrap"/>
          <Button x:Name="ShowCodeButton" Content="Show a pairing code"
                  Background="#3C3C3C" Foreground="#CCCCCC" Padding="14,8" CornerRadius="2"
                  BorderThickness="0" HorizontalAlignment="Left"/>
        </StackPanel>

      </StackPanel>
    </ScrollViewer>

    <!-- State 2: waiting - the 4-digit code with countdown (the fallback in progress) -->
    <StackPanel x:Name="CodePanel" Spacing="12" Margin="0,18,0,0" IsVisible="False">
      <TextBlock Text="Type this code into the new Director's Connect to Gateway dialog."
                 FontSize="13" Foreground="#CCCCCC" TextWrapping="Wrap"/>
      <Border Background="#252526" CornerRadius="3" Padding="14">
        <StackPanel Spacing="10">
          <TextBlock x:Name="CodeText" Text="0000" FontSize="46" FontFamily="Consolas,Courier New"
                     Foreground="#FFFFFF" HorizontalAlignment="Center"
                     LetterSpacing="10"/>
          <TextBlock x:Name="CountdownText" Text="Expires in 5:00" FontSize="12"
                     FontFamily="Consolas,Courier New" Foreground="#F0B848"
                     HorizontalAlignment="Center"/>
        </StackPanel>
      </Border>
      <TextBlock x:Name="WaitText" Text="Waiting for the device..." FontSize="12" Foreground="#AAAAAA"
                 HorizontalAlignment="Center"/>
      <Button x:Name="CancelCodeButton" Content="Cancel"
              Background="#3C3C3C" Foreground="#CCCCCC" Padding="12,6" CornerRadius="2"
              BorderThickness="0" HorizontalAlignment="Center"/>
    </StackPanel>

    <!-- State 3: joined - confirmation -->
    <StackPanel x:Name="JoinedPanel" Spacing="14" Margin="0,24,0,0" IsVisible="False"
                VerticalAlignment="Center">
      <Border Background="#14241A" BorderBrush="#2E7D32" BorderThickness="1" CornerRadius="3" Padding="16">
        <StackPanel Spacing="6">
          <TextBlock x:Name="JoinedTitleText" Text="Device joined" FontSize="15" FontWeight="SemiBold"
                     Foreground="#CFE9CF"/>
          <TextBlock x:Name="JoinedSubText" Text="" FontSize="12" Foreground="#8FB98F"/>
        </StackPanel>
      </Border>
      <Button x:Name="DoneButton" Content="Done"
              Background="#007ACC" Foreground="#FFFFFF" Padding="16,8" CornerRadius="2"
              BorderThickness="0" HorizontalAlignment="Left"/>
    </StackPanel>

  </DockPanel>
</Window>
