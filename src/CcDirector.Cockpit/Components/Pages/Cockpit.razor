    // ===== Right panel tabs (Screenshots / Queue / Director) =====
    private string _rightTab = "shots";

    private async Task SetRightTab(string tab)
    {
        if (tab is not ("shots" or "queue" or "director")) return;
        ActionInfo("right-tab", $"tab={tab}");
        _rightTab = tab;
        await SavePref("cockpit.rightTab", tab);
        await LoadRightTabAsync();
    }

    // Lazy-load the data the active tab needs. Queue is already polled; Director is static
    // session data. Screenshots fetch on demand and are cleared on session switch.
    private async Task LoadRightTabAsync()
    {
        if (_rightTab == "shots" && _shots.Count == 0) await LoadScreenshotsAsync();
    }

    // ===== Screenshots gallery =====
    // Same-origin to the Gateway (issue #317): the Gateway resolves the owning Director by sid
    // and proxies the image bytes, so a remote browser never needs the Director's (possibly
    // loopback) address - the same fix #268 made for the WS legs. All three byte sinks
    // (thumbnail <img>, View, Copy) flow through this one builder.
    private string ShotUrl(string fileName)
    {
        var sid = Selected?.SessionId;
        if (string.IsNullOrWhiteSpace(sid)) return "";
        return CockpitShotUrls.Screenshot(Nav.BaseUri, sid, fileName);
    }

    private async Task LoadScreenshotsAsync()
    {
        var sel = Selected;
        if (sel is null) return;
        _shotsBusy = true;
        _shotsError = null;
        _shotsOffline = false;
        await InvokeAsync(StateHasChanged);
        try
        {
            using var cts = CancellationTokenSource.CreateLinkedTokenSource(_cts.Token);
            cts.CancelAfter(TimeSpan.FromSeconds(10));
            var r = await Director.GetScreenshotsAsync(sel.SessionId, ShotsFetchCount, cts.Token);
            _shots = r.Items;
            // Old Directors ignore ?count and report Total=0: everything came back, so the
            // list itself is the total.
            _shotsTotal = Math.Max(r.Total, r.Items.Count);
            _shotsShown = ShotsInitialShown;
        }
        catch (OperationCanceledException) { }
        catch (ScreenshotsDirectorOfflineException ex)
        {
            // Issue #412: the owning Director is offline - show the graceful message + Retry, not
            // the raw "Response status code does not indicate success: 503" string.
            _shotsOffline = true;
            Log.LogWarning(ex, "LoadScreenshots: owning director offline");
        }
        catch (Exception ex)
        {
            _shotsError = "Could not load screenshots from the Director. Use Refresh to try again.";
            Log.LogWarning(ex, "LoadScreenshots failed");
        }
        finally
        {
            _shotsBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private Task RefreshScreenshots()
    {
        _shots = new();   // force a reload (LoadScreenshotsAsync replaces wholesale anyway)
        return LoadScreenshotsAsync();
    }

    // Clear the displayed list only (does NOT delete files) - matches the desktop's "Clear All".
    private void ClearScreenshots()
    {
        _shots = new();
        _shotsTotal = 0;
        _shotsShown = ShotsInitialShown;
    }

    // Reveal the next batch of already-fetched thumbnails (no network call).
    private void ShowMoreShots() => _shotsShown += ShotsShowMoreStep;

    // View: open the image full-size in a new browser tab at the same-origin Gateway URL.
    private async Task ViewScreenshot(string fileName)
    {
        var url = ShotUrl(fileName);
        if (string.IsNullOrEmpty(url)) return;
        try { await JS.InvokeVoidAsync("window.open", url, "_blank"); }
        catch (Exception ex) { Log.LogDebug(ex, "ViewScreenshot open failed"); }
    }

    // Copy: put the actual image on the browser clipboard (the Director-side path is meaningless
    // on whatever device is viewing the Cockpit). cockpit-shots.js fetches the bytes and writes a
    // ClipboardItem, converting to PNG via canvas when needed.
    private async Task CopyScreenshot(string fileName)
    {
        var url = ShotUrl(fileName);
        if (string.IsNullOrEmpty(url)) return;
        try
        {
            var mod = await ShotsModule();
            var ok = await mod.InvokeAsync<bool>("copyImage", url);
            _shotStatus = ok ? "copied image to clipboard" : "copy failed (clipboard blocked)";
        }
        catch (Exception ex)
        {
            _shotStatus = $"copy failed: {ex.Message}";
            Log.LogWarning(ex, "CopyScreenshot failed");
        }
        await InvokeAsync(StateHasChanged);
    }

    private async Task DeleteScreenshot(string fileName)
    {
        var sel = Selected;
        if (sel is null) return;
        try
        {
            await Director.DeleteScreenshotAsync(sel.SessionId, fileName, _cts.Token);
            _shots = _shots.Where(s => s.FileName != fileName).ToList();
        }
        catch (Exception ex)
        {
            _shotsError = $"delete failed: {ex.Message}";
            Log.LogWarning(ex, "DeleteScreenshot failed");
        }
        await InvokeAsync(StateHasChanged);
    }

    private IJSObjectReference? _shotsJsModule;

    // The import travels the same HTTP front door as the page itself, but a long-lived page's
    // Blazor circuit survives a front-door outage (the WebSocket is already established), so
    // this import can be the first request to DISCOVER the door is dead - and the browser then
    // throws a raw "Failed to fetch dynamically imported module" TypeError that used to leak
    // straight into the status line (issue #200). Translate the boundary failure into a
    // message the user can act on; the field stays null on failure, so the next action retries.
    private async Task<IJSObjectReference> ShotsModule()
    {
        if (_shotsJsModule is not null) return _shotsJsModule;
        try
        {
            return _shotsJsModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/cockpit-shots.js");
        }
        catch (Exception ex)
        {
            Log.LogWarning(ex, "cockpit-shots.js import failed - gateway front door unreachable?");
            throw new InvalidOperationException("connection to the gateway was interrupted - try again", ex);
        }
    }

    // ===== Session Story column (Wingman center tab): headline + tokens + turn history + recap =====

