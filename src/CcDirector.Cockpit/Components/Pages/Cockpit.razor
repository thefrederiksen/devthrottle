@page "/cockpit"
@page "/cockpit/{SidParam}"
@using System.Reflection
@inject GatewayClient Gateway
@inject DirectorClient Director
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject ILogger<Cockpit> Log
@implements IDisposable

<div class="shell">
    <header class="topbar">
        <span class="brand">CC Director</span>
        <span class="brand-sub">Gateway Cockpit</span>

        <span class="counts">
            <span class="count-total">@_sessions.Count sessions</span>
            @if (NeedsYou > 0)
            {
                <span class="count-needs">@NeedsYou need you</span>
            }
            @if (_errors.Count > 0)
            {
                <span class="count-err">@_errors.Count director@(_errors.Count == 1 ? "" : "s") unreachable</span>
            }
        </span>

        <span class="topbar-right">
            <button class="btn tb" @onclick="OpenNewSession" title="Start a new session on any Director">+ New session</button>
            <button class="btn tb" @onclick="OpenFanout" title="Broadcast a prompt to several sessions">Fan-out</button>
            <button class="btn tb" @onclick="OpenSettings" title="Edit a Director's settings">Settings</button>
            <span class="gw" title="Gateway base URL">@Gateway.BaseUrl</span>
            <span class="ver" title="@VersionFull">@VersionDisplay</span>
            <span class="refreshed">@(_lastRefresh is null ? "connecting..." : $"updated {_lastRefresh:HH:mm:ss}")</span>
        </span>
    </header>

    @if (_lastError is not null)
    {
        <div class="banner-error">Gateway error: @_lastError</div>
    }

    <div class="body @(_leftCollapsed ? "body-collapsed" : "")">
        <aside class="left @(_leftCollapsed ? "left-collapsed" : "")">
            @if (_leftCollapsed)
            {
                @* Collapsed: a thin rail of status dots so at-a-glance awareness survives,
                   plus an expand control. Click a dot to jump to that session. *@
                <button class="left-expand" title="Expand sessions" @onclick="ToggleLeft">&raquo;</button>
                <div class="rail-mini">
                    @foreach (var s in SessionOrdering.InDesktopOrder(_sessions))
                    {
                        <button type="button"
                                class="@($"mini-dot{(s.SessionId == _selectedId ? " mini-sel" : "")}")"
                                style="background:@DotColor(SessionOrdering.EffectiveColor(s))"
                                title="@($"{SessionTitle(s)} - {s.ActivityState}")"
                                @onclick="@(() => OnSelect(s.SessionId, "rail-mini"))"></button>
                    }
                </div>
            }
            else
            {
                <div class="left-head">
                    <div class="view-toggle" role="tablist">
                        <button class="@($"vt{(_viewMode == "tree" ? " vt-on" : "")}")"
                                @onclick='() => SetViewMode("tree")'
                                title="Machine / Director tree, in desktop order">Tree</button>
                        <button class="@($"vt{(_viewMode == "triage" ? " vt-on" : "")}")"
                                @onclick='() => SetViewMode("triage")'
                                title="Needs-you first, on-hold last">Triage</button>
                    </div>
                    <button class="left-collapse" title="Collapse panel" @onclick="ToggleLeft">&laquo;</button>
                </div>
                @if (_railNotice is not null)
                {
                    <div class="rail-notice">@_railNotice</div>
                }
                <SessionRail Sessions="_sessions"
                             Errors="_errors"
                             Directors="_directors"
                             SelectedSessionId="@_selectedId"
                             ClosingSessionIds="ClosingSessionIds"
                             ViewMode="@_viewMode"
                             OnSelect="@(sid => OnSelect(sid, "rail"))"
                             OnNewSession="OpenNewSessionFor"
                             OnMenuAction="OnRailMenuAction" />
            }
        </aside>

        <main class="right">
            @if (Selected is null)
            {
                <div class="right-empty">
                    <div class="right-empty-title">Select a session</div>
                    <div class="right-empty-sub">Pick a session on the left to drive it: live terminal, screenshots, queue, and the composer.</div>
                </div>
            }
            else if (string.IsNullOrWhiteSpace(Selected.TailnetEndpoint))
            {
                <div class="detail-head">
                    <span class="detail-dot" style="background:@DotColor(SessionOrdering.EffectiveColor(Selected))"></span>
                    <span class="detail-name">@SessionTitle(Selected)</span>
                    <span class="detail-state">@(Selected.AssessedState ?? Selected.ActivityState)</span>
                </div>
                <div class="right-empty">
                    <div class="right-empty-sub">This session's Director has no tailnet endpoint, so it can't be driven over Tailscale. (Restart that Director with the current build so it registers a reachable https endpoint.)</div>
                </div>
            }
            else
            {
                <div class="detail-head">
                    @* Effective color, same rule as the rail and triage (issue #196): the
                       header dot must never show red while the chip says the wingman is
                       still reading. *@
                    <span class="detail-dot" style="background:@DotColor(SessionOrdering.EffectiveColor(Selected))"></span>
                    @if (_renaming)
                    {
                        <input class="rename-input" @bind="_renameText" @bind:event="oninput" @onkeydown="OnRenameKey" autofocus />
                        <button class="btn tb" @onclick="SaveRename" disabled="@_acting">Save</button>
                        <button class="btn tb" @onclick="() => _renaming = false">Cancel</button>
                    }
                    else
                    {
                        <span class="detail-name">@SessionTitle(Selected)</span>
                    }
                    @* Session type (issue #211): the badge rides next to the name in the
                       header too, so the open session declares its purpose. *@
                    @if (Selected.Type == "Discuss")
                    {
                        <span class="tag tag-type tag-discuss" title="Discussion session - talk only, no edits or commits">[D] discuss</span>
                    }
                    else if (Selected.Type == "BugReport")
                    {
                        <span class="tag tag-type tag-bug" title="Bug-report session - investigate and file an issue, never fix here">[B] bug report</span>
                    }
                    else if (Selected.Type == "IssueSubmitter")
                    {
                        <span class="tag tag-type tag-submit" title="Issue-submitter session - files GitHub issues only, never writes code">[S] issue submitter</span>
                    }
                    else if (Selected.Type == "QA")
                    {
                        <span class="tag tag-type tag-qa" title="QA session - verifies what was built, never fixes; reports findings">[Q] QA</span>
                    }
                    <span class="detail-meta">@Selected.MachineName / director @ShortId(Selected.DirectorId)</span>
                    @* assessed-when-present (issue #186): the Gateway's brain may have refuted
                       the mechanical quiet; the raw detector state is the fallback. *@
                    <span class="detail-state">@(Selected.AssessedState ?? Selected.ActivityState)</span>
                    @if (SessionOrdering.IsBriefing(Selected))
                    {
                        <span class="briefing-chip">wingman reading...</span>
                    }
                    <span class="detail-actions">
                        @if (!_renaming)
                        {
                            <button class="btn tb" @onclick="OpenAwareness" title="Recap + turn summaries for this session">What's happening</button>
                            <button class="btn tb" @onclick="OpenHandover" title="Hand this session's context to another session">Handover</button>
                            <button class="btn tb" @onclick="StartRename" title="Rename this session">Rename</button>
                        }
                        @if (_killArmed)
                        {
                            <button class="btn tb danger" @onclick="KillSelected" disabled="@_acting">Confirm kill</button>
                            <button class="btn tb" @onclick="() => _killArmed = false">Cancel</button>
                        }
                        else
                        {
                            <button class="btn tb danger" @onclick="() => _killArmed = true" title="Kill this session">Kill</button>
                        }
                    </span>
                </div>

                <div class="detail-split">
                    @* ---- Center column: Brief (default) or Terminal, + composer ---- *@
                    <div class="center">
                        <div class="center-tabs">
                            <button class="ctab @(CenterTab == "brief" ? "on" : "")" @onclick="@(() => SetCenterTab("brief"))">Wingman</button>
                            <button class="ctab @(CenterTab == "term" ? "on" : "")" @onclick="@(() => SetCenterTab("term"))">Terminal</button>
                            <span class="center-tabs-spacer"></span>
                            @* Needs-you conveyor: flip through the sessions waiting on the user,
                               in the same order the rail's triage view shows them. *@
                            @if (NeedsYouOrdered.Count > 0)
                            {
                                <span class="ny-nav">
                                    <button class="ny-btn" title="Previous session that needs you" @onclick="() => StepNeedsYou(-1)">&#9664;</button>
                                    <span class="ny-count">@NeedsYouPosLabel</span>
                                    <button class="ny-btn" title="Next session that needs you" @onclick="() => StepNeedsYou(1)">&#9654;</button>
                                </span>
                            }
                        </div>
                        @if (CenterTab == "term")
                        {
                            @* Lazy: the stream socket only opens when the Terminal tab is opened,
                               so flipping through briefs never pays the replay cost. *@
                            <div class="term-wrap">
                                <TerminalPane @key="Selected.SessionId" SessionId="@Selected.SessionId" DirectorBase="@Selected.TailnetEndpoint" RowState="@(Selected.AssessedState ?? Selected.ActivityState)" />
                            </div>
                        }
                        else
                        {
                            @* The Wingman tab splits: brief on the left, the SESSION STORY as a
                               FIXED right column - headline + tokens + turn cards stay on screen
                               at all times while this tab is open (they never hide behind the
                               shared right panel's tab flips). *@
                            <div class="brief-split">
                                <div class="brief-scroll">
                                    @if (!string.IsNullOrEmpty(_quickReplyNotice))
                                    {
                                        @* Issue #227: explicit answer-transition / acknowledged
                                           notice - no silent conveyor teleport, and the
                                           only-one-needs-you case gets immediate feedback. *@
                                        <div class="quick-reply-notice">
                                            <span class="quick-reply-notice-dot"></span>
                                            <span>@_quickReplyNotice</span>
                                        </div>
                                    }
                                    <BriefPane @key="Selected.SessionId" SessionId="@Selected.SessionId"
                                               DirectorBase="@Selected.TailnetEndpoint"
                                               ActivityState="@Selected.ActivityState"
                                               BriefingState="@Selected.BriefingState"
                                               OnOpenTerminal="@(() => SetCenterTab("term"))"
                                               OnQuickReply="QuickReplyAsync"
                                               Replying="@_quickReplying"
                                               OnCloseSession="CloseSelectedFromBriefAsync"
                                               OnExplainPending="OnExplainPending" />
                                </div>

                                <aside class="story-col">
                                    <div class="rightpanel-head">
                                        <span class="rightpanel-title">SESSION STORY</span>
                                        <button class="linkbtn" @onclick="GenerateRecap" disabled="@_recapBusy">@(_recapBusy ? "generating (~90s)..." : "Recap")</button>
                                    </div>
                                    <div class="story-body">
                                        @if (!string.IsNullOrEmpty(_awareError))
                                        {
                                            <div class="gallery-error">@_awareError</div>
                                        }

                                        @* ---- HEADLINE: the session's newspaper front page (TurnBrief v2.2).
                                           Re-judged by the wingman every turn, changed only when the story
                                           changes - "since turn N" walks the stored briefs to the last change. ---- *@
                                        @if (!string.IsNullOrEmpty(StoryHeadline))
                                        {
                                            <div class="story-headline">@StoryHeadline</div>
                                            @if (HeadlineSinceTurn is int since)
                                            {
                                                <div class="story-since">headline since turn @since</div>
                                            }
                                        }
                                        else if (_turnTimeline is { Count: > 0 })
                                        {
                                            @* Pre-v2.2 briefs carry no headline - fall back to the rolling intent. *@
                                            <div class="story-headline story-headline-fallback">@_turnTimeline[0].Intent</div>
                                        }

                                        @* ---- TOKENS: session totals from the transcript's usage blocks ---- *@
                                        @if (_usage is not null)
                                        {
                                            <div class="tl-label">TOKENS THIS SESSION</div>
                                            <div class="story-tokens">
                                                <span title="uncached input tokens (sum)">in @FmtTokens(_usage.InputTokens)</span>
                                                <span title="output tokens (sum)">out @FmtTokens(_usage.OutputTokens)</span>
                                                <span title="cache reads (sum)">cache @FmtTokens(_usage.CacheReadTokens)</span>
                                                <span title="latest context size (input + cache)">ctx @FmtTokens(_usage.ContextTokens)</span>
                                            </div>
                                        }

                                        @* ---- CHAPTERS: the things this session has worked on - one collapsed
                                           card per chapter (wingman's explicit NewChapter signal, never a
                                           string compare). Scanning beats reading: title only by default,
                                           expand for the turn descriptions inside. ---- *@
                                        <div class="tl-label">CHAPTERS</div>
                                        @if (_turnTimeline is null)
                                        {
                                            <div class="aware-muted">Loading&hellip;</div>
                                        }
                                        else if (_turnTimeline.Count == 0)
                                        {
                                            <div class="aware-muted">No turn briefs yet (the wingman briefs each turn as it ends; old Directors need a relaunch).</div>
                                        }
                                        else
                                        {
                                            var chapters = Chapters;
                                            @foreach (var (ch, ci) in chapters.Select((c, ci) => (c, ci)))
                                            {
                                                var open = _openChapters.Contains(ch.FirstTurn);
                                                <div class="chap @(open ? "open" : "")">
                                                    <button type="button" class="chap-row" @onclick="() => ToggleChapter(ch.FirstTurn)"
                                                            title="@(open ? "Collapse" : "Show the turns in this chapter")">
                                                        <span class="chap-caret">@(open ? "v" : ">")</span>
                                                        <span class="chap-title">@ch.Title</span>
                                                        @if (ci == 0)
                                                        {
                                                            <span class="chap-now">now</span>
                                                        }
                                                        <span class="chap-turns">@(ch.FirstTurn == ch.LastTurn ? $"t{ch.FirstTurn}" : $"t{ch.FirstTurn}-{ch.LastTurn}")</span>
                                                    </button>
                                                    @if (open)
                                                    {
                                                        <div class="chap-body">
                                                            @foreach (var b in ch.Briefs)
                                                            {
                                                                var turnOpen = _openTurns.Contains(b.TurnNumber);
                                                                <div class="chap-turn @(b.Degraded ? "degraded" : "")">
                                                                    <button type="button" class="chap-turn-row" @onclick="() => ToggleTurn(b.TurnNumber)"
                                                                            title="@(turnOpen ? "Collapse" : "Full turn description")">
                                                                        <span class="tl-turn">@b.TurnNumber</span>
                                                                        <span class="chap-turn-title">@(string.IsNullOrEmpty(b.TurnTitle) ? (b.Did.FirstOrDefault() ?? b.Intent) : b.TurnTitle)</span>
                                                                        <span class="tl-time">@b.GeneratedAtUtc.ToLocalTime().ToString("HH:mm")</span>
                                                                        @if (TurnTokens(b) is long tk)
                                                                        {
                                                                            <span class="tl-tokens" title="new tokens this turn">~@FmtTokens(tk)</span>
                                                                        }
                                                                    </button>
                                                                    @if (b.NeedsYou is not null && !turnOpen)
                                                                    {
                                                                        <div class="tl-rail chap-rail">@b.NeedsYou.RailLine</div>
                                                                    }
                                                                    @if (turnOpen)
                                                                    {
                                                                        <div class="chap-turn-detail">
                                                                            <div class="tl-intent">@b.Intent</div>
                                                                            @if (b.NeedsYou is not null)
                                                                            {
                                                                                <div class="tl-rail">@b.NeedsYou.RailLine</div>
                                                                            }
                                                                            @if (b.Did.Count > 0)
                                                                            {
                                                                                <ul class="tl-did">
                                                                                    @foreach (var d in b.Did)
                                                                                    {
                                                                                        <li>@d</li>
                                                                                    }
                                                                                </ul>
                                                                            }
                                                                            <div class="aware-meta">@b.Model</div>
                                                                        </div>
                                                                    }
                                                                </div>
                                                            }
                                                        </div>
                                                    }
                                                </div>
                                            }
                                            @* ---- D7: "this brief is wrong" -> stored as a labeled example ---- *@
                                            <div class="tl-feedback">
                                                <input @bind="_briefFeedbackNote" placeholder="Latest brief wrong? Say why..." />
                                                <button class="linkbtn" disabled="@(string.IsNullOrWhiteSpace(_briefFeedbackNote) || _briefFeedbackBusy)"
                                                        @onclick="SendBriefFeedback">@(_briefFeedbackBusy ? "saving..." : "report")</button>
                                            </div>
                                            @if (!string.IsNullOrEmpty(_briefFeedbackStatus))
                                            {
                                                <div class="aware-muted">@_briefFeedbackStatus</div>
                                            }
                                        }

                                        <div class="tl-label" style="margin-top:14px">RECAP</div>
                                        @if (_recap is null)
                                        {
                                            <div class="aware-muted">No recap loaded.</div>
                                        }
                                        else if (_recap.Status == "ok" && !string.IsNullOrWhiteSpace(_recap.Recap))
                                        {
                                            <div class="aware-recap">@_recap.Recap</div>
                                            <div class="aware-meta">@_recap.Model &middot; @(_recap.IsStale ? "stale (new turns since)" : "current") &middot; generated @(_recap.GeneratedAt?.ToLocalTime().ToString("HH:mm:ss"))</div>
                                        }
                                        else
                                        {
                                            <div class="aware-muted">@(_recap.Error ?? "No recap yet. Click Recap.")</div>
                                        }
                                    </div>
                                </aside>
                            </div>
                        }

                        <div class="detail-dock">
                            @* ---- Composer: Speak / Send / Queue + Interrupt / Esc ---- *@
                            <div class="composer">
                                <textarea @ref="_composerEl" @bind="_compose" @bind:event="oninput" @onkeydown="OnComposerKey"
                                          placeholder="Message this session... (Enter to send, Shift+Enter for newline; drop an image here)"></textarea>
                                @* Drag an image straight onto the composer (desktop parity with the
                                   prompt-box drop). A document-level handler (cockpit-composer-drop.js)
                                   routes images dropped on .composer into this hidden input, which runs
                                   the same OnDropImages upload+inject path - so it works even when the
                                   right Screenshots panel is collapsed. Text drops fall through to the
                                   textarea's native behaviour. *@
                                <InputFile OnChange="OnDropImages" multiple accept="image/*" class="composer-drop-input" />
                                <div class="composer-btns">
                                    @* Attach an image from THIS device (phone photo / local file not yet on the
                                       Director): upload it, then drop the saved path into the prompt. This is a
                                       message-composition action, so it lives in the composer - not the gallery.
                                       The native file input is hidden behind the styled label (no "Choose Files"). *@
                                    <label class="btn attach" title="Attach an image from this device">
                                        <InputFile OnChange="OnDropImages" multiple accept="image/*" />
                                        Attach
                                    </label>
                                    <button class="btn speak @(_dictating ? "on" : "")" @onclick="OpenDictate" title="Dictate" disabled="@_dictating">Speak</button>
                                    <button class="btn send" @onclick="SendNow" disabled="@(_acting || string.IsNullOrWhiteSpace(_compose))">Send</button>
                                    <button class="btn queue" @onclick="QueueIt" disabled="@(_acting || string.IsNullOrWhiteSpace(_compose))">Queue</button>
                                    <button class="btn danger" @onclick="Interrupt" title="Ctrl+C">Interrupt</button>
                                    <button class="btn danger" @onclick="Escape" title="Esc">Esc</button>
                                </div>
                            </div>
                            @if (!string.IsNullOrEmpty(_shotStatus))
                            {
                                <div class="shots-status">@_shotStatus</div>
                            }
                            @if (!string.IsNullOrEmpty(_actError))
                            {
                                <div class="act-error">@_actError</div>
                            }
                        </div>
                    </div>

                    @* ---- Right panel: tabbed (Screenshots / Queue / Director), collapsible.
                       The Session Story is NOT here - it is a fixed column inside the Wingman
                       center tab, so the title cards can never hide behind a tab flip. ---- *@
                    <aside class="rightpanel @(_rightCollapsed ? "rightpanel-collapsed" : "")">
                        @if (_rightCollapsed)
                        {
                            <button class="right-expand" title="Show panel" @onclick="ToggleRight">&laquo;</button>
                            @if (_queue.Count > 0)
                            {
                                <div class="rail-qbadge" title="@_queue.Count queued">@_queue.Count</div>
                            }
                        }
                        else
                        {
                            <div class="right-tabs">
                                <button class="right-tab @(_rightTab == "shots" ? "on" : "")" @onclick='() => SetRightTab("shots")'>Screenshots</button>
                                <button class="right-tab @(_rightTab == "queue" ? "on" : "")" @onclick='() => SetRightTab("queue")'>Queue@(_queue.Count > 0 ? $" ({_queue.Count})" : "")</button>
                                <button class="right-tab @(_rightTab == "director" ? "on" : "")" @onclick='() => SetRightTab("director")'>Director</button>
                                <button class="right-collapse" title="Hide panel" @onclick="ToggleRight">&raquo;</button>
                            </div>

                            <div class="right-body">
                                @* ================= Screenshots tab ================= *@
                                @if (_rightTab == "shots")
                                {
                                    <div class="rightpanel-head">
                                        <span class="rightpanel-title">SCREENSHOTS</span>
                                        <button class="linkbtn" @onclick="RefreshScreenshots" disabled="@_shotsBusy" title="Reload from the Director">Refresh</button>
                                        <button class="linkbtn" @onclick="ClearScreenshots" title="Clear this list (does not delete files)">Clear All</button>
                                    </div>

                                    @* Gallery of captured screenshots on the Director's machine.
                                       Clicking a thumbnail VIEWS it (opens full-size in a new tab); inserting a
                                       path into the prompt is a deliberate action via the Insert button only -
                                       a click never inserts. To attach a device-local image, use the composer's
                                       Attach button. *@
                                    <div class="gallery">
                                        @if (!string.IsNullOrEmpty(_shotsError))
                                        {
                                            <div class="gallery-error">@_shotsError</div>
                                        }
                                        else if (_shotsBusy && _shots.Count == 0)
                                        {
                                            <div class="gallery-empty">Loading screenshots&hellip;</div>
                                        }
                                        else if (_shots.Count == 0)
                                        {
                                            <div class="gallery-empty">No screenshots in this Director's folder yet.</div>
                                        }
                                        else
                                        {
                                            @* Only the newest _shotsShown thumbnails render; each <img> is the
                                               full-size file fetched from the Director, so rendering all 1000+
                                               folder entries at once would melt the tab. Show more grows the
                                               list from the already-fetched metadata - no network call. *@
                                            @foreach (var s in _shots.Take(_shotsShown))
                                            {
                                                <div class="shot-card" @key="s.FileName">
                                                    @* Click the thumbnail to VIEW full-size. Insert is the explicit
                                                       button only, so a path never lands in the prompt by accident. *@
                                                    <img class="shot-thumb" src="@ShotUrl(s.FileName)" alt="@s.FileName" loading="lazy"
                                                         title="Click to view full size" @onclick="() => ViewScreenshot(s.FileName)" />
                                                    <div class="shot-row">
                                                        <span class="shot-time">@s.TimeLabel</span>
                                                        <button class="linkbtn" @onclick="() => InsertScreenshot(s)" title="Insert path into the prompt">Insert</button>
                                                        <button class="linkbtn" @onclick="() => CopyScreenshot(s.FileName)">Copy</button>
                                                        <button class="linkbtn del" @onclick="() => DeleteScreenshot(s.FileName)">Del</button>
                                                    </div>
                                                </div>
                                            }
                                            @if (_shots.Count > _shotsShown)
                                            {
                                                <button class="gallery-more" @onclick="ShowMoreShots">
                                                    Show @Math.Min(ShotsShowMoreStep, _shots.Count - _shotsShown) more
                                                    (@(_shotsTotal - _shotsShown) older)
                                                </button>
                                            }
                                            else if (_shotsTotal > _shots.Count)
                                            {
                                                <div class="gallery-footnote">
                                                    Newest @_shots.Count of @_shotsTotal - older files stay on the Director's disk.
                                                </div>
                                            }
                                        }
                                    </div>
                                }
                                @* ================= Queue tab ================= *@
                                else if (_rightTab == "queue")
                                {
                                    <div class="rightpanel-head">
                                        <span class="rightpanel-title">QUEUE (@_queue.Count)</span>
                                    </div>
                                    <div class="queue">
                                        @if (_queue.Count == 0)
                                        {
                                            <div class="queue-empty">Nothing queued. Type a message and hit Queue to stage it here.</div>
                                        }
                                        else
                                        {
                                            @foreach (var q in _queue)
                                            {
                                                <div class="queue-item">
                                                    <span class="queue-text">@q.Text</span>
                                                    <button class="qbtn" title="Send now" @onclick="() => SendQueued(q.Id)">send</button>
                                                    <button class="qbtn qdel" title="Remove" @onclick="() => RemoveQueued(q.Id)">&times;</button>
                                                </div>
                                            }
                                        }
                                    </div>
                                }
                                @* ================= Director tab ================= *@
                                else if (_rightTab == "director")
                                {
                                    <div class="rightpanel-head">
                                        <span class="rightpanel-title">DIRECTOR</span>
                                    </div>
                                    <dl class="dir-info">
                                        <dt>Machine</dt><dd>@Selected.MachineName</dd>
                                        <dt>Director ID</dt><dd class="mono">@Selected.DirectorId</dd>
                                        <dt>Endpoint</dt><dd class="mono">@Selected.TailnetEndpoint</dd>
                                        <dt>Agent</dt><dd>@Selected.Agent</dd>
                                        <dt>Activity</dt><dd>@Selected.ActivityState</dd>
                                        <dt>Repo</dt><dd class="mono">@Selected.RepoPath</dd>
                                    </dl>
                                }
                            </div>
                        }
                    </aside>
                </div>
            }
        </main>
    </div>

    @* ===== New session dialog (desktop parity: tabs + repo table + browse) ===== *@
    @if (_showNewSession)
    {
        <div class="modal-backdrop" @onclick="CloseNewSession">
            <div class="modal modal-ns" @onclick:stopPropagation="true">
                <div class="modal-head ns-head">
                    <span>New session</span>
                    <label class="ns-dir">
                        <span class="fld-label">Director</span>
                        <select @bind="_nsDirectorId" @bind:after="OnNsDirectorChanged">
                            @foreach (var d in _directors)
                            {
                                <option value="@d.DirectorId">@DirectorLabel(d)</option>
                            }
                        </select>
                    </label>
                </div>

                <div class="modal-body ns-body">
                    <div class="ns-agents">
                        <span class="fld-label">Agent:</span>
                        @foreach (var a in NsAgents)
                        {
                            <button class="chip @(_nsAgent == a ? "on" : "")" @onclick="() => SetAgent(a)">@AgentLabel(a)</button>
                        }
                    </div>

                    @* Session type (issue #211): one-click identity, Implement preselected. *@
                    <div class="ns-types">
                        <span class="fld-label">Type:</span>
                        @foreach (var t in NsTypes)
                        {
                            <button class="chip @(_nsType == t.Key ? "on" : "")" title="@t.Hint"
                                    @onclick="() => SetType(t.Key)">@t.Label</button>
                        }
                    </div>

                    <input class="ns-search" @bind="_nsRepoFilter" @bind:event="oninput" placeholder="Filter repositories by name or path" />

                    <div class="ns-table">
                        <div class="ns-row ns-hd">
                            <button class="ns-c-name" @onclick='() => SortRepos("Name")'>Name@(SortArrow("Name"))</button>
                            <button class="ns-c-path" @onclick='() => SortRepos("Path")'>Path@(SortArrow("Path"))</button>
                            <button class="ns-c-used" @onclick='() => SortRepos("LastUsed")'>Last Used@(SortArrow("LastUsed"))</button>
                            <span class="ns-c-x"></span>
                        </div>
                        <div class="ns-rows">
                            @foreach (var r in FilteredRepos)
                            {
                                <div class="ns-row @(EffectiveNsRepo == r.Path ? "sel" : "")" @onclick="() => SelectRepo(r.Path)">
                                    <span class="ns-c-name" title="@r.Name">@r.Name</span>
                                    <span class="ns-c-path" title="@r.Path">@r.Path</span>
                                    <span class="ns-c-used">@RelLastUsed(r.LastUsed)</span>
                                    <button class="ns-c-x" title="Remove from list" @onclick:stopPropagation="true" @onclick="() => RemoveRepo(r.Path)">x</button>
                                </div>
                            }
                            @if (FilteredRepos.Count == 0)
                            {
                                <div class="ns-empty">No repositories. Type a path below or Browse.</div>
                            }
                        </div>
                    </div>

                    <div class="ns-pathrow">
                        <input class="ns-path" @bind="_nsRepoPathManual" @bind:event="oninput" placeholder="D:\path\to\repo" />
                        <button class="btn" @onclick="OpenBrowse">Browse...</button>
                    </div>

                    <div class="ns-opts">
                        <label class="ck @(_nsAgent != "ClaudeCode" ? "off" : "")">
                            <input type="checkbox" @bind="_nsBypass" disabled="@(_nsAgent != "ClaudeCode")" /> Bypass permission prompts
                        </label>
                        <label class="ck">
                            <input type="checkbox" @bind="_nsWingman" /> Wingman (auto-explain on turn-end + Voice tabs)
                        </label>
                    </div>

                    @if (!string.IsNullOrEmpty(_nsError))
                    {
                        <div class="modal-error">@_nsError</div>
                    }
                </div>

                <div class="modal-foot">
                    <button class="btn" @onclick="CloseNewSession">Cancel</button>
                    <button class="btn send" @onclick="CreateSession" disabled="@(_acting || string.IsNullOrWhiteSpace(EffectiveNsRepo))">@(_acting ? "Creating session..." : "Create")</button>
                </div>
            </div>
        </div>

        @if (_browseOpen)
        {
            <div class="modal-backdrop ns-browse-back" @onclick="CloseBrowse">
                <div class="modal modal-browse" @onclick:stopPropagation="true">
                    <div class="modal-head">Browse for a folder (on @DirectorShort)</div>
                    <div class="modal-body">
                        <div class="ns-browse-path">@(_browseListing?.CurrentPath ?? "(drives)")</div>
                        <div class="ns-browse-list">
                            @if (_browseBusy)
                            {
                                <div class="ns-empty">Loading...</div>
                            }
                            else
                            {
                                @if (_browseListing?.CurrentPath is not null)
                                {
                                    <div class="ns-browse-item up" @onclick="BrowseUp">.. (up)</div>
                                }
                                @foreach (var e in (_browseListing?.Entries ?? new List<DirEntryDto>()))
                                {
                                    <div class="ns-browse-item" @onclick="() => BrowseNavigate(e.Path)">@(e.IsDrive ? e.Path : e.Name)</div>
                                }
                                @if ((_browseListing?.Entries.Count ?? 0) == 0)
                                {
                                    <div class="ns-empty">No sub-folders here.</div>
                                }
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(_browseError))
                        {
                            <div class="modal-error">@_browseError</div>
                        }
                    </div>
                    <div class="modal-foot">
                        <button class="btn" @onclick="CloseBrowse">Cancel</button>
                        <button class="btn send" @onclick="BrowseSelect" disabled="@string.IsNullOrEmpty(_browseListing?.CurrentPath)">Select this folder</button>
                    </div>
                </div>
            </div>
        }
    }

    @* ===== Settings modal ===== *@
    @if (_showSettings)
    {
        <div class="modal-backdrop" @onclick="CloseSettings">
            <div class="modal modal-wide" @onclick:stopPropagation="true">
                <div class="modal-head">Settings</div>
                <div class="modal-body">
                    <label class="fld">
                        <span class="fld-label">Director</span>
                        <select @bind="_setDirectorId" @bind:after="LoadSettings">
                            @foreach (var d in _directors)
                            {
                                <option value="@d.DirectorId">@DirectorLabel(d)</option>
                            }
                        </select>
                    </label>
                    <textarea class="settings-json" @bind="_settingsJson" spellcheck="false"></textarea>
                    @if (!string.IsNullOrEmpty(_setError))
                    {
                        <div class="modal-error">@_setError</div>
                    }
                    @if (!string.IsNullOrEmpty(_setStatus))
                    {
                        <div class="modal-status">@_setStatus</div>
                    }
                </div>
                <div class="modal-foot">
                    <button class="btn" @onclick="CloseSettings">Close</button>
                    <button class="btn send" @onclick="SaveSettings" disabled="@(_acting || string.IsNullOrWhiteSpace(_settingsJson))">Save</button>
                </div>
            </div>
        </div>
    }

    @* ===== Awareness: "what's happening" (recap + turn summaries) ===== *@
    @if (_showAwareness)
    {
        <div class="modal-backdrop" @onclick="CloseAwareness">
            <div class="modal modal-wide" @onclick:stopPropagation="true">
                <div class="modal-head">What's happening@(_awareTitle is null ? "" : $" - {_awareTitle}")</div>
                <div class="modal-body">
                    <div class="aware-section">
                        <div class="aware-h"><span>GIT</span></div>
                        @if (_git is null)
                        {
                            <div class="aware-muted">Loading...</div>
                        }
                        else if (_git.Status == "ok")
                        {
                            <div class="git-line">
                                <span class="git-branch">@_git.Branch</span>
                                <span class="@(_git.Dirty ? "git-dirty" : "git-clean")">@(_git.Dirty ? "dirty" : "clean")</span>
                                @if (_git.Ahead > 0) { <span class="git-ab">ahead @_git.Ahead</span> }
                                @if (_git.Behind > 0) { <span class="git-ab">behind @_git.Behind</span> }
                            </div>
                            @if (!string.IsNullOrWhiteSpace(_git.LastCommit))
                            {
                                <div class="git-commit">@_git.LastCommit</div>
                            }
                        }
                        else
                        {
                            <div class="aware-muted">@(_git.Error ?? "no git info")</div>
                        }
                    </div>
                    <div class="aware-section">
                        <div class="aware-h">
                            <span>RECAP</span>
                            <button class="btn tb" @onclick="GenerateRecap" disabled="@_recapBusy">@(_recapBusy ? "generating (~90s)..." : "Generate fresh")</button>
                        </div>
                        @if (_recap is null)
                        {
                            <div class="aware-muted">Loading...</div>
                        }
                        else if (_recap.Status == "ok" && !string.IsNullOrWhiteSpace(_recap.Recap))
                        {
                            <div class="aware-recap">@_recap.Recap</div>
                            <div class="aware-meta">@_recap.Model &middot; @(_recap.IsStale ? "stale (new turns since)" : "current") &middot; generated @(_recap.GeneratedAt?.ToLocalTime().ToString("HH:mm:ss"))</div>
                        }
                        else
                        {
                            <div class="aware-muted">@(_recap.Error ?? "No recap yet. Click Generate fresh.")</div>
                        }
                    </div>
                    <div class="aware-section">
                        <div class="aware-h"><span>TURN SUMMARIES (@_turns.Count)</span></div>
                        @if (_turns.Count == 0)
                        {
                            <div class="aware-muted">No turn summaries yet for this session.</div>
                        }
                        else
                        {
                            @foreach (var t in _turns)
                            {
                                <div class="turn">
                                    <div class="turn-headline">
                                        @if (t.NeedsUser != "no")
                                        {
                                            <span class="turn-needs">needs you</span>
                                        }
                                        @t.Headline
                                    </div>
                                    @if (t.FilesTouched.Count > 0)
                                    {
                                        <div class="turn-meta">files: @string.Join(", ", t.FilesTouched.Take(6))</div>
                                    }
                                    <div class="turn-time">@t.GeneratedAt.ToLocalTime().ToString("HH:mm:ss")</div>
                                </div>
                            }
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(_awareError))
                    {
                        <div class="modal-error">@_awareError</div>
                    }
                </div>
                <div class="modal-foot">
                    <button class="btn" @onclick="CloseAwareness">Close</button>
                </div>
            </div>
        </div>
    }

    @* ===== Fan-out: broadcast a prompt to several sessions ===== *@
    @if (_showFanout)
    {
        <div class="modal-backdrop" @onclick="CloseFanout">
            <div class="modal modal-wide" @onclick:stopPropagation="true">
                <div class="modal-head">Fan-out a prompt to multiple sessions</div>
                <div class="modal-body">
                    <div class="fanout-list">
                        @foreach (var s in _sessions.Where(s => !string.IsNullOrWhiteSpace(s.TailnetEndpoint)))
                        {
                            var sid = s.SessionId;
                            <label class="fanout-item">
                                <input type="checkbox" checked="@_fanoutSelected.Contains(sid)" @onchange="e => ToggleFanout(sid, (bool)(e.Value ?? false))" />
                                <span class="fanout-dot" style="background:@DotColor(SessionOrdering.EffectiveColor(s))"></span>
                                <span class="fanout-name">@SessionTitle(s)</span>
                                <span class="fanout-meta">@s.MachineName / @ShortId(s.DirectorId)</span>
                            </label>
                        }
                    </div>
                    <label class="fld">
                        <span class="fld-label">Prompt to send to the @_fanoutSelected.Count selected session(s)</span>
                        <textarea class="fanout-text" @bind="_fanoutText" @bind:event="oninput" spellcheck="false" placeholder="any prompt, e.g. 'commit your work and summarize what you did'"></textarea>
                    </label>
                    @if (_fanoutResults.Count > 0)
                    {
                        <div class="fanout-results">
                            @foreach (var r in _fanoutResults)
                            {
                                <div class="fanout-result"><span class="@(r.Error is null ? "git-clean" : "git-dirty")">@(r.Error is null ? "delivered" : "failed")</span> &nbsp;@ShortId(r.SessionId) @r.Error</div>
                            }
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(_fanoutError))
                    {
                        <div class="modal-error">@_fanoutError</div>
                    }
                </div>
                <div class="modal-foot">
                    <button class="btn" @onclick="CloseFanout">Cancel</button>
                    <button class="btn send" @onclick="DoFanout" disabled="@(_fanoutBusy || _fanoutSelected.Count == 0 || string.IsNullOrWhiteSpace(_fanoutText))">@(_fanoutBusy ? "sending..." : $"Send to {_fanoutSelected.Count}")</button>
                </div>
            </div>
        </div>
    }

    @* ===== Handover: hand a session's context to a new or existing session ===== *@
    @if (_showHandover && Selected is not null)
    {
        <div class="modal-backdrop" @onclick="CloseHandover">
            <div class="modal modal-wide" @onclick:stopPropagation="true">
                <div class="modal-head">Hand over - @SessionTitle(Selected)</div>
                <div class="modal-body">
                    <div class="aware-h"><span>CONTEXT PREVIEW (what the target session receives)</span></div>
                    <div class="handover-preview">@(_handoverContext ?? "Loading...")</div>

                    <label class="fld">
                        <span class="fld-label">Hand over to</span>
                        <select @bind="_hoMode">
                            <option value="new">a new session</option>
                            <option value="existing">an existing session (same Director)</option>
                        </select>
                    </label>

                    @if (_hoMode == "new")
                    {
                        <label class="fld">
                            <span class="fld-label">Director</span>
                            <select @bind="_hoDirectorId">
                                @foreach (var d in _directors)
                                {
                                    <option value="@d.DirectorId">@DirectorLabel(d)</option>
                                }
                            </select>
                        </label>
                        <label class="fld">
                            <span class="fld-label">Repo path</span>
                            <input @bind="_hoRepoPath" @bind:event="oninput" placeholder="D:/path/to/repo" />
                        </label>
                        <label class="fld">
                            <span class="fld-label">Agent</span>
                            <select @bind="_hoAgent">
                                <option>ClaudeCode</option>
                                <option>Codex</option>
                                <option>Gemini</option>
                                <option>Pi</option>
                                <option>OpenCode</option>
                            </select>
                        </label>
                    }
                    else
                    {
                        <label class="fld">
                            <span class="fld-label">Existing session</span>
                            <select @bind="_hoToSessionId">
                                <option value="">-- pick a session on the same Director --</option>
                                @foreach (var s in _sessions.Where(s => s.SessionId != Selected.SessionId && s.DirectorId == Selected.DirectorId))
                                {
                                    <option value="@s.SessionId">@SessionTitle(s)</option>
                                }
                            </select>
                        </label>
                    }

                    <label class="fld">
                        <span class="fld-label">Extra context (optional)</span>
                        <textarea class="fanout-text" @bind="_hoExtra" @bind:event="oninput" spellcheck="false" placeholder="anything else the target session should know"></textarea>
                    </label>
                    <label class="ho-check"><input type="checkbox" @bind="_hoArchive" /> Archive this handover to the vault</label>

                    @if (!string.IsNullOrEmpty(_hoError)) { <div class="modal-error">@_hoError</div> }
                    @if (!string.IsNullOrEmpty(_hoStatus)) { <div class="modal-status">@_hoStatus</div> }
                </div>
                <div class="modal-foot">
                    <button class="btn" @onclick="CloseHandover">Cancel</button>
                    <button class="btn send" @onclick="DoHandover" disabled="@(_hoBusy || !HandoverReady)">@(_hoBusy ? "handing over..." : "Hand over")</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    // Product version stamped by Directory.Build.props ("0.6.3+sha", SourceLink suffix).
    // Cockpit does not reference Core, so parse inline (mirror of AppVersion).
    private static readonly string VersionFull =
        typeof(Cockpit).Assembly.GetCustomAttribute<AssemblyInformationalVersionAttribute>()?.InformationalVersion ?? "0.0.0";
    private static readonly string VersionDisplay = $"v{VersionFull.Split('+')[0]}";

    private List<SessionDto> _sessions = new();
    private List<MachineErrorDto> _errors = new();
    private string? _selectedId;
    private string? _lastError;
    private DateTime? _lastRefresh;
    private readonly CancellationTokenSource _cts = new();

    // Effective color (issue #196): a session the wingman is still reading is yellow,
    // so it neither counts as "needs you" nor enters the conveyor until the brief lands.
    private int NeedsYou => _sessions.Count(s => SessionOrdering.EffectiveColor(s) == "red");
    private SessionDto? Selected => _sessions.FirstOrDefault(s => s.SessionId == _selectedId);

    // ----- optimistic explain overlay (issue #217 reactivity) -----

    /// <summary>Session the user just requested an explain for. The in-memory roster is
    /// stamped BriefingState=Explaining immediately (rail dot + chip + brief pane all flip
    /// in the same render as the click), and re-stamped across roster swaps in
    /// <see cref="RefreshAsync"/> until the Gateway's polled state confirms.</summary>
    private string? _explainPendingSid;
    private DateTime _explainPendingAt;
    /// <summary>The session's last server-reported BriefingState before the optimistic
    /// stamp overwrote it, so a failed POST restores the truth (e.g. "Briefed") instead
    /// of blanking to "None" until the next poll.</summary>
    private string _explainPriorBriefState = "None";

    /// <summary>BriefPane's explain click (true) or POST failure (false). The stamp makes
    /// every surface that folds through SessionOrdering - dot, chip, triage bucket - go
    /// orange NOW instead of after the next 2s poll.</summary>
    private void OnExplainPending(bool active)
    {
        if (active && Selected is not null)
        {
            _explainPendingSid = Selected.SessionId;
            _explainPendingAt = DateTime.UtcNow;
            _explainPriorBriefState = Selected.BriefingState;
            Selected.BriefingState = "Explaining";
            Log.LogInformation("Cockpit: optimistic explain stamp for sid={Sid}", _explainPendingSid);
        }
        else
        {
            // POST failed: un-stamp so the rail does not lie about a dive that never queued.
            if (_explainPendingSid is not null)
            {
                var dto = _sessions.FirstOrDefault(s => s.SessionId == _explainPendingSid);
                if (dto is not null && dto.BriefingState == "Explaining") dto.BriefingState = _explainPriorBriefState;
            }
            _explainPendingSid = null;
        }
    }

    // ----- center tab (Brief is the default; choice persists per session for the circuit) -----
    private readonly Dictionary<string, string> _centerTabBySession = new();
    private string CenterTab =>
        Selected is not null && _centerTabBySession.TryGetValue(Selected.SessionId, out var t) ? t : "brief";
    private async Task SetCenterTab(string tab)
    {
        if (Selected is null) return;
        ActionInfo("center-tab", $"tab={tab}");
        _centerTabBySession[Selected.SessionId] = tab;
        // Coming back to the Wingman tab re-shows the story column - make sure its data is
        // there (cleared on session switch; cheap no-op when already loaded).
        if (tab == "brief" && (_recap is null || _turnTimeline is null)) await LoadWingmanAsync();
    }

    // ----- needs-you conveyor: flip through red sessions in the rail's stable order -----
    private List<SessionDto> NeedsYouOrdered =>
        SessionOrdering.InDesktopOrder(_sessions).Where(s => SessionOrdering.EffectiveColor(s) == "red").ToList();

    private string NeedsYouPosLabel
    {
        get
        {
            var list = NeedsYouOrdered;
            var idx = list.FindIndex(s => s.SessionId == _selectedId);
            return idx >= 0 ? $"{idx + 1}/{list.Count}" : $"{list.Count}";
        }
    }

    private async Task StepNeedsYou(int delta)
    {
        var list = NeedsYouOrdered;
        if (list.Count == 0) return;
        var idx = list.FindIndex(s => s.SessionId == _selectedId);
        // Not on a needs-you session: jump to the first (or last when stepping back).
        var next = idx < 0
            ? (delta > 0 ? 0 : list.Count - 1)
            : (idx + delta + list.Count) % list.Count;
        await OnSelect(list[next].SessionId, "needs-you-nav");
    }

    // One-click answer from the Brief's option buttons: send the key as the reply, then
    // advance the conveyor to the next session that needs the user (FIFO behaviour).
    private bool _quickReplying;
    /// <summary>Explicit answer-transition notice (issue #227): replaces the silent conveyor
    /// teleport. When the answer advances to another needs-you session we say so before the
    /// jump; when it was the only one we acknowledge the answer immediately instead of leaving
    /// the user to wait for the 2s poll to repaint the session blue. Cleared on the next
    /// selection (OnSelect).</summary>
    private string? _quickReplyNotice;
    private async Task QuickReplyAsync(string text)
    {
        var sel = Selected;
        var dir = DirBase;
        if (sel is null || string.IsNullOrWhiteSpace(dir) || _quickReplying) return;
        _quickReplying = true;
        _quickReplyNotice = null;
        try
        {
            await Director.SendPromptAsync(dir, sel.SessionId, text, _cts.Token);
            // Advance past the answered session when others are waiting. The answered one
            // drops out of the needs-you list on the next poll. Either way the user gets an
            // explicit message - no silent teleport, no dead air on the single-session case.
            var others = NeedsYouOrdered.Where(s => s.SessionId != sel.SessionId).ToList();
            if (others.Count > 0)
            {
                // Switch first (OnSelect clears per-session state incl. any stale notice),
                // THEN stamp the transition message so it survives onto the next session.
                await OnSelect(others[0].SessionId, "quick-reply-advance");
                _quickReplyNotice = "answered - moving to the next session that needs you";
            }
            else
            {
                _quickReplyNotice = "answered - waiting for Claude to pick it up";
            }
        }
        catch (Exception ex)
        {
            Log.LogWarning(ex, "quick reply failed for sid={Sid}", sel.SessionId);
            _actError = $"Quick reply failed: {ex.Message}";
        }
        finally
        {
            _quickReplying = false;
        }
    }

    /// <summary>Deep-link route parameter: /cockpit/{sid} selects that session on load.</summary>
    [Parameter] public string? SidParam { get; set; }

    protected override async Task OnInitializedAsync()
    {
        Log.LogInformation("Cockpit initializing against Gateway {Base}", Gateway.BaseUrl);
        await RefreshAsync();
        _ = PollLoopAsync();
    }

    // Runs after OnInitializedAsync (roster loaded) and again on every /cockpit/{sid}
    // navigation within the circuit (e.g. a dashboard needs-you click while already here).
    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(SidParam) && SidParam != _selectedId
            && _sessions.Any(s => s.SessionId == SidParam))
            await OnSelect(SidParam, "deep-link");
    }

    // Restore the left-panel preferences once the circuit can do JS interop. These are
    // pure UI conveniences; if localStorage is unavailable the defaults (expanded, tree)
    // stand, which is correct behaviour rather than a hidden failure.
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try
        {
            // Wire composer drag-drop once via event delegation, so it survives every
            // composer re-render (session switches) without re-binding. init() is idempotent.
            _composerDropModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/cockpit-composer-drop.js");
            await _composerDropModule.InvokeVoidAsync("init");
        }
        catch (Exception ex)
        {
            Log.LogDebug(ex, "Cockpit: wiring composer drop failed");
        }
        try
        {
            // Preload the screenshot-gallery module while the page is known-healthy. The lazy
            // import used to be deferred to the first screenshot click, which made it the first
            // request to hit a front-door outage minutes later (issue #200). A preload failure
            // is only logged: ShotsModule() retries on demand with a user-facing message.
            await ShotsModule();
        }
        catch (Exception ex)
        {
            Log.LogDebug(ex, "Cockpit: preloading cockpit-shots.js failed; will retry on first use");
        }
        try
        {
            var collapsed = await JS.InvokeAsync<string?>("localStorage.getItem", "cockpit.leftCollapsed");
            var mode = await JS.InvokeAsync<string?>("localStorage.getItem", "cockpit.viewMode");
            var rightCollapsed = await JS.InvokeAsync<string?>("localStorage.getItem", "cockpit.rightCollapsed");
            var rightTab = await JS.InvokeAsync<string?>("localStorage.getItem", "cockpit.rightTab");
            var changed = false;
            if (collapsed == "1" && !_leftCollapsed) { _leftCollapsed = true; changed = true; }
            // Pattern match narrows `mode` to non-null, so no null-forgiving operator is needed.
            if (mode is "tree" or "triage" && mode != _viewMode) { _viewMode = mode; changed = true; }
            if (rightCollapsed == "1" && !_rightCollapsed) { _rightCollapsed = true; changed = true; }
            // "wingman" is intentionally absent: the Session Story moved into the Wingman
            // center tab, so a stale stored "wingman" pref falls back to the default.
            if (rightTab is "shots" or "queue" or "director" && rightTab != _rightTab) { _rightTab = rightTab; changed = true; }
            if (changed) await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Log.LogDebug(ex, "Cockpit: restoring left-panel prefs failed");
        }
    }

    private async Task PollLoopAsync()
    {
        var timer = new PeriodicTimer(TimeSpan.FromSeconds(2));
        try
        {
            while (await timer.WaitForNextTickAsync(_cts.Token))
                await RefreshAsync();
        }
        catch (OperationCanceledException)
        {
            // circuit tearing down; normal.
        }
        finally
        {
            timer.Dispose();
        }
    }

    private bool _refreshing;

    private async Task RefreshAsync()
    {
        // The 2s tick can fire again while a slow refresh is still in flight; skip overlapping
        // runs so two GetSessions responses can't land out of order and flash stale data.
        if (_refreshing) return;
        _refreshing = true;
        try
        {
            var env = await Gateway.GetSessionsAsync(_cts.Token);
            _sessions = env.Sessions;
            _errors = env.MachineErrors;
            _lastError = null;
            _lastRefresh = DateTime.Now;

            // Optimistic explain overlay (issue #217): keep the just-requested session
            // orange across roster swaps until the Gateway confirms. The POST flips the
            // Gateway's pending state synchronously, so the first poll completing after
            // it must confirm; 10s unconfirmed means the request died - stop overriding.
            if (_explainPendingSid is not null)
            {
                var pending = _sessions.FirstOrDefault(s => s.SessionId == _explainPendingSid);
                if (pending is null || pending.BriefingState == "Explaining"
                    || DateTime.UtcNow - _explainPendingAt > TimeSpan.FromSeconds(10))
                {
                    _explainPendingSid = null;
                }
                else
                {
                    // Remember the freshest server truth before overwriting, so a failed
                    // POST restores it instead of blanking the state until the next poll.
                    _explainPriorBriefState = pending.BriefingState;
                    pending.BriefingState = "Explaining";
                }
            }

            // Optimistic close-dim reconcile (issue #228): a row stays dimmed only until the
            // Gateway drops the torn-down session from the roster. Clear any sid that has left
            // the roster (teardown confirmed) or whose stamp is older than 15s (teardown never
            // landed - stop dimming a live row).
            if (_closingSids.Count > 0)
            {
                var live = _sessions.Select(s => s.SessionId).ToHashSet();
                var stale = _closingSids
                    .Where(kv => !live.Contains(kv.Key) || DateTime.UtcNow - kv.Value > TimeSpan.FromSeconds(15))
                    .Select(kv => kv.Key)
                    .ToList();
                foreach (var sid in stale) _closingSids.Remove(sid);
            }

            // Rail group headers show per-Director version + uptime from the registry.
            // The registry is near-static (start/stop events only), so refresh it at most
            // every 30s instead of on every roster tick; minute-resolution uptime stays honest.
            if (DateTime.UtcNow - _directorsRefreshedAt >= TimeSpan.FromSeconds(30))
            {
                _directors = await Gateway.GetDirectorsAsync(_cts.Token);
                _directorsRefreshedAt = DateTime.UtcNow;
            }

            // Drop the selection if that session has gone away.
            if (_selectedId is not null && _sessions.All(s => s.SessionId != _selectedId))
                _selectedId = null;

            // Show the fresh roster immediately - a slow per-Director queue load must never
            // delay the fleet view (one slow Director can't stall the UI).
            await InvokeAsync(StateHasChanged);

            // Keep the queue panel current (catches external drains too), but not while the
            // user is acting on the queue: the action's response is authoritative, and a poll
            // load racing it could clobber a just-enqueued/removed item until the next tick.
            if (!_acting)
                await LoadQueueAsync();

            // Session story column: when the wingman finishes reading a turn (Briefing ->
            // Briefed/Failed) while the Wingman center tab is showing, pull the fresh brief +
            // usage so the headline and turn history never sit stale on screen.
            var briefState = Selected?.BriefingState;
            if (CenterTab == "brief"
                && _lastSeenBriefingState == "Briefing" && briefState is "Briefed" or "Failed")
                await LoadWingmanAsync();
            _lastSeenBriefingState = briefState;
        }
        catch (OperationCanceledException)
        {
            throw;
        }
        catch (Exception ex)
        {
            _lastError = ex.Message;
            Log.LogWarning(ex, "Cockpit RefreshAsync failed against {Base}", Gateway.BaseUrl);
        }
        finally
        {
            _refreshing = false;
        }
        await InvokeAsync(StateHasChanged);
    }

    // ----- selection + composer/queue/screenshots state -----
    private string _compose = "";
    private List<QueueItem> _queue = new();
    private bool _acting;
    private string? _actError;
    private string? _shotStatus;

    // Screenshots gallery (the captured-screenshots list on the selected session's Director).
    // The folder can hold THOUSANDS of images and each thumbnail is the full-size file fetched
    // over the tailnet, so the gallery is deliberately incremental: fetch metadata for the
    // newest ShotsFetchCount only, render ShotsInitialShown thumbnails, and grow on demand.
    private const int ShotsFetchCount = 100;
    private const int ShotsInitialShown = 12;
    private const int ShotsShowMoreStep = 24;
    private List<ScreenshotInfo> _shots = new();
    private int _shotsTotal;                       // full folder count reported by the Director
    private int _shotsShown = ShotsInitialShown;   // thumbnails currently rendered
    private bool _shotsBusy;
    private string? _shotsError;

    // Source of a selection (issue #199): which gesture drove it - rail click, the needs-you
    // conveyor, a deep link, or a quick-reply advance. Logged so a session-switch line in the
    // persisted log says WHY the session changed, not just that it did.
    private async Task OnSelect(string sessionId, string source = "rail")
    {
        var picked = _sessions.FirstOrDefault(s => s.SessionId == sessionId);
        Log.LogInformation(
            "Cockpit action=select-session source={Source} sid={Sid} dir={Dir}",
            source, sessionId, picked?.TailnetEndpoint ?? "(none)");
        // Blank-terminal failure mode (issue #199 / #198): a selected session whose Director
        // advertised no reachable tailnet endpoint cannot be driven over Tailscale - the detail
        // pane shows the "no tailnet endpoint" guard and the live terminal (TerminalPane) never
        // mounts, so the user faces the silent ungovernable terminal we could not previously
        // diagnose. This WARNING is emitted on the selection funnel (which every source - rail,
        // needs-you nav, deep-link, quick-reply advance - routes through), so the degraded state
        // is visible in the persisted log the moment the user lands on such a session, rather than
        // hidden behind a render branch that short-circuits before any terminal logging runs.
        if (picked is not null && string.IsNullOrWhiteSpace(picked.TailnetEndpoint))
            Log.LogWarning(
                "Cockpit empty DirectorBase for sid={Sid} source={Source} (rowState={RowState}); session has no tailnet endpoint, live terminal cannot connect - blank-terminal failure mode",
                sessionId, source, picked.AssessedState ?? picked.ActivityState);
        _selectedId = sessionId;
        // Keep the address bar deep-linkable (/cockpit/{sid}) without adding history entries.
        // OnParametersSetAsync guards on SidParam != _selectedId, so this never re-enters.
        Nav.NavigateTo($"/cockpit/{sessionId}", replace: true);
        _compose = "";
        _actError = null;
        _quickReplyNotice = null;   // a manual selection clears any stale answer-transition notice
        _shotStatus = null;
        _renaming = false;
        _killArmed = false;
        _queue = new();
        _shots = new();
        _shotsTotal = 0;
        _shotsShown = ShotsInitialShown;
        _shotsError = null;
        _turnTimeline = null;
        _usage = null;
        _briefFeedbackStatus = null;
        _recap = null;
        _awareError = null;
        await LoadQueueAsync();
        // Load whatever the active right-panel tab needs for the newly-selected session.
        await LoadRightTabAsync();
        // The Session Story column rides the Wingman center tab (the default), so its data
        // loads on selection - not behind a right-panel tab flip.
        if (CenterTab == "brief") await LoadWingmanAsync();
    }

    private string? DirBase => Selected?.TailnetEndpoint;

    private async Task LoadQueueAsync()
    {
        var sel = Selected; var dir = sel?.TailnetEndpoint;
        if (sel is null || string.IsNullOrWhiteSpace(dir)) return;
        try
        {
            // Short cap so a hung /queue on the selected Director can't stall the poll loop for
            // the client's full timeout. Linked to _cts so circuit teardown still cancels it.
            using var cts = CancellationTokenSource.CreateLinkedTokenSource(_cts.Token);
            cts.CancelAfter(TimeSpan.FromSeconds(8));
            _queue = await Director.GetQueueAsync(dir!, sel.SessionId, cts.Token);
        }
        catch (OperationCanceledException) { }
        catch (Exception ex) { Log.LogDebug(ex, "LoadQueue failed"); }
    }

    // Each action captures the selected session + its endpoint into locals BEFORE awaiting.
    // `Selected`/`DirBase` are computed properties over `_sessions`, which the 2s poll loop
    // replaces wholesale; re-reading them across an await can return null mid-action and throw
    // a spurious NRE that surfaces as a misleading error banner. Capture once, use the locals.
    private async Task SendNow()
    {
        var sel = Selected; var dir = sel?.TailnetEndpoint;
        if (sel is null || string.IsNullOrWhiteSpace(_compose) || string.IsNullOrWhiteSpace(dir)) return;
        Log.LogInformation("Cockpit action=send sid={Sid} dir={Dir} chars={Chars}", sel.SessionId, dir, _compose.Length);
        await Act(async () =>
        {
            await Director.SendPromptAsync(dir!, sel.SessionId, _compose, _cts.Token);
            _compose = "";
        });
    }

    private async Task QueueIt()
    {
        var sel = Selected; var dir = sel?.TailnetEndpoint;
        if (sel is null || string.IsNullOrWhiteSpace(_compose) || string.IsNullOrWhiteSpace(dir)) return;
        Log.LogInformation("Cockpit action=queue sid={Sid} dir={Dir} chars={Chars}", sel.SessionId, dir, _compose.Length);
        await Act(async () =>
        {
            _queue = await Director.EnqueueAsync(dir!, sel.SessionId, _compose, _cts.Token);
            _compose = "";
        });
    }

    private async Task SendQueued(string itemId)
    {
        var sel = Selected; var dir = sel?.TailnetEndpoint;
        if (sel is null || string.IsNullOrWhiteSpace(dir)) return;
        await Act(async () => _queue = await Director.SendQueueItemAsync(dir!, sel.SessionId, itemId, _cts.Token));
    }

    private async Task RemoveQueued(string itemId)
    {
        var sel = Selected; var dir = sel?.TailnetEndpoint;
        if (sel is null || string.IsNullOrWhiteSpace(dir)) return;
        await Act(async () => _queue = await Director.DeleteQueueItemAsync(dir!, sel.SessionId, itemId, _cts.Token));
    }

    private async Task Interrupt()
    {
        var sel = Selected; var dir = sel?.TailnetEndpoint;
        if (sel is null || string.IsNullOrWhiteSpace(dir)) return;
        Log.LogInformation("Cockpit action=interrupt sid={Sid} dir={Dir}", sel.SessionId, dir);
        await Act(() => Director.InterruptAsync(dir!, sel.SessionId, _cts.Token));
    }

    private async Task Escape()
    {
        var sel = Selected; var dir = sel?.TailnetEndpoint;
        if (sel is null || string.IsNullOrWhiteSpace(dir)) return;
        Log.LogInformation("Cockpit action=escape sid={Sid} dir={Dir}", sel.SessionId, dir);
        await Act(() => Director.EscapeAsync(dir!, sel.SessionId, _cts.Token));
    }

    private async Task OnComposerKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
            await SendNow();
    }

    // The composer textarea, so screenshot inserts land at the caret (web equivalent of the
    // desktop "drag the image onto the prompt").
    private ElementReference _composerEl;

    // "Select image" / composer file-drop: a file on THIS device that isn't on the Director yet.
    // Upload it, then insert the saved Director-side path at the composer cursor (NOT into the
    // PTY) - the same end state as tapping a gallery thumbnail. A trailing space separates images.
    private async Task OnDropImages(InputFileChangeEventArgs e)
    {
        var sel = Selected; var dir = sel?.TailnetEndpoint;
        if (sel is null || string.IsNullOrWhiteSpace(dir)) return;
        var files = e.GetMultipleFiles(10);
        var sent = 0;
        foreach (var f in files)
        {
            // One INFO line per attachment (name + size), per the issue's composer-Attach action.
            Log.LogInformation(
                "Cockpit action=attach sid={Sid} dir={Dir} name={Name} bytes={Bytes}",
                sel.SessionId, dir, f.Name, f.Size);
            try
            {
                await using var s = f.OpenReadStream(20 * 1024 * 1024, _cts.Token); // 20 MB cap
                var path = await Director.UploadImageAsync(dir!, sel.SessionId, s, f.Name, f.ContentType, _cts.Token);

                if (!string.IsNullOrWhiteSpace(path))
                    await InsertIntoComposer(path + " ");

                sent++;
                _shotStatus = $"inserted {sent} image{(sent == 1 ? "" : "s")} into the prompt";
                // Off the dispatcher after the awaits above - must marshal back, not call directly.
                await InvokeAsync(StateHasChanged);
            }
            catch (Exception ex)
            {
                _actError = $"image upload failed: {ex.Message}";
                Log.LogWarning(ex, "upload-image failed for {File}", f.Name);
            }
        }
    }

    // Tap-to-insert a gallery screenshot: it already lives on the Director, so just drop its
    // absolute path into the composer at the cursor - no upload. This is the desktop-parity move.
    private async Task InsertScreenshot(ScreenshotInfo s)
    {
        if (string.IsNullOrWhiteSpace(s.Path)) return;
        try
        {
            await InsertIntoComposer(s.Path + " ");
            _shotStatus = "inserted path into the prompt";
        }
        catch (Exception ex)
        {
            _shotStatus = $"insert failed: {ex.Message}";
            Log.LogWarning(ex, "InsertScreenshot failed");
        }
        await InvokeAsync(StateHasChanged);
    }

    // Insert text into the composer textarea at the caret via JS, which fires 'input' so the
    // bound _compose updates. Used by both gallery tap-to-insert and the upload path.
    private async Task InsertIntoComposer(string text)
    {
        var mod = await ShotsModule();
        await mod.InvokeVoidAsync("insertAtCursor", _composerEl, text);
    }

    // Speak: opens the desktop-parity Dictate dialog (cockpit-dictate.js), the browser twin
    // of the Avalonia SpeakDialog. It streams the mic to the owning Director's /dictate
    // pipeline (OpenAI + shared dictionary + verbatim cleanup) inside a modal with a mic
    // selector, live equalizer, editable transcript, and Cancel / Pause / Insert / Send.
    // It returns the cleaned text via OnDictateInsert (drop into composer) or OnDictateSend
    // (drop into composer AND submit). _dictating guards against opening it twice.
    private bool _dictating;
    private DotNetObjectReference<Cockpit>? _dictateRef;
    private IJSObjectReference? _composerDropModule;

    private async Task OpenDictate()
    {
        if (Selected is null || string.IsNullOrWhiteSpace(DirBase) || _dictating) return;
        Log.LogInformation("Cockpit action=speak-start sid={Sid} dir={Dir}", Selected.SessionId, DirBase);
        try
        {
            _dictating = true;
            _actError = null;
            _dictateRef ??= DotNetObjectReference.Create(this);
            // Issue #268: dictate over a same-origin WS to the GATEWAY (never the Director's own
            // address); the Gateway resolves the owning Director and reverse-proxies /dictate.
            var wsUrl = CockpitWsUrls.Dictate(Nav.BaseUri, Selected.SessionId);
            await JS.InvokeVoidAsync("cockpitDictate.start", _dictateRef, wsUrl, "/js/dictate-worklet.js", "default");
        }
        catch (OperationCanceledException)
        {
            // Dialog dismissed / interop torn down - a user cancellation, not a failure.
            // The dialog's own OnDictateCancel callback already resets _dictating; never
            // surface this as a red error banner ("A task was canceled").
            _dictating = false;
        }
        catch (Exception ex)
        {
            _dictating = false;
            _actError = $"dictation unavailable: {ex.Message}";
        }
    }

    // Insert: the dialog finished and the user chose Insert - append the cleaned text to the
    // composer for review (no auto-submit), mirroring the desktop dialog's Insert button.
    [JSInvokable]
    public Task OnDictateInsert(string text)
    {
        _dictating = false;
        ActionInfo("speak-stop", "result=insert");
        if (!string.IsNullOrWhiteSpace(text))
            _compose = string.IsNullOrEmpty(_compose) ? text : _compose + " " + text;
        return InvokeAsync(StateHasChanged);
    }

    // Send: the dialog finished and the user chose Send - append the cleaned text and submit
    // immediately via the normal composer send path.
    [JSInvokable]
    public async Task OnDictateSend(string text)
    {
        _dictating = false;
        ActionInfo("speak-stop", "result=send");
        if (!string.IsNullOrWhiteSpace(text))
            _compose = string.IsNullOrEmpty(_compose) ? text : _compose + " " + text;
        await InvokeAsync(StateHasChanged);
        await SendNow();
    }

    // Cancel / closed with no text.
    [JSInvokable]
    public Task OnDictateCancel()
    {
        _dictating = false;
        ActionInfo("speak-stop", "result=cancel");
        return InvokeAsync(StateHasChanged);
    }

    // One INFO line per user action (issue #199), every line carrying the selected session id and
    // its owning Director endpoint so a click can be traced to the session + box it drove. `detail`
    // appends action-specific context (tab name, attachment, etc.).
    private void ActionInfo(string action, string? detail = null)
    {
        var sel = Selected;
        var tail = detail is null ? "" : $" {detail}";
        Log.LogInformation(
            "Cockpit action={Action} sid={Sid} dir={Dir}{Detail}",
            action, sel?.SessionId ?? "(none)", sel?.TailnetEndpoint ?? "(none)", tail);
    }

    private async Task Act(Func<Task> action)
    {
        _acting = true;
        _actError = null;
        try { await action(); }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            _actError = ex.Message;
            Log.LogWarning(ex, "Cockpit action failed");
        }
        finally { _acting = false; }
        await InvokeAsync(StateHasChanged);
    }

    // ===== Left panel: collapse + view mode (persisted to localStorage) =====
    private bool _leftCollapsed;
    private string _viewMode = "tree";   // "tree" | "triage"

    private async Task ToggleLeft()
    {
        _leftCollapsed = !_leftCollapsed;
        await SavePref("cockpit.leftCollapsed", _leftCollapsed ? "1" : "0");
    }

    // ===== Right panel: collapse (screenshots + queue), persisted to localStorage =====
    private bool _rightCollapsed;

    private async Task ToggleRight()
    {
        _rightCollapsed = !_rightCollapsed;
        await SavePref("cockpit.rightCollapsed", _rightCollapsed ? "1" : "0");
    }

    // ===== Right panel tabs (Screenshots / Queue / Director) =====
    private string _rightTab = "shots";

    private async Task SetRightTab(string tab)
    {
        if (tab is not ("shots" or "queue" or "director")) return;
        ActionInfo("right-tab", $"tab={tab}");
        _rightTab = tab;
        await SavePref("cockpit.rightTab", tab);
        await LoadRightTabAsync();
    }

    // Lazy-load the data the active tab needs. Queue is already polled; Director is static
    // session data. Screenshots fetch on demand and are cleared on session switch.
    private async Task LoadRightTabAsync()
    {
        if (_rightTab == "shots" && _shots.Count == 0) await LoadScreenshotsAsync();
    }

    // ===== Screenshots gallery =====
    private string ShotUrl(string fileName)
        => string.IsNullOrWhiteSpace(DirBase) ? "" : DirectorClient.ScreenshotUrl(DirBase!, fileName);

    private async Task LoadScreenshotsAsync()
    {
        var sel = Selected; var dir = sel?.TailnetEndpoint;
        if (sel is null || string.IsNullOrWhiteSpace(dir)) return;
        _shotsBusy = true;
        _shotsError = null;
        await InvokeAsync(StateHasChanged);
        try
        {
            using var cts = CancellationTokenSource.CreateLinkedTokenSource(_cts.Token);
            cts.CancelAfter(TimeSpan.FromSeconds(10));
            var r = await Director.GetScreenshotsAsync(dir!, ShotsFetchCount, cts.Token);
            _shots = r.Items;
            // Old Directors ignore ?count and report Total=0: everything came back, so the
            // list itself is the total.
            _shotsTotal = Math.Max(r.Total, r.Items.Count);
            _shotsShown = ShotsInitialShown;
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            _shotsError = $"could not load screenshots: {ex.Message}";
            Log.LogWarning(ex, "LoadScreenshots failed");
        }
        finally
        {
            _shotsBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private Task RefreshScreenshots()
    {
        _shots = new();   // force a reload (LoadScreenshotsAsync replaces wholesale anyway)
        return LoadScreenshotsAsync();
    }

    // Clear the displayed list only (does NOT delete files) - matches the desktop's "Clear All".
    private void ClearScreenshots()
    {
        _shots = new();
        _shotsTotal = 0;
        _shotsShown = ShotsInitialShown;
    }

    // Reveal the next batch of already-fetched thumbnails (no network call).
    private void ShowMoreShots() => _shotsShown += ShotsShowMoreStep;

    // View: open the image full-size in a new browser tab, served browser-direct by the Director.
    private async Task ViewScreenshot(string fileName)
    {
        var url = ShotUrl(fileName);
        if (string.IsNullOrEmpty(url)) return;
        try { await JS.InvokeVoidAsync("window.open", url, "_blank"); }
        catch (Exception ex) { Log.LogDebug(ex, "ViewScreenshot open failed"); }
    }

    // Copy: put the actual image on the browser clipboard (the Director-side path is meaningless
    // on whatever device is viewing the Cockpit). cockpit-shots.js fetches the bytes and writes a
    // ClipboardItem, converting to PNG via canvas when needed.
    private async Task CopyScreenshot(string fileName)
    {
        var url = ShotUrl(fileName);
        if (string.IsNullOrEmpty(url)) return;
        try
        {
            var mod = await ShotsModule();
            var ok = await mod.InvokeAsync<bool>("copyImage", url);
            _shotStatus = ok ? "copied image to clipboard" : "copy failed (clipboard blocked)";
        }
        catch (Exception ex)
        {
            _shotStatus = $"copy failed: {ex.Message}";
            Log.LogWarning(ex, "CopyScreenshot failed");
        }
        await InvokeAsync(StateHasChanged);
    }

    private async Task DeleteScreenshot(string fileName)
    {
        var sel = Selected; var dir = sel?.TailnetEndpoint;
        if (sel is null || string.IsNullOrWhiteSpace(dir)) return;
        try
        {
            await Director.DeleteScreenshotAsync(dir!, fileName, _cts.Token);
            _shots = _shots.Where(s => s.FileName != fileName).ToList();
        }
        catch (Exception ex)
        {
            _shotsError = $"delete failed: {ex.Message}";
            Log.LogWarning(ex, "DeleteScreenshot failed");
        }
        await InvokeAsync(StateHasChanged);
    }

    private IJSObjectReference? _shotsJsModule;

    // The import travels the same HTTP front door as the page itself, but a long-lived page's
    // Blazor circuit survives a front-door outage (the WebSocket is already established), so
    // this import can be the first request to DISCOVER the door is dead - and the browser then
    // throws a raw "Failed to fetch dynamically imported module" TypeError that used to leak
    // straight into the status line (issue #200). Translate the boundary failure into a
    // message the user can act on; the field stays null on failure, so the next action retries.
    private async Task<IJSObjectReference> ShotsModule()
    {
        if (_shotsJsModule is not null) return _shotsJsModule;
        try
        {
            return _shotsJsModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/cockpit-shots.js");
        }
        catch (Exception ex)
        {
            Log.LogWarning(ex, "cockpit-shots.js import failed - gateway front door unreachable?");
            throw new InvalidOperationException("connection to the gateway was interrupted - try again", ex);
        }
    }

    // ===== Session Story column (Wingman center tab): headline + tokens + turn history + recap =====
    private async Task LoadWingmanAsync()
    {
        var sel = Selected; var dir = sel?.TailnetEndpoint;
        if (sel is null || string.IsNullOrWhiteSpace(dir)) return;
        _awareError = null;
        try
        {
            using var cts = CancellationTokenSource.CreateLinkedTokenSource(_cts.Token);
            cts.CancelAfter(TimeSpan.FromSeconds(10));
            // The turn timeline (the session's story) loads first - it's the story column's
            // primary content; the cached recap rides along. The GATEWAY is the one brief
            // store (#187 deleted the Director-side pipeline).
            var gatewayBriefs = await Gateway.GetTurnBriefsAsync(sel.SessionId, cts.Token);
            _turnTimeline = gatewayBriefs?.Items ?? new List<TurnBriefDto>();
            _usage = await Director.GetSessionUsageAsync(dir!, sel.SessionId, cts.Token);
            _recap = await Director.GetRecapAsync(dir!, sel.SessionId, cts.Token);
        }
        catch (OperationCanceledException) { }
        catch (Exception ex) { _awareError = ex.Message; Log.LogWarning(ex, "LoadWingman failed"); }
        await InvokeAsync(StateHasChanged);
    }

    // ----- Session story: headline + token helpers -----
    private SessionUsageDto? _usage;
    private string? _lastSeenBriefingState;

    /// The session's standing headline: the newest stored brief that carries one (stub and
    /// pre-v2.2 briefs have an empty headline and are skipped).
    private string? StoryHeadline
        => _turnTimeline?.Select(b => b.Headline).FirstOrDefault(h => !string.IsNullOrWhiteSpace(h));

    /// "since turn N": the current chapter's first turn.
    private int? HeadlineSinceTurn => Chapters.FirstOrDefault()?.Briefs[^1].TurnNumber;

    /// One chapter: a run of consecutive briefs covering ONE piece of work. Briefs are
    /// newest-first inside, matching the timeline.
    private sealed record Chapter(List<TurnBriefDto> Briefs)
    {
        /// The chapter title: the NEWEST title wording inside the chapter (the wingman may
        /// refine wording as the work drifts), falling back to intent for pre-v2.2 briefs.
        public string Title => Briefs.Select(b => b.Headline).FirstOrDefault(h => !string.IsNullOrWhiteSpace(h))
                               ?? Briefs[0].Intent;
        public int FirstTurn => Briefs[^1].TurnNumber;
        public int LastTurn => Briefs[0].TurnNumber;
    }

    /// Group the timeline (newest first) into chapters. The boundary is the wingman's
    /// EXPLICIT NewChapter flag (v2.3) - never a string comparison; a refined title is the
    /// same chapter. Pre-v2.3 briefs (flag always false) fall back to title-change grouping
    /// so old sessions still get a usable chapter list.
    private List<Chapter> Chapters
    {
        get
        {
            var briefs = _turnTimeline;
            if (briefs is null || briefs.Count == 0) return new();
            var anyFlag = briefs.Any(b => b.NewChapter);
            var chapters = new List<Chapter>();
            var current = new List<TurnBriefDto>();
            for (var i = 0; i < briefs.Count; i++) // newest -> oldest
            {
                var b = briefs[i];
                current.Add(b);
                // This brief STARTED a chapter -> close the group here (it is the group's
                // oldest member). Legacy briefs (flag never set): a brief starts a chapter
                // when the next-older titled brief carries a DIFFERENT title.
                var breaks = anyFlag ? b.NewChapter : LegacyStartsChapter(briefs, i);
                if (breaks)
                {
                    chapters.Add(new Chapter(current));
                    current = new List<TurnBriefDto>();
                }
            }
            if (current.Count > 0) chapters.Add(new Chapter(current));
            return chapters;
        }
    }

    private static bool LegacyStartsChapter(List<TurnBriefDto> briefs, int idx)
    {
        if (string.IsNullOrWhiteSpace(briefs[idx].Headline)) return false;
        for (var i = idx + 1; i < briefs.Count; i++)
            if (!string.IsNullOrWhiteSpace(briefs[i].Headline))
                return briefs[i].Headline != briefs[idx].Headline;
        return true; // oldest titled brief = the first chapter
    }

    // Expanded chapter cards (keyed by the chapter's first turn) and expanded turn rows
    // (keyed by turn number). Collapsed by default: scanning beats reading.
    private readonly HashSet<int> _openChapters = new();
    private readonly HashSet<int> _openTurns = new();
    private void ToggleChapter(int firstTurn)
    {
        if (!_openChapters.Remove(firstTurn)) _openChapters.Add(firstTurn);
