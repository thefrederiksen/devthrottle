@page "/cockpit"
@page "/cockpit/{SidParam}"
@using System.Reflection
@inject GatewayClient Gateway
@inject DirectorClient Director
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject ILogger<Cockpit> Log
@implements IDisposable

<div class="shell">
    <header class="topbar">
        <span class="brand">DevThrottle</span>
        <span class="brand-sub">Gateway Cockpit</span>

        <span class="counts">
            <span class="count-total">@_sessions.Count sessions</span>
            @if (NeedsYou > 0)
            {
                <span class="count-needs">@NeedsYou need you</span>
            }
            @if (_errors.Count > 0)
            {
                <span class="count-err">@_errors.Count director@(_errors.Count == 1 ? "" : "s") unreachable</span>
            }
        </span>

        <span class="topbar-right">
            <button class="btn tb" @onclick="OpenNewSession" title="Start a new session on any Director">+ New session</button>
            <button class="btn tb" @onclick="OpenFanout" title="Broadcast a prompt to several sessions" style="display:none">Fan-out</button>
            <button class="btn tb" @onclick="OpenSettings" title="Edit a Director's settings" style="display:none">Settings</button>
            <span class="gw" title="Gateway base URL">@Gateway.BaseUrl</span>
            <span class="ver" title="@VersionFull">@VersionDisplay</span>
            <span class="refreshed">@(_lastRefresh is null ? "connecting..." : $"updated {_lastRefresh:HH:mm:ss}")</span>
        </span>
    </header>

    @if (_lastError is not null)
    {
        <div class="banner-error">Gateway error: @_lastError</div>
    }

    <div class="body @(_leftCollapsed ? "body-collapsed" : "")">
        <aside class="left @(_leftCollapsed ? "left-collapsed" : "")">
            @if (_leftCollapsed)
            {
                @* Collapsed: a thin rail of status dots so at-a-glance awareness survives,
                   plus an expand control. Click a dot to jump to that session. *@
                <button class="left-expand" title="Expand sessions" @onclick="ToggleLeft">&raquo;</button>
                <div class="rail-mini">
                    @foreach (var s in SessionOrdering.InDesktopOrder(_sessions))
                    {
                        <button type="button"
                                class="@($"mini-dot{(s.SessionId == _selectedId ? " mini-sel" : "")}")"
                                style="background:@DotColor(SessionOrdering.EffectiveColor(s))"
                                title="@($"{SessionTitle(s)} - {s.ActivityState}")"
                                @onclick="@(() => OnSelect(s.SessionId, "rail-mini"))"></button>
                    }
                </div>
            }
            else
            {
                <div class="left-head">
                    <div class="view-toggle" role="tablist">
                        <button class="@($"vt{(_viewMode == "tree" ? " vt-on" : "")}")"
                                @onclick='() => SetViewMode("tree")'
                                title="Machine / Director tree, in desktop order">Tree</button>
                        <button class="@($"vt{(_viewMode == "triage" ? " vt-on" : "")}")"
                                @onclick='() => SetViewMode("triage")'
                                title="Needs-you first, on-hold last">Triage</button>
                        <button class="@($"vt{(_viewMode == "repo" ? " vt-on" : "")}")"
                                @onclick='() => SetViewMode("repo")'
                                title="Grouped by repository across machines, alphabetical">Repo</button>
                    </div>
                    <button class="left-collapse" title="Collapse panel" @onclick="ToggleLeft">&laquo;</button>
                </div>
                @* Interrupted sessions (issue #212): sessions whose Director died abnormally,
                   recoverable from the crash journal. Moved here from the retired Fleet page so
                   restore lives next to the live roster you drive. Only renders when there is
                   something to recover. *@
                @if (_interrupted.Count > 0)
                {
                    <div class="rail-int">
                        @* Collapsed by default so the live roster stays on top: the header is a
                           toggle that shows the count; the cards only render when expanded. *@
                        <button type="button" class="rail-int-banner" @onclick="() => _intExpanded = !_intExpanded"
                                title="@(_intExpanded ? "Hide interrupted sessions" : "Show interrupted sessions")">
                            <span class="rail-int-badge">INTERRUPTED</span>
                            <span class="rail-int-text">@_interrupted.Count session@(_interrupted.Count == 1 ? "" : "s") lost to a crash. @(_intExpanded ? "" : "Recover or dismiss.")</span>
                            <span class="rail-int-chev">@(_intExpanded ? (MarkupString)"&#9650;" : (MarkupString)"&#9660;")</span>
                        </button>
                        @if (_intExpanded)
                        {
                        @foreach (var g in InterruptedGroups())
                        {
                            <div class="rail-int-group">
                                <div class="rail-int-head">
                                    <span class="rail-int-machine">@(string.IsNullOrWhiteSpace(g.MachineName) ? "(unknown)" : g.MachineName)</span>
                                    <span class="rail-int-when">died @RelativeTime(g.DiedAtUtc) ago</span>
                                    <button class="rail-int-dismissall" @onclick="() => DismissGroup(g)"
                                            disabled="@(_dismissing.Contains(g.Key))" title="Dismiss the whole crash journal">
                                        @(_dismissing.Contains(g.Key) ? "..." : "Dismiss all")
                                    </button>
                                </div>
                                @foreach (var s in g.Sessions)
                                {
                                    <div class="rail-int-card" @key="s.SessionId">
                                        <div class="rail-int-name @(string.IsNullOrWhiteSpace(s.Name) ? "rail-int-unnamed" : "")">
                                            @(string.IsNullOrWhiteSpace(s.Name) ? "(unnamed)" : s.Name)
                                        </div>
                                        <div class="rail-int-repo" title="@s.RepoPath">@RepoBasename(s.RepoPath)</div>
                                        @if (!string.IsNullOrWhiteSpace(s.RailLine))
                                        {
                                            <div class="rail-int-last"><span class="lbl">last wingman read</span>@s.RailLine</div>
                                        }
                                        else if (!string.IsNullOrWhiteSpace(s.Headline))
                                        {
                                            <div class="rail-int-last"><span class="lbl">was working on</span>@s.Headline</div>
                                        }
                                        <div class="rail-int-actions">
                                            @if (_restored.TryGetValue(s.SessionId, out var newSid))
                                            {
                                                <span class="rail-int-done">Restored</span>
                                                <button class="rail-int-open" @onclick="@(() => Nav.NavigateTo($"/cockpit/{newSid}"))">Open &rarr;</button>
                                            }
                                            else if (_restoring.Contains(s.SessionId))
                                            {
                                                <button class="rail-int-restore" disabled>Restoring...</button>
                                            }
                                            else
                                            {
                                                <button class="rail-int-restore" @onclick="() => RestoreSession(g, s)">Restore</button>
                                                <button class="rail-int-dismiss" @onclick="() => DismissSession(g, s)"
                                                        disabled="@(_dismissing.Contains(s.SessionId))">Dismiss</button>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        }
                    </div>
                }
                @if (_railNotice is not null)
                {
                    <div class="rail-notice">@_railNotice</div>
                }
                <SessionRail Sessions="_sessions"
                             Errors="_errors"
                             Directors="_directors"
                             SelectedSessionId="@_selectedId"
                             ClosingSessionIds="ClosingSessionIds"
                             ViewMode="@_viewMode"
                             OnSelect="@(sid => OnSelect(sid, "rail"))"
                             OnNewSession="OpenNewSessionFor"
                             OnMenuAction="OnRailMenuAction" />
            }
        </aside>

        <main class="right">
            @if (Selected is null)
            {
                <div class="right-empty">
                    <div class="right-empty-title">Select a session</div>
                    <div class="right-empty-sub">Pick a session on the left to drive it: live terminal, screenshots, queue, and the composer.</div>
                </div>
            }
            @* Issue #372: the old "no tailnet endpoint" dead-end branch is gone - every session
               leg (terminal WS, screenshots, REST verbs) rides same-origin through the Gateway
               now, so a loopback-only Director is fully drivable. *@
            else
            {
                <div class="detail-head">
                    @* Effective color, same rule as the rail and triage (issue #196): the
                       header dot must never show red while the chip says the wingman is
                       still reading. *@
                    <span class="detail-dot" style="background:@DotColor(SessionOrdering.EffectiveColor(Selected))"></span>
                    @if (_renaming)
                    {
                        <input class="rename-input" @bind="_renameText" @bind:event="oninput" @onkeydown="OnRenameKey" autofocus />
                        <button class="btn tb" @onclick="SaveRename" disabled="@_acting">Save</button>
                        <button class="btn tb" @onclick="() => _renaming = false">Cancel</button>
                    }
                    else
                    {
                        @* Issue #820: three-digit session number as a muted prefix on the per-session view title. *@
                        @if (Selected.Number is int selNum)
                        {
                            <span class="detail-num" title="Session number">@selNum</span>
                        }
                        <span class="detail-name">@SessionTitle(Selected)</span>
                    }
                    <span class="detail-meta">@Selected.MachineName / director @ShortId(Selected.DirectorId)</span>
                    @* assessed-when-present (issue #186): the Gateway's brain may have refuted
                       the mechanical quiet; the raw detector state is the fallback. *@
                    <span class="detail-state">@(Selected.AssessedState ?? Selected.ActivityState)</span>
                    @if (SessionOrdering.IsBriefing(Selected))
                    {
                        <span class="briefing-chip">wingman reading...</span>
                    }
                    <span class="detail-actions">
                        @if (!_renaming)
                        {
                            <button class="btn tb" @onclick="OpenAwareness" title="Recap + turn summaries for this session" style="display:none">What's happening</button>
                            <button class="btn tb" @onclick="OpenHandover" title="Hand this session's context to another session">Handover</button>
                            <button class="btn tb" @onclick="StartRename" title="Rename this session">Rename</button>
                        }
                        @if (_killArmed)
                        {
                            <button class="btn tb danger" @onclick="KillSelected" disabled="@_acting">Confirm kill</button>
                            <button class="btn tb" @onclick="() => _killArmed = false">Cancel</button>
                        }
                        else
                        {
                            <button class="btn tb danger" @onclick="() => _killArmed = true" title="Kill this session">Kill</button>
                        }
                    </span>
                </div>

                <div class="detail-split">
                    @* ---- Center column: Brief (default) or Terminal, + composer ---- *@
                    <div class="center">
                        <div class="center-tabs">
                            @* Issue #549: the always-on "Wingman" briefs center tab is retired with the
                               turn-brief pipeline. Terminal is the default; Voice (issue #531) stays. *@
                            <button class="ctab @(CenterTab == "term" ? "on" : "")" @onclick="@(() => SetCenterTab("term"))">Terminal</button>
                            <button class="ctab @(CenterTab == "voice" ? "on" : "")" @onclick="@(() => SetCenterTab("voice"))">Voice</button>
                            @* History (epic #733): the read-only conversation thread, the web peer of
                               the desktop History tab. Lazy: the pane (and its live poll) exist only
                               while this tab is shown. *@
                            <button class="ctab @(CenterTab == "history" ? "on" : "")" @onclick="@(() => SetCenterTab("history"))">History</button>
                            <span class="center-tabs-spacer"></span>
                            @* Needs-you conveyor: flip through the sessions waiting on the user,
                               in the same order the rail's triage view shows them. *@
                            @if (NeedsYouOrdered.Count > 0)
                            {
                                <span class="ny-nav">
                                    <button class="ny-btn" title="Previous session that needs you" @onclick="() => StepNeedsYou(-1)">&#9664;</button>
                                    <span class="ny-count">@NeedsYouPosLabel</span>
                                    <button class="ny-btn" title="Next session that needs you" @onclick="() => StepNeedsYou(1)">&#9654;</button>
                                </span>
                            }
                        </div>
                        @if (CenterTab == "term")
                        {
                            @* Lazy: the stream socket only opens when the Terminal tab is opened,
                               so flipping through briefs never pays the replay cost. *@
                            <div class="term-wrap">
                                <TerminalPane @key="Selected.SessionId" SessionId="@Selected.SessionId" RowState="@(Selected.AssessedState ?? Selected.ActivityState)" />
                            </div>
                        }
                        else if (CenterTab == "voice")
                        {
                            @* ---- Voice tab (issue #531): talk to the agent; the wingman translates
                                 the reply into a faithful, speakable summary that sits here SILENTLY.
                                 Tap Listen to hear it - it is never read automatically. Speech-to-text
                                 reuses the existing dictation pipeline; the typed box is the same flow
                                 with no microphone, which is how the translation was tested. ---- *@
                            <div class="voice-tab">
                                <div class="voice-cta">
                                    <button class="btn voice-talk @(_dictating ? "on" : "")" @onclick="StartVoiceTalk"
                                            disabled="@(_dictating || _voiceBusy)">
                                        @(_dictating ? "Listening - finish in the dialog" : "Tap to talk")
                                    </button>
                                    @if (!string.IsNullOrEmpty(_voiceStatus))
                                    {
                                        <span class="voice-status">@_voiceStatus</span>
                                    }
                                </div>

                                <div class="voice-typed">
                                    <textarea @bind="_voiceText" @bind:event="oninput" rows="2"
                                              placeholder="...or type what you would say, then Ask"></textarea>
                                    <div class="voice-typed-btns">
                                        <button class="btn send" @onclick="() => RunWingmanVoiceTurnAsync(_voiceText)"
                                                disabled="@(_voiceBusy || string.IsNullOrWhiteSpace(_voiceText))">Ask the agent</button>
                                        <button class="btn" @onclick="() => RunWingmanDirectAsync(_voiceText)"
                                                disabled="@(_voiceBusy || string.IsNullOrWhiteSpace(_voiceText))"
                                                title="Talk to the wingman itself, not the working session">Ask the wingman</button>
                                    </div>
                                </div>

                                @if (_voiceBusy)
                                {
                                    <div class="voice-working">The agent is working - the wingman will summarize when the turn finishes...</div>
                                }

                                @if (!string.IsNullOrEmpty(_voiceSpoken))
                                {
                                    <div class="voice-summary">
                                        <div class="voice-summary-head">
                                            <span class="voice-summary-title">WINGMAN</span>
                                            <button class="btn" @onclick="ListenSpoken" title="Read this summary aloud">Listen</button>
                                            <button class="btn" @onclick="StopListen" title="Stop reading">Stop</button>
                                        </div>
                                        <div class="voice-summary-text">@_voiceSpoken</div>
                                        @if (!string.IsNullOrEmpty(_voiceReply))
                                        {
                                            <details class="voice-full">
                                                <summary>Show full reply</summary>
                                                <pre class="voice-full-body">@_voiceReply</pre>
                                            </details>
                                        }
                                    </div>
                                }

                                @if (!string.IsNullOrEmpty(_voiceError))
                                {
                                    <div class="act-error">@_voiceError</div>
                                }
                            </div>
                        }
                        else if (CenterTab == "history")
                        {
                            @* Lazy: HistoryPane mounts only here, so its live poll never runs while
                               the tab is hidden. Keyed by session so a switch gives a fresh pane. *@
                            <div class="hist-wrap">
                                <HistoryPane @key="Selected.SessionId" SessionId="@Selected.SessionId" />
                            </div>
                        }

                        <div class="detail-dock">
                            @* ---- Driver action bar: Stop / Interrupt / Clear context / History,
                                 rendered from the SELECTED session's driver capabilities (verbatim -
                                 a verb the tool lacks is simply absent, never guessed). Mirrors the
                                 desktop SessionActionBar; sits directly above the composer. ---- *@
                            <div class="action-bar">
                                @if (HasCap("Cancel"))
                                {
                                    <button class="btn act stop" @onclick="Escape" disabled="@_acting"
                                            title="Stop the current turn (the driver's soft cancel - Esc for Claude and pi)">Stop</button>
                                }
                                @if (HasCap("Interrupt"))
                                {
                                    <button class="btn act" @onclick="Interrupt" disabled="@_acting"
                                            title="Hard interrupt (Ctrl+C) - stronger than Stop">Interrupt</button>
                                }
                                @if (HasCap("ClearContext"))
                                {
                                    <button class="btn act" @onclick="ClearContext" disabled="@_acting"
                                            title="Reset the conversation in place (/clear for Claude, /new for pi) - the process keeps running">Clear context</button>
                                }
                                @if (HasCap("History"))
                                {
                                    <button class="btn act" @onclick="ShowHistory" disabled="@_acting"
                                            title="Open the in-terminal history picker (Claude's double-Esc)">History</button>
                                }
                                @if (!string.IsNullOrEmpty(_actionStatus))
                                {
                                    <span class="action-status">@_actionStatus</span>
                                }
                            </div>
                            @* ---- Composer: Send / Speak / Queue ---- *@
                            <div class="composer">
                                <textarea @ref="_composerEl" @bind="_compose" @bind:event="oninput" @onkeydown="OnComposerKey"
                                          rows="3"
                                          placeholder="Type a message... (Ctrl+Enter to send, Ctrl+Shift+Enter to queue)"></textarea>
                                <InputFile OnChange="OnDropImages" multiple accept="image/*" class="composer-drop-input" />
                                <div class="composer-btns">
                                    <button class="btn send" @onclick="SendNow" disabled="@(_acting || string.IsNullOrWhiteSpace(_compose))">Send</button>
                                    <button class="btn speak @(_dictating ? "on" : "")" @onclick="OpenDictate" title="Dictate" disabled="@_dictating">Speak</button>
                                    <button class="btn queue" @onclick="QueueIt" disabled="@(_acting || string.IsNullOrWhiteSpace(_compose))">Queue</button>
                                </div>
                            </div>
                            @if (!string.IsNullOrEmpty(_shotStatus))
                            {
                                <div class="shots-status">@_shotStatus</div>
                            }
                            @if (!string.IsNullOrEmpty(_actError))
                            {
                                <div class="act-error">@_actError</div>
                            }
                        </div>
                    </div>

                    @* ---- Right panel: tabbed (Screenshots / Queue / Director), collapsible.
                       The Session Story is NOT here - it is a fixed column inside the Wingman
                       center tab, so the title cards can never hide behind a tab flip. ---- *@
                    <aside class="rightpanel @(_rightCollapsed ? "rightpanel-collapsed" : "")">
                        @if (_rightCollapsed)
                        {
                            <button class="right-expand" title="Show panel" @onclick="ToggleRight">&laquo;</button>
                            @if (_queue.Count > 0)
                            {
                                <div class="rail-qbadge" title="@_queue.Count queued">@_queue.Count</div>
                            }
                        }
                        else
                        {
                            <div class="right-tabs">
                                <button class="right-tab @(_rightTab == "shots" ? "on" : "")" @onclick='() => SetRightTab("shots")'>Screenshots</button>
                                <button class="right-tab @(_rightTab == "queue" ? "on" : "")" @onclick='() => SetRightTab("queue")'>Queue@(_queue.Count > 0 ? $" ({_queue.Count})" : "")</button>
                                <button class="right-collapse" title="Hide panel" @onclick="ToggleRight">&raquo;</button>
                            </div>

                            <div class="right-body">
                                @* ================= Screenshots tab ================= *@
                                @if (_rightTab == "shots")
                                {
                                    <div class="rightpanel-head">
                                        <span class="rightpanel-title">SCREENSHOTS</span>
                                        <button class="linkbtn" @onclick="RefreshScreenshots" disabled="@_shotsBusy" title="Reload from the Director">Refresh</button>
                                        <button class="linkbtn" @onclick="ClearScreenshots" title="Clear this list (does not delete files)">Clear All</button>
                                    </div>

                                    @* Gallery of captured screenshots on the Director's machine.
                                       Clicking a thumbnail VIEWS it (opens full-size in a new tab); inserting a
                                       path into the prompt is a deliberate action via the Insert button only -
                                       a click never inserts. To attach a device-local image, use the composer's
                                       Attach button. *@
                                    <div class="gallery">
                                        @if (_shotsOffline)
                                        {
                                            @* Issue #412: graceful offline state - human-readable, with a Retry
                                               (the same Refresh action) - never the raw 503 exception string. *@
                                            <div class="gallery-error">
                                                Screenshots unavailable &mdash; the Director running this session is offline.
                                                <button class="linkbtn" @onclick="RefreshScreenshots" disabled="@_shotsBusy" title="Try loading the screenshots again">Retry</button>
                                            </div>
                                        }
                                        else if (!string.IsNullOrEmpty(_shotsError))
                                        {
                                            <div class="gallery-error">
                                                @_shotsError
                                                <button class="linkbtn" @onclick="RefreshScreenshots" disabled="@_shotsBusy" title="Try loading the screenshots again">Retry</button>
                                            </div>
                                        }
                                        else if (_shotsBusy && _shots.Count == 0)
                                        {
                                            <div class="gallery-empty">Loading screenshots&hellip;</div>
                                        }
                                        else if (_shots.Count == 0)
                                        {
                                            <div class="gallery-empty">No screenshots in this Director's folder yet.</div>
                                        }
                                        else
                                        {
                                            @* Only the newest _shotsShown thumbnails render; each <img> is the
                                               full-size file fetched same-origin through the Gateway's proxy
                                               (#317), so rendering all 1000+ folder entries at once would melt
                                               the tab. Show more grows the list from the already-fetched
                                               metadata - no network call. *@
                                            @foreach (var s in _shots.Take(_shotsShown))
                                            {
                                                <div class="shot-card" @key="s.FileName">
                                                    @* Click the thumbnail to VIEW full-size. Insert is the explicit
                                                       button only, so a path never lands in the prompt by accident. *@
                                                    <img class="shot-thumb" src="@ShotUrl(s.FileName)" alt="@s.FileName" loading="lazy"
                                                         title="Click to view full size" @onclick="() => ViewScreenshot(s.FileName)" />
                                                    <div class="shot-row">
                                                        <span class="shot-time">@s.TimeLabel</span>
                                                        <button class="linkbtn" @onclick="() => InsertScreenshot(s)" title="Insert path into the prompt">Insert</button>
                                                        <button class="linkbtn" @onclick="() => CopyScreenshot(s.FileName)">Copy</button>
                                                        <button class="linkbtn del" @onclick="() => DeleteScreenshot(s.FileName)">Del</button>
                                                    </div>
                                                </div>
                                            }
                                            @if (_shots.Count > _shotsShown)
                                            {
                                                <button class="gallery-more" @onclick="ShowMoreShots">
                                                    Show @Math.Min(ShotsShowMoreStep, _shots.Count - _shotsShown) more
                                                    (@(_shotsTotal - _shotsShown) older)
                                                </button>
                                            }
                                            else if (_shotsTotal > _shots.Count)
                                            {
                                                <div class="gallery-footnote">
                                                    Newest @_shots.Count of @_shotsTotal - older files stay on the Director's disk.
                                                </div>
                                            }
                                        }
                                    </div>
                                }
                                @* ================= Queue tab ================= *@
                                else if (_rightTab == "queue")
                                {
                                    <div class="rightpanel-head">
                                        <span class="rightpanel-title">@(_queue.Count == 0 ? "QUEUE" : $"QUEUE ({_queue.Count})")</span>
                                        @if (_queue.Count > 0)
                                        {
                                            <button class="linkbtn" @onclick="ClearQueue" title="Clear all queued prompts">Clear</button>
                                        }
                                    </div>
                                    <div class="queue">
                                        @if (_queue.Count == 0)
                                        {
                                            <div class="queue-empty">No queued prompts</div>
                                        }
                                        else
                                        {
                                            @for (int qi = 0; qi < _queue.Count; qi++)
                                            {
                                                var q = _queue[qi];
                                                var idx = qi + 1;
                                                var isFirst = qi == 0;
                                                var isLast = qi == _queue.Count - 1;
                                                var isEditing = _editingQueueId == q.Id;
                                                <div class="queue-item" @key="q.Id">
                                                    <div class="queue-item-top">
                                                        <span class="queue-idx">@idx</span>
                                                        <span class="queue-text">@q.Text</span>
                                                    </div>
                                                    <div class="queue-btns">
                                                        <button class="qbtn" title="Move up" disabled="@(isFirst || _acting)" @onclick="() => MoveQueuedUp(q.Id)">/\</button>
                                                        <button class="qbtn" title="Move down" disabled="@(isLast || _acting)" @onclick="() => MoveQueuedDown(q.Id)">\/</button>
                                                        <button class="qbtn" title="Edit text" @onclick="() => StartEditQueue(q.Id, q.Text)">Edit</button>
                                                        <button class="qbtn" title="Remove from queue and paste into composer" @onclick="() => PopQueued(q.Id, q.Text)">Pop</button>
                                                        <button class="qbtn qdel" title="Remove" @onclick="() => RemoveQueued(q.Id)">&times;</button>
                                                    </div>
                                                    @if (isEditing)
                                                    {
                                                        <div class="queue-edit">
                                                            <textarea class="queue-edit-box" @bind="_editingQueueText" rows="3"></textarea>
                                                            <div class="queue-edit-btns">
                                                                <button class="qbtn" @onclick="() => SaveEditQueue(q.Id)">Save</button>
                                                                <button class="qbtn" @onclick="CancelEditQueue">Cancel</button>
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </aside>
                </div>
            }
        </main>
    </div>

    @* ===== New session dialog (desktop parity: tabs + repo table + browse) ===== *@
    @if (_showNewSession)
    {
        <div class="modal-backdrop" @onclick="CloseNewSession">
            <div class="modal modal-ns" @onclick:stopPropagation="true">
                <div class="modal-head ns-head">
                    <span>New session</span>
                    <label class="ns-dir">
                        <span class="fld-label">Director</span>
                        <select @bind="_nsDirectorId" @bind:after="OnNsDirectorChanged">
                            @foreach (var d in _directors)
                            {
                                <option value="@d.DirectorId">@DirectorLabel(d)</option>
                            }
                        </select>
                    </label>
                </div>

                <div class="modal-body ns-body">
                    <div class="ns-agents">
                        <span class="fld-label">Agent:</span>
                        @foreach (var a in NsAgents)
                        {
                            <button class="chip @(_nsAgent == a ? "on" : "")" @onclick="() => SetAgent(a)">@AgentLabel(a)</button>
                        }
                    </div>

                    <input class="ns-search" @bind="_nsRepoFilter" @bind:event="oninput" placeholder="Filter repositories by name or path" />

                    <div class="ns-table">
                        <div class="ns-row ns-hd">
                            <button class="ns-c-name" @onclick='() => SortRepos("Name")'>Name@(SortArrow("Name"))</button>
                            <button class="ns-c-path" @onclick='() => SortRepos("Path")'>Path@(SortArrow("Path"))</button>
                            <button class="ns-c-used" @onclick='() => SortRepos("LastUsed")'>Last Used@(SortArrow("LastUsed"))</button>
                            <span class="ns-c-x"></span>
                        </div>
                        <div class="ns-rows">
                            @foreach (var r in FilteredRepos)
                            {
                                <div class="ns-row @(EffectiveNsRepo == r.Path ? "sel" : "")" @onclick="() => SelectRepo(r.Path)">
                                    <span class="ns-c-name" title="@r.Name">@r.Name</span>
                                    <span class="ns-c-path" title="@r.Path">@r.Path</span>
                                    <span class="ns-c-used">@RelLastUsed(r.LastUsed)</span>
                                    <button class="ns-c-x" title="Remove from list" @onclick:stopPropagation="true" @onclick="() => RemoveRepo(r.Path)">x</button>
                                </div>
                            }
                            @if (FilteredRepos.Count == 0)
                            {
                                <div class="ns-empty">No repositories. Type a path below or Browse.</div>
                            }
                        </div>
                    </div>

                    <div class="ns-pathrow">
                        <input class="ns-path" @bind="_nsRepoPathManual" @bind:event="oninput" placeholder="D:\path\to\repo" />
                        <button class="btn" @onclick="OpenBrowse">Browse...</button>
                    </div>

                    <div class="ns-opts">
                        <label class="ck @(_nsAgent != "ClaudeCode" ? "off" : "")">
                            <input type="checkbox" @bind="_nsBypass" disabled="@(_nsAgent != "ClaudeCode")" /> Bypass permission prompts
                        </label>
                        <label class="ck">
                            <input type="checkbox" @bind="_nsWingman" /> Wingman (auto-explain on turn-end + Voice tabs)
                        </label>
                    </div>

                    @if (!string.IsNullOrEmpty(_nsError))
                    {
                        <div class="modal-error">@_nsError</div>
                    }
                </div>

                <div class="modal-foot">
                    <button class="btn" @onclick="CloseNewSession">Cancel</button>
                    <button class="btn send" @onclick="CreateSession" disabled="@(_acting || string.IsNullOrWhiteSpace(EffectiveNsRepo))">@(_acting ? "Creating session..." : "Create")</button>
                </div>
            </div>
        </div>

        @if (_browseOpen)
        {
            <div class="modal-backdrop ns-browse-back" @onclick="CloseBrowse">
                <div class="modal modal-browse" @onclick:stopPropagation="true">
                    <div class="modal-head">Browse for a folder (on @DirectorShort)</div>
                    <div class="modal-body">
                        <div class="ns-browse-path">@(_browseListing?.CurrentPath ?? "(drives)")</div>
                        <div class="ns-browse-list">
                            @if (_browseBusy)
                            {
                                <div class="ns-empty">Loading...</div>
                            }
                            else
                            {
                                @if (_browseListing?.CurrentPath is not null)
                                {
                                    <div class="ns-browse-item up" @onclick="BrowseUp">.. (up)</div>
                                }
                                @foreach (var e in (_browseListing?.Entries ?? new List<DirEntryDto>()))
                                {
                                    <div class="ns-browse-item" @onclick="() => BrowseNavigate(e.Path)">@(e.IsDrive ? e.Path : e.Name)</div>
                                }
                                @if ((_browseListing?.Entries.Count ?? 0) == 0)
                                {
                                    <div class="ns-empty">No sub-folders here.</div>
                                }
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(_browseError))
                        {
                            <div class="modal-error">@_browseError</div>
                        }
                    </div>
                    <div class="modal-foot">
                        <button class="btn" @onclick="CloseBrowse">Cancel</button>
                        <button class="btn send" @onclick="BrowseSelect" disabled="@string.IsNullOrEmpty(_browseListing?.CurrentPath)">Select this folder</button>
                    </div>
                </div>
            </div>
        }
    }

    @* ===== Settings modal ===== *@
    @if (_showSettings)
    {
        <div class="modal-backdrop" @onclick="CloseSettings">
            <div class="modal modal-wide" @onclick:stopPropagation="true">
                <div class="modal-head">Settings</div>
                <div class="modal-body">
                    <label class="fld">
                        <span class="fld-label">Director</span>
                        <select @bind="_setDirectorId" @bind:after="LoadSettings">
                            @foreach (var d in _directors)
                            {
                                <option value="@d.DirectorId">@DirectorLabel(d)</option>
                            }
                        </select>
                    </label>
                    <textarea class="settings-json" @bind="_settingsJson" spellcheck="false"></textarea>
                    @if (!string.IsNullOrEmpty(_setError))
                    {
                        <div class="modal-error">@_setError</div>
                    }
                    @if (!string.IsNullOrEmpty(_setStatus))
                    {
                        <div class="modal-status">@_setStatus</div>
                    }
                </div>
                <div class="modal-foot">
                    <button class="btn" @onclick="CloseSettings">Close</button>
                    <button class="btn send" @onclick="SaveSettings" disabled="@(_acting || string.IsNullOrWhiteSpace(_settingsJson))">Save</button>
                </div>
            </div>
        </div>
    }

    @* ===== Awareness: "what's happening" (recap + turn summaries) ===== *@
    @if (_showAwareness)
    {
        <div class="modal-backdrop" @onclick="CloseAwareness">
            <div class="modal modal-wide" @onclick:stopPropagation="true">
                <div class="modal-head">What's happening@(_awareTitle is null ? "" : $" - {_awareTitle}")</div>
                <div class="modal-body">
                    <div class="aware-section">
                        <div class="aware-h"><span>GIT</span></div>
                        @if (_git is null)
                        {
                            <div class="aware-muted">Loading...</div>
                        }
                        else if (_git.Status == "ok")
                        {
                            <div class="git-line">
                                <span class="git-branch">@_git.Branch</span>
                                <span class="@(_git.Dirty ? "git-dirty" : "git-clean")">@(_git.Dirty ? "dirty" : "clean")</span>
                                @if (_git.Ahead > 0) { <span class="git-ab">ahead @_git.Ahead</span> }
                                @if (_git.Behind > 0) { <span class="git-ab">behind @_git.Behind</span> }
                            </div>
                            @if (!string.IsNullOrWhiteSpace(_git.LastCommit))
                            {
                                <div class="git-commit">@_git.LastCommit</div>
                            }
                        }
                        else
                        {
                            <div class="aware-muted">@(_git.Error ?? "no git info")</div>
                        }
                    </div>
                    <div class="aware-section">
                        <div class="aware-h">
                            <span>RECAP</span>
                            <button class="btn tb" @onclick="GenerateRecap" disabled="@_recapBusy">@(_recapBusy ? "generating (~90s)..." : "Generate fresh")</button>
                        </div>
                        @if (_recap is null)
                        {
                            <div class="aware-muted">Loading...</div>
                        }
                        else if (_recap.Status == "ok" && !string.IsNullOrWhiteSpace(_recap.Recap))
                        {
                            <div class="aware-recap">@_recap.Recap</div>
                            <div class="aware-meta">@_recap.Model &middot; @(_recap.IsStale ? "stale (new turns since)" : "current") &middot; generated @(_recap.GeneratedAt?.ToLocalTime().ToString("HH:mm:ss"))</div>
                        }
                        else
                        {
                            <div class="aware-muted">@(_recap.Error ?? "No recap yet. Click Generate fresh.")</div>
                        }
                    </div>
                    <div class="aware-section">
                        <div class="aware-h"><span>TURN SUMMARIES (@_turns.Count)</span></div>
                        @if (_turns.Count == 0)
                        {
                            <div class="aware-muted">No turn summaries yet for this session.</div>
                        }
                        else
                        {
                            @foreach (var t in _turns)
                            {
                                <div class="turn">
                                    <div class="turn-headline">
                                        @if (t.NeedsUser != "no")
                                        {
                                            <span class="turn-needs">needs you</span>
                                        }
                                        @t.Headline
                                    </div>
                                    @if (t.FilesTouched.Count > 0)
                                    {
                                        <div class="turn-meta">files: @string.Join(", ", t.FilesTouched.Take(6))</div>
                                    }
                                    <div class="turn-time">@t.GeneratedAt.ToLocalTime().ToString("HH:mm:ss")</div>
                                </div>
                            }
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(_awareError))
                    {
                        <div class="modal-error">@_awareError</div>
                    }
                </div>
                <div class="modal-foot">
                    <button class="btn" @onclick="CloseAwareness">Close</button>
                </div>
            </div>
        </div>
    }

    @* ===== Fan-out: broadcast a prompt to several sessions ===== *@
    @if (_showFanout)
    {
        <div class="modal-backdrop" @onclick="CloseFanout">
            <div class="modal modal-wide" @onclick:stopPropagation="true">
                <div class="modal-head">Fan-out a prompt to multiple sessions</div>
                <div class="modal-body">
                    <div class="fanout-list">
                        @foreach (var s in _sessions)
                        {
                            var sid = s.SessionId;
                            <label class="fanout-item">
                                <input type="checkbox" checked="@_fanoutSelected.Contains(sid)" @onchange="e => ToggleFanout(sid, (bool)(e.Value ?? false))" />
                                <span class="fanout-dot" style="background:@DotColor(SessionOrdering.EffectiveColor(s))"></span>
                                <span class="fanout-name">@SessionTitle(s)</span>
                                <span class="fanout-meta">@s.MachineName / @ShortId(s.DirectorId)</span>
                            </label>
                        }
                    </div>
                    <label class="fld">
                        <span class="fld-label">Prompt to send to the @_fanoutSelected.Count selected session(s)</span>
                        <textarea class="fanout-text" @bind="_fanoutText" @bind:event="oninput" spellcheck="false" placeholder="any prompt, e.g. 'commit your work and summarize what you did'"></textarea>
                    </label>
                    @if (_fanoutResults.Count > 0)
                    {
                        <div class="fanout-results">
                            @foreach (var r in _fanoutResults)
                            {
                                <div class="fanout-result"><span class="@(r.Error is null ? "git-clean" : "git-dirty")">@(r.Error is null ? "delivered" : "failed")</span> &nbsp;@ShortId(r.SessionId) @r.Error</div>
                            }
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(_fanoutError))
                    {
                        <div class="modal-error">@_fanoutError</div>
                    }
                </div>
                <div class="modal-foot">
                    <button class="btn" @onclick="CloseFanout">Cancel</button>
                    <button class="btn send" @onclick="DoFanout" disabled="@(_fanoutBusy || _fanoutSelected.Count == 0 || string.IsNullOrWhiteSpace(_fanoutText))">@(_fanoutBusy ? "sending..." : $"Send to {_fanoutSelected.Count}")</button>
                </div>
            </div>
        </div>
    }

    @* ===== Handover: hand a session's context to a new or existing session ===== *@
    @if (_showHandover && Selected is not null)
    {
        <div class="modal-backdrop" @onclick="CloseHandover">
            <div class="modal modal-wide" @onclick:stopPropagation="true">
                <div class="modal-head">Hand over - @SessionTitle(Selected)</div>
                <div class="modal-body">
                    <div class="aware-h"><span>CONTEXT PREVIEW (what the target session receives)</span></div>
                    <div class="handover-preview">@(_handoverContext ?? "Loading...")</div>

                    <label class="fld">
                        <span class="fld-label">Hand over to</span>
                        <select @bind="_hoMode">
                            <option value="new">a new session</option>
                            <option value="existing">an existing session (same Director)</option>
                        </select>
                    </label>

                    @if (_hoMode == "new")
                    {
                        <label class="fld">
                            <span class="fld-label">Director</span>
                            <select @bind="_hoDirectorId">
                                @foreach (var d in _directors)
                                {
                                    <option value="@d.DirectorId">@DirectorLabel(d)</option>
                                }
                            </select>
                        </label>
                        <label class="fld">
                            <span class="fld-label">Repo path</span>
                            <input @bind="_hoRepoPath" @bind:event="oninput" placeholder="D:/path/to/repo" />
                        </label>
                        <label class="fld">
                            <span class="fld-label">Agent</span>
                            <select @bind="_hoAgent">
                                <option>ClaudeCode</option>
                                <option>Codex</option>
                                <option>Gemini</option>
                                <option>Pi</option>
                                <option>OpenCode</option>
                            </select>
                        </label>
                    }
                    else
                    {
                        <label class="fld">
                            <span class="fld-label">Existing session</span>
                            <select @bind="_hoToSessionId">
                                <option value="">-- pick a session on the same Director --</option>
                                @foreach (var s in _sessions.Where(s => s.SessionId != Selected.SessionId && s.DirectorId == Selected.DirectorId))
                                {
                                    <option value="@s.SessionId">@SessionTitle(s)</option>
                                }
                            </select>
                        </label>
                    }

                    <label class="fld">
                        <span class="fld-label">Extra context (optional)</span>
                        <textarea class="fanout-text" @bind="_hoExtra" @bind:event="oninput" spellcheck="false" placeholder="anything else the target session should know"></textarea>
                    </label>
                    <label class="ho-check"><input type="checkbox" @bind="_hoArchive" /> Archive this handover to the vault</label>

                    @if (!string.IsNullOrEmpty(_hoError)) { <div class="modal-error">@_hoError</div> }
                    @if (!string.IsNullOrEmpty(_hoStatus)) { <div class="modal-status">@_hoStatus</div> }
                </div>
                <div class="modal-foot">
                    <button class="btn" @onclick="CloseHandover">Cancel</button>
                    <button class="btn send" @onclick="DoHandover" disabled="@(_hoBusy || !HandoverReady)">@(_hoBusy ? "handing over..." : "Hand over")</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    // Product version stamped by Directory.Build.props ("0.6.3+sha", SourceLink suffix).
    // Cockpit does not reference Core, so parse inline (mirror of AppVersion).
    private static readonly string VersionFull =
        typeof(Cockpit).Assembly.GetCustomAttribute<AssemblyInformationalVersionAttribute>()?.InformationalVersion ?? "0.0.0";
    private static readonly string VersionDisplay = $"v{VersionFull.Split('+')[0]}";

    private List<SessionDto> _sessions = new();
    private List<MachineErrorDto> _errors = new();
    private string? _selectedId;
    private string? _lastError;
    private DateTime? _lastRefresh;
    private readonly CancellationTokenSource _cts = new();

    // Effective color (issue #196): folds through SessionOrdering (dot + triage bucket).
    private int NeedsYou => _sessions.Count(s => SessionOrdering.EffectiveColor(s) == "red");
    private SessionDto? Selected => _sessions.FirstOrDefault(s => s.SessionId == _selectedId);

    // ----- center tab (Terminal is the default; choice persists per session for the circuit) -----
    private readonly Dictionary<string, string> _centerTabBySession = new();
    private string CenterTab =>
        Selected is not null && _centerTabBySession.TryGetValue(Selected.SessionId, out var t) ? t : "term";
    private void SetCenterTab(string tab)
    {
        if (Selected is null) return;
        ActionInfo("center-tab", $"tab={tab}");
        _centerTabBySession[Selected.SessionId] = tab;
    }

    // ----- needs-you conveyor: flip through red sessions in the rail's stable order -----
    private List<SessionDto> NeedsYouOrdered =>
        SessionOrdering.InDesktopOrder(_sessions).Where(s => SessionOrdering.EffectiveColor(s) == "red").ToList();

    private string NeedsYouPosLabel
    {
        get
        {
            var list = NeedsYouOrdered;
            var idx = list.FindIndex(s => s.SessionId == _selectedId);
            return idx >= 0 ? $"{idx + 1}/{list.Count}" : $"{list.Count}";
        }
    }

    private async Task StepNeedsYou(int delta)
    {
        var list = NeedsYouOrdered;
        if (list.Count == 0) return;
        var idx = list.FindIndex(s => s.SessionId == _selectedId);
        // Not on a needs-you session: jump to the first (or last when stepping back).
        var next = idx < 0
            ? (delta > 0 ? 0 : list.Count - 1)
            : (idx + delta + list.Count) % list.Count;
        await OnSelect(list[next].SessionId, "needs-you-nav");
    }


    /// <summary>Deep-link route parameter: /cockpit/{sid} selects that session on load.</summary>
    [Parameter] public string? SidParam { get; set; }

    protected override async Task OnInitializedAsync()
    {
        Log.LogInformation("Cockpit initializing against Gateway {Base}", Gateway.BaseUrl);
        await RefreshAsync();
        _ = PollLoopAsync();
    }

    // Runs after OnInitializedAsync (roster loaded) and again on every /cockpit/{sid}
    // navigation within the circuit (e.g. a dashboard needs-you click while already here).
    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(SidParam) && SidParam != _selectedId
            && _sessions.Any(s => s.SessionId == SidParam))
            await OnSelect(SidParam, "deep-link");
    }

    // Restore the left-panel preferences once the circuit can do JS interop. These are
    // pure UI conveniences; if localStorage is unavailable the defaults (expanded, tree)
    // stand, which is correct behaviour rather than a hidden failure.
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try
        {
            // Wire composer drag-drop once via event delegation, so it survives every
            // composer re-render (session switches) without re-binding. init() is idempotent.
            _composerDropModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/cockpit-composer-drop.js");
            await _composerDropModule.InvokeVoidAsync("init");
        }
        catch (Exception ex)
        {
            Log.LogDebug(ex, "Cockpit: wiring composer drop failed");
        }
        try
        {
            // Preload the screenshot-gallery module while the page is known-healthy. The lazy
            // import used to be deferred to the first screenshot click, which made it the first
            // request to hit a front-door outage minutes later (issue #200). A preload failure
            // is only logged: ShotsModule() retries on demand with a user-facing message.
            await ShotsModule();
        }
        catch (Exception ex)
        {
            Log.LogDebug(ex, "Cockpit: preloading cockpit-shots.js failed; will retry on first use");
        }
        try
        {
            var collapsed = await JS.InvokeAsync<string?>("localStorage.getItem", "cockpit.leftCollapsed");
            var mode = await JS.InvokeAsync<string?>("localStorage.getItem", "cockpit.viewMode");
            var rightCollapsed = await JS.InvokeAsync<string?>("localStorage.getItem", "cockpit.rightCollapsed");
            var rightTab = await JS.InvokeAsync<string?>("localStorage.getItem", "cockpit.rightTab");
            var changed = false;
            if (collapsed == "1" && !_leftCollapsed) { _leftCollapsed = true; changed = true; }
            // Pattern match narrows `mode` to non-null, so no null-forgiving operator is needed.
            if (mode is "tree" or "triage" or "repo" && mode != _viewMode) { _viewMode = mode; changed = true; }
            if (rightCollapsed == "1" && !_rightCollapsed) { _rightCollapsed = true; changed = true; }
            // "wingman" is intentionally absent: the Session Story moved into the Wingman
            // center tab, so a stale stored "wingman" pref falls back to the default.
            if (rightTab is "shots" or "queue" or "director" && rightTab != _rightTab) { _rightTab = rightTab; changed = true; }
            if (changed) await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Log.LogDebug(ex, "Cockpit: restoring left-panel prefs failed");
        }
    }

    private async Task PollLoopAsync()
    {
        var timer = new PeriodicTimer(TimeSpan.FromSeconds(2));
        try
        {
            while (await timer.WaitForNextTickAsync(_cts.Token))
                await RefreshAsync();
        }
        catch (OperationCanceledException)
        {
            // circuit tearing down; normal.
        }
        finally
        {
            timer.Dispose();
        }
    }

    private bool _refreshing;

    private async Task RefreshAsync()
    {
        // The 2s tick can fire again while a slow refresh is still in flight; skip overlapping
        // runs so two GetSessions responses can't land out of order and flash stale data.
        if (_refreshing) return;
        _refreshing = true;
        try
        {
            var env = await Gateway.GetSessionsAsync(_cts.Token);
            _sessions = env.Sessions;
            _errors = env.MachineErrors;
            _lastError = null;
            _lastRefresh = DateTime.Now;

            // Optimistic close-dim reconcile (issue #228): a row stays dimmed only until the
            // Gateway drops the torn-down session from the roster. Clear any sid that has left
            // the roster (teardown confirmed) or whose stamp is older than 15s (teardown never
            // landed - stop dimming a live row).
            if (_closingSids.Count > 0)
            {
                var live = _sessions.Select(s => s.SessionId).ToHashSet();
                var stale = _closingSids
                    .Where(kv => !live.Contains(kv.Key) || DateTime.UtcNow - kv.Value > TimeSpan.FromSeconds(15))
                    .Select(kv => kv.Key)
                    .ToList();
                foreach (var sid in stale) _closingSids.Remove(sid);
            }

            // Rail group headers show per-Director version + uptime from the registry.
            // The registry is near-static (start/stop events only), so refresh it at most
            // every 30s instead of on every roster tick; minute-resolution uptime stays honest.
            if (DateTime.UtcNow - _directorsRefreshedAt >= TimeSpan.FromSeconds(30))
            {
                _directors = await Gateway.GetDirectorsAsync(_cts.Token);
                _directorsRefreshedAt = DateTime.UtcNow;
            }

            // Interrupted-session journal (issue #212): near-static recovery data, refreshed at
            // most every 15s. Stamp the time before the call so a slow/failed fetch does not retry
            // on every 2s tick; RefreshInterruptedAsync is self-guarded so a journal fetch failure
            // never disturbs the live roster.
            if (DateTime.UtcNow - _interruptedRefreshedAt >= TimeSpan.FromSeconds(15))
            {
                _interruptedRefreshedAt = DateTime.UtcNow;
                await RefreshInterruptedAsync();
            }

            // Drop the selection if that session has gone away.
            if (_selectedId is not null && _sessions.All(s => s.SessionId != _selectedId))
                _selectedId = null;

            // Show the fresh roster immediately - a slow per-Director queue load must never
            // delay the fleet view (one slow Director can't stall the UI).
            await InvokeAsync(StateHasChanged);

            // Keep the queue panel current (catches external drains too), but not while the
            // user is acting on the queue: the action's response is authoritative, and a poll
            // load racing it could clobber a just-enqueued/removed item until the next tick.
            if (!_acting)
                await LoadQueueAsync();
        }
        catch (OperationCanceledException)
        {
            throw;
        }
        catch (Exception ex)
        {
            _lastError = ex.Message;
            Log.LogWarning(ex, "Cockpit RefreshAsync failed against {Base}", Gateway.BaseUrl);
        }
        finally
        {
            _refreshing = false;
        }
        await InvokeAsync(StateHasChanged);
    }

    // ----- selection + composer/queue/screenshots state -----
    private string _compose = "";
    private List<QueueItem> _queue = new();
    private string? _editingQueueId;
    private string _editingQueueText = "";
    private bool _acting;
    private string? _actError;
    private string? _shotStatus;

    // Screenshots gallery (the captured-screenshots list on the selected session's Director).
    // The folder can hold THOUSANDS of images and each thumbnail is the full-size file fetched
    // over the tailnet, so the gallery is deliberately incremental: fetch metadata for the
    // newest ShotsFetchCount only, render ShotsInitialShown thumbnails, and grow on demand.
    private const int ShotsFetchCount = 100;
    private const int ShotsInitialShown = 12;
    private const int ShotsShowMoreStep = 24;
    private List<ScreenshotInfo> _shots = new();
    private int _shotsTotal;                       // full folder count reported by the Director
    private int _shotsShown = ShotsInitialShown;   // thumbnails currently rendered
    private bool _shotsBusy;
    private string? _shotsError;
    // Issue #412: the owning Director is offline/unreachable (Gateway 503 on the shots leg) - the
    // panel shows a graceful "Director offline" message + Retry, NOT a raw exception string.
    private bool _shotsOffline;

    // Source of a selection (issue #199): which gesture drove it - rail click, the needs-you
    // conveyor, a deep link, or a quick-reply advance. Logged so a session-switch line in the
    // persisted log says WHY the session changed, not just that it did.
    private async Task OnSelect(string sessionId, string source = "rail")
    {
        var picked = _sessions.FirstOrDefault(s => s.SessionId == sessionId);
        Log.LogInformation(
            "Cockpit action=select-session source={Source} sid={Sid} dir={Dir}",
            source, sessionId, picked?.TailnetEndpoint ?? "(none)");
        // Issue #372: a missing tailnet endpoint is no longer a failure mode - every session
        // leg rides same-origin through the Gateway - so the old blank-terminal WARNING is gone.
        _selectedId = sessionId;
        // Keep the address bar deep-linkable (/cockpit/{sid}) without adding history entries.
        // OnParametersSetAsync guards on SidParam != _selectedId, so this never re-enters.
        Nav.NavigateTo($"/cockpit/{sessionId}", replace: true);
        _compose = "";
        _actError = null;
        _shotStatus = null;
        _renaming = false;
        _killArmed = false;
        _queue = new();
        _shots = new();
        _shotsTotal = 0;
        _shotsShown = ShotsInitialShown;
        _shotsError = null;
        _shotsOffline = false;
        _recap = null;
        _awareError = null;
        await LoadQueueAsync();
        // Load whatever the active right-panel tab needs for the newly-selected session.
        await LoadRightTabAsync();
    }

    private async Task LoadQueueAsync()
    {
        var sel = Selected;
        if (sel is null) return;
        try
        {
            // Short cap so a hung /queue on the selected Director can't stall the poll loop for
            // the client's full timeout. Linked to _cts so circuit teardown still cancels it.
            using var cts = CancellationTokenSource.CreateLinkedTokenSource(_cts.Token);
            cts.CancelAfter(TimeSpan.FromSeconds(8));
            _queue = await Director.GetQueueAsync(sel.SessionId, cts.Token);
        }
        catch (OperationCanceledException) { }
        catch (Exception ex) { Log.LogDebug(ex, "LoadQueue failed"); }
    }

    // Each action captures the selected session into a local BEFORE awaiting.
    // `Selected` is a computed property over `_sessions`, which the 2s poll loop
    // replaces wholesale; re-reading them across an await can return null mid-action and throw
    // a spurious NRE that surfaces as a misleading error banner. Capture once, use the locals.
    private async Task SendNow()
    {
        var sel = Selected;
        if (sel is null || string.IsNullOrWhiteSpace(_compose)) return;
        Log.LogInformation("Cockpit action=send sid={Sid} chars={Chars}", sel.SessionId, _compose.Length);
        await Act(async () =>
        {
            await Director.SendPromptAsync(sel.SessionId, _compose, _cts.Token);
            _compose = "";
        });
    }

    private async Task QueueIt()
    {
        var sel = Selected;
        if (sel is null || string.IsNullOrWhiteSpace(_compose)) return;
        Log.LogInformation("Cockpit action=queue sid={Sid} chars={Chars}", sel.SessionId, _compose.Length);
        await Act(async () =>
        {
            _queue = await Director.EnqueueAsync(sel.SessionId, _compose, _cts.Token);
            _compose = "";
        });
    }

