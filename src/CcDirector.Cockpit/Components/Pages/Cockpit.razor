@page "/"
@inject GatewayClient Gateway
@inject DirectorClient Director
@inject IJSRuntime JS
@inject ILogger<Cockpit> Log
@implements IDisposable

<div class="shell">
    <header class="topbar">
        <span class="brand">CC Director</span>
        <span class="brand-sub">Gateway Cockpit</span>

        <span class="counts">
            <span class="count-total">@_sessions.Count sessions</span>
            @if (NeedsYou > 0)
            {
                <span class="count-needs">@NeedsYou need you</span>
            }
            @if (_errors.Count > 0)
            {
                <span class="count-err">@_errors.Count director@(_errors.Count == 1 ? "" : "s") unreachable</span>
            }
        </span>

        <span class="topbar-right">
            <span class="gw" title="Gateway base URL">@Gateway.BaseUrl</span>
            <span class="refreshed">@(_lastRefresh is null ? "connecting..." : $"updated {_lastRefresh:HH:mm:ss}")</span>
        </span>
    </header>

    @if (_lastError is not null)
    {
        <div class="banner-error">Gateway error: @_lastError</div>
    }

    <div class="body">
        <aside class="left">
            <div class="left-head">SESSIONS (all directors)</div>
            <SessionRail Sessions="_sessions"
                         Errors="_errors"
                         SelectedSessionId="_selectedId"
                         OnSelect="OnSelect" />
        </aside>

        <main class="right">
            @if (Selected is null)
            {
                <div class="right-empty">
                    <div class="right-empty-title">Select a session</div>
                    <div class="right-empty-sub">Pick a session on the left to drive it: live terminal, screenshots, queue, and the composer.</div>
                </div>
            }
            else if (string.IsNullOrWhiteSpace(Selected.TailnetEndpoint))
            {
                <div class="detail-head">
                    <span class="detail-dot" style="background:@DotColor(Selected.StatusColor)"></span>
                    <span class="detail-name">@SessionTitle(Selected)</span>
                    <span class="detail-state">@Selected.ActivityState</span>
                </div>
                <div class="right-empty">
                    <div class="right-empty-sub">This session's Director has no tailnet endpoint, so it can't be driven over Tailscale. (Restart that Director with the current build so it registers a reachable https endpoint.)</div>
                </div>
            }
            else
            {
                <div class="detail-head">
                    <span class="detail-dot" style="background:@DotColor(Selected.StatusColor)"></span>
                    <span class="detail-name">@SessionTitle(Selected)</span>
                    <span class="detail-meta">@Selected.MachineName / director @ShortId(Selected.DirectorId)</span>
                    <span class="detail-state">@Selected.ActivityState</span>
                </div>

                <div class="term-wrap">
                    <TerminalPane @key="Selected.SessionId" SessionId="@Selected.SessionId" DirectorBase="@Selected.TailnetEndpoint" />
                </div>

                <div class="detail-dock">
                    @* ---- Screenshots: drag image files onto here -> sent to Claude ---- *@
                    <div class="shots">
                        <label class="shots-drop">
                            <InputFile OnChange="OnDropImages" multiple accept="image/*" class="shots-file" />
                            <span class="shots-hint">Drag screenshots here (or click) &rarr; sent to Claude Code</span>
                        </label>
                        @if (!string.IsNullOrEmpty(_shotStatus))
                        {
                            <span class="shots-status">@_shotStatus</span>
                        }
                    </div>

                    @* ---- Queue panel ---- *@
                    @if (_queue.Count > 0)
                    {
                        <div class="queue">
                            <div class="queue-head">QUEUE (@_queue.Count)</div>
                            @foreach (var q in _queue)
                            {
                                <div class="queue-item">
                                    <span class="queue-text">@q.Text</span>
                                    <button class="qbtn" title="Send now" @onclick="() => SendQueued(q.Id)">send</button>
                                    <button class="qbtn qdel" title="Remove" @onclick="() => RemoveQueued(q.Id)">&times;</button>
                                </div>
                            }
                        </div>
                    }

                    @* ---- Composer: Speak / Send / Queue + Interrupt / Esc ---- *@
                    <div class="composer">
                        <textarea @bind="_compose" @bind:event="oninput" @onkeydown="OnComposerKey"
                                  placeholder="Message this session... (Enter to send, Shift+Enter for newline)"></textarea>
                        <div class="composer-btns">
                            <button class="btn speak @(_speaking ? "on" : "")" @onclick="ToggleSpeak" title="Dictate">@(_speaking ? "Stop" : "Speak")</button>
                            <button class="btn send" @onclick="SendNow" disabled="@(_acting || string.IsNullOrWhiteSpace(_compose))">Send</button>
                            <button class="btn queue" @onclick="QueueIt" disabled="@(_acting || string.IsNullOrWhiteSpace(_compose))">Queue</button>
                            <button class="btn danger" @onclick="Interrupt" title="Ctrl+C">Interrupt</button>
                            <button class="btn danger" @onclick="Escape" title="Esc">Esc</button>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(_actError))
                    {
                        <div class="act-error">@_actError</div>
                    }
                </div>
            }
        </main>
    </div>
</div>

@code {
    private List<SessionDto> _sessions = new();
    private List<MachineErrorDto> _errors = new();
    private string? _selectedId;
    private string? _lastError;
    private DateTime? _lastRefresh;
    private readonly CancellationTokenSource _cts = new();

    private int NeedsYou => _sessions.Count(s => s.StatusColor == "red");
    private SessionDto? Selected => _sessions.FirstOrDefault(s => s.SessionId == _selectedId);

    protected override async Task OnInitializedAsync()
    {
        Log.LogInformation("Cockpit initializing against Gateway {Base}", Gateway.BaseUrl);
        await RefreshAsync();
        _ = PollLoopAsync();
    }

    private async Task PollLoopAsync()
    {
        var timer = new PeriodicTimer(TimeSpan.FromSeconds(2));
        try
        {
            while (await timer.WaitForNextTickAsync(_cts.Token))
                await RefreshAsync();
        }
        catch (OperationCanceledException)
        {
            // circuit tearing down; normal.
        }
        finally
        {
            timer.Dispose();
        }
    }

    private async Task RefreshAsync()
    {
        try
        {
            var env = await Gateway.GetSessionsAsync(_cts.Token);
            _sessions = env.Sessions;
            _errors = env.MachineErrors;
            _lastError = null;
            _lastRefresh = DateTime.Now;

            // Drop the selection if that session has gone away.
            if (_selectedId is not null && _sessions.All(s => s.SessionId != _selectedId))
                _selectedId = null;

            // Keep the queue panel current (catches external drains too).
            await LoadQueueAsync();
        }
        catch (OperationCanceledException)
        {
            throw;
        }
        catch (Exception ex)
        {
            _lastError = ex.Message;
            Log.LogWarning(ex, "Cockpit RefreshAsync failed against {Base}", Gateway.BaseUrl);
        }
        await InvokeAsync(StateHasChanged);
    }

    // ----- selection + composer/queue/screenshots state -----
    private string _compose = "";
    private List<QueueItem> _queue = new();
    private bool _acting;
    private bool _speaking;
    private string? _actError;
    private string? _shotStatus;

    private async Task OnSelect(string sessionId)
    {
        _selectedId = sessionId;
        _compose = "";
        _actError = null;
        _shotStatus = null;
        _queue = new();
        await LoadQueueAsync();
    }

    private string? DirBase => Selected?.TailnetEndpoint;

    private async Task LoadQueueAsync()
    {
        if (Selected is null || string.IsNullOrWhiteSpace(DirBase)) return;
        try { _queue = await Director.GetQueueAsync(DirBase!, Selected.SessionId, _cts.Token); }
        catch (OperationCanceledException) { }
        catch (Exception ex) { Log.LogDebug(ex, "LoadQueue failed"); }
    }

    private async Task SendNow()
    {
        if (Selected is null || string.IsNullOrWhiteSpace(_compose) || string.IsNullOrWhiteSpace(DirBase)) return;
        await Act(async () =>
        {
            await Director.SendPromptAsync(DirBase!, Selected.SessionId, _compose, _cts.Token);
            _compose = "";
        });
    }

    private async Task QueueIt()
    {
        if (Selected is null || string.IsNullOrWhiteSpace(_compose) || string.IsNullOrWhiteSpace(DirBase)) return;
        await Act(async () =>
        {
            _queue = await Director.EnqueueAsync(DirBase!, Selected.SessionId, _compose, _cts.Token);
            _compose = "";
        });
    }

    private async Task SendQueued(string itemId)
    {
        if (Selected is null || string.IsNullOrWhiteSpace(DirBase)) return;
        await Act(async () => _queue = await Director.SendQueueItemAsync(DirBase!, Selected.SessionId, itemId, _cts.Token));
    }

    private async Task RemoveQueued(string itemId)
    {
        if (Selected is null || string.IsNullOrWhiteSpace(DirBase)) return;
        await Act(async () => _queue = await Director.DeleteQueueItemAsync(DirBase!, Selected.SessionId, itemId, _cts.Token));
    }

    private async Task Interrupt()
    {
        if (Selected is null || string.IsNullOrWhiteSpace(DirBase)) return;
        await Act(() => Director.InterruptAsync(DirBase!, Selected.SessionId, _cts.Token));
    }

    private async Task Escape()
    {
        if (Selected is null || string.IsNullOrWhiteSpace(DirBase)) return;
        await Act(() => Director.EscapeAsync(DirBase!, Selected.SessionId, _cts.Token));
    }

    private async Task OnComposerKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
            await SendNow();
    }

    // Drag-drop (or click) screenshots -> forwarded to the owning Director -> Claude Code.
    private async Task OnDropImages(InputFileChangeEventArgs e)
    {
        if (Selected is null || string.IsNullOrWhiteSpace(DirBase)) return;
        var files = e.GetMultipleFiles(10);
        var sent = 0;
        foreach (var f in files)
        {
            try
            {
                await using var s = f.OpenReadStream(20 * 1024 * 1024, _cts.Token); // 20 MB cap
                await Director.UploadImageAsync(DirBase!, Selected.SessionId, s, f.Name, f.ContentType, _cts.Token);
                sent++;
                _shotStatus = $"sent {sent} image{(sent == 1 ? "" : "s")} to Claude";
                StateHasChanged();
            }
            catch (Exception ex)
            {
                _actError = $"image upload failed: {ex.Message}";
                Log.LogWarning(ex, "upload-image failed for {File}", f.Name);
            }
        }
    }

    // Speak: browser dictation that fills the composer (start/stop). Uses the cockpit-speech
    // JS module; the result is dropped into the textarea so the user reviews before Send/Queue.
    private async Task ToggleSpeak()
    {
        try
        {
            if (!_speaking)
            {
                _speaking = true;
                await JS.InvokeVoidAsync("cockpitSpeech.start", DotNetObjectReference.Create(this));
            }
            else
            {
                _speaking = false;
                await JS.InvokeVoidAsync("cockpitSpeech.stop");
            }
        }
        catch (Exception ex)
        {
            _speaking = false;
            _actError = $"dictation unavailable: {ex.Message}";
        }
    }

    [JSInvokable]
    public Task OnDictation(string text)
    {
        if (!string.IsNullOrWhiteSpace(text))
            _compose = string.IsNullOrEmpty(_compose) ? text : _compose + " " + text;
        return InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public Task OnDictationEnded()
    {
        _speaking = false;
        return InvokeAsync(StateHasChanged);
    }

    private async Task Act(Func<Task> action)
    {
        _acting = true;
        _actError = null;
        try { await action(); }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            _actError = ex.Message;
            Log.LogWarning(ex, "Cockpit action failed");
        }
        finally { _acting = false; }
        await InvokeAsync(StateHasChanged);
    }

    private static string SessionTitle(SessionDto s) =>
        string.IsNullOrWhiteSpace(s.Name) ? s.RepoPath : s.Name!;

    private static string ShortId(string id) =>
        string.IsNullOrEmpty(id) ? "?" : (id.Length <= 8 ? id : id[..8]);

    private static string DotColor(string c) => c switch
    {
        "green" => "#22C55E",
        "blue" => "#3B82F6",
        "yellow" => "#F59E0B",
        "red" => "#F14C4C",
        _ => "#6B7280",
    };

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
    }
}
