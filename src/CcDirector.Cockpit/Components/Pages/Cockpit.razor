    // ===== Rail kebab menu (#191): the rail reports the action, this page executes it =====

    /// <summary>Transient feedback line above the rail (copy confirmations, action errors).</summary>
    private string? _railNotice;
    private CancellationTokenSource? _railNoticeCts;

    /// <summary>Sessions the user just confirmed Close for, dimmed optimistically in the rail
    /// while the Director tears them down (#228). The next poll reconciles: a sid drops out the
    /// moment its session leaves the roster, and a stale-cap timestamp clears any sid whose
    /// teardown never lands so a row can't sit dimmed forever.</summary>
    private readonly Dictionary<string, DateTime> _closingSids = new();

    /// <summary>HashSet view passed to <see cref="SessionRail"/> so it can dim closing rows.</summary>
    private HashSet<string> ClosingSessionIds => _closingSids.Keys.ToHashSet();

    private void StampClosing(string sid) => _closingSids[sid] = DateTime.UtcNow;

    private void ShowRailNotice(string text)
    {
        _railNotice = text;
        _railNoticeCts?.Cancel();
        _railNoticeCts = new CancellationTokenSource();
        var ct = _railNoticeCts.Token;
        _ = Task.Run(async () =>
        {
            try
            {
                await Task.Delay(TimeSpan.FromSeconds(6), ct);
                _railNotice = null;
                await InvokeAsync(StateHasChanged);
            }
            catch (OperationCanceledException) { /* replaced by a newer notice */ }
        });
    }

    private async Task OnRailMenuAction(SessionRail.MenuActionArgs a)
    {
        var s = a.Session;
        Log.LogInformation("Cockpit action=kebab kebab={Kebab} sid={Sid}", a.Action, s.SessionId);
        try
        {
            switch (a.Action)
            {
                case "rename":
                    // Reuse the detail header's inline rename: select the session, enter rename mode.
                    await OnSelect(s.SessionId);
                    _renameText = s.Name ?? "";
                    _renaming = true;
                    break;

                case "copy-handover":
                    // Same block the desktop's Copy Handover Info builds: enough for another
                    // agent to locate, recall, and talk to this exact session.
                    var text = string.Join("\n", new[]
                    {
                        $"Name: {SessionTitle(s)}",
                        $"Session ID: {s.SessionId}",
                        $"Repo: {s.RepoPath}",
                        $"Director ID: {s.DirectorId}",
                        $"Machine: {s.MachineName}",
                        $"Control API: {s.TailnetEndpoint}",
                    });
                    await JS.InvokeVoidAsync("navigator.clipboard.writeText", text);
                    ShowRailNotice($"Copied handover info for {SessionTitle(s)}");
                    break;

                case "github-issue":
                    // The Director resolves the repo's origin remote (the repo lives on ITS
                    // machine); the browser just opens the new-issue form. Resolving the remote
                    // is a Director round-trip, so say so optimistically before the await (#228).
                    ShowRailNotice("Resolving GitHub repo...");
                    await InvokeAsync(StateHasChanged);
                    var url = await Director.GetGitHubNewIssueUrlAsync(s.SessionId, _cts.Token);
                    await JS.InvokeVoidAsync("window.open", url, "_blank");
                    break;

                case "hold":
                    // In-progress notice BEFORE the Director round-trip + refresh, replaced by
                    // the existing result notice when they complete (#228).
                    ShowRailNotice(s.OnHold ? $"Taking {SessionTitle(s)} off hold..." : $"Putting {SessionTitle(s)} on hold...");
                    await InvokeAsync(StateHasChanged);
                    await Director.SetHoldAsync(s.SessionId, !s.OnHold, _cts.Token);
                    ShowRailNotice(s.OnHold ? $"Took {SessionTitle(s)} off hold" : $"Put {SessionTitle(s)} on hold");
                    await RefreshAsync();
                    break;

                case "wingman":
                    // In-progress notice BEFORE the Director round-trip + refresh (#228).
                    ShowRailNotice($"Updating Wingman for {SessionTitle(s)}...");
                    await InvokeAsync(StateHasChanged);
                    await Director.SetWingmanEnabledAsync(s.SessionId, !s.WingmanEnabled, _cts.Token);
                    ShowRailNotice(s.WingmanEnabled ? $"Removed wingman from {SessionTitle(s)}" : $"Added wingman to {SessionTitle(s)}");
                    await RefreshAsync();
                    break;

                case "close":
                    // The rail already two-stepped the confirm; this is the committed click.
                    // Optimistic feedback BEFORE the teardown round-trip (#228): the in-progress
                    // notice plus a dimmed row (the #217 stamp-the-roster pattern), reconciled by
                    // the next poll - the row vanishes once the Gateway drops the session.
                    StampClosing(s.SessionId);
                    ShowRailNotice($"Closing {SessionTitle(s)}...");
                    await InvokeAsync(StateHasChanged);
                    await Director.DeleteSessionAsync(s.SessionId, _cts.Token);
                    if (_selectedId == s.SessionId) _selectedId = null;
                    ShowRailNotice($"Closed {SessionTitle(s)}");
                    await RefreshAsync();
                    break;

                case "start-bug-session":
                    // One-click bug session (issue #236): spawn a session in the SAME repo on
                    // the SAME Director, wingman ON (the retire step needs it). No dialog - the
                    // whole point is zero-friction capture. The seed prompt drives
                    // investigate-and-file.
                    var bugReq = new NewSessionRequest
                    {
                        RepoPath = s.RepoPath,
                        Agent = s.Agent,          // mirror the source row's CLI (same repo, same tooling)
                        WingmanEnabled = true,
                    };
                    var createdBug = await Gateway.CreateSessionAsync(s.DirectorId, bugReq, _cts.Token);
                    if (createdBug is not null)
                    {
                        // The request carries no name; give it the spec's "Bug Report" label
                        // until the playbook renames it "Bug: #N <title>" after filing.
                        try { await Director.RenameSessionAsync(createdBug.SessionId, "Bug Report", _cts.Token); }
                        catch (Exception rex) { Log.LogWarning(rex, "bug session rename failed sid={Sid}", createdBug.SessionId); }
                        ShowRailNotice($"Started bug session in {RepoShortName(s.RepoPath)}");
                        await RefreshAsync();
                        await OnSelect(createdBug.SessionId);
                    }
                    break;
            }
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            // A close that threw never tore down: un-dim the row so the rail doesn't lie about
            // a session that is still alive (#228). Other actions leave no optimistic stamp.
            _closingSids.Remove(s.SessionId);
            Log.LogWarning(ex, "rail menu action {Action} failed for sid={Sid}", a.Action, s.SessionId);
            ShowRailNotice(ex.Message);
        }
        await InvokeAsync(StateHasChanged);
    }

