    // The selected session's driver capabilities drive the action bar: one button per verb
    // the driver declares (Cancel/Interrupt/ClearContext/History), rendered verbatim - a verb
    // the tool lacks is simply absent. Mirrors the desktop SessionActionBar reading
    // Session.Driver.Capabilities; the names come over the wire in SessionDto.DriverCapabilities.
    private bool HasCap(string capability)
        => Selected?.DriverCapabilities?.Contains(capability) == true;

    // Transient note beside the action bar (e.g. "context cleared"); the bar is not a log, so
    // it fades after a few seconds. Mirrors the desktop SessionActionBar's ActionStatus text.
    private string? _actionStatus;
    private CancellationTokenSource? _actionStatusCts;

    private void ShowActionStatus(string text)
    {
        _actionStatus = text;
        _actionStatusCts?.Cancel();
        _actionStatusCts = new CancellationTokenSource();
        var token = _actionStatusCts.Token;
        _ = Task.Run(async () =>
        {
            try { await Task.Delay(TimeSpan.FromSeconds(5), token); }
            catch (TaskCanceledException) { return; }
            _actionStatus = null;
            await InvokeAsync(StateHasChanged);
        });
    }

