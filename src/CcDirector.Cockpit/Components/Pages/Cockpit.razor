    // ----- repo table: filter + sort + select + remove -----
    private List<RepositoryDto> FilteredRepos
    {
        get
        {
            IEnumerable<RepositoryDto> q = _nsRepos;
            var f = _nsRepoFilter?.Trim();
            if (!string.IsNullOrEmpty(f))
                q = q.Where(r => (r.Name?.Contains(f, StringComparison.OrdinalIgnoreCase) ?? false)
                              || (r.Path?.Contains(f, StringComparison.OrdinalIgnoreCase) ?? false));
            q = _nsRepoSort switch
            {
                "Name" => _nsRepoSortAsc ? q.OrderBy(r => r.Name, StringComparer.OrdinalIgnoreCase) : q.OrderByDescending(r => r.Name, StringComparer.OrdinalIgnoreCase),
                "Path" => _nsRepoSortAsc ? q.OrderBy(r => r.Path, StringComparer.OrdinalIgnoreCase) : q.OrderByDescending(r => r.Path, StringComparer.OrdinalIgnoreCase),
                _ => _nsRepoSortAsc ? q.OrderBy(r => r.LastUsed ?? DateTime.MinValue) : q.OrderByDescending(r => r.LastUsed ?? DateTime.MinValue),
            };
            return q.ToList();
        }
    }

    private void SortRepos(string col)
    {
        if (_nsRepoSort == col) _nsRepoSortAsc = !_nsRepoSortAsc;
        else { _nsRepoSort = col; _nsRepoSortAsc = col != "LastUsed"; }
    }

    private string SortArrow(string col) => _nsRepoSort == col ? (_nsRepoSortAsc ? "  ^" : "  v") : "";

