    private async Task OnComposerKey(KeyboardEventArgs e)
    {
        // Ctrl+Shift+Enter = Queue (mirrors desktop Ctrl+Shift+Enter)
        if (e.Key == "Enter" && e.CtrlKey && e.ShiftKey)
        {
            await QueueIt();
            return;
        }
        // Ctrl+Enter = Send (mirrors desktop Ctrl+Enter)
        if (e.Key == "Enter" && e.CtrlKey)
        {
            await SendNow();
            return;
        }
        // Plain Enter = newline (default textarea behavior - do nothing here)
    }

    // The composer textarea, so screenshot inserts land at the caret (web equivalent of the
    // desktop "drag the image onto the prompt").
    private ElementReference _composerEl;

    // "Select image" / composer file-drop: a file on THIS device that isn't on the Director yet.
    // Upload it, then insert the saved Director-side path at the composer cursor (NOT into the
    // PTY) - the same end state as tapping a gallery thumbnail. A trailing space separates images.
    private async Task OnDropImages(InputFileChangeEventArgs e)
    {
        var sel = Selected;
        if (sel is null) return;
        var files = e.GetMultipleFiles(10);
        var total = files.Count;
        var sent = 0;
        var index = 0;
        foreach (var f in files)
        {
            index++;
            // One INFO line per attachment (name + size), per the issue's composer-Attach action.
            Log.LogInformation(
                "Cockpit action=attach sid={Sid} name={Name} bytes={Bytes}",
                sel.SessionId, f.Name, f.Size);
            try
            {
                // Optimistic status: render BEFORE the upload await so a large image on a slow
                // link shows feedback immediately instead of nothing until the bytes finish.
                _shotStatus = $"uploading {f.Name} ({index} of {total})...";
                await InvokeAsync(StateHasChanged);

                await using var s = f.OpenReadStream(20 * 1024 * 1024, _cts.Token); // 20 MB cap
                var path = await Director.UploadImageAsync(sel.SessionId, s, f.Name, f.ContentType, _cts.Token);

                if (!string.IsNullOrWhiteSpace(path))
                    await InsertIntoComposer(path + " ");

                sent++;
                _shotStatus = $"inserted {sent} image{(sent == 1 ? "" : "s")} into the prompt";
                // Off the dispatcher after the awaits above - must marshal back, not call directly.
                await InvokeAsync(StateHasChanged);
            }
            catch (Exception ex)
            {
                _actError = $"image upload failed: {ex.Message}";
                Log.LogWarning(ex, "upload-image failed for {File}", f.Name);
            }
        }
    }

    // Tap-to-insert a gallery screenshot: it already lives on the Director, so just drop its
    // absolute path into the composer at the cursor - no upload. This is the desktop-parity move.
    private async Task InsertScreenshot(ScreenshotInfo s)
    {
        if (string.IsNullOrWhiteSpace(s.Path)) return;
        try
        {
            await InsertIntoComposer(s.Path + " ");
            _shotStatus = "inserted path into the prompt";
        }
        catch (Exception ex)
        {
            _shotStatus = $"insert failed: {ex.Message}";
            Log.LogWarning(ex, "InsertScreenshot failed");
        }
        await InvokeAsync(StateHasChanged);
    }

    // Insert text into the composer textarea at the caret via JS, which fires 'input' so the
    // bound _compose updates. Used by both gallery tap-to-insert and the upload path.
    private async Task InsertIntoComposer(string text)
    {
        var mod = await ShotsModule();
        await mod.InvokeVoidAsync("insertAtCursor", _composerEl, text);
    }

    // Speak: opens the shared Dictate dialog (dictation-overlay.js via the cockpitDictate shim),
    // the browser twin of the Avalonia SpeakDialog. It sends the mic to the owning Director's /dictate
    // pipeline (OpenAI + shared dictionary + verbatim cleanup) inside a modal with a mic
    // selector, live equalizer, editable transcript, and Cancel / Pause / Insert / Send.
    // It returns the cleaned text via OnDictateInsert (drop into composer) or OnDictateSend
    // (drop into composer AND submit). _dictating guards against opening it twice.
    private bool _dictating;
    private DotNetObjectReference<Cockpit>? _dictateRef;
    private IJSObjectReference? _composerDropModule;

    // ---- Voice tab (issue #531) ----
    // When true, the dictation result routes to the wingman voice-turn flow instead of the
    // composer, so the same proven dictation dialog feeds the Voice tab.
    private bool _voiceDictation;
    private bool _voiceBusy;
    private string _voiceText = "";
    private string _voiceStatus = "";
    private string _voiceSpoken = "";
    private string _voiceReply = "";
    private string? _voiceError;

    // Speech-to-text reuses the existing dictation pipeline; on Send/Insert the cleaned text is
    // routed into the wingman voice-turn (see the dictation callbacks) rather than the composer.
    private async Task StartVoiceTalk()
    {
        if (Selected is null || _dictating || _voiceBusy) return;
        _voiceDictation = true;
        await OpenDictate();
    }

    // Drive one turn: send the message into the working session, wait for the agent to finish,
    // then show the wingman's faithful, speakable translation - SILENTLY (tap Listen to hear it).
    private async Task RunWingmanVoiceTurnAsync(string text)
    {
        if (Selected is null || _voiceBusy || string.IsNullOrWhiteSpace(text)) return;
        Log.LogInformation("Cockpit action=wingman-voice-turn sid={Sid}", Selected.SessionId);
        _voiceBusy = true; _voiceError = null; _voiceSpoken = ""; _voiceReply = "";
        _voiceStatus = "Sending to the agent...";
        await InvokeAsync(StateHasChanged);
        try
        {
            var r = await Gateway.WingmanVoiceTurnAsync(Selected.SessionId, text.Trim(), _cts.Token);
            if (!string.IsNullOrEmpty(r.Error)) { _voiceError = r.Error; _voiceStatus = ""; }
            else
            {
                _voiceReply = r.Reply ?? "";
                _voiceSpoken = r.Spoken ?? "";
                _voiceStatus = "Tap Listen to hear it.";
                _voiceText = "";
            }
        }
        catch (OperationCanceledException) { }
        catch (Exception ex) { _voiceError = ex.Message; _voiceStatus = ""; }
        finally { _voiceBusy = false; await InvokeAsync(StateHasChanged); }
    }

    // Direct-to-wingman: talk to the wingman itself, not the working session.
    private async Task RunWingmanDirectAsync(string text)
    {
        if (_voiceBusy || string.IsNullOrWhiteSpace(text)) return;
        Log.LogInformation("Cockpit action=wingman-ask-direct");
        _voiceBusy = true; _voiceError = null; _voiceSpoken = ""; _voiceReply = "";
        _voiceStatus = "Asking the wingman...";
        await InvokeAsync(StateHasChanged);
        try
        {
            var r = await Gateway.WingmanAskDirectAsync(text.Trim(), _cts.Token);
            if (!string.IsNullOrEmpty(r.Error)) { _voiceError = r.Error; _voiceStatus = ""; }
            else { _voiceSpoken = r.Spoken ?? ""; _voiceStatus = "Tap Listen to hear it."; _voiceText = ""; }
        }
        catch (OperationCanceledException) { }
        catch (Exception ex) { _voiceError = ex.Message; _voiceStatus = ""; }
        finally { _voiceBusy = false; await InvokeAsync(StateHasChanged); }
    }

    private async Task ListenSpoken()
    {
        if (string.IsNullOrEmpty(_voiceSpoken)) return;
        try { await JS.InvokeVoidAsync("cockpitVoice.speak", _voiceSpoken); }
        catch (Exception ex) { Log.LogDebug(ex, "cockpitVoice.speak failed"); }
    }

    private async Task StopListen()
    {
        try { await JS.InvokeVoidAsync("cockpitVoice.stop"); }
        catch (Exception ex) { Log.LogDebug(ex, "cockpitVoice.stop failed"); }
    }

    private async Task OpenDictate()
    {
        if (Selected is null || _dictating) return;
        Log.LogInformation("Cockpit action=speak-start sid={Sid}", Selected.SessionId);
        try
        {
            _dictating = true;
            _actError = null;
            _dictateRef ??= DotNetObjectReference.Create(this);
            // Issue #268: dictate over a same-origin WS to the GATEWAY (never the Director's own
            // address); the Gateway resolves the owning Director and reverse-proxies /dictate.
            var wsUrl = CockpitWsUrls.Dictate(Nav.BaseUri, Selected.SessionId);
            await JS.InvokeVoidAsync("cockpitDictate.start", _dictateRef, wsUrl, "/js/dictate-worklet.js", "default");
        }
        catch (OperationCanceledException)
        {
            // Dialog dismissed / interop torn down - a user cancellation, not a failure.
            // The dialog's own OnDictateCancel callback already resets _dictating; never
            // surface this as a red error banner ("A task was canceled").
            _dictating = false;
        }
        catch (Exception ex)
        {
            _dictating = false;
            _actError = $"dictation unavailable: {ex.Message}";
        }
    }

    // Insert: the dialog finished and the user chose Insert - append the cleaned text to the
    // composer for review (no auto-submit), mirroring the desktop dialog's Insert button.
    [JSInvokable]
    public async Task OnDictateInsert(string text)
    {
        _dictating = false;
        ActionInfo("speak-stop", "result=insert");
        if (_voiceDictation)
        {
            // Voice tab: the spoken text drives the wingman turn, not the composer.
            _voiceDictation = false;
            await InvokeAsync(StateHasChanged);
            if (!string.IsNullOrWhiteSpace(text)) await RunWingmanVoiceTurnAsync(text);
            return;
        }
        if (!string.IsNullOrWhiteSpace(text))
            _compose = string.IsNullOrEmpty(_compose) ? text : _compose + " " + text;
        await InvokeAsync(StateHasChanged);
    }

    // Send: the dialog finished and the user chose Send - append the cleaned text and submit
    // immediately via the normal composer send path.
    [JSInvokable]
    public async Task OnDictateSend(string text)
    {
        _dictating = false;
        ActionInfo("speak-stop", "result=send");
        if (_voiceDictation)
        {
            // Voice tab: Send means "run this through the agent and have the wingman translate".
            _voiceDictation = false;
            await InvokeAsync(StateHasChanged);
            if (!string.IsNullOrWhiteSpace(text)) await RunWingmanVoiceTurnAsync(text);
            return;
        }
        if (!string.IsNullOrWhiteSpace(text))
            _compose = string.IsNullOrEmpty(_compose) ? text : _compose + " " + text;
        await InvokeAsync(StateHasChanged);
        await SendNow();
    }

    // Cancel / closed with no text.
    [JSInvokable]
    public Task OnDictateCancel()
    {
        _dictating = false;
        _voiceDictation = false;
        ActionInfo("speak-stop", "result=cancel");
        return InvokeAsync(StateHasChanged);
    }

    // One INFO line per user action (issue #199), every line carrying the selected session id and
    // its owning Director endpoint so a click can be traced to the session + box it drove. `detail`
    // appends action-specific context (tab name, attachment, etc.).
    private void ActionInfo(string action, string? detail = null)
    {
        var sel = Selected;
        var tail = detail is null ? "" : $" {detail}";
        Log.LogInformation(
            "Cockpit action={Action} sid={Sid} dir={Dir}{Detail}",
            action, sel?.SessionId ?? "(none)", sel?.TailnetEndpoint ?? "(none)", tail);
    }

    private async Task Act(Func<Task> action)
    {
        _acting = true;
        _actError = null;
        try { await action(); }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            _actError = ex.Message;
            Log.LogWarning(ex, "Cockpit action failed");
        }
        finally { _acting = false; }
        await InvokeAsync(StateHasChanged);
    }

