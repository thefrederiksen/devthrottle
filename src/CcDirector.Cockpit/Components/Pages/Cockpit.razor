            await Gateway.RemoveRepoAsync(_nsDirectorId, path, _cts.Token);
            if (EffectiveNsRepo == path) { _nsRepoPath = ""; _nsRepoPathManual = ""; }
            _nsRepos = await Gateway.GetReposAsync(_nsDirectorId, _cts.Token);
        }
        catch (Exception ex) { _nsError = $"could not remove repo: {ex.Message}"; }
    }

    private static string RelLastUsed(DateTime? utc)
    {
        if (utc is null || utc.Value == DateTime.MinValue) return "";
        var span = DateTime.UtcNow - DateTime.SpecifyKind(utc.Value, DateTimeKind.Utc);
        if (span.TotalMinutes < 1) return "just now";
        if (span.TotalMinutes < 60) return $"{(int)span.TotalMinutes}m ago";
        if (span.TotalHours < 24) return $"{(int)span.TotalHours}h ago";
        if (span.TotalDays < 30) return $"{(int)span.TotalDays}d ago";
        if (span.TotalDays < 365) return $"{(int)(span.TotalDays / 30)}mo ago";
        return $"{(int)(span.TotalDays / 365)}y ago";
    }

    // Claude flags only; other agents take no extra args (mirrors the desktop dialog).
    private string? BuildArgs()
    {
        if (_nsAgent != "ClaudeCode") return null;
        return _nsBypass ? "--dangerously-skip-permissions" : null;
    }

    private async Task CreateSession()
    {
        if (string.IsNullOrWhiteSpace(_nsDirectorId) || string.IsNullOrWhiteSpace(EffectiveNsRepo)) return;
        await CreateLocal(EffectiveNsRepo, BuildArgs());
    }

    private async Task CreateLocal(string repo, string? args)
    {
        _acting = true; _nsError = null;
        // New-session submit (issue #199): no sid exists yet, so log the director it targets plus
        // the repo + options chosen; the created sid is logged once the Gateway returns it.
        Log.LogInformation(
            "Cockpit action=new-session-submit director={Director} repo={Repo} agent={Agent} wingman={Wingman}",
            _nsDirectorId, repo, _nsAgent, _nsWingman);
        try
        {
            var req = new NewSessionRequest
            {
                RepoPath = repo,
                Agent = _nsAgent,
                Args = args,
                WingmanEnabled = _nsWingman,
            };
            var created = await Gateway.CreateSessionAsync(_nsDirectorId, req, _cts.Token);
            Log.LogInformation("Cockpit new-session created sid={Sid} director={Director}",
                created?.SessionId ?? "(none)", _nsDirectorId);
            _showNewSession = false;
            await RefreshAsync();
            if (created is not null) await OnSelect(created.SessionId, "new-session");
        }
        catch (Exception ex) { _nsError = ex.Message; Log.LogWarning(ex, "CreateSession failed"); }
        finally { _acting = false; }
        await InvokeAsync(StateHasChanged);
    }

