    // ===== Phase 4: fan-out (broadcast a prompt to several sessions) =====
    private bool _showFanout;
    private HashSet<string> _fanoutSelected = new();
    private string _fanoutText = "";
    private List<FanoutResult> _fanoutResults = new();
    private bool _fanoutBusy;
    private string? _fanoutError;

    private void OpenFanout()
    {
        _showFanout = true;
        _fanoutError = null;
        _fanoutResults = new();
        _fanoutText = "";
        _fanoutSelected = new();
        if (Selected is not null)
            _fanoutSelected.Add(Selected.SessionId);
    }

    private void CloseFanout() => _showFanout = false;

    private void ToggleFanout(string sid, bool on)
    {
        if (on) _fanoutSelected.Add(sid); else _fanoutSelected.Remove(sid);
    }

    private async Task DoFanout()
    {
        if (_fanoutSelected.Count == 0 || string.IsNullOrWhiteSpace(_fanoutText)) return;
        Log.LogInformation("Cockpit action=fanout targets={Count} chars={Chars} sids={Sids}",
            _fanoutSelected.Count, _fanoutText.Length, string.Join(",", _fanoutSelected));
        _fanoutBusy = true;
        _fanoutError = null;
        _fanoutResults = new();
        await InvokeAsync(StateHasChanged);
        try
        {
            // Issue #372 slice 3: ONE call to the Gateway's fleet-wide /fanout - it resolves each
            // session's owning Director itself, so no per-Director grouping (and no
            // TailnetEndpoint dependency) here anymore.
            var ids = _fanoutSelected.ToList();
            var resp = await Director.FanoutAsync(ids, _fanoutText, _cts.Token);
            var all = resp?.Results ?? new List<FanoutResult>();
            _fanoutResults = all;
            if (all.Count > 0 && all.All(r => r.Error is null)) _fanoutText = "";
        }
        catch (Exception ex) { _fanoutError = ex.Message; Log.LogWarning(ex, "Fanout failed"); }
        finally { _fanoutBusy = false; }
        await InvokeAsync(StateHasChanged);
    }

    // ===== Phase 4: handover (hand a session's context to a new/existing session) =====
    private bool _showHandover;
    private string? _handoverContext;
    private string _hoMode = "new";
    private string _hoDirectorId = "";
    private string _hoRepoPath = "";
    private string _hoAgent = "ClaudeCode";
    private string _hoToSessionId = "";
    private string _hoExtra = "";
    private bool _hoArchive = true;
    private bool _hoBusy;
    private string? _hoError;
    private string? _hoStatus;

    private bool HandoverReady => _hoMode == "new"
        ? !string.IsNullOrWhiteSpace(_hoRepoPath)
        : !string.IsNullOrWhiteSpace(_hoToSessionId);

    private async Task OpenHandover()
    {
        if (Selected is null) return;
        _showHandover = true;
        _handoverContext = null;
        _hoError = null; _hoStatus = null;
        _hoMode = "new"; _hoRepoPath = ""; _hoToSessionId = ""; _hoExtra = ""; _hoArchive = true; _hoAgent = "ClaudeCode";
        var sid = Selected.SessionId;
        try
        {
            _directors = await Gateway.GetDirectorsAsync(_cts.Token);
            _hoDirectorId = Selected.DirectorId;
            _handoverContext = await Director.GetHandoverContextAsync(sid, _cts.Token);
        }
        catch (Exception ex) { _hoError = ex.Message; Log.LogWarning(ex, "OpenHandover failed"); }
        await InvokeAsync(StateHasChanged);
    }

    private void CloseHandover() => _showHandover = false;

    private async Task DoHandover()
    {
        if (Selected is null || !HandoverReady) return;
        _hoBusy = true; _hoError = null; _hoStatus = null;
        await InvokeAsync(StateHasChanged);
        try
        {
            var req = new HandoverRequest
            {
                FromSessionId = Selected.SessionId,
                ExtraContext = string.IsNullOrWhiteSpace(_hoExtra) ? null : _hoExtra,
                ArchiveToVault = _hoArchive,
                ToAgent = _hoAgent,
            };
            if (_hoMode == "new") { req.ToRepoPath = _hoRepoPath.Trim(); req.ToDirectorId = _hoDirectorId; }
            else { req.ToSessionId = _hoToSessionId; }

            var resp = await Gateway.HandoverAsync(req, _cts.Token);
            if (resp?.Accepted == true)
            {
                await RefreshAsync();
                var target = resp.TargetSession?.SessionId;
                _showHandover = false;
                if (!string.IsNullOrEmpty(target)) await OnSelect(target, "handover-target");
            }
            else { _hoError = resp?.Error ?? "handover was not accepted"; }
        }
        catch (Exception ex) { _hoError = ex.Message; Log.LogWarning(ex, "DoHandover failed"); }
        finally { _hoBusy = false; }
        await InvokeAsync(StateHasChanged);
    }

    private static string SessionTitle(SessionDto s) =>
        string.IsNullOrWhiteSpace(s.Name) ? s.RepoPath : s.Name!;

    private static string ShortId(string id) =>
        string.IsNullOrEmpty(id) ? "?" : (id.Length <= 8 ? id : id[..8]);

    /// <summary>Repo folder name from a full path, for rail notices (issue #236).</summary>
    private static string RepoShortName(string repoPath) =>
        string.IsNullOrWhiteSpace(repoPath) ? "this repo" : System.IO.Path.GetFileName(repoPath.TrimEnd('\\', '/'));

    private static string DotColor(string c) => c switch
    {
        "green" => "#22C55E",
        "blue" => "#3B82F6",
        "yellow" => "#F59E0B",
        "orange" => "#F97316",
        "red" => "#F14C4C",
        "supporting" => "#64748B",
        _ => "#6B7280",
