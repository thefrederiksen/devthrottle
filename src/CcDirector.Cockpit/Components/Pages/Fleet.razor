@page "/fleet"
@inject GatewayClient Gateway
@inject ILogger<Fleet> Log
@implements IDisposable

@* The Cards dashboard, ported from the Gateway's embedded directory.html (one-URL plan:
   docs/plans/one-url-cockpit.md). Same shape: machine groups, wingman-owned status dots,
   inline rename, Open session. Phone-first: one column under 720px. *@

<PageTitle>DevThrottle - Fleet</PageTitle>

<div class="fl-root">
<header class="fl-header">
  <h1>DEVTHROTTLE</h1>
  <span class="fl-stats">
    @($"{_sessions.Count} session{(_sessions.Count == 1 ? "" : "s")}")
    @if (RedCount > 0)
    {
      <span class="fl-red">&middot; @RedCount red</span>
    }
    @if (YellowCount > 0)
    {
      <span class="fl-yellow">&middot; @YellowCount yellow</span>
    }
    @if (_interrupted.Count > 0)
    {
      <span class="fl-interrupted">&middot; @_interrupted.Count interrupted</span>
    }
  </span>
  <span class="fl-spacer"></span>
  <a class="fl-link fl-link-accent" href="/cockpit">cockpit</a>
  <a class="fl-link fl-link-accent" href="/transcripts">voice</a>
  <a class="fl-link fl-link-accent" href="/exes">exes</a>
</header>

<main class="fl-main">
  @if (_lastError is not null)
  {
    <div class="fl-error">Failed to fetch sessions: @_lastError</div>
  }

  @* Interrupted sessions (issue #212 W3): sessions whose Director died abnormally, grouped by
     the crash journal that holds them. One Dismiss per journal (the file is per-Director). *@
  @if (_interrupted.Count > 0)
  {
    <section class="fl-int-wrap">
      <div class="fl-int-banner">
        <span class="fl-int-badge">INTERRUPTED</span>
        <span class="fl-int-bannertext">
          @_interrupted.Count session@(_interrupted.Count == 1 ? "" : "s") were lost to an unexpected Director shutdown.
          Their context is below - recover it, or dismiss what you no longer need.
        </span>
      </div>

      @foreach (var g in InterruptedGroups())
      {
        <div class="fl-int-group">
          <div class="fl-int-head">
            <span class="fl-int-machine">@(string.IsNullOrWhiteSpace(g.MachineName) ? "(unknown machine)" : g.MachineName)</span>
            <span class="fl-int-when">Director died @RelativeTime(g.DiedAtUtc) ago &middot; @g.Sessions.Count session@(g.Sessions.Count == 1 ? "" : "s")</span>
            <span class="fl-spacer"></span>
            <button class="fl-int-dismiss" @onclick="() => DismissGroup(g)" disabled="@(_dismissing.Contains(g.Key))">
              @(_dismissing.Contains(g.Key) ? "Dismissing..." : "Dismiss all")
            </button>
          </div>
          <div class="fl-cards">
            @foreach (var s in g.Sessions)
            {
              <article class="fl-int-card">
                <div class="fl-card-head">
                  <span class="fl-dot interrupted" title="Director died @RelativeTime(g.DiedAtUtc) ago"></span>
                  <span class="fl-title @(string.IsNullOrWhiteSpace(s.Name) ? "fl-unnamed" : "")">
                    @(string.IsNullOrWhiteSpace(s.Name) ? "(unnamed)" : s.Name)
                  </span>
                  <span class="fl-agent">@(string.IsNullOrWhiteSpace(s.Agent) ? "?" : s.Agent)</span>
                </div>
                <div class="fl-repo" title="@s.RepoPath">@RepoBasename(s.RepoPath)</div>
                @if (!string.IsNullOrWhiteSpace(s.RailLine))
                {
                  <div class="fl-int-rail"><span class="lbl">last wingman read</span>@s.RailLine</div>
                }
                else if (!string.IsNullOrWhiteSpace(s.Headline))
                {
                  <div class="fl-int-rail"><span class="lbl">was working on</span>@s.Headline</div>
                }
                @* One-click restore (issue #212 W4): the Gateway spawns a continuation session
                   seeded with this session's surviving briefs, then pulls the row from the
                   journal. The restored chip keeps the jump link to the new session. *@
                <div class="fl-int-actions">
                  @if (_restored.TryGetValue(s.SessionId, out var newSid))
                  {
                    <span class="fl-int-restoredone">Restored<a href="/sessions/@newSid">Open session &rarr;</a></span>
                  }
                  else if (_restoring.Contains(s.SessionId))
                  {
                    <button class="fl-int-restore" disabled>Restoring...</button>
                    <span class="fl-int-restoring">creating continuation session</span>
                  }
                  else
                  {
                    <button class="fl-int-restore" @onclick="() => RestoreSession(g, s)">Restore</button>
                    <button class="fl-int-carddismiss" @onclick="() => DismissSession(g, s)"
                            disabled="@(_dismissing.Contains(s.SessionId))">Dismiss</button>
                  }
                </div>
              </article>
            }
          </div>
        </div>
      }
    </section>
  }

  @if (_sessions.Count == 0 && _errors.Count == 0)
  {
    <div class="fl-empty">
      <p>No sessions registered anywhere on the fleet.</p>
      <p class="fl-empty-sub">A session will appear here when a Director starts one. Make sure the Director has <code>gateway.url</code> configured if it is running on another machine.</p>
    </div>
  }
  else
  {
    @foreach (var g in Groups())
    {
      <section class="fl-group">
        <div class="fl-machine">
          <span class="fl-mname">@g.Name</span>
          @if (!string.IsNullOrEmpty(g.User))
          {
            <span class="fl-muser">&middot; @g.User</span>
          }
          <span class="fl-mcount">&middot; @g.Sessions.Count session@(g.Sessions.Count == 1 ? "" : "s")</span>
          @if (g.Error is not null)
          {
            <span class="fl-munreachable">&middot; unreachable: @g.Error</span>
          }
        </div>

        @if (g.Sessions.Count > 0)
        {
          <div class="fl-cards">
            @foreach (var s in g.Sessions)
            {
              <article class="fl-card">
                <div class="fl-card-head">
                  <span class="fl-dot @ColorClass(s)" title="@DotTooltip(s)"></span>
                  @* Issue #820: three-digit session number, a muted prefix separate from the name. *@
                  @if (s.Number is int num)
                  {
                    <span class="fl-num" title="Session number">@num</span>
                  }
                  @if (_editingSid == s.SessionId)
                  {
                    <input class="fl-name-edit" @bind="_editName" @bind:event="oninput"
                           @onkeydown="e => OnEditKey(e, s)" @onblur="() => CommitRename(s)"
                           placeholder="Session name" maxlength="120" @ref="_editInput" />
                  }
                  else
                  {
                    <span class="fl-title @(string.IsNullOrWhiteSpace(s.Name) ? "fl-unnamed" : "")"
                          title="Click to rename" @onclick="() => BeginRename(s)">
                      @(string.IsNullOrWhiteSpace(s.Name) ? "(unnamed)" : s.Name)<span class="fl-pencil">&#9998;</span>
                    </span>
                  }
                  <span class="fl-agent">@(string.IsNullOrWhiteSpace(s.Agent) ? "?" : s.Agent)</span>
                </div>
                <div class="fl-repo" title="@s.RepoPath">@RepoBasename(s.RepoPath)</div>
                <div class="fl-state-row">
                  <span class="fl-state">@HumanizeState(s.AssessedState ?? s.ActivityState)</span>
                  <span class="fl-idle" title="last activity @s.LastActivityAt">@RelativeTime(s.LastActivityAt)</span>
                </div>
                @* Issue #182: "Open session" deep-links into the Cockpit session view
                   (/cockpit/{sid}) - the single driving UI behind the Gateway front door
                   (one-URL plan) - NOT the Director-embedded troubleshooting /view page that
                   s.ViewUrl points at. The Cockpit route @page "/cockpit/{SidParam}" then
                   selects this session on load via OnParametersSetAsync -> OnSelect(..., "deep-link").
                   Mirrors Home.razor's hotlist (OpenSession -> /cockpit/{sid}). *@
                @if (!string.IsNullOrWhiteSpace(s.SessionId))
                {
                  <a class="fl-open" href="@($"/cockpit/{s.SessionId}")">Open session &rarr;</a>
                }
              </article>
            }
          </div>
        }
      </section>
    }
  }
</main>
</div>

@code {
    private List<SessionDto> _sessions = new();
    private List<MachineErrorDto> _errors = new();
    private string? _lastError;
    private string? _editingSid;
    private string _editName = "";
    private ElementReference _editInput;
    private bool _focusPending;
    private readonly CancellationTokenSource _cts = new();

    // Interrupted sessions (issue #212 W3). Polled on its own slow cadence: recovery data is
    // near-static, and a second fast fanout to every Director would double their poll load.
    private List<InterruptedSessionDto> _interrupted = new();
    private readonly HashSet<string> _dismissing = new();

    // Restore (issue #212 W4): per-card in-flight markers and, once restored, the NEW session
    // id for the jump link. Restored rows leave the journal, so the refresh loop would drop
    // them - RefreshInterruptedAsync keeps restored rows as ghosts so the link stays visible.
    private readonly HashSet<string> _restoring = new();
    private readonly Dictionary<string, string> _restored = new();

    private int RedCount => _sessions.Count(s => ColorClass(s) == "red");
    private int YellowCount => _sessions.Count(s => ColorClass(s) == "yellow");

    protected override void OnInitialized()
    {
        _ = RefreshLoopAsync();
        _ = RefreshInterruptedLoopAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_focusPending)
        {
            _focusPending = false;
            try { await _editInput.FocusAsync(); } catch { /* element may have re-rendered away */ }
        }
    }

    private async Task RefreshLoopAsync()
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(2));
        while (!_cts.IsCancellationRequested)
        {
            await RefreshAsync();
            try { await timer.WaitForNextTickAsync(_cts.Token); }
            catch (OperationCanceledException) { break; }
        }
    }

    private async Task RefreshInterruptedLoopAsync()
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(15));
        while (!_cts.IsCancellationRequested)
        {
            await RefreshInterruptedAsync();
            try { await timer.WaitForNextTickAsync(_cts.Token); }
            catch (OperationCanceledException) { break; }
        }
    }

    private async Task RefreshInterruptedAsync()
    {
        try
        {
            var fresh = await Gateway.GetInterruptedAsync(_cts.Token);
            // Keep restored rows visible as ghosts: a successful restore removes the row from
            // the journal, but its "Restored -> Open session" chip is the user's jump link to
            // the continuation. Group dismissal still sweeps ghosts (RemoveAll matches them).
            foreach (var old in _interrupted)
            {
                if (_restored.ContainsKey(old.SessionId)
                    && !fresh.Any(f => f.SessionId == old.SessionId))
                {
                    fresh.Add(old);
                }
            }
            _interrupted = fresh;
        }
        catch (OperationCanceledException) { return; }
        catch (Exception ex)
        {
            // Non-fatal: the live roster is the primary view; just log and keep the last list.
            Log.LogWarning("Fleet interrupted refresh failed: {Error}", ex.Message);
            return;
        }
        await InvokeAsync(StateHasChanged);
    }

    // ---- interrupted grouping + dismiss ----

    private sealed record InterruptedGroup(string Key, string DeadDirectorId, int DeadPid, string MachineName,
        string ReportedByDirectorId, DateTime DiedAtUtc, List<InterruptedSessionDto> Sessions);

    private List<InterruptedGroup> InterruptedGroups()
    {
        return _interrupted
            .GroupBy(s => $"{s.DeadDirectorId}.{s.DeadPid}")
            .Select(grp =>
            {
                var first = grp.First();
                return new InterruptedGroup(grp.Key, first.DeadDirectorId, first.DeadPid, first.MachineName,
                    first.ReportedByDirectorId, first.DiedAtUtc.UtcDateTime,
                    grp.OrderBy(s => s.CreatedAtUtc).ToList());
            })
            .OrderByDescending(g => g.DiedAtUtc)
            .ToList();
    }

    /// <summary>
    /// One-click restore (issue #212 W4): the Gateway creates a continuation session seeded
    /// with this session's surviving turn-brief context and removes the row from the journal.
    /// On success the card flips to "Restored" with a link to the new session.
    /// </summary>
    private async Task RestoreSession(InterruptedGroup g, InterruptedSessionDto s)
    {
        if (!_restoring.Add(s.SessionId)) return;
        await InvokeAsync(StateHasChanged);
        try
        {
            var result = await Gateway.RestoreInterruptedAsync(
                g.DeadDirectorId, g.DeadPid, s.SessionId, g.ReportedByDirectorId, _cts.Token);
            var newSid = result.TargetSession?.SessionId;
            if (string.IsNullOrWhiteSpace(newSid))
                throw new InvalidOperationException("restore returned no target session");
            _restored[s.SessionId] = newSid;
            Log.LogInformation("Restored interrupted session {Sid} as {NewSid}", s.SessionId, newSid);
        }
        catch (Exception ex)
        {
            _lastError = $"Restore failed: {ex.Message}";
            Log.LogWarning("Restore interrupted failed for {Sid}: {Error}", s.SessionId, ex.Message);
        }
        finally
        {
            _restoring.Remove(s.SessionId);
        }
        await InvokeAsync(StateHasChanged);
    }

    /// <summary>
    /// Per-card dismiss (issue #212 W4): drop ONE session from the journal, keeping its
    /// siblings in the Interrupted sessions list. "Dismiss all" on the group header remains the journal-level sweep.
    /// </summary>
    private async Task DismissSession(InterruptedGroup g, InterruptedSessionDto s)
    {
        if (!_dismissing.Add(s.SessionId)) return;
        await InvokeAsync(StateHasChanged);
        try
        {
            await Gateway.DismissInterruptedSessionAsync(
                g.DeadDirectorId, g.DeadPid, s.SessionId, g.ReportedByDirectorId, _cts.Token);
            _interrupted.RemoveAll(x => x.SessionId == s.SessionId
                && x.DeadDirectorId == g.DeadDirectorId && x.DeadPid == g.DeadPid);
        }
        catch (Exception ex)
        {
            _lastError = $"Dismiss failed: {ex.Message}";
            Log.LogWarning("Dismiss interrupted session failed for {Sid}: {Error}", s.SessionId, ex.Message);
        }
        finally
        {
            _dismissing.Remove(s.SessionId);
        }
        await InvokeAsync(StateHasChanged);
    }

    private async Task DismissGroup(InterruptedGroup g)
    {
        if (!_dismissing.Add(g.Key)) return;
        await InvokeAsync(StateHasChanged);
        try
        {
            await Gateway.DismissInterruptedAsync(g.DeadDirectorId, g.DeadPid, g.ReportedByDirectorId, _cts.Token);
            // The whole journal is gone; drop all of its rows locally for an instant update.
            _interrupted.RemoveAll(s => s.DeadDirectorId == g.DeadDirectorId && s.DeadPid == g.DeadPid);
        }
        catch (Exception ex)
        {
            _lastError = $"Dismiss failed: {ex.Message}";
            Log.LogWarning("Dismiss interrupted failed for {Key}: {Error}", g.Key, ex.Message);
        }
        finally
        {
            _dismissing.Remove(g.Key);
        }
        await InvokeAsync(StateHasChanged);
    }

    private async Task RefreshAsync()
    {
        if (_editingSid is not null) return; // never clobber an in-progress rename
        try
        {
            var env = await Gateway.GetSessionsAsync(_cts.Token);
            _sessions = env.Sessions;
            _errors = env.MachineErrors;
            _lastError = null;
        }
        catch (OperationCanceledException) { return; }
        catch (Exception ex)
        {
            _lastError = ex.Message;
            Log.LogWarning("Fleet refresh failed: {Error}", ex.Message);
        }
        await InvokeAsync(StateHasChanged);
    }

    // ---- grouping ----

    private sealed record Group(string Name, string User, List<SessionDto> Sessions, string? Error);

    private List<Group> Groups()
    {
        var byMachine = new Dictionary<string, (string user, List<SessionDto> list, string? error)>(StringComparer.OrdinalIgnoreCase);
        foreach (var s in _sessions)
        {
            var key = string.IsNullOrWhiteSpace(s.MachineName) ? "(unknown)" : s.MachineName;
            if (!byMachine.TryGetValue(key, out var g))
                byMachine[key] = g = (s.User ?? "", new List<SessionDto>(), null);
            g.list.Add(s);
        }
        // Unreachable Directors still get a header (error-only machines).
        foreach (var me in _errors)
        {
            var key = string.IsNullOrWhiteSpace(me.MachineName) ? "(unknown)" : me.MachineName;
            if (byMachine.TryGetValue(key, out var g))
                byMachine[key] = (g.user, g.list, me.Error);
            else
                byMachine[key] = ("", new List<SessionDto>(), me.Error);
        }

        // Stable card order: by creation time (a card must not jump when its color changes).
        var groups = byMachine
            .Select(kv => new Group(
                kv.Key, kv.Value.user,
                kv.Value.list.OrderBy(s => s.CreatedAt).ThenBy(s => s.SessionId, StringComparer.Ordinal).ToList(),
                kv.Value.error))
            .OrderBy(g => g.Name, StringComparer.OrdinalIgnoreCase)
            .ToList();
        return groups;
    }

    // ---- rename ----

    private void BeginRename(SessionDto s)
    {
        _editingSid = s.SessionId;
        _editName = s.Name ?? "";
        _focusPending = true;
    }

    private async Task OnEditKey(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e, SessionDto s)
    {
        if (e.Key == "Enter") await CommitRename(s);
        else if (e.Key == "Escape") _editingSid = null;
    }

    private async Task CommitRename(SessionDto s)
    {
        if (_editingSid != s.SessionId) return;
        var trimmed = (_editName ?? "").Trim();
        _editingSid = null;
        if (trimmed == (s.Name ?? "")) return;
        try
        {
            var dto = await Gateway.RenameSessionAsync(s.SessionId, trimmed);
            s.Name = dto?.Name;
        }
        catch (Exception ex)
        {
            _lastError = $"Rename failed: {ex.Message}";
            Log.LogWarning("Rename failed for {SessionId}: {Error}", s.SessionId, ex.Message);
        }
        await InvokeAsync(StateHasChanged);
    }

    // ---- display helpers (mirroring directory.html exactly) ----

    // The raw status color is OWNED by the Director's SessionStatusWingman; the one
    // permitted fold is SessionOrdering.EffectiveColor (issue #196): while the Gateway's
    // wingman reads a finished turn the session presents yellow, never red-plus-briefing.
    // Anything else renders gray "unknown".
    private static string ColorClass(SessionDto s)
    {
        var c = (SessionOrdering.EffectiveColor(s) ?? "").ToLowerInvariant();
        return c is "red" or "yellow" or "orange" or "green" or "blue" or "purple" ? c : "unknown";
    }

    private static readonly Dictionary<string, string> ColorMeaning = new()
    {
        ["green"] = "Green - ready",
        ["blue"] = "Blue - agent working",
        ["yellow"] = "Yellow - warning",
        ["orange"] = "Orange - wingman explaining the session",
        ["red"] = "Red - needs you",
        ["purple"] = "Purple - running in background",
        ["unknown"] = "Gray - unknown / unreachable",
    };

    private static string DotTooltip(SessionDto s)
    {
        var meaning = ColorMeaning.GetValueOrDefault(ColorClass(s), ColorClass(s));
        return string.IsNullOrWhiteSpace(s.LastStatusReason) ? meaning : $"{meaning}\n({s.LastStatusReason})";
    }

    private static string HumanizeState(string? state) => state switch
    {
        "WaitingForInput" => "Waiting for input",
        "WaitingForPerm" => "Waiting for permission",
        "Idle" => "Idle",
        "Working" => "Working",
        "Starting" => "Starting",
        "Exited" => "Exited",
        null or "" => "-",
        _ => state,
    };

    private static string RepoBasename(string? path)
    {
        if (string.IsNullOrWhiteSpace(path)) return "(no repo)";
        var norm = path.Replace('\\', '/').TrimEnd('/');
        var i = norm.LastIndexOf('/');
        return i >= 0 ? norm[(i + 1)..] : norm;
    }

    private static string RelativeTime(DateTime? utc)
    {
        if (utc is null) return "-";
        var seconds = Math.Max(0, (int)(DateTime.UtcNow - utc.Value).TotalSeconds);
        if (seconds < 5) return "just now";
        if (seconds < 60) return $"{seconds}s";
        var mins = seconds / 60;
        if (mins < 60) return $"{mins}m";
        var hours = mins / 60;
        if (hours < 24) return $"{hours}h";
        return $"{hours / 24}d";
    }

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
    }
}
