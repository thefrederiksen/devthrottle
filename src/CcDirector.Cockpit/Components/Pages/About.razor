@page "/about"
@using CcDirector.Gateway.Contracts
@inject CcDirector.Cockpit.Services.GatewayClient Gateway

<PageTitle>About - CC Director</PageTitle>

<div style="padding:24px; color:#ccc; font-family:'Segoe UI',sans-serif; max-width:780px;">
    <h1 style="color:#fff; font-size:22px; font-weight:600; margin:0 0 4px;">About CC Director</h1>
    <div style="color:#888; font-size:12px; margin-bottom:16px;">What this Gateway is running and what's installed.</div>

    @if (_error is not null)
    {
        <div style="background:#3a1d1d; border:1px solid #cc4444; color:#ffaaaa; padding:12px; border-radius:6px;">
            Could not load About info from the Gateway: @_error
        </div>
    }
    else if (_about is null)
    {
        <p style="color:#888;">Loading...</p>
    }
    else
    {
        <div style="background:#252526; border-radius:8px; padding:18px;">
            @Row("Product", _about.Product)
            @Row("Version", _about.Version)
            @Row("Build date", _about.BuildDate ?? "(unknown)")
            @Row("Machine", _about.MachineName)
            @Row("Install root", _about.InstallRoot)
            @Row("Cockpit URL", _about.CockpitUrl ?? "(Tailscale unavailable)")
            @Row("Gateway time (UTC)", _about.ServerTime.ToString("yyyy-MM-dd HH:mm:ss"))
        </div>

        <h2 style="color:#007ACC; font-size:12px; font-weight:600; margin:22px 0 8px;">INSTALLED COMPONENTS</h2>
        <div style="background:#252526; border-radius:8px; padding:18px;">
            @if (_about.InstalledComponents.Count == 0)
            {
                <div style="color:#888; font-size:13px;">(no installed.json - the Gateway may be running from a dev build)</div>
            }
            else
            {
                @foreach (var kv in _about.InstalledComponents.OrderBy(k => k.Key, StringComparer.OrdinalIgnoreCase))
                {
                    @Row(kv.Key, kv.Value)
                }
            }
        </div>
    }
</div>

@code {
    private AboutDto? _about;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try { _about = await Gateway.GetAboutAsync(); }
        catch (Exception ex) { _error = ex.Message; }
    }

    private RenderFragment Row(string label, string value) => __builder =>
    {
        <div style="display:flex; margin-bottom:6px;">
            <div style="width:170px; color:#aaa; font-size:13px;">@label</div>
            <div style="flex:1; color:#ccc; font-size:13px; font-family:'Cascadia Mono',Consolas,monospace; word-break:break-all;">@value</div>
        </div>
    };
}
