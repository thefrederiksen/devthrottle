@implements IAsyncDisposable
@inject IJSRuntime JS
@inject DirectorClient Director
@inject NavigationManager Nav
@inject ILogger<TerminalPane> Log

@* Live terminal for one session. The parent keys this component by SessionId, so switching
   sessions disposes this pane and creates a fresh one - this pane serves exactly one session.
   It connects as soon as SessionId is valid (not only on firstRender): a Gateway restart can
   mount the pane before the session envelope is ready, and gating the single connect on
   firstRender left the pane blank forever (issue #198). Output streams over a WSS to the
   GATEWAY (issue #268: same-origin, so a remote Cockpit never needs a Director's own address);
   the Gateway reverse-proxies the stream to the owning Director. Keystrokes (typed into xterm)
   are forwarded back through the existing raw-input REST path, so the terminal is fully
   interactive (Esc, Ctrl+C, arrows, slash-command UI) with no Director change. *@
<div class="term-host" @ref="_host"></div>

@code {
    [Parameter] public string SessionId { get; set; } = "";
    [Parameter] public string DirectorBase { get; set; } = "";   // e.g. https://host:7887

    private ElementReference _host;
    private IJSObjectReference? _module;
    private DotNetObjectReference<TerminalPane>? _selfRef;
    private string _connectedSid = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Connect as soon as we have a valid SessionId - NOT only on firstRender. The pane is
        // keyed by SessionId, so a Gateway restart can mount it before the session envelope is
        // populated; gating the single connect on firstRender (issue #198) left the pane blank
        // forever because the keyed instance is never recreated to retrigger it. The stream URL
        // is same-origin (#268) and needs only SessionId - DirectorBase is no longer required to
        // connect (it is still used for the keystroke leg in OnInput). Guard on _connectedSid so
        // we connect exactly once per session, with a retry on a later render if the attempt throws.
        if (string.IsNullOrEmpty(SessionId) || _connectedSid == SessionId) return;
        _connectedSid = SessionId;
        try
        {
            _selfRef = DotNetObjectReference.Create(this);
            _module = await JS.InvokeAsync<IJSObjectReference>("import", "./js/cockpit-terminal.js");
            var wsUrl = CockpitWsUrls.Stream(Nav.BaseUri, SessionId);
            Log.LogInformation("TerminalPane connecting sid={Sid} to {WsUrl}", SessionId, wsUrl);
            await _module.InvokeVoidAsync("connect", SessionId, _host, wsUrl, _selfRef);
        }
        catch (Exception ex)
        {
            _connectedSid = "";   // allow a later render to retry the connect
            Log.LogError(ex, "TerminalPane connect failed for sid={Sid}", SessionId);
        }
    }

    /// <summary>
    /// Called from xterm's onData on every keystroke. Forwards the raw bytes to the owning
    /// Director's PTY (no Enter appended). The resulting render comes back over the output
    /// stream, so there is no local echo to manage.
    /// </summary>
    [JSInvokable]
    public async Task OnInput(string data)
    {
        if (string.IsNullOrEmpty(data) || string.IsNullOrEmpty(DirectorBase) || string.IsNullOrEmpty(SessionId))
            return;
        try
        {
            await Director.SendInputAsync(DirectorBase, SessionId, data);
        }
        catch (Exception ex)
        {
            Log.LogDebug(ex, "terminal input send failed for sid={Sid}", SessionId);
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try { await _module.InvokeVoidAsync("dispose", SessionId); } catch { /* circuit gone */ }
            try { await _module.DisposeAsync(); } catch { /* already disposed */ }
        }
        _selfRef?.Dispose();
    }
}
