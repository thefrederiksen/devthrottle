@implements IAsyncDisposable
@inject IJSRuntime JS
@inject ILogger<TerminalPane> Log

@* Live terminal for one session. The parent keys this component by SessionId, so switching
   sessions disposes this pane and creates a fresh one - this pane connects exactly once, to
   one session, over a direct WSS to the owning Director (built from its tailnet endpoint). *@
<div class="term-host" @ref="_host"></div>

@code {
    [Parameter] public string SessionId { get; set; } = "";
    [Parameter] public string DirectorBase { get; set; } = "";   // e.g. https://host:7887

    private ElementReference _host;
    private IJSObjectReference? _module;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        if (string.IsNullOrEmpty(SessionId) || string.IsNullOrEmpty(DirectorBase))
        {
            Log.LogWarning("TerminalPane: missing SessionId/DirectorBase, cannot connect");
            return;
        }
        try
        {
            _module = await JS.InvokeAsync<IJSObjectReference>("import", "./js/cockpit-terminal.js");
            var wsUrl = BuildWsUrl(DirectorBase, SessionId);
            Log.LogInformation("TerminalPane connecting sid={Sid} to {WsUrl}", SessionId, wsUrl);
            await _module.InvokeVoidAsync("connect", SessionId, _host, wsUrl);
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "TerminalPane connect failed for sid={Sid}", SessionId);
        }
    }

    // https://host:port -> wss://host:port/sessions/{sid}/stream  (Tailscale Serve fronts the
    // Director's loopback port as HTTPS, so the WebSocket upgrade rides wss over the tailnet).
    private static string BuildWsUrl(string directorBase, string sid)
    {
        var b = directorBase.TrimEnd('/');
        string ws = b.StartsWith("https://") ? "wss://" + b["https://".Length..]
                  : b.StartsWith("http://") ? "ws://" + b["http://".Length..]
                  : b;
        return $"{ws}/sessions/{sid}/stream";
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try { await _module.InvokeVoidAsync("dispose", SessionId); } catch { /* circuit gone */ }
            try { await _module.DisposeAsync(); } catch { /* already disposed */ }
        }
    }
}
