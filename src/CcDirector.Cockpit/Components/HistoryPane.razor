@implements IAsyncDisposable
@inject DirectorClient Director
@inject IJSRuntime JS
@inject ILogger<HistoryPane> Log

@* The History tab: a read-only, agent-agnostic view of one session's conversation, rendered from
   the Director's parsed history endpoint (GET /sessions/{sid}/history, proxied by the Gateway).
   It polls live and renders user / assistant / tool bubbles - the web peer of the desktop History
   tab. The parent keys this by SessionId, so a session switch disposes this pane and mounts a fresh
   one; mounting only while the History tab is shown means the poll never runs while hidden.

   Bodies render Markdown (#739, the BriefPane pipeline with DisableHtml). File paths and URLs are
   surfaced as actions (#740): URLs open in a new tab plus Copy URL, paths get Copy path - reusing
   the product's shared LinkDetector. The header shows the transcript-derived history state (#741),
   a label distinct from the live status badge.

   Scroll model (GitHub #744): sticky-bottom. The view follows new turns while the reader is at the
   bottom, stops following the instant they scroll up, and re-engages when they scroll back down.
   Activation lands at the bottom. cockpit-history-scroll.js owns the measuring/setting; this
   component owns when to stick. *@

<div class="hist">
    <div class="hist-head">
        <span class="hist-title">Conversation history</span>
        @if (_bubbles.Count > 0)
        {
            <span class="hist-count">@_bubbles.Count message@(_bubbles.Count == 1 ? "" : "s")</span>
        }
        <span class="hist-live">live</span>
        @if (_historyState is not null)
        {
            <span class="hist-state @StateClass(_historyState)" title="Transcript-derived state - separate from the live status badge">@StateLabel(_historyState)</span>
        }

        @* Compact "Show:" filter (issue #760), mirroring the desktop History tab: hide tool calls,
           tool results, or thinking to read just the conversation. Choice is remembered per browser. *@
        <span class="hist-filter">
            <span>Show:</span>
            <label title="Show the &quot;[tool] ...&quot; lines where the assistant calls a tool.">
                <input type="checkbox" @bind="_showToolCalls" @bind:after="OnFilterChangedAsync" /> Tool calls
            </label>
            <label title="Show the &quot;Tool result&quot; bubbles (command output, file lists, exit codes).">
                <input type="checkbox" @bind="_showToolResults" @bind:after="OnFilterChangedAsync" /> Results
            </label>
            <label title="Show the assistant's &quot;(thinking) ...&quot; reasoning lines.">
                <input type="checkbox" @bind="_showThinking" @bind:after="OnFilterChangedAsync" /> Thinking
            </label>
        </span>
    </div>

    @if (_loadFailed)
    {
        <div class="hist-empty">Could not read this session's history right now. Retrying...</div>
    }
    else if (_bubbles.Count == 0)
    {
        <div class="hist-empty">@_emptyText</div>
    }
    else
    {
        <div class="hist-scroll" @ref="_scrollEl">
            @foreach (var (rendered, i) in _bubbles.Select((b, i) => (b, i)))
            {
                <div class="hist-bubble @rendered.Bubble.Kind" @key="i">
                    <div class="hist-speaker">@rendered.Bubble.Speaker</div>
                    @if (rendered.Bubble.IsRawText)
                    {
                        <pre class="hist-body raw">@rendered.Bubble.Body</pre>
                    }
                    else
                    {
                        <div class="hist-body md">@rendered.Html</div>
                    }
                    @if (rendered.Links.Count > 0)
                    {
                        <div class="hist-links">
                            @foreach (var link in rendered.Links)
                            {
                                <span class="hist-link @(link.IsUrl ? "url" : "path")">
                                    @if (link.IsUrl)
                                    {
                                        <a class="hist-link-open" href="@link.Text" target="_blank" rel="noopener noreferrer" title="@link.Text">@LinkLabel(link.Text)</a>
                                    }
                                    else
                                    {
                                        <span class="hist-link-text" title="@link.Text">@LinkLabel(link.Text)</span>
                                    }
                                    <button class="hist-link-copy" @onclick="() => CopyAsync(link.Text)">
                                        @(link.IsUrl ? "Copy URL" : "Copy path")
                                    </button>
                                    @if (_copiedText == link.Text)
                                    {
                                        <span class="hist-link-copied">copied</span>
                                    }
                                </span>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public string SessionId { get; set; } = "";

    /// <summary>A bubble plus its precomputed Markdown HTML and detected links, so rendering does
    /// not re-parse Markdown or re-scan for links on every Blazor render pass.</summary>
    private sealed record RenderedBubble(HistoryBubble Bubble, MarkupString Html, List<HistoryLink> Links);

    private readonly List<RenderedBubble> _bubbles = new();
    private string _emptyText = "Waiting for the conversation to start...";
    private bool _loadFailed;
    private string? _historyState;
    private string? _copiedText;

    // "Show:" filter state (issue #760). Defaults to showing everything; loaded from the browser's
    // localStorage on first render so the reader's choice sticks. The last fetched history is cached
    // so a toggle re-renders instantly from memory without waiting for the next poll.
    private bool _showToolCalls = true;
    private bool _showToolResults = true;
    private bool _showThinking = true;
    private SessionHistoryDto? _lastHistory;
    private const string FilterStorageKey = "ccHistoryFilter";

    private HistoryBubbleFilter Filter => new(_showToolCalls, _showToolResults, _showThinking);

    private ElementReference _scrollEl;
    private IJSObjectReference? _module;
    private DotNetObjectReference<HistoryPane>? _selfRef;
    private bool _listenerAttached;

    // Sticky-bottom state. _following mirrors "is the reader at the bottom" (updated by the scroll
    // listener via UpdateFollow); _scrollAfterRender asks the next OnAfterRender to stick to the
    // bottom because content changed. A scrolled-up reader (_following == false) is never moved.
    private bool _following = true;
    private bool _scrollAfterRender;

    // Cheap change signature so an unchanged poll does not re-render (and so a steady stream of
    // identical polls never disturbs the scroll position of a reader who has scrolled up).
    private string _signature = "";
    private readonly CancellationTokenSource _cts = new();

    protected override Task OnInitializedAsync()
    {
        _ = PollLoopAsync();
        return Task.CompletedTask;
    }

    private async Task PollLoopAsync()
    {
        await RefreshAsync();
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(2.5));
        try
        {
            while (await timer.WaitForNextTickAsync(_cts.Token))
                await RefreshAsync();
        }
        catch (OperationCanceledException) { }
    }

    private async Task RefreshAsync()
    {
        if (string.IsNullOrEmpty(SessionId))
            return;

        try
        {
            var history = await Director.GetSessionHistoryAsync(SessionId, _cts.Token);
            _loadFailed = false;
            _lastHistory = history; // cache so a filter toggle can re-render without re-fetching
            await RenderHistoryAsync(history);
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            _loadFailed = true;
            Log.LogDebug(ex, "HistoryPane refresh failed for sid={Sid}", SessionId);
            await InvokeAsync(StateHasChanged);
        }
    }

    /// <summary>
    /// Map the given history through the current "Show:" filter and render it, unless the result is
    /// byte-identical to what is already shown (the signature guard keeps a steady poll from
    /// disturbing a scrolled-up reader). Shared by the poll and by a filter toggle.
    /// </summary>
    private async Task RenderHistoryAsync(SessionHistoryDto? history)
    {
        // null = 404 (old Director or unknown session): treat as "nothing yet", not an error.
        var bubbles = HistoryBubbleMapper.Map(history, Filter);

        if (history is { IsSupported: false })
            _emptyText = "History is not available for this agent yet.";
        else if (bubbles.Count == 0 && Filter.AnyHidden && history is { Messages.Count: > 0 })
            _emptyText = "No messages match the current filters.";
        else
            _emptyText = "Waiting for the conversation to start...";

        _historyState = history?.HistoryState;

        var signature = BuildSignature(bubbles, _historyState, Filter);
        if (signature == _signature)
            return; // unchanged - do not re-render or touch the scroll position
        _signature = signature;

        _bubbles.Clear();
        foreach (var bubble in bubbles)
        {
            var html = bubble.IsRawText ? default : (MarkupString)HistoryMarkdown.ToHtml(bubble.Body);
            var links = bubble.IsRawText ? new List<HistoryLink>() : HistoryLinks.Extract(bubble.Body);
            _bubbles.Add(new RenderedBubble(bubble, html, links));
        }

        // Stick to the bottom after this render only if the reader is currently following.
        _scrollAfterRender = _following;
        await InvokeAsync(StateHasChanged);
    }

    /// <summary>A "Show:" checkbox flipped: remember the choice and re-render the cached history
    /// immediately through the new filter.</summary>
    private async Task OnFilterChangedAsync()
    {
        await PersistFilterAsync();
        await RenderHistoryAsync(_lastHistory);
    }

    private async Task LoadFilterAsync()
    {
        try
        {
            var raw = await JS.InvokeAsync<string>("localStorage.getItem", FilterStorageKey);
            if (string.IsNullOrEmpty(raw))
                return;
            var parts = raw.Split(',');
            if (parts.Length == 3
                && bool.TryParse(parts[0], out var tc)
                && bool.TryParse(parts[1], out var tr)
                && bool.TryParse(parts[2], out var th))
            {
                _showToolCalls = tc;
                _showToolResults = tr;
                _showThinking = th;
            }
        }
        catch (Exception ex)
        {
            Log.LogDebug(ex, "HistoryPane load filter failed for sid={Sid}", SessionId);
        }
    }

    private async Task PersistFilterAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("localStorage.setItem", FilterStorageKey,
                $"{_showToolCalls},{_showToolResults},{_showThinking}");
        }
        catch (Exception ex)
        {
            Log.LogDebug(ex, "HistoryPane persist filter failed for sid={Sid}", SessionId);
        }
    }

    private static string BuildSignature(List<HistoryBubble> bubbles, string? state, HistoryBubbleFilter filter)
    {
        // Fold the filter into the signature so toggling it forces a re-render even when the
        // underlying transcript has not changed.
        var f = $"{filter.ShowToolCalls}{filter.ShowToolResults}{filter.ShowThinking}";
        if (bubbles.Count == 0)
            return $"0|{state}|{f}";
        var last = bubbles[^1];
        var total = 0;
        foreach (var b in bubbles)
            total += b.Body.Length;
        // count + total chars + last bubble's tail catches appends and last-bubble edits cheaply.
        var tail = last.Body.Length <= 64 ? last.Body : last.Body[^64..];
        return $"{bubbles.Count}|{total}|{tail}|{state}|{f}";
    }

    private async Task CopyAsync(string text)
    {
        try
        {
            await JS.InvokeAsync<bool>("ccTools.copyText", text);
            _copiedText = text;
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Log.LogDebug(ex, "HistoryPane copy failed for sid={Sid}", SessionId);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                _module = await JS.InvokeAsync<IJSObjectReference>("import", "./js/cockpit-history-scroll.js");
                _selfRef = DotNetObjectReference.Create(this);
            }
            catch (Exception ex)
            {
                Log.LogDebug(ex, "HistoryPane scroll module import failed for sid={Sid}", SessionId);
            }

            // localStorage is only reachable after the first render (Blazor Server). Load the saved
            // filter now and re-render the cached history through it, so the reader's choice applies.
            await LoadFilterAsync();
            await RenderHistoryAsync(_lastHistory);
        }

        if (_module is null)
            return;

        try
        {
            // Attach the scroll listener once the scroll container exists (it is absent while the
            // empty state shows), and land at the bottom on activation.
            if (_selfRef is not null && _bubbles.Count > 0 && !_listenerAttached)
            {
                _listenerAttached = true;
                await _module.InvokeVoidAsync("init", _scrollEl, _selfRef);
            }

            if (_scrollAfterRender && _following && _bubbles.Count > 0)
            {
                _scrollAfterRender = false;
                await _module.InvokeVoidAsync("scrollToBottom", _scrollEl);
            }
        }
        catch (Exception ex)
        {
            Log.LogDebug(ex, "HistoryPane scroll update failed for sid={Sid}", SessionId);
        }
    }

    /// <summary>Called from JS when the reader crosses the at-bottom boundary. While not at the
    /// bottom, new turns never move the view; returning to the bottom re-engages auto-follow.</summary>
    [JSInvokable]
    public void UpdateFollow(bool atBottom)
    {
        _following = atBottom;
    }

    // ----- derived history-state label (#741): transcript-derived, distinct from the live badge -----
    private static string StateLabel(string state) => state switch
    {
        "BackgroundRunning" => "history: Background running",
        "Working" => "history: Working",
        "NeedsYou" => "history: Needs you",
        _ => "history: Idle",
    };

    private static string StateClass(string state) => state switch
    {
        "BackgroundRunning" => "bg",
        "Working" => "working",
        "NeedsYou" => "needs",
        _ => "idle",
    };

    private static string LinkLabel(string text)
        => text.Length <= 60 ? text : text[..28] + "..." + text[^28..];

    public async ValueTask DisposeAsync()
    {
        _cts.Cancel();
        if (_module is not null)
        {
            try { await _module.InvokeVoidAsync("dispose", _scrollEl); } catch { /* circuit gone */ }
            try { await _module.DisposeAsync(); } catch { /* already disposed */ }
        }
        _selfRef?.Dispose();
        _cts.Dispose();
    }
}
