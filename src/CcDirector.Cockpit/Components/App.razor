<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="stylesheet" href="lib/xterm.css" />
    <link rel="stylesheet" href="app.css?v=@CacheBust" />
    @* Scoped-CSS bundle (CSS isolation, e.g. Fleet.razor.css); name follows AssemblyName. *@
    <link rel="stylesheet" href="devthrottle-cockpit.styles.css?v=@CacheBust" />
    <title>DevThrottle - Cockpit</title>
    <HeadOutlet />
</head>
<body>
    <Routes @rendermode="new InteractiveServerRenderMode(prerender: false)" />
    <script src="lib/xterm.js"></script>
    @* No canvas addon: the DOM renderer uses native ClearType, matching the desktop
       terminal's text rendering (see cockpit-terminal.js header). *@
    @* Shared Dictate overlay - the ONE web dictation dialog, also embedded into the
       Director's Control API. Defines window.dictationOverlay + a cockpitDictate shim. *@
    <script src="js/dictation-overlay.js?v=@CacheBust"></script>
    @* Wingman Voice tab tap-to-listen (issue #531): browser speech synthesis for the summary. *@
    <script src="js/cockpit-voice.js?v=@CacheBust"></script>
    @* Tool-page helpers (issue #183): native confirm/alert, clipboard, segmented audio playback. *@
    <script src="js/tool-pages.js?v=@CacheBust"></script>
    <script src="_framework/blazor.web.js"></script>
</body>
</html>

@code {
    // Cache-busting stamp for the Cockpit's own static assets (app.css, the scoped-CSS bundle, the
    // js/*.js helpers). It is stable for the life of this Cockpit process and fresh on every restart -
    // and every deploy restarts the Cockpit - so a browser never keeps running a stale cached script
    // or stylesheet after an update (the bug where a new js function was "not a function" client-side).
    // The _framework and lib assets are content-hashed by the framework already, so they are untouched.
    private static readonly long CacheBust = DateTime.UtcNow.Ticks;
}
