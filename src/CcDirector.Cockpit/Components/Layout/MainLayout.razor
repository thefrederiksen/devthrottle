@inherits LayoutComponentBase

@* App shell: the shared navigation rail on the left, the active page filling the rest.
   Every Blazor page gets the rail here. The plain-HTML tool pages (/exes,
   /transcripts, /dictionary, /settings) are not Blazor, so they reproduce the
   SAME rail via wwwroot/pages/tool-nav.css + tool-nav.js (keep the item list in
   NavMenu.razor and tool-nav.js in sync). *@
<div class="cockpit-root">
    <NavMenu />
    <main class="app-page">
        @Body
    </main>
</div>
