@using System.Reflection
@inject NavigationManager Nav
@inject IJSRuntime JS

@* The Cockpit-wide navigation rail: the one menu every page shares (the Cockpit is the
   Gateway's whole dashboard, so all of its pages hang off this). The rail stays put when
   you navigate - selecting a session or any page NEVER collapses it. It collapses ONLY
   when the user clicks the chevron toggle (or on phones, via the CSS media query). That
   choice is persisted in localStorage under the same key the plain-HTML tool pages use
   (tool-nav.js), so the Blazor rail and the tool-page rail always agree. *@

<nav class="nv @(Collapsed ? "nv-collapsed" : "")">
    <div class="nv-head">
        <span class="nv-brand" title="DevThrottle">DT</span>
        <button class="nv-toggle" title="@(Collapsed ? "Expand menu" : "Collapse menu")"
                @onclick="Toggle">@(Collapsed ? (MarkupString)"&raquo;" : (MarkupString)"&laquo;")</button>
    </div>

    <NavLink class="nv-item" href="/" Match="NavLinkMatch.All" title="Home - gateway dashboard">
        <svg class="nv-ico" viewBox="0 0 16 16"><path d="M2 8.5 8 3l6 5.5M4 8v5h8V8" /></svg>
        <span class="nv-label">Home</span>
    </NavLink>
    <NavLink class="nv-item" href="/cockpit" title="Cockpit - drive sessions">
        <svg class="nv-ico" viewBox="0 0 16 16"><rect x="1.5" y="2.5" width="13" height="11" rx="1.5" /><path d="M4 6l2.5 2L4 10M8 10.5h4" /></svg>
        <span class="nv-label">Cockpit</span>
    </NavLink>
    <NavLink class="nv-item" href="/lists" title="Lists - named priority work lists" style="display:none">
        <svg class="nv-ico" viewBox="0 0 16 16"><path d="M5 4h9M5 8h9M5 12h6" /><path d="M2.4 4h.01M2.4 8h.01M2.4 12h.01" /></svg>
        <span class="nv-label">Lists</span>
    </NavLink>
    <NavLink class="nv-item" href="/sessions" title="Sessions - every session on the fleet" style="display:none">
        <svg class="nv-ico" viewBox="0 0 16 16"><path d="M2 4h12M2 8h12M2 12h8" /></svg>
        <span class="nv-label">Sessions</span>
    </NavLink>
    @* The Schedule nav item (the Cockpit cron page, issue #488) is hidden for the v1 default
       install (issue #621, same v1-alpha posture as the hidden Voice item #571 and the desktop
       Scheduler overlay #570). The page itself is NOT deleted - /schedule still loads by direct
       URL and is fully functional (list, next-run, run history, create/run/delete) - it is simply
       not advertised in the default nav. The documented, discoverable opt-in is to navigate to
       /schedule directly; see the "Scheduling" section of docs/CC_TOOLS.md. Agents use cc-cron. *@
    <NavLink class="nv-item" href="/schedule" title="Schedule - cron jobs on the Gateway" style="display:none">
        <svg class="nv-ico" viewBox="0 0 16 16"><circle cx="8" cy="8" r="6" /><path d="M8 5v3l2 1.5" /></svg>
        <span class="nv-label">Schedule</span>
    </NavLink>
    <NavLink class="nv-item" href="/directors" title="Directors - every registered Director">
        <svg class="nv-ico" viewBox="0 0 16 16"><rect x="2" y="2.5" width="12" height="4.5" rx="1" /><rect x="2" y="9" width="12" height="4.5" rx="1" /><path d="M4.5 4.75h.01M4.5 11.25h.01" /></svg>
        <span class="nv-label">Directors</span>
    </NavLink>
    <NavLink class="nv-item" href="/fleet" title="Fleet - session cards by machine" style="display:none">
        <svg class="nv-ico" viewBox="0 0 16 16"><rect x="2" y="2" width="5" height="5" rx="1" /><rect x="9" y="2" width="5" height="5" rx="1" /><rect x="2" y="9" width="5" height="5" rx="1" /><rect x="9" y="9" width="5" height="5" rx="1" /></svg>
        <span class="nv-label">Fleet</span>
    </NavLink>
    <NavLink class="nv-item" href="/wingman" title="Wingman Pipeline - the one-brain queue and brain health" style="display:none">
        <svg class="nv-ico" viewBox="0 0 16 16"><circle cx="8" cy="8" r="2.5" /><path d="M8 1.5v2M8 12.5v2M1.5 8h2M12.5 8h2" /></svg>
        <span class="nv-label">Wingman</span>
    </NavLink>
    @* The Voice nav item (the mobile-first /m voice screen) is hidden for the v1 default install
       (issue #571, the Cockpit counterpart of the desktop hide #559). The screen itself is NOT
       deleted - /m/index.html still loads by direct URL for internal testing - it is simply not
       advertised in the default nav. *@
    <NavLink class="nv-item" href="/feedback" title="Wingman feedback corpus" style="display:none">
        <svg class="nv-ico" viewBox="0 0 16 16"><path d="M2.5 3.5h11v7h-6L4 13.5v-3h-1.5z" /><path d="M5 6h6M5 8h4" /></svg>
        <span class="nv-label">Feedback</span>
    </NavLink>

    <div class="nv-sep"></div>

    @* Settings/keys are still plain HTML (not Blazor) - force a full document load so the
       Blazor router never tries to resolve them as components. Exes/Recordings/Dictionary became
       Blazor pages (issue #183), so they are in-app NavLinks now (no full reload). Exes and
       Recordings remain hidden (style="display:none"), Dictionary stays visible - same visibility
       as before the conversion. (The "Recordings" item at /transcripts is the recordings+transcripts
       page; the separate visible "Voice" item above links to the mobile /voice page, issue #420.) *@
    <a class="nv-item" href="/settings" data-enhance-nav="false" title="Settings - transcription, gateway, wingman, phone">
        <svg class="nv-ico" viewBox="0 0 16 16"><circle cx="8" cy="8" r="2.25" /><path d="M8 1.5v2M8 12.5v2M1.5 8h2M12.5 8h2M3.4 3.4l1.4 1.4M11.2 11.2l1.4 1.4M12.6 3.4l-1.4 1.4M4.8 11.2l-1.4 1.4" /></svg>
        <span class="nv-label">Settings</span>
    </a>
    <NavLink class="nv-item" href="/exes" title="Builds - local_builds slots" style="display:none">
        <svg class="nv-ico" viewBox="0 0 16 16"><path d="M8 1.5 14 5v6l-6 3.5L2 11V5l6-3.5zM2 5l6 3.5L14 5M8 8.5v6" /></svg>
        <span class="nv-label">Builds</span>
    </NavLink>
    <NavLink class="nv-item" href="/transcripts" title="Recordings - recordings and transcripts" style="display:none">
        <svg class="nv-ico" viewBox="0 0 16 16"><rect x="6" y="1.5" width="4" height="8" rx="2" /><path d="M3.5 7.5a4.5 4.5 0 0 0 9 0M8 12v2.5" /></svg>
        <span class="nv-label">Recordings</span>
    </NavLink>
    <NavLink class="nv-item" href="/dictionary" title="Dictionary - dictation terms">
        <svg class="nv-ico" viewBox="0 0 16 16"><path d="M3 2.5h8.5A1.5 1.5 0 0 1 13 4v9.5H4.5A1.5 1.5 0 0 1 3 12V2.5zM3 11.5h10M6 5.5h4" /></svg>
        <span class="nv-label">Dictionary</span>
    </NavLink>
    @* Learning - the in-product help page (issue #472): what DevThrottle is, how to start,
       and an Ask Wingman box. In-app NavLink (no full reload), same rail pattern as the rest. *@
    <NavLink class="nv-item" href="/learn" title="Learning - what DevThrottle is and how to use it">
        <svg class="nv-ico" viewBox="0 0 16 16"><path d="M2 4.5 8 2l6 2.5L8 7 2 4.5zM4 6v3.5c0 1 1.8 2 4 2s4-1 4-2V6M14 5v3.5" /></svg>
        <span class="nv-label">Learning</span>
    </NavLink>
    @* The standalone "API Keys" item was folded into Settings > Transcription (issue #497):
       both transcription keys are managed where they are used. *@
    @* Account - the DevThrottle identity this Gateway is signed in as, plus the Log out action
       (issue #648). The credential lives on the Gateway, so identity + logout surface here on the
       Cockpit. In-app NavLink, same rail pattern as the rest. *@
    <NavLink class="nv-item" href="/account" title="Account - the signed-in DevThrottle identity and Log out">
        <svg class="nv-ico" viewBox="0 0 16 16"><circle cx="8" cy="5.5" r="2.75" /><path d="M3 13.5c0-2.5 2.2-4 5-4s5 1.5 5 4" /></svg>
        <span class="nv-label">Account</span>
    </NavLink>
    @* Telemetry - the fleet-wide richer-usage-telemetry consent (opt-out), default ON (issue #649).
       The setting lives on the Gateway, so it surfaces here on the Cockpit. In-app NavLink, same rail
       pattern as the rest. *@
    <NavLink class="nv-item" href="/telemetry" title="Telemetry - fleet-wide usage telemetry consent">
        <svg class="nv-ico" viewBox="0 0 16 16"><path d="M8 1.5a6.5 6.5 0 0 0-6.5 6.5M8 4.5a3.5 3.5 0 0 0-3.5 3.5" /><circle cx="8" cy="8" r="1.25" /></svg>
        <span class="nv-label">Telemetry</span>
    </NavLink>
    <NavLink class="nv-item" href="/about" title="About - version, URL, what's installed">
        <svg class="nv-ico" viewBox="0 0 16 16"><circle cx="8" cy="8" r="6.5" /><path d="M8 7.25v3.75M8 5h.01" /></svg>
        <span class="nv-label">About</span>
    </NavLink>

    <div class="nv-spacer"></div>
    <div class="nv-foot" title="@VersionFull">@VersionDisplay</div>
</nav>

@code {
    // localStorage key shared with the plain-HTML tool pages (wwwroot/pages/tool-nav.js)
    // so both rails read/write the same collapse state and never disagree.
    private const string StorageKey = "cc-toolnav-collapsed";

    private static readonly string VersionFull =
        typeof(NavMenu).Assembly.GetCustomAttribute<AssemblyInformationalVersionAttribute>()?.InformationalVersion ?? "0.0.0";
    private static readonly string VersionDisplay = $"v{VersionFull.Split('+')[0]}";

    // The only thing that drives collapse: the user's explicit chevron toggle, restored
    // from localStorage on first render. Navigation does NOT touch this.
    private bool Collapsed { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        var stored = await JS.InvokeAsync<string?>("localStorage.getItem", StorageKey);
        var collapsed = stored == "1";
        if (collapsed != Collapsed)
        {
            Collapsed = collapsed;
            StateHasChanged();
        }
    }

    private async Task Toggle()
    {
        Collapsed = !Collapsed;
        await JS.InvokeVoidAsync("localStorage.setItem", StorageKey, Collapsed ? "1" : "0");
    }
}
