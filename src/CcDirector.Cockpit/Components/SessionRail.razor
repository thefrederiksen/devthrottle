@* Gateway-wide session rail with three layouts (ViewMode):

   "tree"   - Machine -> Director -> Sessions. Sessions keep their owning Director's
              desktop order (SortOrder), so they hold a stable slot and don't reshuffle.
              Each Director carries a [+] to start a session on it. Every reachable Director
              in the registry is shown - INCLUDING ones with zero sessions - because that
              [+] is the only way to start the first session on a Director. Unreachable
              Directors are shown inline so a dead Director is never silently dropped.

   "triage" - one flat priority list across every Director: sessions that NEED YOU
              (StatusColor "red") at the top, ON HOLD (user/agent parked) at the bottom,
              everything else in between. The owning Director short-id is shown per row
              since the grouping is dropped here.

   "repo"   - one group per repository across every machine/Director (issue #219): repo
              headers sorted alphabetically (case-insensitive), each followed by that
              repo's sessions in desktop order, then a "(no repo)" group last. Grouping by
              repo drops the machine/Director context, so the owning Director short-id is
              shown per row, exactly as in triage mode.

   StatusColor and OnHold are rendered verbatim from the Director; never derived. *@

<div class="rail @ViewMode">
    @* Suppress the empty message in tree mode when idle Directors will still render (each
       carries a [+] to start its first session). Other modes only group sessions, so an
       empty roster there really is empty. *@
    @if (Sessions.Count == 0 && Errors.Count == 0 && !(ViewMode == "tree" && Directors.Count > 0))
    {
        <div class="rail-empty">No sessions. The Gateway returned an empty roster.</div>
    }

    @if (_menuSid is not null)
    {
        @* Invisible backdrop: any click outside the open menu closes it. *@
        <div class="sess-menu-backdrop" @onclick="CloseMenu"></div>
    }

    @{
        // One row template shared by both layouts. The director short-id span is always
        // emitted; CSS hides it in tree mode (redundant under a dir-head) and shows it in
        // triage mode (where rows are no longer grouped by Director).
        // The row is a div (not a button) so the kebab menu button can nest inside it.
        RenderFragment<SessionDto> SessionRow = s =>
        @<div role="button" tabindex="0"
              class="@($"sess{(s.SessionId == SelectedSessionId ? " sess-selected" : "")}{(ClosingSessionIds.Contains(s.SessionId) ? " sess-closing" : "")}")"
              style="border-left-color:@DotColor(SessionOrdering.EffectiveColor(s))"
              title="@($"{SessionOrdering.EffectiveColor(s)}: {(SessionOrdering.IsExplaining(s) ? "wingman explaining the session" : SessionOrdering.IsBriefing(s) ? "wingman reading the turn" : s.LastStatusReason)}")"
              @onclick="() => OnSelect.InvokeAsync(s.SessionId)">
            <span class="sess-dot" style="background:@DotColor(SessionOrdering.EffectiveColor(s))"></span>
            <span class="sess-body">
                <span class="sess-name">@* Issue #820: muted three-digit session number prefix. *@@if (s.Number is int num)
                    {<span class="sess-num">@num</span>}@(string.IsNullOrWhiteSpace(s.Name) ? s.RepoPath : s.Name)</span>
                <span class="sess-state">
                    @* assessed-when-present (issue #186): the Gateway's brain may have
                       refuted the mechanical quiet signal; raw state is the fallback. *@
                    @(s.AssessedState ?? s.ActivityState)
                    @* Session type (issue #211): outlined chip so identity never reads as
                       state. Only non-default types show - Implement stays clutter-free. *@
                    @if (s.Type == "Discuss")
                    {
                        <span class="tag tag-type tag-discuss" title="Discussion session - talk only, no edits or commits">[D] discuss</span>
                    }
                    else if (s.Type == "BugReport")
                    {
                        <span class="tag tag-type tag-bug" title="Bug-report session - investigate and file an issue, never fix here">[B] bug report</span>
                    }
                    else if (s.Type == "IssueSubmitter")
                    {
                        <span class="tag tag-type tag-submit" title="Issue-submitter session - files GitHub issues only, never writes code">[S] issue submitter</span>
                    }
                    else if (s.Type == "QA")
                    {
                        <span class="tag tag-type tag-qa" title="QA session - verifies what was built, never fixes; reports findings">[Q] QA</span>
                    }
                    @if (s.OnHold)
                    {
                        <span class="tag tag-hold">hold</span>
                    }
                    @* In-voice-mode ear indicator (issue #554): a vector ear (outer fold + inner
                       canal), never a glyph, in place of the old "voice" text. Keeps the tag-voice
                       hook so the pill styling and color stay in one place. *@
                    @if (s.VoiceMode)
                    {
                        <span class="tag tag-voice" title="In voice mode - a phone is driving this session by voice">
                            <svg class="ear-icon" viewBox="0 0 24 24" fill="none" aria-label="voice mode" role="img">
                                <path d="M7 11 C7 6.6 10.1 4 12.5 4 C15.5 4 18 6.4 18 9.5 C18 12.4 16 13.7 14.7 14.7 C13.7 15.5 13 16.1 13 17.2 C13 18.7 11.9 19.9 10.4 19.9 C9 19.9 7.9 18.8 7.9 17.4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                                <path d="M10.2 10.4 C10.2 9.1 11.2 8.1 12.5 8.1 C13.8 8.1 14.8 9.1 14.8 10.4 C14.8 11.6 13.9 12.1 13.2 12.7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                        </span>
                    }
                    @* Issue #237: show the Director's port (resolved from the registry by the
                       session's DirectorId), not the GUID prefix. Full GUID stays in the title. *@
                    <span class="sess-dir" title="@s.DirectorId">@PortLabelFor(s.DirectorId)</span>
                    @* Generic fallback pill when no brief exists (old Directors / brief
                       pending) - small enough to stay on the state line. *@
                    @if (SessionOrdering.EffectiveColor(s) == "red" && string.IsNullOrWhiteSpace(s.RailLine) && !s.OnHold)
                    {
                        <span class="needs-pill">needs you</span>
                    }
                    @* Issue #218: how long this session has been waiting (NEEDS YOU). The
                       Gateway stamps NeedsYouSince the moment EffectiveColor becomes red and
                       clears it when it leaves red, so the label only shows on red rows and is
                       absent (not "0s") on active/blue/briefing sessions. now-NeedsYouSince is
                       recomputed each 2s roster refresh, so it ticks up while the session stays
                       red. *@
                    @if (SessionOrdering.EffectiveColor(s) == "red" && s.NeedsYouSince is { } since)
                    {
                        <span class="needs-wait" title="Waiting for you since @since.ToLocalTime():HH:mm:ss">@Waiting(since)</span>
                    }
                </span>
                @* The wingman's railLine: WHAT the session wants, not just that it wants
                   something (TURN_BRIEFING.md). Rendered UNDER the name/state so it never
                   squeezes the session name. While the wingman reads, say so - and ONLY
                   then: this line, the dot, and the triage bucket all key off the same
                   shared effective state so they can never contradict (issue #196). *@
                @if (SessionOrdering.IsExplaining(s))
                {
                    <span class="rail-line explaining">wingman explaining...</span>
                }
                else if (SessionOrdering.IsBriefing(s))
                {
                    <span class="rail-line briefing">wingman reading...</span>
                }
                else if (SessionOrdering.EffectiveColor(s) == "red" && !string.IsNullOrWhiteSpace(s.RailLine))
                {
                    <span class="rail-line">@s.RailLine</span>
                }
            </span>
            @* Per-session menu (#191): mirrors the desktop session context menu, web-adapted.
               The kebab never steals the row's click-to-select (stopPropagation). *@
            <button type="button" class="sess-kebab @(_menuSid == s.SessionId ? "open" : "")"
                    title="Session menu"
                    @onclick="() => ToggleMenu(s.SessionId)" @onclick:stopPropagation="true">&#8942;</button>
            @if (_menuSid == s.SessionId)
            {
                <div class="sess-menu" @onclick:stopPropagation="true">
                    <button class="sess-menu-item" @onclick='() => FireAsync("rename", s)'>Rename</button>
                    <button class="sess-menu-item" @onclick='() => FireAsync("copy-handover", s)'>Copy Handover Info</button>
                    <div class="sess-menu-sep"></div>
                    <button class="sess-menu-item" @onclick='() => FireAsync("github-issue", s)'>New GitHub Issue</button>
                    @* One-click bug session (issue #236): spawn a Bug Report session in the
                       same repo. Hidden ON a bug session - a bug session spawning a bug
                       session is noise. *@
                    @if (s.Type != "BugReport")
                    {
                        <button class="sess-menu-item bug" @onclick='() => FireAsync("start-bug-session", s)'>Start bug session</button>
                    }
                    <div class="sess-menu-sep"></div>
                    <button class="sess-menu-item" @onclick='() => FireAsync("hold", s)'>@(s.OnHold ? "Take Off Hold" : "Hold")</button>
                    <button class="sess-menu-item" @onclick='() => FireAsync("wingman", s)'>@(s.WingmanEnabled ? "Remove Wingman" : "Add Wingman")</button>
                    <div class="sess-menu-sep"></div>
                    @if (_closeArmed)
                    {
                        <button class="sess-menu-item danger" @onclick='() => FireAsync("close", s)'>Confirm close</button>
                    }
                    else
                    {
                        @* Two-step like the detail header's Kill: closing ends the live agent. *@
                        <button class="sess-menu-item danger" @onclick="ArmClose">Close Session</button>
                    }
                </div>
            }
        </div>;
    }

    @if (ViewMode == "triage")
    {
        var needs = SessionOrdering.InBucket(Sessions, SessionOrdering.TriageBucket.NeedsYou);
        var active = SessionOrdering.InBucket(Sessions, SessionOrdering.TriageBucket.Active);
        var held = SessionOrdering.InBucket(Sessions, SessionOrdering.TriageBucket.OnHold);

        @if (needs.Count > 0)
        {
            <div class="triage-sec">
                <div class="triage-head needs">NEEDS YOU <span class="triage-count">@needs.Count</span></div>
                @foreach (var s in needs) { @SessionRow(s) }
            </div>
        }
        @if (active.Count > 0)
        {
            <div class="triage-sec">
                <div class="triage-head">ACTIVE <span class="triage-count">@active.Count</span></div>
                @foreach (var s in active) { @SessionRow(s) }
            </div>
        }
        @if (held.Count > 0)
        {
            <div class="triage-sec">
                <div class="triage-head hold">ON HOLD <span class="triage-count">@held.Count</span></div>
                @foreach (var s in held) { @SessionRow(s) }
            </div>
        }
        @if (Errors.Count > 0)
        {
            <div class="triage-sec">
                <div class="triage-head err">UNREACHABLE <span class="triage-count">@Errors.Count</span></div>
                @foreach (var e in Errors)
                {
                    <div class="dir-error" title="@($"{e.DirectorId} - {e.Error}")">
                        @* Issue #237: port when resolvable (registry lookup by DirectorId),
                           else the GUID prefix - never blank. Full GUID in the title. *@
                        @MachineKey(e.MachineName) / director @PortLabelFor(e.DirectorId) &mdash; @e.Error
                    </div>
                }
            </div>
        }
    }
    else if (ViewMode == "repo")
    {
        @* Issue #219: one group per repository across every machine/Director, headers
           alphabetical (case-insensitive), "(no repo)" last; in-group desktop order keeps
           rows from reshuffling on a color change. The grouping policy lives on
           SessionOrdering so it is shared and unit-tested, never inline LINQ here. *@
        @foreach (var group in SessionOrdering.InRepoGroups(Sessions))
        {
            <div class="repo-grp">
                <div class="repo-head @(group.IsNoRepo ? "norepo" : "")">
                    <span class="repo-name">@group.Name</span>
                    <span class="repo-count">@group.Sessions.Count</span>
                </div>
                @foreach (var s in group.Sessions)
                {
                    @SessionRow(s)
                }
            </div>
        }
    }
    else
    {
        @foreach (var machine in Machines())
        {
            var machineSessions = Sessions.Where(s => MachineKey(s.MachineName) == machine).ToList();
            var machineErrors = Errors.Where(e => MachineKey(e.MachineName) == machine).ToList();
            var needsYou = machineSessions.Count(s => SessionOrdering.EffectiveColor(s) == "red");

            <div class="machine">
                <div class="machine-head">
                    <span class="machine-name">@machine</span>
                    <span class="machine-count">@machineSessions.Count</span>
                    @if (needsYou > 0)
                    {
                        <span class="machine-needs">@needsYou need you</span>
                    }
                </div>

                @* Every Director for this machine - those that own a session here UNION the
                   registry's Directors that have none yet - so an idle Director still shows
                   its [+] (the only way to start its first session). *@
                @foreach (var dirId in DirectorIdsForMachine(machine, machineSessions, machineErrors))
                {
                    var dirSessions = machineSessions.Where(s => s.DirectorId == dirId).ToList();
                    <div class="dir-head">
                        @* Issue #237: label each Director by its port (short, restart-stable, maps
                           to the slot convention) not the meaningless per-process GUID prefix. The
                           full DirectorId stays in the tooltip; it remains the routing key below. *@
                        <span class="dir-head-label" title="@dirId">director @PortLabelFor(dirId)</span>
                        @* Version + uptime from the Gateway's Director registry: makes a
                           stale pre-fix Director stand out without leaving the rail. *@
                        @if (DirectorFor(dirId) is { } meta)
                        {
                            <span class="dir-meta"
                                  title="@($"v{meta.Version}, started {meta.StartedAt.ToLocalTime():yyyy-MM-dd HH:mm}")">
                                v@(ShortVersion(meta.Version)) up @Uptime(meta.StartedAt)
                            </span>
                        }
                        @* An idle Director (registered, reachable, zero sessions) reads as empty
                           without this hint - so a human knows the [+] is what it is for. *@
                        @if (dirSessions.Count == 0)
                        {
                            <span class="dir-idle" title="This Director has no sessions yet">no sessions</span>
                        }
                        <button type="button" class="dir-add"
                                title="Start a new session on this Director"
                                @onclick="() => OnNewSession.InvokeAsync(dirId)">+</button>
                    </div>

                    @foreach (var s in SessionOrdering.InDesktopOrder(dirSessions))
                    {
                        @SessionRow(s)
                    }
                }

                @foreach (var e in machineErrors)
                {
                    <div class="dir-error" title="@($"{e.DirectorId} - {e.Error}")">
                        @* Issue #237: port when resolvable (registry lookup by DirectorId),
                           else the GUID prefix - never blank. Full GUID in the title. *@
                        director @PortLabelFor(e.DirectorId) &mdash; unreachable (@e.Error)
                    </div>
                }
            </div>
        }
    }
</div>

@code {
    [Parameter] public List<SessionDto> Sessions { get; set; } = new();
    [Parameter] public List<MachineErrorDto> Errors { get; set; } = new();

    /// <summary>The Gateway's Director registry (GET /directors): supplies the version and
    /// start time shown on each Director group header. Empty list = headers render without
    /// the meta span (e.g. registry fetch not landed yet).</summary>
    [Parameter] public List<DirectorDto> Directors { get; set; } = new();
    [Parameter] public string? SelectedSessionId { get; set; }

    /// <summary>Sessions the user just confirmed Close for. Their rows are dimmed
    /// (<c>sess-closing</c>) optimistically while the Director tears them down, until the next
    /// poll drops the session from the roster (issue #228). Empty = nothing is closing.</summary>
    [Parameter] public HashSet<string> ClosingSessionIds { get; set; } = new();

    [Parameter] public EventCallback<string> OnSelect { get; set; }

    /// <summary>"tree" (Machine -> Director -> Sessions, desktop order), "triage"
    /// (needs-you first, on-hold last, flat across Directors), or "repo" (grouped by
    /// repository across all machines, alphabetical, "(no repo)" last; issue #219).</summary>
    [Parameter] public string ViewMode { get; set; } = "tree";

    /// <summary>Raised with a Director id when the user clicks a Director's [+] to start
    /// a new session there.</summary>
    [Parameter] public EventCallback<string> OnNewSession { get; set; }

    /// <summary>One action picked from a row's kebab menu (#191). The parent owns the
    /// execution (it has the DirectorClient, JS, and roster refresh); this component only
    /// reports WHICH action on WHICH session.</summary>
    public sealed record MenuActionArgs(string Action, SessionDto Session);

    /// <summary>Raised when the user picks an item from a session's kebab menu.</summary>
    [Parameter] public EventCallback<MenuActionArgs> OnMenuAction { get; set; }

    // ===== kebab menu state: at most one menu open, close-confirm is two-step =====
    private string? _menuSid;
    private bool _closeArmed;

    private void ToggleMenu(string sid)
    {
        _closeArmed = false;
        _menuSid = _menuSid == sid ? null : sid;
    }

    private void CloseMenu()
    {
        _menuSid = null;
        _closeArmed = false;
    }

    private void ArmClose() => _closeArmed = true;

    private async Task FireAsync(string action, SessionDto s)
    {
        CloseMenu();
        await OnMenuAction.InvokeAsync(new MenuActionArgs(action, s));
    }

    private static string MachineKey(string? machine) =>
        string.IsNullOrWhiteSpace(machine) ? "(this machine)" : machine;

    private IEnumerable<string> Machines()
    {
        var fromSessions = Sessions.Select(s => MachineKey(s.MachineName));
        var fromErrors = Errors.Select(e => MachineKey(e.MachineName));
        // A machine whose only Directors are idle (registered, zero sessions, no error) has
        // nothing in Sessions/Errors - include it so its Directors' [+] are still reachable.
        var fromDirectors = Directors.Select(d => MachineKey(d.MachineName));
        return fromSessions.Concat(fromErrors).Concat(fromDirectors).Distinct().OrderBy(m => m);
    }

    /// <summary>
    /// The Director ids to render under a machine in tree mode: the Directors that own a
    /// session here UNION the registry's Directors for this machine that have none yet, so an
    /// idle Director still shows its [+] (the only way to start its first session). Directors
    /// surfaced as unreachable (<paramref name="machineErrors"/>) are excluded - they get the
    /// dedicated error row instead of an empty header. Ordered by the rail's port label so the
    /// list is human-sorted and stable across refreshes.
    /// </summary>
    private IReadOnlyList<string> DirectorIdsForMachine(
        string machine, List<SessionDto> machineSessions, List<MachineErrorDto> machineErrors)
    {
        var unreachable = machineErrors.Select(e => e.DirectorId).ToHashSet();
        var ids = new HashSet<string>(machineSessions.Select(s => s.DirectorId));
        foreach (var d in Directors.Where(d => MachineKey(d.MachineName) == machine))
            ids.Add(d.DirectorId);
        ids.ExceptWith(unreachable);
        return ids.OrderBy(PortLabelFor, StringComparer.OrdinalIgnoreCase).ToList();
    }

    private static string ShortId(string id) =>
        string.IsNullOrEmpty(id) ? "?" : (id.Length <= 8 ? id : id[..8]);

    private DirectorDto? DirectorFor(string directorId) =>
        Directors.FirstOrDefault(d => d.DirectorId == directorId);

    /// <summary>Parses the port out of a Director endpoint URL ("http://127.0.0.1:7884" or
    /// "http://host:7884/") - the short, restart-stable identifier a human knows (issue #237).
    /// Returns "?" when the endpoint is empty or carries no port (caller decides the fallback).
    /// Reference implementation: phone/CcDirectorClient/ExesPage.xaml.cs PortOf.</summary>
    private static string PortOf(string? endpoint)
    {
        if (string.IsNullOrEmpty(endpoint)) return "?";
        var m = System.Text.RegularExpressions.Regex.Match(endpoint, @":(\d+)/?$");
        return m.Success ? m.Groups[1].Value : "?";
    }

    /// <summary>The port for a Director's registry entry: parsed from <see cref="DirectorDto.ControlEndpoint"/>,
    /// falling back to <see cref="DirectorDto.TailnetEndpoint"/> when the control endpoint is empty
    /// (cross-machine HTTP-registered Directors). Returns "?" when neither yields a port.</summary>
    private static string PortOf(DirectorDto dir)
    {
        var port = PortOf(dir.ControlEndpoint);
        if (port != "?") return port;
        return PortOf(dir.TailnetEndpoint);
    }

    /// <summary>The rail label for a Director id: ":&lt;port&gt;" resolved from the Director registry,
    /// or the GUID short-id when the Director is not (or no longer) in the registry, or its endpoints
    /// carry no port. Used by the per-session span and the unreachable rows, which have no endpoint of
    /// their own (issue #237). Never blank - always either a port or the prior GUID prefix.</summary>
    private string PortLabelFor(string directorId)
    {
        if (DirectorFor(directorId) is { } dir)
        {
            var port = PortOf(dir);
            if (port != "?") return $":{port}";
        }
        return ShortId(directorId);
    }

    /// <summary>Version without build metadata: "0.6.7+41d82c4" -> "0.6.7". The full string
    /// stays available in the header tooltip via StartedAt anyway.</summary>
    private static string ShortVersion(string version) =>
        string.IsNullOrWhiteSpace(version) ? "?" : version.Split('+')[0];

    /// <summary>Compact uptime from the registration's UTC start: "2d 4h", "1h 16m", "12m".
    /// Re-rendered on every roster refresh, so minute resolution stays honest.</summary>
    private static string Uptime(DateTime startedAtUtc)
    {
        var up = DateTime.UtcNow - startedAtUtc.ToUniversalTime();
        if (up < TimeSpan.Zero) up = TimeSpan.Zero;
        return up.TotalDays >= 1 ? $"{(int)up.TotalDays}d {up.Hours}h"
             : up.TotalHours >= 1 ? $"{(int)up.TotalHours}h {up.Minutes}m"
             : $"{up.Minutes}m";
    }

    /// <summary>Issue #218: compact elapsed-waiting label for a NEEDS YOU session, from the
    /// Gateway-owned <see cref="SessionDto.NeedsYouSince"/> UTC stamp. Same compact style as
    /// <see cref="Uptime"/> ("2d 4h" / "1h 16m" / "12m") but seconds-aware for sub-minute waits
    /// ("12s") so a freshly-red session shows a meaningful value rather than "0m". Recomputed on
    /// every roster refresh (the Cockpit's 2s poll), so it ticks up while the session stays red.</summary>
    private static string Waiting(DateTime sinceUtc)
    {
        var w = DateTime.UtcNow - sinceUtc.ToUniversalTime();
        if (w < TimeSpan.Zero) w = TimeSpan.Zero;
        return w.TotalDays >= 1 ? $"{(int)w.TotalDays}d {w.Hours}h"
             : w.TotalHours >= 1 ? $"{(int)w.TotalHours}h {w.Minutes}m"
             : w.TotalMinutes >= 1 ? $"{(int)w.TotalMinutes}m"
             : $"{(int)w.TotalSeconds}s";
    }

    // Verbatim render of the Director-authored StatusColor. Never derived from other fields.
    private static string DotColor(string c) => c switch
    {
        "green" => "#22C55E",
        "blue" => "#3B82F6",
        "yellow" => "#F59E0B",
        "orange" => "#F97316",
        "red" => "#F14C4C",
        "supporting" => "#64748B",
        _ => "#6B7280",
    };
}
