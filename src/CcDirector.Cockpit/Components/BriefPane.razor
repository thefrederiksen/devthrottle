@implements IDisposable
@inject DirectorClient Director
@inject GatewayClient Gateway
@inject NavigationManager Nav
@inject ILogger<BriefPane> Log
@inject IJSRuntime JS
@using Markdig

@* The full-page session Brief. TIERED (TURN_BRIEFING.md):
     1. WINGMAN TIER - the stored TurnBrief (strong-model interpretation generated at turn
        end): YOU'RE DOING / YOU ASKED / NEEDS YOU (synthesized + verbatim receipts +
        one-tap options, incl. multi-select toggle+Submit) / CLAUDE DID.
     2. CONDENSER TIER - the v1 /brief (mini-model bullets + final-paragraph fallback).
     3. RAW TIER - /summary fields.
     4. The Terminal tab.
   Every tier LABELS itself. NOTHING in this component parses model output - options come
   structured from the wingman (D6: the regex option parser was deleted, as designed).

   While the session WORKS or the wingman is READING (yellow), nothing stale masquerades as
   current: the ask plus a live terminal tail. *@

<div class="brief">
    @if (_loading && _turnBrief is null && _brief is null && _summary is null && _error is null)
    {
        <div class="brief-loading">Loading brief...</div>
    }
    else if (_error is not null)
    {
        <div class="brief-error">
            <div>@_error</div>
            <div class="brief-error-hint">Use the Terminal tab to see this session.</div>
        </div>
    }
    else if (_turnBrief is null && _brief is not null && _brief.Status != "ok")
    {
        <div class="brief-status">
            <div class="blabel">BRIEF UNAVAILABLE (@_brief.Status)</div>
            <div class="brief-muted">@(_brief.Error ?? "The transcript is not readable yet.")</div>
            <div class="brief-error-hint">
                @(_brief.Status == "no_session_id"
                    ? "This session has not linked to a Claude transcript yet - usually it just started. The Terminal tab always works."
                    : "Use the Terminal tab to see this session.")
            </div>
        </div>
    }
    else
    {
        @* ---- "I am lost - explain" (issue #217): one tap and the wingman re-reads the
             WHOLE session in its own round; the session shows ORANGE while it works. The
             newest report stays pinned here until the next explain. The banner flips ON
             in the same render as the click (optimistic, before the POST even leaves) -
             user-action feedback never waits on the roster poll. *@
        @if (IsExplainingNow)
        {
            <div class="explain-banner">
                <span class="explain-banner-dot"></span>
                <span><strong>Wingman is re-reading this whole session.</strong>
                    The explain report will appear here when it is ready - usually well under a minute.</span>
            </div>
        }
        else
        {
            <div class="explain-row">
                <button class="explain-btn" disabled="@_explainBusy" @onclick="RequestExplainAsync"
                        title="The wingman re-reads the whole session and answers: what happened, what we did, what next.">
                    I am lost - explain
                </button>
                @if (_explainStatus is not null)
                {
                    <span class="brief-muted">@_explainStatus</span>
                }
            </div>
        }
        @if (_explain is not null)
        {
            <div class="explain-report">
                <div class="blabel">
                    @(_explain.Degraded ? "EXPLAIN FAILED" : "EXPLAIN")
                    <span class="brief-verbatim-tag">@_explain.Model - requested @_explain.RequestedAtUtc.ToLocalTime().ToString("HH:mm"), ready @_explain.GeneratedAtUtc.ToLocalTime().ToString("HH:mm")</span>
                </div>
                <div class="explain-section">
                    <div class="brief-muted">WHAT HAPPENED</div>
                    <div class="explain-text">@_explain.WhatHappened</div>
                </div>
                <div class="explain-section">
                    <div class="brief-muted">WHAT WE DID</div>
                    <ul class="explain-did">
                        @foreach (var item in _explain.WhatWeDid)
                        {
                            <li>@item</li>
                        }
                    </ul>
                </div>
                <div class="explain-section">
                    <div class="brief-muted">WHAT NEXT</div>
                    <div class="explain-text">@_explain.WhatNext</div>
                </div>
            </div>
        }

        @* ---- YOU'RE DOING (wingman rolling intent) or GOAL (degrade) ---- *@
        @if (HasWingmanBrief)
        {
            <div class="brief-goal">
                <span class="blabel">YOU'RE DOING</span>
                <span class="brief-goal-text">@_turnBrief!.Intent</span>
            </div>
        }
        else if (Goal is not null)
        {
            <div class="brief-goal">
                <span class="blabel">GOAL</span>
                <span class="brief-goal-text">@Goal</span>
            </div>
        }

        <div class="brief-block">
            <div class="blabel">YOU ASKED</div>
            @if (LastAsk is not null)
            {
                <div class="brief-ask">@LastAsk</div>
                @* A bare ack ("yes", "1", "go ahead") is meaningless on its own (issue
                   #206: 'YOU ASKED: yes'). When the wingman interpreted the turn, say
                   what the ack actually meant. Classifying the USER's prompt with a
                   fixed word list is mechanical - no model output is parsed (D6). *@
                @if (HasWingmanBrief && IsBareAck(LastAsk))
                {
                    <div class="brief-muted">interpreted: @_turnBrief!.Intent</div>
                }
            }
            else
            {
                <div class="brief-muted">No user prompt found in the transcript yet.</div>
            }
        </div>

        @if (IsBriefing)
        {
            <div class="brief-block">
                <div class="blabel yellow">WINGMAN IS READING THE TURN...</div>
                @if (!string.IsNullOrWhiteSpace(_tail))
                {
                    <pre class="brief-tail">@_tail</pre>
                }
            </div>
        }
        else if (ReplyPending && ActivityState == "WaitingForInput" && !HasWingmanNeedsYou)
        {
            @* On-screen interactive prompt with no wingman brief yet (old Director or
               brief pending): show the screen so the question is readable. *@
            <div class="brief-block">
                <div class="blabel red">NEEDS YOU - ON-SCREEN PROMPT</div>
                <div class="brief-needsyou urgency-blocking">
                    Claude is asking with an interactive prompt that only the terminal shows.
                </div>
                @if (!string.IsNullOrWhiteSpace(_tail))
                {
                    <pre class="brief-tail">@_tail</pre>
                }
                <button class="brief-open-term" @onclick="() => OnOpenTerminal.InvokeAsync()">Open the Terminal to answer</button>
            </div>
        }
        else if (IsWorking || (ReplyPending && !HasWingmanNeedsYou))
        {
            <div class="brief-block">
                <div class="blabel">CLAUDE IS WORKING</div>
                @if (!string.IsNullOrWhiteSpace(_tail))
                {
                    <pre class="brief-tail">@_tail</pre>
                }
                else
                {
                    <div class="brief-working">Claude is @(ReplyPending ? "writing its reply" : "working") - nothing needed from you right now.</div>
                }
            </div>
        }
        else if (HasWingmanNeedsYou)
        {
            var n = _turnBrief!.NeedsYou!;
            <div class="brief-block">
                <div class="blabel @(n.Urgency == "fyi" ? "" : "red")">
                    @(n.Urgency == "fyi" ? "FYI" : "NEEDS YOU")
                    <span class="brief-verbatim-tag">@TierLabel</span>
                    @if (n.Confidence == "ambiguous")
                    {
                        <span class="brief-cond-warn">wingman unsure</span>
                    }
                </div>
                @* v3.4 (the trust fix): Claude's actual decisive line, verbatim, shown FIRST
                   and expanded - the brief leads with Claude's own words instead of competing
                   with the terminal on fidelity. The synthesized statement follows it. *@
                @if (!string.IsNullOrWhiteSpace(n.Evidence))
                {
                    <div class="brief-claude-said">
                        <span class="brief-claude-said-label">Claude said</span>
                        <div class="brief-evidence">@n.Evidence</div>
                    </div>
                }
                <div class="brief-needsyou urgency-@n.Urgency">@n.Statement</div>

                @if (n.Options.Count > 0 && n.SelectionMode == "multiple")
                {
                    <div class="brief-quick">
                        @foreach (var o in n.Options)
                        {
                            <button class="brief-quick-btn @(_toggled.Contains(o.Send) ? "toggled" : "")"
                                    disabled="@_answering" title="@(o.Note ?? "toggle")"
                                    @onclick="() => Toggle(o.Send)">
                                <b>@(_toggled.Contains(o.Send) ? "[x]" : "[ ]")</b> @o.Key
                                @if (o.Note is not null)
                                {
                                    <span class="brief-opt-note">@o.Note</span>
                                }
                            </button>
                        }
                        <button class="brief-quick-btn submit" disabled="@(_answering || _toggled.Count == 0)"
                                @onclick="() => SubmitMultiAsync(n)">
                            Submit @(_toggled.Count > 0 ? $"({_toggled.Count})" : "")
                        </button>
                    </div>
                }
                else if (n.Options.Count > 0)
                {
                    <div class="brief-quick">
                        @foreach (var o in n.Options)
                        {
                            @* v3 (issue #205): the wingman's pick renders as "(recommended)" with
                               the reason in its note - at most one, enforced server-side. Spelled
                               out, not "(rec)", which read as "record" to users.
                               Issue #227: the option group disables on the optimistic _answering
                               flag OR the parent's Replying busy flag (the previously-dead wire,
                               now live), and the clicked option shows "answering..." instantly. *@
                            <button class="brief-quick-btn @(o.Recommended ? "recommended" : "") @(_answeringSend == o.Send ? "answering" : "")"
                                    disabled="@(_answering || Replying)"
                                    title="@(o.Note ?? DescribeSend(o.Send))"
                                    @onclick="() => AnswerSingleAsync(n, o)">
                                <b>@o.Key@(o.Recommended ? " (recommended)" : "")</b>
                                @if (_answeringSend == o.Send)
                                {
                                    <span class="brief-opt-note brief-answering-note">answering...</span>
                                }
                                else if (o.Note is not null)
                                {
                                    <span class="brief-opt-note">@o.Note</span>
                                }
                            </button>
                        }
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(n.IfIgnored))
                {
                    @* v3 (issue #205): the single most decision-relevant fact for triage. *@
                    <div class="brief-ifignored">If you do nothing: @n.IfIgnored</div>
                }

            </div>
        }
        @if (HasSuggestedClose)
        {
            @* MISSION COMPLETE (v2.4, issue #201): the wingman judged the session's goal
               delivered - the real action is closing the session. Suggestion only: the
               two-step click below IS the approval; nothing ever auto-closes. Hidden the
               moment the session works or the wingman reads again (stale suggestions
               must not outlive new activity). *@
            <div class="brief-block brief-mission-complete">
                <div class="blabel">MISSION COMPLETE<span class="brief-verbatim-tag">wingman suggestion</span></div>
                <div class="brief-needsyou urgency-fyi">@_turnBrief!.SuggestedAction!.Reason</div>
                <div class="brief-quick">
                    @if (!_closeArmed)
                    {
                        <button class="brief-quick-btn brief-close-btn" disabled="@_closing"
                                @onclick="() => _closeArmed = true">
                            Close this session
                        </button>
                    }
                    else
                    {
                        <button class="brief-quick-btn brief-close-btn armed" disabled="@_closing"
                                @onclick="ConfirmCloseAsync">
                            @(_closing ? "closing..." : "Confirm close")
                        </button>
                        <button class="brief-quick-btn" disabled="@_closing"
                                @onclick="() => _closeArmed = false">
                            Keep it open
                        </button>
                    }
                </div>
            </div>
        }

        @if (HasWingmanAllClear && !HasSuggestedClose && !IsBriefing && !IsWorking && !ReplyPending)
        {
            @* The wingman read this turn and concluded NOTHING is needed (issue #206).
               That verdict is first-class: it must never be overridden by the condenser
               paragraph under a red header - the red lie from the epic's evidence.
               v3 (issue #205): the wingman authors the concrete all-clear line itself
               ("v0.3.0 published and live - nothing to do"); pre-v3 briefs fall back to
               the generic sentence. *@
            <div class="brief-block">
                <div class="blabel">
                    ALL CLEAR
                    <span class="brief-verbatim-tag">@TierLabel</span>
                </div>
                <div class="brief-needsyou urgency-fyi">@(string.IsNullOrWhiteSpace(_turnBrief!.AllClear) ? "The wingman read this turn and concluded nothing is needed from you." : _turnBrief.AllClear)</div>
            </div>
        }
        else if (!HasWingmanBrief && NeedsYou is not null && !IsBriefing && !IsWorking && !ReplyPending)
        {
            @* Condenser/raw degrade tier: ONLY when there is no (non-degraded) wingman
               brief at all. A wingman brief - including one whose verdict is "nothing
               needed" - always outranks this tier (issue #206). NO option buttons -
               options only ever come structured from the wingman (D6). *@
            <div class="brief-block">
                <div class="blabel red">
                    NEEDS YOU
                    <span class="brief-verbatim-tag">@(_brief?.NeedsYouSource == "model" ? "condenser tier - Claude's words" : "condenser tier - reply's final paragraph")</span>
                </div>
                <div class="brief-needsyou urgency-review">@NeedsYou</div>
            </div>
        }

        @if (!IsWorking && !IsBriefing && !(ReplyPending && !HasWingmanNeedsYou))
        {
            <div class="brief-divider"></div>

            <div class="brief-block">
                <div class="blabel">
                    CLAUDE DID
                    <span class="brief-verbatim-tag">@TierLabel</span>
                </div>
                @if (HasWingmanBrief && _turnBrief!.Did.Count > 0)
                {
                    <ul class="brief-did">
                        @foreach (var b in _turnBrief.Did)
                        {
                            <li>@b</li>
                        }
                    </ul>
                }
                else if (_brief?.DidBullets.Count > 0)
                {
                    <ul class="brief-did">
                        @foreach (var b in _brief.DidBullets)
                        {
                            <li>@b</li>
                        }
                    </ul>
                }
                else if (FullReply is not null)
                {
                    <div class="brief-reply-md">@RenderMarkdown(FullReply)</div>
                }
                else
                {
                    <div class="brief-muted">Claude has not replied yet.</div>
                }

                @if ((HasWingmanBrief || _brief?.DidBullets.Count > 0) && FullReply is not null)
                {
                    <button class="brief-expand" @onclick="() => _showFull = !_showFull">
                        @(_showFull ? "hide full reply" : "full reply")
                    </button>
                    @if (_showFull)
                    {
                        <div class="brief-reply-md">@RenderMarkdown(FullReply)</div>
                    }
                }
            </div>
        }

        @if (_turnBrief is not null)
        {
            <div class="brief-feedback-panel">
                <div class="brief-feedback-head">
                    <span class="blabel">BRIEF FEEDBACK</span>
                    <span class="brief-muted">One tap records a replayable case with the brief + TurnPackage.</span>
                </div>
                <div class="brief-feedback-actions">
                    <button class="brief-vote-btn up" disabled="@_feedbackBusy" @onclick='() => VoteBriefAsync("up")' title="Mark this brief as useful">
                        <svg class="vote-ico" viewBox="0 0 16 16"><path d="M2.5 7h2.5v6H2.5z" /><path d="M5 12.5V7.5l3-4.3c1-.9 2.3 0 1.9 1.2L9.2 7h3.2c.8 0 1.3.7 1.1 1.4l-1 3.6c-.2.6-.7 1-1.4 1z" /></svg> useful
                    </button>
                    <button class="brief-vote-btn down" disabled="@_feedbackBusy" @onclick='() => VoteBriefAsync("down")' title="Mark this brief as wrong or unhelpful">
                        <svg class="vote-ico" viewBox="0 0 16 16"><path d="M2.5 3h2.5v6H2.5z" /><path d="M5 3.5v5l3 4.3c1 .9 2.3 0 1.9-1.2L9.2 9h3.2c.8 0 1.3-.7 1.1-1.4l-1-3.6c-.2-.6-.7-1-1.4-1z" /></svg> wrong
                    </button>
                </div>
                @if (_feedbackOpen)
                {
                    <div class="brief-feedback-reason">
                        <textarea @bind="_feedbackReason" placeholder="What is wrong or missing? Type it or use Speak..." />
                        <div class="brief-feedback-actions">
                            <button class="brief-vote-btn" disabled="@(_feedbackBusy || _dictatingFeedback)" @onclick="OpenFeedbackDictateAsync">
                                @(_dictatingFeedback ? "listening..." : "Speak")
                            </button>
                            <button class="brief-vote-btn down" disabled="@(_feedbackBusy || string.IsNullOrWhiteSpace(_feedbackReason))" @onclick="SaveFeedbackReasonAsync">
                                @(_feedbackBusy ? "saving..." : "save reason")
                            </button>
                        </div>
                    </div>
                }
                @if (!string.IsNullOrWhiteSpace(_feedbackStatus))
                {
                    <div class="brief-muted">@_feedbackStatus</div>
                }
            </div>
        }

        <div class="brief-foot">
            @if (_summary is not null && _brief is null && _turnBrief is null)
            {
                <span class="brief-muted">Raw summary tier (this Director predates the Brief endpoints - relaunch it on a new build).</span>
            }
            @if (!string.IsNullOrEmpty(_answerStatus))
            {
                <span class="brief-muted">@_answerStatus</span>
            }
            <span class="spacer"></span>
            <button class="brief-refresh" @onclick="() => LoadAsync()" disabled="@_loading">@(_loading ? "refreshing..." : "refresh")</button>
        </div>
    }
</div>

@code {
    [Parameter] public string SessionId { get; set; } = "";
    [Parameter] public string DirectorBase { get; set; } = "";
    [Parameter] public string ActivityState { get; set; } = "";
    /// <summary>"None"|"Briefing"|"Briefed"|"Failed" from the roster poll - drives the
    /// yellow "wingman reading" window and the refresh-on-Briefed reload.</summary>
    [Parameter] public string BriefingState { get; set; } = "None";
    [Parameter] public EventCallback OnOpenTerminal { get; set; }
    /// <summary>Typed-reply answer path (parent sends as a prompt and advances the conveyor).</summary>
    [Parameter] public EventCallback<string> OnQuickReply { get; set; }
    [Parameter] public bool Replying { get; set; }
    /// <summary>Mission-complete approval path (issue #201): the parent closes the session
    /// through the SAME path as the rail kebab's Close. Invoked only after the two-step
    /// confirm in this pane - the click IS the approval.</summary>
    [Parameter] public EventCallback OnCloseSession { get; set; }
    /// <summary>Optimistic explain notification (issue #217 reactivity): true the instant
    /// the explain button is clicked (parent paints the rail orange immediately), false if
    /// the POST fails. The Gateway's polled BriefingState reconciles afterwards.</summary>
    [Parameter] public EventCallback<bool> OnExplainPending { get; set; }

    private TurnBriefDto? _turnBrief;
    private BriefResponse? _brief;
    private SessionSummaryDto? _summary;
    private string? _error;
    private bool _loading;
    private bool _showFull;
    private bool _answering;
    /// <summary>The <c>Send</c> of the option the user just clicked (issue #227): drives the
    /// "answering..." label on that single option, so the click target itself shows the busy
    /// state, not just a disabled group. Null when no answer is in flight.</summary>
    private string? _answeringSend;
    private string? _answerStatus;
    private readonly HashSet<string> _toggled = new(StringComparer.Ordinal);
    private string _lastSeenState = "";
    private string _lastSeenBriefState = "";
    private CancellationTokenSource? _loadCts;

    private bool IsWorking => ActivityState == "Working";
    private bool IsBriefing => BriefingState == "Briefing";
    private bool ReplyPending => _brief?.ReplyPending == true;
    private bool HasWingmanBrief => _turnBrief is not null && !_turnBrief.Degraded;
    private bool HasWingmanNeedsYou => HasWingmanBrief && _turnBrief!.NeedsYou is not null;
    /// <summary>The wingman read the turn and concluded nothing is needed (issue #206).
    /// A first-class verdict: it suppresses the condenser fallback entirely.</summary>
    private bool HasWingmanAllClear => HasWingmanBrief && _turnBrief!.NeedsYou is null;
    /// <summary>Mission-complete close suggestion (issue #201), shown ONLY while the session
    /// is quiet - the moment it works or the wingman reads again, the suggestion is stale.</summary>
    private bool HasSuggestedClose => HasWingmanBrief
        && _turnBrief!.SuggestedAction?.Type == "close_session"
        && !IsWorking && !IsBriefing && !ReplyPending;
    /// <summary>Tier provenance tag. For the wingman tier it includes the turn number and
    /// local generation time (issue #206): a brief for turn 153 must never silently look
    /// like it describes turn 158.</summary>
    private string TierLabel => HasWingmanBrief
        ? $"{_turnBrief!.Model} - turn {_turnBrief.TurnNumber}, {_turnBrief.GeneratedAtUtc.ToLocalTime():HH:mm}"
        : (_brief is not null ? "condenser tier" : "raw tier");

    /// <summary>Bare approvals/acks whose meaning lives entirely in the question they
    /// answered ("yes", "2", "go ahead"). A fixed mechanical list - never inference.</summary>
    private static readonly System.Text.RegularExpressions.Regex BareAckPattern = new(
        @"^\s*(y|yes|yeah|yep|ok|okay|sure|no|n|nope|go|go ahead|do it|proceed|approved?|push it|ship it|\d{1,2})\s*[.!]?\s*$",
        System.Text.RegularExpressions.RegexOptions.IgnoreCase,
        TimeSpan.FromMilliseconds(50));

    private static bool IsBareAck(string ask) => BareAckPattern.IsMatch(ask);

    private string? Goal => _brief?.Goal;

    /// <summary>Dictated prompts arrive as one bare @file token ("@.temp/input_*.txt") -
    /// an opaque path tells the reader nothing (issue #208, review rounds 3-6). The
    /// wingman brief carries the RESOLVED words (TurnBrief.YouAsked, substituted from the
    /// file at capture time) - prefer those exactly and only when the raw ask is such a
    /// token. Mechanical check, mirrors DictatedPromptResolver's bare-reference shape.</summary>
    private static readonly System.Text.RegularExpressions.Regex BareFileRefPattern = new(
        @"^@[\w.\-]+(?:[/\\][\w.\-]+)+$",
        System.Text.RegularExpressions.RegexOptions.None,
        TimeSpan.FromMilliseconds(50));

    private static bool IsBareFileRef(string? ask)
        => ask is not null && BareFileRefPattern.IsMatch(ask.Trim());

    /// <summary>Tooltip fallback when an option has no note: a control-only send ("\r" -
    /// the parked-reply press-Enter convention, v3.2+) would render as blank - say what
    /// it does instead (issue #208 human review).</summary>
    private static string DescribeSend(string send)
        => send.Length > 0 && send.All(c => c is '\r' or '\n')
            ? "presses Enter - submits the reply you already typed"
            : $"send: {send}";

    private string? LastAsk
    {
        get
        {
            var raw = _brief?.LastAsk ?? _summary?.LastUserPrompt;
            if (IsBareFileRef(raw)
                && !string.IsNullOrWhiteSpace(_turnBrief?.YouAsked)
                && !IsBareFileRef(_turnBrief.YouAsked))
                return _turnBrief.YouAsked;
            return raw;
        }
    }
    private string? FullReply => _brief?.FullReply ?? _summary?.LastAssistantText;
    private string? NeedsYou => _brief?.NeedsYou
        ?? (ActivityState == "WaitingForInput" && _summary?.LastAssistantText is not null
            ? Services.BriefFallback.FinalParagraph(_summary.LastAssistantText)
            : null);

    // ===== answering =====

    private bool _closeArmed;
    private bool _closing;
    private ExplainReportDto? _explain;
    private bool _explainBusy;
    private string? _explainStatus;
    /// <summary>Optimistic "explaining" presentation, set in the SAME render as the click
    /// (issue #217 reactivity): the banner must appear within milliseconds of the button
    /// press, never after the next roster poll. Cleared when the Gateway's authoritative
    /// BriefingState confirms, on POST failure, or by the stale-guard in
    /// <see cref="OnParametersSetAsync"/>.</summary>
    private bool _explainOptimistic;
    private DateTime _explainOptimisticAt;

    /// <summary>The Gateway is running the user-requested deep dive (issue #217): the
    /// session presents ORANGE and the button yields to the working banner. Optimistic
    /// local state ORs in so the flip never waits on the parent's poll.</summary>
    private bool IsExplainingNow => BriefingState == "Explaining" || _explainOptimistic;

    /// <summary>The explain button (issue #217): flip the banner and the parent's rail
    /// orange FIRST (optimistic), then queue the deep dive on the Gateway. The roster
    /// poll confirms; the report lands via the Explaining-&gt;done transition reload.</summary>
    private async Task RequestExplainAsync()
    {
        if (_explainBusy || string.IsNullOrEmpty(SessionId)) return;
        _explainBusy = true;
        _explainStatus = null;
        _explainOptimistic = true;
        _explainOptimisticAt = DateTime.UtcNow;
        await InvokeAsync(StateHasChanged);
        try
        {
            // Parent stamps the in-memory roster so the rail dot/chip go orange in the
            // same UI cycle - before the network round-trip below.
            await OnExplainPending.InvokeAsync(true);
            await Gateway.PostExplainAsync(SessionId);
        }
        catch (Exception ex)
        {
            Log.LogWarning(ex, "BriefPane explain request failed for sid={Sid}", SessionId);
            _explainOptimistic = false;
            _explainStatus = $"explain failed: {ex.Message}";
            await OnExplainPending.InvokeAsync(false);
        }
        finally
        {
            _explainBusy = false;
        }
    }

    private bool _feedbackBusy;
    private bool _feedbackOpen;
    private string _feedbackVote = "down";
    private string _feedbackReason = "";
    private string? _feedbackId;
    private string? _feedbackStatus;
    private bool _dictatingFeedback;
    private DotNetObjectReference<BriefPane>? _feedbackDictateRef;

    /// <summary>The committed click of the two-step mission-complete confirm: hand the
    /// close to the parent (same path as the rail kebab's Close).</summary>
    private async Task ConfirmCloseAsync()
    {
        _closing = true;
        try
        {
            Log.LogInformation("BriefPane: wingman close suggestion approved for sid={Sid} (reason: {Reason})",
                SessionId, _turnBrief?.SuggestedAction?.Reason);
            await OnCloseSession.InvokeAsync();
        }
        catch (Exception ex)
        {
            Log.LogWarning(ex, "BriefPane: close failed for sid={Sid}", SessionId);
            _answerStatus = $"close failed: {ex.Message}";
        }
        finally
        {
            _closing = false;
            _closeArmed = false;
        }
    }

    private async Task VoteBriefAsync(string vote)
    {
        if (_turnBrief is null || _feedbackBusy) return;
        _feedbackBusy = true;
        _feedbackVote = vote;
        _feedbackStatus = vote == "down" ? "Saving downvote..." : "Saving useful vote...";
        if (vote == "down") _feedbackOpen = true;
        await InvokeAsync(StateHasChanged);
        try
        {
            var result = await Gateway.PostBriefFeedbackAsync(SessionId, _turnBrief.TurnNumber, vote, _feedbackReason, _feedbackId);
            _feedbackId = result.FeedbackId;
            _feedbackStatus = vote == "down"
                ? "Downvote saved. Add a reason now or move on."
                : "Useful vote saved as a contrast example.";
        }
        catch (Exception ex)
        {
            Log.LogWarning(ex, "BriefPane feedback vote failed for sid={Sid}", SessionId);
            _feedbackStatus = $"feedback failed: {ex.Message}";
        }
        finally
        {
            _feedbackBusy = false;
        }
    }

    private async Task SaveFeedbackReasonAsync()
    {
        if (_turnBrief is null || _feedbackBusy || string.IsNullOrWhiteSpace(_feedbackReason)) return;
        _feedbackBusy = true;
        _feedbackStatus = "Saving reason...";
        await InvokeAsync(StateHasChanged);
        try
        {
            var result = await Gateway.PostBriefFeedbackAsync(SessionId, _turnBrief.TurnNumber, _feedbackVote, _feedbackReason.Trim(), _feedbackId);
            _feedbackId = result.FeedbackId;
            _feedbackStatus = "Reason saved on the same replayable feedback record.";
        }
        catch (Exception ex)
        {
            Log.LogWarning(ex, "BriefPane feedback reason failed for sid={Sid}", SessionId);
            _feedbackStatus = $"reason save failed: {ex.Message}";
        }
        finally
        {
            _feedbackBusy = false;
        }
    }

    private async Task OpenFeedbackDictateAsync()
    {
        if (string.IsNullOrWhiteSpace(SessionId) || _dictatingFeedback) return;
        try
        {
            _dictatingFeedback = true;
            _feedbackStatus = "Listening for reason...";
            _feedbackDictateRef ??= DotNetObjectReference.Create(this);
            // Issue #268: dictate over a same-origin WS to the GATEWAY (never the Director's own
            // address); the Gateway resolves the owning Director and reverse-proxies /dictate.
            var wsUrl = CockpitWsUrls.Dictate(Nav.BaseUri, SessionId);
            await JS.InvokeVoidAsync("cockpitDictate.start", _feedbackDictateRef, wsUrl, "/js/dictate-worklet.js", "default");
        }
        catch (OperationCanceledException)
        {
            _dictatingFeedback = false;
        }
        catch (Exception ex)
        {
            _dictatingFeedback = false;
            Log.LogWarning(ex, "BriefPane feedback dictation failed for sid={Sid}", SessionId);
            _feedbackStatus = $"dictation unavailable: {ex.Message}";
        }
    }

    [JSInvokable]
    public Task OnDictateInsert(string text)
    {
        _dictatingFeedback = false;
        if (!string.IsNullOrWhiteSpace(text))
            _feedbackReason = string.IsNullOrWhiteSpace(_feedbackReason) ? text : _feedbackReason.TrimEnd() + " " + text;
        _feedbackStatus = string.IsNullOrWhiteSpace(text) ? "Dictation cancelled." : "Reason dictated. Tap save reason.";
        return InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public async Task OnDictateSend(string text)
    {
        _dictatingFeedback = false;
        if (!string.IsNullOrWhiteSpace(text))
            _feedbackReason = string.IsNullOrWhiteSpace(_feedbackReason) ? text : _feedbackReason.TrimEnd() + " " + text;
        await InvokeAsync(StateHasChanged);
        await SaveFeedbackReasonAsync();
    }

    [JSInvokable]
    public Task OnDictateCancel()
    {
        _dictatingFeedback = false;
        _feedbackStatus = _feedbackId is null ? null : "Vote saved. Reason skipped.";
        return InvokeAsync(StateHasChanged);
    }

    private void Toggle(string send)
    {
        if (!_toggled.Remove(send)) _toggled.Add(send);
    }

    /// <summary>Single-select answer: keys go raw to the PTY; replies go through the
    /// parent's prompt path (which also advances the needs-you conveyor). Either way the
    /// clicked option flips to its busy state in the SAME render as the click (issue #227,
    /// the #217 optimistic pattern): the option group disables and the clicked option shows
    /// "answering..." BEFORE the POST leaves, so the most-used action never looks ignored.</summary>
    private async Task AnswerSingleAsync(TurnBriefNeedsYou n, TurnBriefOption o)
    {
        if (n.AnswerVia == "reply")
        {
            // Optimistic busy state, set and rendered before the prompt POST leaves. The
            // parent advances the needs-you conveyor (or, when this was the only one, leaves
            // us here) - this pane is re-keyed on a session switch, so the visible busy state
            // lives only until that switch; rolled back here only on failure.
            _answering = true;
            _answeringSend = o.Send;
            _answerStatus = "answering...";
            await InvokeAsync(StateHasChanged);
            try
            {
                await OnQuickReply.InvokeAsync(o.Send);
            }
            catch (Exception ex)
            {
                Log.LogWarning(ex, "reply answer failed for sid={Sid}", SessionId);
                _answering = false;
                _answeringSend = null;
                _answerStatus = $"answer failed: {ex.Message}";
            }
            return;
        }
        _answering = true;
        _answeringSend = o.Send;
        _answerStatus = "sending...";
        await InvokeAsync(StateHasChanged);
        try
        {
            await Director.SendInputAsync(DirectorBase, SessionId, o.Send);
            _answerStatus = $"sent: {o.Key}";
        }
        catch (Exception ex)
        {
            Log.LogWarning(ex, "keys answer failed for sid={Sid}", SessionId);
            _answerStatus = $"send failed: {ex.Message}";
        }
        finally
        {
            _answering = false;
            _answeringSend = null;
        }
    }

    /// <summary>Multi-select: send each toggled option's key (toggling the checklist),
    /// then the submit sequence. Small gaps let the TUI repaint between toggles.</summary>
    private async Task SubmitMultiAsync(TurnBriefNeedsYou n)
    {
        _answering = true;
        _answerStatus = null;
        try
        {
            foreach (var o in n.Options.Where(o => _toggled.Contains(o.Send)))
            {
                await Director.SendInputAsync(DirectorBase, SessionId, o.Send);
                await Task.Delay(300);
            }
            if (!string.IsNullOrEmpty(n.Submit))
                await Director.SendInputAsync(DirectorBase, SessionId, n.Submit);
            _answerStatus = $"submitted {_toggled.Count} selection(s)";
            _toggled.Clear();
        }
        catch (Exception ex)
        {
            Log.LogWarning(ex, "multi-select submit failed for sid={Sid}", SessionId);
            _answerStatus = $"submit failed: {ex.Message}";
        }
        finally
        {
            _answering = false;
        }
    }

    // ===== live terminal tail (working / briefing / on-screen-prompt states) =====

    private const int TailLines = 8;
    private string _tail = "";
    private CancellationTokenSource? _tailCts;

    private bool TailWanted => IsWorking || IsBriefing || (ReplyPending && !HasWingmanNeedsYou);

    private void SyncTailLoop()
    {
        if (TailWanted && _tailCts is null)
        {
            _tailCts = new CancellationTokenSource();
            _ = PollTailAsync(_tailCts.Token);
        }
        else if (!TailWanted && _tailCts is not null)
        {
            _tailCts.Cancel();
            _tailCts = null;
            _tail = "";
        }
    }

    private async Task PollTailAsync(CancellationToken ct)
    {
        try
        {
            while (!ct.IsCancellationRequested)
            {
                try
                {
                    _tail = await Director.GetScreenTailAsync(DirectorBase, SessionId, TailLines, ct);
                    await InvokeAsync(StateHasChanged);
                }
                catch (OperationCanceledException) { throw; }
                catch (Exception ex)
                {
                    Log.LogDebug(ex, "tail poll failed for sid={Sid}", SessionId);
                }
                await Task.Delay(TimeSpan.FromSeconds(2), ct);
            }
        }
        catch (OperationCanceledException)
        {
            // state changed or pane disposed; normal.
        }
    }

    // ===== markdown =====

    private static readonly MarkdownPipeline _mdPipeline =
        new MarkdownPipelineBuilder().UseAdvancedExtensions().DisableHtml().Build();

    private static MarkupString RenderMarkdown(string text)
        => (MarkupString)Markdown.ToHtml(text, _mdPipeline);

    // ===== lifecycle =====

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        _lastSeenState = ActivityState;
        _lastSeenBriefState = BriefingState;
        await LoadAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        // The Gateway confirmed the deep dive (the roster poll caught up with the click):
        // the authoritative BriefingState drives from here - drop the optimistic overlay.
        if (_explainOptimistic && BriefingState == "Explaining")
        {
            _explainOptimistic = false;
        }
        // Stale-guard: the POST flips the Gateway's pending state synchronously, so the
        // FIRST poll after a successful POST must report Explaining. If 8s (4 poll
        // cycles) pass unconfirmed, the dive either died upstream or finished between
        // polls - drop the overlay and reload to pick up whatever landed.
        else if (_explainOptimistic && !_explainBusy && !_loading
                 && DateTime.UtcNow - _explainOptimisticAt > TimeSpan.FromSeconds(8))
        {
            _explainOptimistic = false;
            _lastSeenBriefState = BriefingState;
            _lastSeenState = ActivityState;
            SyncTailLoop();
            await LoadAsync();
            return;
        }

        // The deep dive finished (issue #217): the explain report is in the store - reload.
        if (_lastSeenBriefState == "Explaining" && BriefingState != "Explaining" && !_loading)
        {
            _lastSeenBriefState = BriefingState;
            _lastSeenState = ActivityState;
            SyncTailLoop();
            await LoadAsync();
            return;
        }

        // The wingman finished reading: the fresh brief is in the store - reload.
        if (_lastSeenBriefState == "Briefing" && BriefingState is "Briefed" or "Failed" && !_loading)
        {
            _lastSeenBriefState = BriefingState;
            _lastSeenState = ActivityState;
            SyncTailLoop();
            await LoadAsync();
            return;
        }
        _lastSeenBriefState = BriefingState;

        // A turn completed without a briefing transition (old Director / killed pipeline).
        if (_lastSeenState == "Working" && ActivityState != "Working" && !_loading)
        {
            _lastSeenState = ActivityState;
            SyncTailLoop();
            await LoadAsync();
            return;
        }
        _lastSeenState = ActivityState;
        SyncTailLoop();
    }

    private async Task LoadAsync()
    {
        if (string.IsNullOrEmpty(SessionId) || string.IsNullOrEmpty(DirectorBase))
        {
            _error = "This session has no reachable Director endpoint.";
            return;
        }

        _loadCts?.Cancel();
        _loadCts = new CancellationTokenSource(TimeSpan.FromSeconds(30));
        var ct = _loadCts.Token;

        _loading = true;
        _error = null;
        await InvokeAsync(StateHasChanged);
        try
        {
            // Wingman tier and condenser tier load together: the TurnBrief drives the three
            // blocks; /brief supplies YOU ASKED + the full reply markdown for the expander.
            // The GATEWAY is the one brief store (#187 deleted the Director-side pipeline).
            var gatewayBriefTask = Gateway.GetLatestTurnBriefAsync(SessionId, ct);
            var explainTask = Gateway.GetLatestExplainAsync(SessionId, ct);
            var briefTask = Director.GetBriefAsync(DirectorBase, SessionId, ct);
            _turnBrief = await gatewayBriefTask;
            _explain = await explainTask;
            _brief = await briefTask;
            _toggled.Clear();
            _closeArmed = false;   // a fresh brief invalidates any armed close confirm
            _feedbackOpen = false;
            _feedbackReason = "";
            _feedbackId = null;
            _feedbackStatus = null;

            if (_turnBrief is null && _brief is null)
            {
                Log.LogInformation("BriefPane: no turnbrief and no /brief for sid={Sid}, degrading to /summary", SessionId);
                _summary = await Director.GetSummaryAsync(DirectorBase, SessionId, ct);
                if (_summary is null)
                    _error = "This Director does not know the session (or predates the summary endpoint).";
                else if (_summary.Status != "ok")
                    _error = $"Transcript not readable: {_summary.Error ?? _summary.Status}";
            }
            else
            {
                _summary = null;
            }
        }
        catch (OperationCanceledException)
        {
            // superseded by a newer load or circuit teardown; keep what we have.
        }
        catch (Exception ex)
        {
            Log.LogWarning(ex, "BriefPane load failed for sid={Sid}", SessionId);
            _error = $"Brief load failed: {ex.Message}";
        }
        finally
        {
            _loading = false;
            SyncTailLoop();
            await InvokeAsync(StateHasChanged);
        }
    }

    public void Dispose()
    {
        _loadCts?.Cancel();
        _tailCts?.Cancel();
        _feedbackDictateRef?.Dispose();
    }
}
