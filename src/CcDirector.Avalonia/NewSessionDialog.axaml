<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CcDirector.Avalonia.NewSessionDialog"
        Title="New Session"
        Width="900" Height="600"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        Background="#252526">

    <Window.Styles>
        <!-- QuickLaunchCard style -->
        <Style Selector="Button.quickLaunchCard">
            <Setter Property="Width" Value="200" />
            <Setter Property="Height" Value="56" />
            <Setter Property="Margin" Value="0,0,12,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="#2D2D30" />
            <Setter Property="BorderBrush" Value="#3C3C3C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="12,8" />
        </Style>
        <Style Selector="Button.quickLaunchCard:pointerover">
            <Setter Property="Background" Value="#007ACC" />
            <Setter Property="BorderBrush" Value="#007ACC" />
        </Style>

        <!-- Tab header styling -->
        <Style Selector="TabItem">
            <Setter Property="Background" Value="#3C3C3C" />
            <Setter Property="Foreground" Value="#CCCCCC" />
        </Style>
    </Window.Styles>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Tab Control -->
        <TabControl x:Name="MainTabs" Grid.Row="0"
                    Background="#252526"
                    SelectionChanged="MainTabs_SelectionChanged">

            <!-- New Session Tab (first) -->
            <TabItem Header="New Session">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Vertical">
                    <!-- Named sessions (issue #508): a reusable item = repository + agent + name
                         (optionally a colour and extra arguments). The list shows saved items,
                         each launchable in one click; the save row stores the current selection.
                         An item whose saved agent is no longer registered is shown as unavailable
                         and is not launchable. -->
                    <Border x:Name="NamedSessionPanel" Background="#2D2D30"
                            BorderBrush="#3C3C3C" BorderThickness="1" CornerRadius="6"
                            Padding="12,10" Margin="0,0,0,12">
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="Named sessions" Foreground="#AAAAAA"
                                       FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8" />

                            <!-- Empty-state hint when nothing is saved yet -->
                            <TextBlock x:Name="NoNamedSessionsHint"
                                       Text="No named sessions yet. Pick a repository and agent below, type a name, and click Save."
                                       Foreground="#888888" FontSize="12" FontStyle="Italic"
                                       TextWrapping="Wrap" Margin="0,0,0,8"
                                       IsVisible="False" />

                            <!-- Saved items: one row each, with Launch and Delete. -->
                            <ItemsControl x:Name="NamedSessionList" Margin="0,0,0,8">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Colour indicator bar -->
                                            <Border Grid.Column="0" Width="4" Height="16"
                                                    CornerRadius="2" Margin="0,0,8,0"
                                                    VerticalAlignment="Center"
                                                    Background="{Binding ColorBrush}"
                                                    IsVisible="{Binding HasColor}" />

                                            <!-- Name + repository/agent detail -->
                                            <StackPanel Grid.Column="1" Orientation="Vertical"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontWeight="Medium"
                                                           FontSize="13" Foreground="#CCCCCC"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding Detail}" FontSize="11"
                                                           Foreground="#888888"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>

                                            <!-- Launch (disabled + relabelled when the agent is gone) -->
                                            <Button Grid.Column="2" Content="{Binding LaunchLabel}"
                                                    Click="BtnLaunchNamedSession_Click"
                                                    Tag="{Binding Slug}"
                                                    IsEnabled="{Binding IsAvailable}"
                                                    Height="26" Padding="12,0" Margin="8,0,0,0"
                                                    Background="#007ACC" Foreground="White"
                                                    BorderThickness="0" Cursor="Hand"
                                                    ToolTip.Tip="{Binding LaunchTooltip}" />

                                            <!-- Delete -->
                                            <Button Grid.Column="3" Content="X"
                                                    Click="BtnDeleteNamedSession_Click"
                                                    Tag="{Binding Slug}"
                                                    Width="24" Height="26" Margin="6,0,0,0"
                                                    Background="Transparent" Foreground="#CC4444"
                                                    BorderThickness="0" Cursor="Hand"
                                                    FontWeight="Bold"
                                                    ToolTip.Tip="Delete this named session" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Save the current selection (repo + agent + name) as a named session. -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Save as:" Foreground="#CCCCCC"
                                           FontSize="13" VerticalAlignment="Center"
                                           Margin="0,0,12,0" />
                                <TextBox x:Name="NamedSessionNameBox" Grid.Column="1"
                                         Background="#1E1E1E" Foreground="#CCCCCC"
                                         BorderBrush="#3C3C3C" Padding="6,4"
                                         VerticalContentAlignment="Center"
                                         Watermark="Name for this repository + agent"
                                         TextChanged="NamedSessionNameBox_TextChanged"
                                         ToolTip.Tip="Saves the selected repository and agent under this name" />
                                <Button x:Name="BtnSaveNamedSession" Grid.Column="2"
                                        Content="Save" Width="80" Height="28" Margin="8,0,0,0"
                                        Click="BtnSaveNamedSession_Click"
                                        Background="#3C3C3C" Foreground="#CCCCCC"
                                        BorderThickness="0" Cursor="Hand"
                                        ToolTip.Tip="Save the current repository + agent as a named session" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Create-mode toggle (issue #254): "Single session" (the Type dropdown
                         applies) vs "Group" (a preset that creates several tied, typed sessions
                         at once). Exactly one of the Type dropdown / Group panel is shown below,
                         so the dialog reads as one control rather than two competing pickers. -->
                    <StackPanel x:Name="CreateModePanel" Orientation="Horizontal" Margin="0,0,0,12"
                                IsVisible="False">
                        <TextBlock Text="Create:"
                                   Foreground="#CCCCCC" FontSize="14"
                                   VerticalAlignment="Center" Margin="0,0,16,0" />
                        <RadioButton x:Name="ModeRadioSingle" GroupName="CreateMode"
                                     Content="Single session"
                                     IsChecked="True"
                                     Foreground="#CCCCCC" FontSize="14"
                                     VerticalAlignment="Center" Margin="0,0,24,0"
                                     IsCheckedChanged="CreateModeRadio_CheckedChanged"
                                     ToolTip.Tip="One session - pick its type from the dropdown" />
                        <RadioButton x:Name="ModeRadioGroup" GroupName="CreateMode"
                                     Content="Group"
                                     Foreground="#CCCCCC" FontSize="14"
                                     VerticalAlignment="Center"
                                     IsCheckedChanged="CreateModeRadio_CheckedChanged"
                                     ToolTip.Tip="Several tied sessions created together from a preset group" />
                    </StackPanel>

                    <!-- Agent picker (issue #490): one radio per ENABLED agent.entries entry (#489),
                         in stored order, labeled by the entry's display name, first pre-selected.
                         No alpha gating - the agent list is purely what the user configured. The
                         radios are generated at runtime from AgentEntryOptions; an empty list shows
                         the "no agents configured" hint instead. -->
                    <StackPanel x:Name="AgentPickerPanel" Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="Agent:"
                                   Foreground="#CCCCCC" FontSize="14"
                                   VerticalAlignment="Center" Margin="0,0,16,0" />
                        <ItemsControl x:Name="AgentEntryList" VerticalAlignment="Center">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <RadioButton GroupName="Agent"
                                                 Content="{Binding DisplayName}"
                                                 IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                 Foreground="#CCCCCC" FontSize="14"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,24,0"
                                                 IsCheckedChanged="AgentRadio_CheckedChanged" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock x:Name="NoAgentsHint"
                                   Text="No agents configured. Add one in Settings &gt; Agents."
                                   Foreground="#888888" FontSize="13" FontStyle="Italic"
                                   VerticalAlignment="Center"
                                   IsVisible="False" />
                    </StackPanel>

                    <!-- Custom CLI panel (issue #333): shown only when "Custom CLI" agent is selected.
                         Command = executable path or bare command; Args = extra arguments. Both are
                         carried on the session and reported in GET /sessions as the Agent fact. -->
                    <StackPanel x:Name="CustomCliPanel" Orientation="Vertical" Margin="0,0,0,12"
                                IsVisible="False">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Command:"
                                       Foreground="#CCCCCC" FontSize="13"
                                       VerticalAlignment="Center" Margin="0,0,12,0" Width="72" />
                            <TextBox x:Name="CustomCommandBox" Grid.Column="1"
                                     Background="#1E1E1E" Foreground="#CCCCCC"
                                     BorderBrush="#3C3C3C" Padding="6,4"
                                     VerticalContentAlignment="Center"
                                     Watermark="e.g. pwsh  or  C:\Tools\aider.exe"
                                     TextChanged="CustomCommandBox_TextChanged"
                                     ToolTip.Tip="Executable to run: bare command name (resolved via PATH) or absolute path" />
                        </Grid>
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Arguments:"
                                       Foreground="#AAAAAA" FontSize="13"
                                       VerticalAlignment="Center" Margin="0,0,12,0" Width="72" />
                            <TextBox x:Name="CustomArgsBox" Grid.Column="1"
                                     Background="#1E1E1E" Foreground="#CCCCCC"
                                     BorderBrush="#3C3C3C" Padding="6,4"
                                     VerticalContentAlignment="Center"
                                     Watermark="Optional extra arguments"
                                     ToolTip.Tip="Optional arguments appended to the command" />
                        </Grid>
                    </StackPanel>

                    <!-- Session-type dropdown (issue #211, redesigned to a ComboBox in #254):
                         identity chosen at creation, Developer preselected. Each item carries
                         its enum name in Tag; the playbook for non-default types is seeded into
                         the agent at startup. Shown only in Single mode. -->
                    <StackPanel x:Name="TypePickerPanel" Orientation="Horizontal" Margin="0,0,0,12"
                                IsVisible="False">
                        <TextBlock Text="Type:"
                                   Foreground="#CCCCCC" FontSize="14"
                                   VerticalAlignment="Center" Margin="0,0,16,0" />
                        <ComboBox x:Name="TypeCombo" Width="460" SelectedIndex="0"
                                  Background="#1E1E1E" Foreground="#CCCCCC"
                                  BorderBrush="#3C3C3C"
                                  VerticalAlignment="Center"
                                  ToolTip.Tip="What this session is for - drives its playbook">
                            <!-- Primary types (issue #259): Implementation is the default - it builds
                                 AND verifies in one session (the dev<->QA loop). -->
                            <ComboBoxItem Tag="Implementation">
                                <StackPanel Orientation="Horizontal">
                                    <Border BorderBrush="#14B8A6" BorderThickness="1" CornerRadius="6"
                                            Padding="6,0" Margin="0,0,8,0" VerticalAlignment="Center">
                                        <TextBlock Text="I" Foreground="#14B8A6" FontSize="10" FontWeight="SemiBold" />
                                    </Border>
                                    <TextBlock Text="Implementation" FontWeight="SemiBold" Foreground="#CCCCCC" Width="104" />
                                    <TextBlock Text="Build and verify - dev/QA loop in one session (default)" Foreground="#888888" />
                                </StackPanel>
                            </ComboBoxItem>
                            <ComboBoxItem Tag="Product">
                                <StackPanel Orientation="Horizontal">
                                    <Border BorderBrush="#EC4899" BorderThickness="1" CornerRadius="6"
                                            Padding="6,0" Margin="0,0,8,0" VerticalAlignment="Center">
                                        <TextBlock Text="P" Foreground="#EC4899" FontSize="10" FontWeight="SemiBold" />
                                    </Border>
                                    <TextBlock Text="Product" FontWeight="SemiBold" Foreground="#CCCCCC" Width="104" />
                                    <TextBlock Text="Scope the work, file the issue; never codes" Foreground="#888888" />
                                </StackPanel>
                            </ComboBoxItem>
                            <ComboBoxItem Tag="Discuss">
                                <StackPanel Orientation="Horizontal">
                                    <Border BorderBrush="#22D3EE" BorderThickness="1" CornerRadius="6"
                                            Padding="6,0" Margin="0,0,8,0" VerticalAlignment="Center">
                                        <TextBlock Text="D" Foreground="#22D3EE" FontSize="10" FontWeight="SemiBold" />
                                    </Border>
                                    <TextBlock Text="Discuss" FontWeight="SemiBold" Foreground="#CCCCCC" Width="104" />
                                    <TextBlock Text="Talk only; never edits or commits" Foreground="#888888" />
                                </StackPanel>
                            </ComboBoxItem>
                            <!-- Advanced/solo divider (issue #259): the single-role types. Developer
                                 and QA are the halves of Implementation; rarely needed on their own. -->
                            <ComboBoxItem IsEnabled="False">
                                <TextBlock Text="ADVANCED - single role, rarely needed solo"
                                           Foreground="#666666" FontSize="10" FontWeight="SemiBold" />
                            </ComboBoxItem>
                            <ComboBoxItem Tag="Developer">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Developer" FontWeight="SemiBold" Foreground="#CCCCCC" Width="104" Margin="32,0,0,0" />
                                    <TextBlock Text="Pure code, no QA hat" Foreground="#888888" />
                                </StackPanel>
                            </ComboBoxItem>
                            <ComboBoxItem Tag="QA">
                                <StackPanel Orientation="Horizontal">
                                    <Border BorderBrush="#A855F7" BorderThickness="1" CornerRadius="6"
                                            Padding="6,0" Margin="0,0,8,0" VerticalAlignment="Center">
                                        <TextBlock Text="Q" Foreground="#A855F7" FontSize="10" FontWeight="SemiBold" />
                                    </Border>
                                    <TextBlock Text="QA" FontWeight="SemiBold" Foreground="#CCCCCC" Width="104" />
                                    <TextBlock Text="Pure verify, never fixes" Foreground="#888888" />
                                </StackPanel>
                            </ComboBoxItem>
                            <ComboBoxItem Tag="Support">
                                <StackPanel Orientation="Horizontal">
                                    <Border BorderBrush="#10B981" BorderThickness="1" CornerRadius="6"
                                            Padding="6,0" Margin="0,0,8,0" VerticalAlignment="Center">
                                        <TextBlock Text="S" Foreground="#10B981" FontSize="10" FontWeight="SemiBold" />
                                    </Border>
                                    <TextBlock Text="Support" FontWeight="SemiBold" Foreground="#CCCCCC" Width="104" />
                                    <TextBlock Text="Triage incoming requests, file issues" Foreground="#888888" />
                                </StackPanel>
                            </ComboBoxItem>
                        </ComboBox>
                    </StackPanel>

                    <!-- Group dropdown + preview card (issue #254): shown only in Group mode.
                         The dropdown lists the built-in group definitions (only "Product"
                         today); the card previews exactly which member sessions get created. -->
                    <StackPanel x:Name="GroupPickerPanel" Orientation="Vertical" Margin="0,0,0,12"
                                IsVisible="False">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Group:"
                                       Foreground="#CCCCCC" FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,16,0" />
                            <ComboBox x:Name="GroupCombo" Width="240"
                                      Background="#1E1E1E" Foreground="#CCCCCC"
                                      BorderBrush="#3C3C3C"
                                      VerticalAlignment="Center"
                                      SelectionChanged="GroupCombo_SelectionChanged"
                                      ToolTip.Tip="A preset that creates several tied sessions at once">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" Foreground="#CCCCCC" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <Border Background="#2D2D30" BorderBrush="#3C3C3C" BorderThickness="1"
                                CornerRadius="6" Padding="12,10">
                            <StackPanel>
                                <TextBlock Text="This group creates:" Foreground="#AAAAAA"
                                           FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8" />
                                <ItemsControl x:Name="GroupPreviewList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                                <Border BorderBrush="{Binding BadgeBrush}" BorderThickness="1"
                                                        CornerRadius="6" Padding="6,0" Margin="0,0,8,0"
                                                        VerticalAlignment="Center" Width="96">
                                                    <TextBlock Text="{Binding TypeBadge}"
                                                               Foreground="{Binding BadgeBrush}"
                                                               FontSize="10" FontWeight="SemiBold" />
                                                </Border>
                                                <TextBlock Text="{Binding RoleLabel}" Foreground="#CCCCCC"
                                                           FontSize="12" VerticalAlignment="Center" Width="90" />
                                                <TextBlock Text="{Binding NameSuffix}" Foreground="#888888"
                                                           FontSize="11" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    </StackPanel>

                    <TextBlock Grid.Row="1" Text="Select a repository:"
                               Foreground="#CCCCCC" FontSize="14" Margin="0,0,0,8" />

                    <TextBox x:Name="RepoSearchBox" Grid.Row="2"
                             Background="#1E1E1E" Foreground="#CCCCCC"
                             BorderBrush="#3C3C3C" Padding="8"
                             TextChanged="RepoSearchBox_TextChanged"
                             ToolTip.Tip="Filter repositories by name or path" />

                    <!-- Column headers -->
                    <Border Grid.Row="3" Background="#2D2D30" Margin="0,8,0,0"
                            BorderBrush="#3C3C3C" BorderThickness="1,1,1,0"
                            Padding="4,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="30" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="RepoHeaderName" Grid.Column="0"
                                    Content="Name" Click="RepoHeader_Click" Tag="Name"
                                    Background="Transparent" Foreground="#AAAAAA"
                                    BorderThickness="0" Padding="8,6" Cursor="Hand"
                                    FontSize="11" FontWeight="SemiBold"
                                    HorizontalContentAlignment="Left" />
                            <Button x:Name="RepoHeaderPath" Grid.Column="1"
                                    Content="Path" Click="RepoHeader_Click" Tag="Path"
                                    Background="Transparent" Foreground="#AAAAAA"
                                    BorderThickness="0" Padding="8,6" Cursor="Hand"
                                    FontSize="11" FontWeight="SemiBold"
                                    HorizontalContentAlignment="Left" />
                            <Button x:Name="RepoHeaderLastUsed" Grid.Column="2"
                                    Content="Last Used  v" Click="RepoHeader_Click" Tag="LastUsed"
                                    Background="Transparent" Foreground="#CCCCCC"
                                    BorderThickness="0" Padding="8,6" Cursor="Hand"
                                    FontSize="11" FontWeight="SemiBold"
                                    HorizontalContentAlignment="Left" />
                        </Grid>
                    </Border>

                    <!-- Repository list with columns -->
                    <ListBox x:Name="RepoList" Grid.Row="4"
                             Background="#1E1E1E" Foreground="#CCCCCC"
                             BorderBrush="#3C3C3C"
                             SelectionChanged="RepoList_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="30" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Name}"
                                               FontWeight="Medium" Padding="8,4"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="1" Text="{Binding Path}"
                                               FontSize="11" Opacity="0.7" Padding="8,5"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="2" Text="{Binding LastUsedDisplay}"
                                               FontSize="11" Foreground="#888888" Padding="8,5" />
                                    <Button Grid.Column="3" Content="X"
                                            Click="BtnRemoveRepo_Click"
                                            Tag="{Binding Path}"
                                            Width="24" Height="24"
                                            Background="Transparent"
                                            Foreground="#CC4444"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            FontWeight="Bold"
                                            VerticalAlignment="Center"
                                            ToolTip.Tip="Remove from list" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Grid Grid.Row="5" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="PathInput" Grid.Column="0"
                                 Background="#1E1E1E" Foreground="#CCCCCC"
                                 BorderBrush="#3C3C3C" Padding="8"
                                 VerticalContentAlignment="Center" />
                        <Button Grid.Column="1" Content="Browse..."
                                Click="BtnBrowse_Click"
                                Width="80" Margin="8,0,0,0"
                                Background="#3C3C3C" Foreground="#CCCCCC"
                                BorderThickness="0" Cursor="Hand" />
                    </Grid>

                    <CheckBox x:Name="BypassPermissionsCheckBox" Grid.Row="6"
                              Content="Bypass permission prompts"
                              IsChecked="True"
                              Foreground="#CCCCCC"
                              Margin="0,12,0,0"
                              ToolTip.Tip="When checked, Claude Code will not prompt for permission to execute tools" />

                    <CheckBox x:Name="WingmanCheckBox" Grid.Row="7"
                              IsVisible="False"
                              Content="Wingman (auto-explain on turn-end + Voice tabs)"
                              IsChecked="False"
                              HorizontalAlignment="Right"
                              Foreground="#CCCCCC"
                              Margin="0,8,0,0"
                              ToolTip.Tip="When checked, the session auto-runs the Wingman briefing on every turn-end and shows Voice/Wingman tabs. Uncheck for a plain terminal-only session." />

                    <!-- Quick-launch cards (alpha feature - hidden unless alpha mode is on) -->
                    <StackPanel x:Name="QuickLaunchPanel" Grid.Row="8" Orientation="Horizontal" Margin="0,16,0,0">
                        <!-- Assistant card -->
                        <Button Tag="assistant" Classes="quickLaunchCard"
                                Click="BtnCoaching_Click"
                                ToolTip.Tip="Tasks, contacts, daily briefing">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Assistant" FontSize="14" FontWeight="SemiBold"
                                               Foreground="#CCCCCC" />
                                    <TextBlock Text="Tasks, contacts, daily briefing" FontSize="11"
                                               Foreground="#888888" />
                                </StackPanel>
                            </Grid>
                        </Button>

                        <!-- Coach card -->
                        <Button Tag="coach" Classes="quickLaunchCard"
                                Click="BtnCoaching_Click"
                                ToolTip.Tip="Life coaching across all domains">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Coach" FontSize="14" FontWeight="SemiBold"
                                               Foreground="#CCCCCC" />
                                    <TextBlock Text="Life coaching across all domains" FontSize="11"
                                               Foreground="#888888" />
                                </StackPanel>
                            </Grid>
                        </Button>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Resume Session Tab (second) -->
            <TabItem Header="Resume Session">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Resume a previous session:"
                               Foreground="#CCCCCC" FontSize="14" Margin="0,0,0,8" />

                    <TextBox x:Name="SessionSearchBox" Grid.Row="1"
                             Background="#1E1E1E" Foreground="#CCCCCC"
                             BorderBrush="#3C3C3C" Padding="8"
                             TextChanged="SessionSearchBox_TextChanged"
                             ToolTip.Tip="Filter sessions by project name or path" />

                    <Grid Grid.Row="2" Margin="0,8,0,0">
                        <!-- Loading indicator -->
                        <TextBlock x:Name="LoadingText" Text="Loading sessions..."
                                   Foreground="#888888" FontStyle="Italic"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />

                        <!-- No sessions message -->
                        <TextBlock x:Name="NoSessionsText" Text="No Claude Code sessions found"
                                   Foreground="#888888" FontStyle="Italic"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   IsVisible="False" />

                        <!-- Session list -->
                        <ListBox x:Name="SessionList"
                                 Background="#1E1E1E" Foreground="#CCCCCC"
                                 BorderBrush="#3C3C3C"
                                 IsVisible="False"
                                 SelectionChanged="SessionList_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="4,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <!-- Row 0: Display name + color indicator -->
                                        <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
                                            <!-- Color indicator bar -->
                                            <Border Width="4" Height="16" CornerRadius="2" Margin="0,0,8,0"
                                                    Background="{Binding CustomColorBrush}"
                                                    IsVisible="{Binding HasCustomColor}" />
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="13" />
                                            <!-- Repo name in parentheses when custom name is set -->
                                            <TextBlock Text="{Binding ProjectNameSuffix}" FontSize="11"
                                                       Foreground="#888888" Margin="6,0,0,0" VerticalAlignment="Center"
                                                       IsVisible="{Binding HasCustomName}" />
                                        </StackPanel>

                                        <!-- Message count and time -->
                                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                                            <TextBlock Text="{Binding MessageCountDisplay}"
                                                       Foreground="#888888" FontSize="11" Margin="0,0,8,0" />
                                            <TextBlock Text="{Binding TimeAgo}"
                                                       Foreground="#888888" FontSize="11" />
                                        </StackPanel>

                                        <!-- Row 1: Summary -->
                                        <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                                   Text="{Binding DisplaySummary}"
                                                   Foreground="#22C55E" FontSize="11"
                                                   TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Handovers Tab (third; alpha feature - hidden unless alpha mode is on).
                 Hiding the TabItem keeps it in Items, so the hardcoded tab indexes
                 (0/1/2/GitHubTabIndex) stay valid either way. -->
            <TabItem x:Name="HandoversTab" Header="Handovers">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Session handover documents:"
                               Foreground="#CCCCCC" FontSize="14" Margin="0,0,0,8" />

                    <TextBox x:Name="HandoverSearchBox" Grid.Row="1"
                             Background="#1E1E1E" Foreground="#CCCCCC"
                             BorderBrush="#3C3C3C" Padding="8"
                             TextChanged="HandoverSearchBox_TextChanged"
                             ToolTip.Tip="Filter handovers by title, session name, repo, or date" />

                    <Grid Grid.Row="2" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Left: handover list -->
                        <Grid Grid.Column="0">
                            <TextBlock x:Name="HandoverLoadingText" Text="Loading handovers..."
                                       Foreground="#888888" FontStyle="Italic"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />

                            <TextBlock x:Name="NoHandoversText"
                                       Text="No handovers found. Use /handover in a session to create one."
                                       Foreground="#888888" FontStyle="Italic"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       TextWrapping="Wrap" Margin="12"
                                       IsVisible="False" />

                            <ListBox x:Name="HandoverList"
                                     Background="#1E1E1E" Foreground="#CCCCCC"
                                     BorderBrush="#3C3C3C"
                                     IsVisible="False"
                                     SelectionChanged="HandoverList_SelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="4,6">
                                            <TextBlock Text="{Binding Title}" FontWeight="Medium" FontSize="13" />
                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                <TextBlock Text="{Binding RepoDisplay}" Foreground="#AAAAAA" FontSize="10" />
                                                <TextBlock Text="  " />
                                                <TextBlock Text="{Binding DateDisplay}" Foreground="#888888" FontSize="10" />
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>

                        <!-- Right: preview -->
                        <Grid Grid.Column="1" Margin="8,0,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="#2D2D30" Padding="12,8"
                                    BorderBrush="#3C3C3C" BorderThickness="1,1,1,0">
                                <StackPanel>
                                    <TextBlock x:Name="HandoverRepoPath"
                                               Foreground="#888888" FontSize="10"
                                               Text="No handover selected" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Background="#1E1E1E" BorderBrush="#3C3C3C"
                                    BorderThickness="1">
                                <Grid>
                                    <TextBlock x:Name="HandoverPlaceholder"
                                               Text="Select a handover to preview"
                                               Foreground="#555555" FontStyle="Italic"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />

                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <TextBox x:Name="HandoverPreview"
                                                 Background="Transparent" Foreground="#CCCCCC"
                                                 BorderThickness="0" IsReadOnly="True"
                                                 TextWrapping="Wrap" Padding="12"
                                                 FontFamily="Cascadia Mono, Consolas, Courier New"
                                                 FontSize="12"
                                                 IsVisible="False" />
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- GitHub (Remote) Tab (fourth; alpha feature - hidden unless alpha mode is on) -->
            <TabItem x:Name="GitHubTab" Header="GitHub (Remote)">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12" Spacing="10">
                        <TextBlock Text="Run this task on a GitHub-hosted runner"
                                   Foreground="#CCCCCC" FontSize="15" FontWeight="SemiBold" />
                        <TextBlock TextWrapping="Wrap" Foreground="#888888" FontSize="12"
                                   Text="The work runs on GitHub's compute, not this machine. CC Director opens an issue (or attaches to one), drives it with @claude comments, and streams the run into this session window. Requires the Claude GitHub App and an @claude workflow on the target repo." />

                        <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto" Margin="0,4,0,0">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Owner / org"
                                       Foreground="#CCCCCC" VerticalAlignment="Center" />
                            <TextBox x:Name="GhOwnerBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8"
                                     Background="#1E1E1E" Foreground="#CCCCCC" BorderBrush="#3C3C3C" Padding="8"
                                     Watermark="thefrederiksen" TextChanged="GhField_Changed" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Repository"
                                       Foreground="#CCCCCC" VerticalAlignment="Center" />
                            <TextBox x:Name="GhRepoBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8"
                                     Background="#1E1E1E" Foreground="#CCCCCC" BorderBrush="#3C3C3C" Padding="8"
                                     Watermark="cc-director" TextChanged="GhField_Changed" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Base branch"
                                       Foreground="#CCCCCC" VerticalAlignment="Center" />
                            <TextBox x:Name="GhBranchBox" Grid.Row="2" Grid.Column="1"
                                     Background="#1E1E1E" Foreground="#CCCCCC" BorderBrush="#3C3C3C" Padding="8"
                                     Text="main" TextChanged="GhField_Changed" />
                        </Grid>

                        <StackPanel Orientation="Horizontal" Spacing="20" Margin="0,4,0,0">
                            <TextBlock Text="Thread:" Foreground="#CCCCCC" VerticalAlignment="Center" />
                            <RadioButton x:Name="GhModeNewIssue" GroupName="GhMode" Content="Create new issue"
                                         IsChecked="True" Foreground="#CCCCCC"
                                         IsCheckedChanged="GhMode_Changed" />
                            <RadioButton x:Name="GhModeExisting" GroupName="GhMode" Content="Existing issue/PR #"
                                         Foreground="#CCCCCC" IsCheckedChanged="GhMode_Changed" />
                            <TextBox x:Name="GhThreadBox" Width="90" IsEnabled="False"
                                     Background="#1E1E1E" Foreground="#CCCCCC" BorderBrush="#3C3C3C" Padding="6"
                                     Watermark="123" TextChanged="GhField_Changed" />
                        </StackPanel>

                        <TextBlock Text="First task for @claude" Foreground="#CCCCCC" Margin="0,4,0,0" />
                        <TextBox x:Name="GhPromptBox"
                                 Background="#1E1E1E" Foreground="#CCCCCC" BorderBrush="#3C3C3C" Padding="8"
                                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="120"
                                 Watermark="Describe the task. e.g. 'Add a --json flag to the export command and update the README.'"
                                 TextChanged="GhField_Changed" />

                        <TextBlock x:Name="GhHintText" TextWrapping="Wrap" Foreground="#888888" FontSize="11"
                                   Text="Token: reads GITHUB_TOKEN from credentials.env at launch (needs repo, actions, issues scopes)." />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Bottom buttons -->
        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Left: Copy to Clipboard (handovers tab only) -->
            <Button x:Name="BtnCopyHandover" Grid.Column="0"
                    Content="Copy to Clipboard" Width="130"
                    Click="BtnCopyHandover_Click"
                    Background="#3C3C3C" Foreground="#CCCCCC"
                    BorderThickness="0" Cursor="Hand"
                    IsVisible="False"
                    ToolTip.Tip="Copy handover content to clipboard" />

            <!-- Right: Action + Cancel -->
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button x:Name="BtnAction" Content="Resume Selected" Width="120"
                        Click="BtnAction_Click"
                        BorderThickness="0" Margin="0,0,8,0"
                        IsEnabled="False"
                        Background="#4A4A4A" Foreground="#AAAAAA"
                        Cursor="Hand" />
                <Button Content="Cancel" Width="80"
                        Click="BtnCancel_Click"
                        Background="#3C3C3C" Foreground="#CCCCCC"
                        BorderThickness="0" Cursor="Hand" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
