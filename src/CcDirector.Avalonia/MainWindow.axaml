<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:terminal="clr-namespace:CcDirector.Terminal.Avalonia;assembly=CcDirector.Terminal.Avalonia"
        xmlns:controls="clr-namespace:CcDirector.Avalonia.Controls"
        xmlns:commMgr="clr-namespace:CcDirector.Avalonia.Controls.CommManager"
        xmlns:mgr="clr-namespace:CcDirector.Avalonia.Controls.ManagerView"
        x:Class="CcDirector.Avalonia.MainWindow"
        Title="CC Director"
        Width="1400" Height="900"
        MinWidth="800" MinHeight="500"
        Background="{DynamicResource PanelBackground}"
        Icon="avares://cc-director/app.ico">

    <Grid ColumnDefinitions="264,Auto,*" RowDefinitions="Auto,*">

        <!-- ==================== SIDEBAR (spans both rows) ==================== -->
        <Border Grid.Column="0" Grid.RowSpan="2"
                Background="{DynamicResource SidebarBackground}"
                BorderBrush="#3C3C3C" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Sidebar header: hamburger + title -->
                <Border DockPanel.Dock="Top" Padding="8,6">
                    <DockPanel>
                        <Button x:Name="BtnAppMenu"
                                Content="="
                                Width="28" Height="28"
                                Background="Transparent"
                                Foreground="{DynamicResource TextForeground}"
                                FontSize="14" FontWeight="Bold"
                                Padding="0"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Click="BtnAppMenu_Click"
                                ToolTip.Tip="Application menu" />
                        <TextBlock Text="SESSIONS"
                                   Foreground="{DynamicResource TextForeground}"
                                   FontSize="12" FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0" />
                    </DockPanel>
                </Border>

                <!-- + New Session button -->
                <Button x:Name="BtnNewSession"
                        DockPanel.Dock="Top"
                        Content="+ New Session"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="White"
                        FontSize="13"
                        Height="32"
                        Margin="8,4,8,8"
                        HorizontalContentAlignment="Center"
                        Click="BtnNewSession_Click"
                        ToolTip.Tip="Create a new session" />

                <!-- Connections button above comms -->
                <Grid DockPanel.Dock="Bottom" Margin="8,2,8,2">
                    <Button x:Name="BtnConnections"
                            Content="Connections"
                            Click="BtnConnections_Click"
                            Background="#2D5A7D"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Height="30"
                            FontSize="13"
                            HorizontalContentAlignment="Center"
                            ToolTip.Tip="Browser Connections" />
                </Grid>

                <!-- Comms button above build info -->
                <Grid DockPanel.Dock="Bottom" Margin="8,2,8,2">
                    <Button x:Name="BtnComms"
                            Content="Communications"
                            Click="BtnComms_Click"
                            Background="#2D7D46"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Height="30"
                            FontSize="13"
                            HorizontalContentAlignment="Center"
                            ToolTip.Tip="Communication Manager" />
                    <!-- Pending count badge overlaid on button -->
                    <Border x:Name="CommsBadge"
                            Background="#DC2626"
                            CornerRadius="8"
                            Padding="5,1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0"
                            IsHitTestVisible="False"
                            IsVisible="False">
                        <TextBlock x:Name="CommsBadgeText"
                                   Text="0"
                                   Foreground="White"
                                   FontSize="10"
                                   FontWeight="SemiBold" />
                    </Border>
                </Grid>

                <!-- Build info + Claude config gear at bottom -->
                <Border DockPanel.Dock="Bottom" Padding="8,4">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock x:Name="BuildInfoText"
                                   Text="Build: --"
                                   Foreground="#555555"
                                   FontSize="10"
                                   VerticalAlignment="Center" />
                        <Button x:Name="BtnClaudeConfig"
                                Click="BtnClaudeConfig_Click"
                                ToolTip.Tip="Claude Code Settings"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                Padding="4,2"
                                Margin="6,0,0,0"
                                VerticalAlignment="Center">
                            <PathIcon Data="M19.14,12.94c0.04,-0.3 0.06,-0.61 0.06,-0.94c0,-0.32 -0.02,-0.64 -0.07,-0.94l2.03,-1.58c0.18,-0.14 0.23,-0.41 0.12,-0.61l-1.92,-3.32c-0.12,-0.22 -0.37,-0.29 -0.59,-0.22l-2.39,0.96c-0.5,-0.38 -1.03,-0.7 -1.62,-0.94L14.4,2.81c-0.04,-0.24 -0.24,-0.41 -0.48,-0.41h-3.84c-0.24,0 -0.43,0.17 -0.47,0.41L9.25,5.35C8.66,5.59 8.12,5.92 7.63,6.29L5.24,5.33c-0.22,-0.08 -0.47,0 -0.59,0.22L2.74,8.87C2.62,9.08 2.66,9.34 2.86,9.48l2.03,1.58C4.84,11.36 4.8,11.69 4.8,12s0.02,0.64 0.07,0.94l-2.03,1.58c-0.18,0.14 -0.23,0.41 -0.12,0.61l1.92,3.32c0.12,0.22 0.37,0.29 0.59,0.22l2.39,-0.96c0.5,0.38 1.03,0.7 1.62,0.94l0.36,2.54c0.05,0.24 0.24,0.41 0.48,0.41h3.84c0.24,0 0.44,-0.17 0.47,-0.41l0.36,-2.54c0.59,-0.24 1.13,-0.56 1.62,-0.94l2.39,0.96c0.22,0.08 0.47,0 0.59,-0.22l1.92,-3.32c0.12,-0.22 0.07,-0.47 -0.12,-0.61L19.14,12.94z M12,15.6c-1.98,0 -3.6,-1.62 -3.6,-3.6s1.62,-3.6 3.6,-3.6s3.6,1.62 3.6,3.6S13.98,15.6 12,15.6z"
                                       Foreground="#555555" Width="12" Height="12" />
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Session list -->
                <ListBox x:Name="SessionList"
                         Background="Transparent"
                         Padding="4"
                         SelectionChanged="SessionList_SelectionChanged"
                         DragDrop.AllowDrop="True">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                        <Style Selector="Button.sessionMenuBtn:pointerover /template/ ContentPresenter">
                            <Setter Property="Foreground" Value="#CCCCCC" />
                            <Setter Property="Background" Value="Transparent" />
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,1">
                                <Grid ColumnDefinitions="*,Auto" Margin="8,6">
                                    <!-- Session content -->
                                    <StackPanel Grid.Column="0">
                                        <StackPanel Orientation="Horizontal">
                                            <!-- Live supervisor status indicator. Reads
                                                 Session.StatusColor (written by the
                                                 SessionStatusSupervisor) so the same
                                                 session shows the same color on Desktop
                                                 and Gateway. Doubles as the drag handle
                                                 for reordering the session list. -->
                                            <Border Width="14" Height="14"
                                                    CornerRadius="3"
                                                    Background="{Binding StatusColorBrush}"
                                                    ToolTip.Tip="{Binding StatusReason}"
                                                    Margin="0,0,6,0"
                                                    VerticalAlignment="Center"
                                                    Cursor="SizeAll"
                                                    PointerPressed="ColorSquare_PointerPressed" />
                                            <TextBlock Text="{Binding DisplayName}"
                                                       Foreground="{DynamicResource TextForeground}"
                                                       FontSize="13"
                                                       FontWeight="Medium"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <!-- Agent badge: shows which CLI this session is running -->
                                            <Border Background="{Binding AgentBadgeBrush}"
                                                    CornerRadius="6"
                                                    Padding="6,1"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,6,0"
                                                    ToolTip.Tip="Agent running in this session">
                                                <TextBlock Text="{Binding AgentLabel}"
                                                           Foreground="White"
                                                           FontSize="9"
                                                           FontWeight="SemiBold" />
                                            </Border>
                                            <TextBlock Text="{Binding ActivityLabel}"
                                                       Foreground="#888888"
                                                       FontSize="11"
                                                       VerticalAlignment="Center" />
                                            <Border IsVisible="{Binding HasUncommittedChanges}"
                                                    Background="#6B4C00"
                                                    CornerRadius="6"
                                                    Padding="4,0"
                                                    Margin="6,0,0,0"
                                                    VerticalAlignment="Center">
                                                <TextBlock Foreground="#F5D060" FontSize="9"
                                                           FontWeight="SemiBold">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="{}{0} chg">
                                                            <Binding Path="UncommittedCount" />
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                    <!-- Queue count badge + Three-dot menu -->
                                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                VerticalAlignment="Top">
                                        <!-- Queue count badge -->
                                        <Border IsVisible="{Binding HasQueuedItems}"
                                                Background="#EF4444"
                                                CornerRadius="9"
                                                MinWidth="18" Height="18"
                                                Padding="5,0"
                                                Margin="0,0,2,0"
                                                VerticalAlignment="Center"
                                                ToolTip.Tip="Queued prompts">
                                            <TextBlock Text="{Binding QueueCount}"
                                                       Foreground="White"
                                                       FontSize="11"
                                                       FontWeight="Bold"
                                                       TextAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                        <Button Content="..."
                                                Click="SessionMenuButton_Click"
                                                Focusable="False"
                                                VerticalAlignment="Center"
                                                Padding="6,2"
                                                Margin="0"
                                                MinWidth="24"
                                                Background="Transparent"
                                                Foreground="#AAAAAA"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                FontWeight="Bold"
                                                FontSize="12"
                                                ToolTip.Tip="Session options"
                                                Classes="sessionMenuBtn" />
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Grid splitter -->
        <GridSplitter Grid.Column="1" Grid.RowSpan="2"
                      Width="3"
                      Background="#3C3C3C"
                      ResizeDirection="Columns" />

        <!-- ==================== TOP APP BAR ==================== -->
        <Border Grid.Row="0" Grid.Column="2"
                Background="{DynamicResource SidebarBackground}"
                BorderBrush="#3C3C3C" BorderThickness="0,0,0,1"
                MinHeight="36"
                ZIndex="0">
            <DockPanel Margin="12,6">
                <!-- Right side: app bar buttons -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button x:Name="BtnClaudeView"
                            Click="BtnClaudeView_Click"
                            ToolTip.Tip="Claude View - Browse Claude config files"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Padding="6,4" Margin="4,0,0,0">
                        <TextBlock Text="Claude" Foreground="#888888"
                                   FontSize="11" FontWeight="SemiBold" />
                    </Button>
                    <Button x:Name="BtnMcpServers"
                            Click="BtnMcpServers_Click"
                            ToolTip.Tip="MCP Servers"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Padding="6,4" Margin="4,0,0,0">
                        <TextBlock Text="MCP" Foreground="#888888"
                                   FontSize="11" FontWeight="SemiBold" />
                    </Button>
                    <Button x:Name="BtnAgentTemplates"
                            Click="BtnAgentTemplates_Click"
                            ToolTip.Tip="Agent Templates"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Padding="6,4" Margin="4,0,0,0">
                        <TextBlock Text="Agents" Foreground="#888888"
                                   FontSize="11" FontWeight="SemiBold" />
                    </Button>
                    <Button x:Name="BtnSettings"
                            Click="BtnSettings_Click"
                            ToolTip.Tip="Settings"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Padding="6,4" Margin="4,0,0,0">
                        <TextBlock Text="Settings" Foreground="#888888"
                                   FontSize="11" FontWeight="SemiBold" />
                    </Button>
                    <Button x:Name="BtnHelp"
                            Click="BtnHelp_Click"
                            ToolTip.Tip="About CC Director"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Padding="6,4" Margin="4,0,0,0">
                        <TextBlock Text="?" Foreground="#888888"
                                   FontSize="14" FontWeight="Bold" />
                    </Button>
                </StackPanel>

                <!-- Left side: spacer -->
                <Panel />
            </DockPanel>
        </Border>

        <!-- ==================== SESSION HEADER BANNER ==================== -->
        <Border x:Name="SessionHeaderBanner"
                Grid.Row="0" Grid.Column="2"
                ZIndex="1"
                Background="#007ACC"
                Padding="12,6"
                IsVisible="False">
            <Grid RowDefinitions="Auto,Auto">
                <!-- Row 0: Session name + badges + buttons -->
                <DockPanel Grid.Row="0">
                    <!-- Right-aligned buttons -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                VerticalAlignment="Center" Spacing="4">
                        <!-- Activity label -->
                        <TextBlock x:Name="HeaderActivityLabel"
                                   Text=""
                                   Foreground="#FFFFFFCC"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />
                        <!-- Open this session's web view in the default browser.
                             Builds http://127.0.0.1:{ControlApi port}/sessions/{sid}/view
                             at click time and shells out via Process.Start. -->
                        <Button x:Name="BtnOpenInBrowser"
                                Content="Open in browser"
                                Click="BtnOpenInBrowser_Click"
                                Background="Transparent"
                                Foreground="White"
                                BorderThickness="0"
                                Cursor="Hand"
                                Padding="6,4"
                                FontSize="11"
                                ToolTip.Tip="Open this session's web view in your default browser" />
                        <!-- Refresh terminal button -->
                        <Button x:Name="BtnRefreshTerminal"
                                Content="Refresh"
                                Click="BtnRefreshTerminal_Click"
                                Background="Transparent"
                                Foreground="White"
                                BorderThickness="0"
                                Cursor="Hand"
                                Padding="6,4"
                                FontSize="11"
                                ToolTip.Tip="Refresh terminal display" />
                    </StackPanel>

                    <!-- Session name -->
                    <TextBlock x:Name="HeaderSessionName"
                               Text=""
                               Foreground="White"
                               FontSize="16" FontWeight="Bold"
                               VerticalAlignment="Center" />
                    <!-- Message count badge -->
                    <Border x:Name="HeaderMessageCountBadge"
                            Background="#1E40AF"
                            CornerRadius="4"
                            Padding="8,3"
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            IsVisible="False">
                        <TextBlock x:Name="HeaderMessageCountText"
                                   Text="0 msgs"
                                   Foreground="White"
                                   FontSize="11"
                                   FontWeight="SemiBold" />
                    </Border>
                </DockPanel>

                <!-- Row 1: Session ID + Director ID -->
                <StackPanel x:Name="HeaderSessionIdPanel" Grid.Row="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,4,0,0"
                            IsVisible="False">
                    <TextBlock Text="Claude ID:"
                               Foreground="#87CEFA"
                               FontSize="10"
                               VerticalAlignment="Center" />
                    <TextBlock x:Name="HeaderSessionId"
                               Text="Not linked"
                               Foreground="#E0E0E0"
                               FontSize="10"
                               FontFamily="Cascadia Mono,Consolas,monospace"
                               Margin="4,0,0,0"
                               VerticalAlignment="Center" />
                    <!-- Verification badge -->
                    <Border x:Name="HeaderVerificationBadge"
                            CornerRadius="2"
                            Padding="4,1"
                            Margin="6,0,0,0"
                            VerticalAlignment="Center"
                            IsVisible="False">
                        <TextBlock x:Name="HeaderVerificationText"
                                   Text="OK"
                                   FontSize="9"
                                   FontWeight="SemiBold"
                                   Foreground="White" />
                    </Border>
                    <!-- Re-link button -->
                    <Button x:Name="BtnRelink"
                            Content="Re-link"
                            Click="BtnRelink_Click"
                            IsVisible="False"
                            Margin="6,0,0,0"
                            Padding="6,2"
                            FontSize="10"
                            Background="#005A9E"
                            Foreground="#E0E0E0"
                            BorderThickness="0"
                            Cursor="Hand" />
                    <TextBlock Text="|"
                               Foreground="#4A5568"
                               FontSize="10"
                               Margin="12,0"
                               VerticalAlignment="Center" />
                    <TextBlock Text="Director ID:"
                               Foreground="#87CEFA"
                               FontSize="10"
                               VerticalAlignment="Center" />
                    <TextBlock x:Name="HeaderDirectorId"
                               Foreground="#E0E0E0"
                               FontSize="10"
                               FontFamily="Cascadia Mono,Consolas,monospace"
                               Margin="4,0,0,0"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ==================== MAIN CONTENT + RIGHT PANEL ==================== -->
        <Grid Grid.Row="1" Grid.Column="2" ColumnDefinitions="*,Auto,Auto">

            <!-- Left: Terminal + Prompt -->
            <Grid Grid.Column="0" RowDefinitions="Auto,*,Auto,Auto">

                <!-- Left tab bar -->
                <Border Grid.Row="0"
                        Background="{DynamicResource SidebarBackground}"
                        Padding="8,0"
                        Height="36">
                    <DockPanel>
                        <!-- Right-aligned capture + refresh buttons -->
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                    VerticalAlignment="Center" Spacing="2">
                            <Button x:Name="TabBarCaptureButton"
                                    Content="Capture"
                                    Click="TabBarCaptureButton_Click"
                                    Background="Transparent"
                                    Foreground="#888888"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Padding="8,4"
                                    FontSize="11"
                                    ToolTip.Tip="Capture terminal diagnostic snapshot (Ctrl+Shift+F12)"
                                    IsVisible="False" />
                            <Button x:Name="TabBarRefreshButton"
                                    Content="Reset View"
                                    Click="TabBarRefreshButton_Click"
                                    Background="Transparent"
                                    Foreground="#888888"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Padding="8,4"
                                    FontSize="11"
                                    ToolTip.Tip="Rebuild terminal and scrollbar from PTY buffer"
                                    IsVisible="False" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Spacing="2">
                            <Button x:Name="TerminalTabButton"
                                    Content="Terminal"
                                    Background="{DynamicResource AccentBrush}"
                                    Foreground="White"
                                    Padding="12,4"
                                    FontSize="12"
                                    Click="TerminalTabButton_Click" />
                            <Button x:Name="SourceControlTabButton"
                                    Content="Source Control"
                                    Background="Transparent"
                                    Foreground="#888888"
                                    Padding="12,4"
                                    FontSize="12"
                                    Click="SourceControlTabButton_Click" />
                            <Button x:Name="SessionTabButton"
                                    Content="Session"
                                    Background="Transparent"
                                    Foreground="#888888"
                                    Padding="12,4"
                                    FontSize="12"
                                    Click="SessionTabButton_Click" />
                            <Button x:Name="AgentTabButton"
                                    Content="Agent (legacy)"
                                    Background="Transparent"
                                    Foreground="#888888"
                                    Padding="12,4"
                                    FontSize="12"
                                    Click="AgentTabButton_Click" />
                            <!-- Separator between fixed tabs and document tabs -->
                            <Border x:Name="DocTabSeparator"
                                    Width="1" Height="16"
                                    Background="#3C3C3C"
                                    Margin="4,0"
                                    IsVisible="False" />

                            <!-- Dynamic document tab buttons inserted here -->
                            <ItemsControl x:Name="DocumentTabBar"
                                          IsVisible="False">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="2" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>

                            <!-- Close All document tabs button -->
                            <Button x:Name="CloseAllDocsButton"
                                    Content="x"
                                    Background="Transparent"
                                    Foreground="#666666"
                                    Padding="6,4"
                                    FontSize="10"
                                    ToolTip.Tip="Close all document tabs"
                                    IsVisible="False"
                                    Click="CloseAllDocsButton_Click" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Left tab content area -->
                <Panel Grid.Row="1" Background="#1E1E1E">

                    <!-- Agent panel (Clean view) -->
                    <Panel x:Name="AgentPanel" IsVisible="False">
                        <controls:CleanView x:Name="CleanView" />
                    </Panel>

                    <!-- Session panel. Just the agent widget feed. The supervisor
                         runs invisibly; its only UI presence is the highlight
                         styling applied to the most recent message card when a
                         question is pending. -->
                    <Panel x:Name="SessionPanel" IsVisible="False">
                        <controls:CleanView x:Name="SessionCleanView" />
                    </Panel>

                    <!-- Terminal panel -->
                    <Panel x:Name="TerminalPanel" IsVisible="True">
                        <!-- Placeholder when no session -->
                        <TextBlock x:Name="PlaceholderText"
                                   Text="Select or create a session to begin"
                                   Foreground="#555555"
                                   FontSize="16"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />

                        <!-- Terminal + scrollbar, plus a bottom-docked pending-question
                             banner that mirrors the Session tab's red callout. The banner
                             is non-interactive (no text input, no focus capture) so the
                             terminal above it stays exactly Claude Code as the user typed
                             it - the sacred-terminal rule. -->
                        <DockPanel x:Name="TerminalDock" IsVisible="False">
                            <!-- Pending-question banner: same visual as the Session tab's
                                 PendingQuestion widget; hidden unless the active session
                                 is red with a non-empty reason. -->
                            <Border x:Name="TerminalPendingQuestionBanner"
                                    DockPanel.Dock="Bottom"
                                    Background="#7C2D12"
                                    BorderBrush="#F97316"
                                    BorderThickness="2"
                                    CornerRadius="8"
                                    Margin="8,8,8,8"
                                    Padding="16,14"
                                    IsVisible="False">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <Border Background="#EA580C"
                                                CornerRadius="6" Width="32" Height="32"
                                                Margin="0,0,12,0">
                                            <TextBlock Text="?" Foreground="White"
                                                       FontFamily="Segoe UI,sans-serif"
                                                       FontSize="18" FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock Text="CLAUDE IS WAITING ON YOUR ANSWER"
                                                   Foreground="White"
                                                   FontSize="14" FontWeight="Bold"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock x:Name="TerminalPendingQuestionText"
                                               Text=""
                                               Foreground="#FFF7ED"
                                               FontFamily="Segoe UI,sans-serif"
                                               FontSize="15" FontWeight="Normal"
                                               LineHeight="22"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <!-- Terminal + scrollbar fill remaining space -->
                            <Grid x:Name="TerminalGrid">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <terminal:TerminalControl x:Name="TerminalHost"
                                                          Grid.Column="0" />
                                <ScrollBar x:Name="TerminalScrollBar" Grid.Column="1"
                                           Orientation="Vertical"
                                           Width="14"
                                           Background="#1E1E1E"
                                           Foreground="#5A5A5A"
                                           AllowAutoHide="False"
                                           Opacity="1" />
                            </Grid>
                        </DockPanel>
                    </Panel>

                    <!-- Source Control panel -->
                    <Panel x:Name="SourceControlPanel" IsVisible="False">
                        <controls:GitChangesView x:Name="GitChangesView" />
                    </Panel>

                    <!-- Document viewer panel (dynamic content swapped per tab) -->
                    <Panel x:Name="DocumentPanel" IsVisible="False" />
                </Panel>

                <!-- ==================== NOTIFICATION BAR ==================== -->
                <Border x:Name="NotificationBar" Grid.Row="2"
                        Background="{DynamicResource SidebarBackground}"
                        BorderBrush="#3C3C3C" BorderThickness="0,1,0,0"
                        Padding="8,4"
                        IsVisible="False">
                    <DockPanel>
                        <TextBlock x:Name="NotificationIcon" DockPanel.Dock="Left"
                                   Text="(i)"
                                   Foreground="#3B82F6"
                                   FontSize="12" FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   IsVisible="False" />
                        <TextBlock x:Name="NotificationText"
                                   Text=""
                                   Foreground="{DynamicResource TextForeground}"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                    </DockPanel>
                </Border>

                <!-- ==================== PROMPT BAR ==================== -->
                <Border Grid.Row="3"
                        x:Name="PromptBarBorder"
                        Background="{DynamicResource SidebarBackground}"
                        BorderBrush="#3C3C3C" BorderThickness="0,1,0,0"
                        Padding="8,6"
                        IsVisible="False">
                    <Panel>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox x:Name="PromptInput"
                                     Grid.Column="0"
                                     Watermark="Type a message..."
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MinHeight="65"
                                     MaxHeight="160"
                                     Background="#1E1E1E"
                                     Foreground="{DynamicResource TextForeground}"
                                     BorderBrush="#3C3C3C"
                                     Padding="8,6"
                                     FontFamily="Cascadia Mono,Consolas,monospace"
                                     FontSize="13"
                                     DragDrop.AllowDrop="True" />

                            <!-- 2x2 button grid: top row = primary (Speak, Send),
                                 bottom row = secondary (Queue, Handover). Fixed
                                 width/height on every button so the bar can't
                                 grow vertically when PromptInput expands. -->
                            <Grid Grid.Column="1"
                                  ColumnDefinitions="Auto,Auto"
                                  RowDefinitions="Auto,Auto"
                                  VerticalAlignment="Bottom"
                                  Margin="8,0,0,0"
                                  ColumnSpacing="4"
                                  RowSpacing="4">
                                <Button x:Name="BtnSpeak"
                                        Grid.Row="0" Grid.Column="0"
                                        Content="Speak"
                                        Width="80" Height="30"
                                        Background="#16A34A"
                                        Foreground="White"
                                        HorizontalContentAlignment="Center"
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        Click="BtnSpeak_Click"
                                        ToolTip.Tip="Dictate using the cc-director dictation library (opens browser)" />
                                <Button x:Name="BtnSend"
                                        Grid.Row="0" Grid.Column="1"
                                        Content="Send"
                                        Width="80" Height="30"
                                        Background="{DynamicResource AccentBrush}"
                                        Foreground="White"
                                        HorizontalContentAlignment="Center"
                                        FontSize="13"
                                        Click="BtnSend_Click" />
                                <Button x:Name="BtnQueuePrompt"
                                        Grid.Row="1" Grid.Column="0"
                                        Content="Queue"
                                        Width="80" Height="30"
                                        Background="{DynamicResource ButtonBackground}"
                                        Foreground="{DynamicResource TextForeground}"
                                        HorizontalContentAlignment="Center"
                                        FontSize="13"
                                        Click="BtnQueuePrompt_Click"
                                        ToolTip.Tip="Add to prompt queue (Ctrl+Shift+Enter)" />
                                <Button x:Name="BtnHandover"
                                        Grid.Row="1" Grid.Column="1"
                                        Content="Handover"
                                        Width="80" Height="30"
                                        Background="#2D2D30"
                                        Foreground="#AAAAAA"
                                        HorizontalContentAlignment="Center"
                                        FontSize="13"
                                        Click="BtnHandover_Click"
                                        ToolTip.Tip="Create a handover document for this session" />
                            </Grid>
                        </Grid>

                        <!-- Slash command autocomplete popup -->
                        <Popup x:Name="SlashCommandPopup"
                               PlacementTarget="{Binding #PromptInput}"
                               Placement="Top"
                               IsLightDismissEnabled="False">
                            <Border Background="#252526"
                                    BorderBrush="#3C3C3C"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    MinWidth="700"
                                    MaxWidth="900"
                                    MaxHeight="420">
                                <Grid ColumnDefinitions="260,1,*">

                                    <!-- Command list -->
                                    <ListBox x:Name="SlashCommandList"
                                             Grid.Column="0"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             MaxHeight="410"
                                             Tapped="SlashCommandList_Tapped"
                                             SelectionChanged="SlashCommandList_SelectionChanged">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="4,2">
                                                    <TextBlock Text="{Binding Name, StringFormat=/\{0\}}"
                                                               Foreground="White"
                                                               FontFamily="Cascadia Mono,Consolas,monospace"
                                                               FontSize="13" />
                                                    <TextBlock Text="{Binding Description}"
                                                               Foreground="#888888"
                                                               FontSize="11"
                                                               TextTrimming="CharacterEllipsis"
                                                               Margin="0,1,0,0" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <!-- Divider -->
                                    <Border Grid.Column="1" Background="#3C3C3C" />

                                    <!-- Documentation panel -->
                                    <ScrollViewer Grid.Column="2"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <StackPanel x:Name="SlashCommandDocPanel" Margin="12,8"
                                                    IsVisible="False">
                                            <TextBlock x:Name="SlashCommandDocTitle"
                                                       Foreground="White"
                                                       FontFamily="Cascadia Mono,Consolas,monospace"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Margin="0,0,0,4" />
                                            <TextBlock x:Name="SlashCommandDocSource"
                                                       Foreground="#4EC9B0"
                                                       FontSize="11"
                                                       Margin="0,0,0,6" />
                                            <TextBlock x:Name="SlashCommandDocDesc"
                                                       Foreground="{DynamicResource TextForeground}"
                                                       FontSize="12" TextWrapping="Wrap"
                                                       Margin="0,0,0,8" />
                                            <Border Background="#1E1E1E"
                                                    CornerRadius="3"
                                                    Padding="10,8">
                                                <TextBlock x:Name="SlashCommandDocBody"
                                                           Foreground="#D4D4D4"
                                                           FontFamily="Cascadia Mono,Consolas,monospace"
                                                           FontSize="11.5" TextWrapping="Wrap" />
                                            </Border>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </Popup>
                    </Panel>
                </Border>
            </Grid>

            <!-- Right panel toggle button -->
            <Button x:Name="RightPanelToggle"
                    Grid.Column="1"
                    Content="&lt;&lt;"
                    Width="24"
                    Background="#2D2D30"
                    Foreground="#888888"
                    BorderThickness="0"
                    FontSize="10"
                    Padding="0"
                    VerticalContentAlignment="Center"
                    HorizontalContentAlignment="Center"
                    Click="RightPanelToggle_Click"
                    ToolTip.Tip="Toggle right panel" />

            <!-- ==================== RIGHT PANEL ==================== -->
            <Border x:Name="RightPanel"
                    Grid.Column="2"
                    Width="280"
                    Background="{DynamicResource SidebarBackground}"
                    BorderBrush="#3C3C3C" BorderThickness="1,0,0,0">

                <TabControl x:Name="RightPanelTabs"
                            Background="Transparent"
                            Padding="0"
                            FontSize="11">
                    <TabControl.Styles>
                        <Style Selector="TabItem">
                            <Setter Property="FontSize" Value="12" />
                            <Setter Property="Padding" Value="8,4" />
                            <Setter Property="MinHeight" Value="28" />
                        </Style>
                    </TabControl.Styles>

                    <!-- ===== Screenshots Tab ===== -->
                    <TabItem Header="Screenshots">
                        <DockPanel>
                            <!-- Top bar -->
                            <Border DockPanel.Dock="Top" Padding="8,6"
                                    BorderBrush="#3C3C3C" BorderThickness="0,0,0,1">
                                <DockPanel>
                                    <Button Content="Clear All" DockPanel.Dock="Right"
                                            Click="BtnClearScreenshots_Click"
                                            Background="Transparent" Foreground="#888888"
                                            BorderThickness="0" FontSize="11" Cursor="Hand"
                                            Padding="6,2" Margin="4,0,0,0" />
                                    <Button Content="Refresh" DockPanel.Dock="Right"
                                            Click="BtnRefreshScreenshots_Click"
                                            Background="Transparent" Foreground="#888888"
                                            BorderThickness="0" FontSize="11" Cursor="Hand"
                                            Padding="6,2" />
                                    <TextBlock Text="SCREENSHOTS"
                                               Foreground="#888888" FontSize="11"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                </DockPanel>
                            </Border>

                            <!-- Screenshot list -->
                            <ListBox x:Name="ScreenshotList"
                                     Background="Transparent"
                                     Padding="4">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="4" Margin="0,2"
                                                Background="#2A2A2A" CornerRadius="4"
                                                PointerPressed="ScreenshotItem_PointerPressed">
                                            <StackPanel>
                                                <Image Source="{Binding Thumbnail}"
                                                       MaxHeight="160"
                                                       Stretch="Uniform" />
                                                <DockPanel Margin="0,4,0,0">
                                                    <TextBlock Text="{Binding TimeLabel}"
                                                               Foreground="#888888" FontSize="10"
                                                               VerticalAlignment="Center" />
                                                    <StackPanel Orientation="Horizontal"
                                                                HorizontalAlignment="Right"
                                                                Spacing="4">
                                                        <Button Content="View"
                                                                Tag="{Binding FilePath}"
                                                                Click="ScreenshotView_Click"
                                                                Background="Transparent"
                                                                Foreground="#CCCCCC"
                                                                BorderThickness="0"
                                                                FontSize="10" Cursor="Hand"
                                                                Padding="4,2" />
                                                        <Button Content="Copy"
                                                                Tag="{Binding FilePath}"
                                                                Click="ScreenshotCopyPath_Click"
                                                                Background="Transparent"
                                                                Foreground="#CCCCCC"
                                                                BorderThickness="0"
                                                                FontSize="10" Cursor="Hand"
                                                                Padding="4,2" />
                                                        <Button Content="Del"
                                                                Tag="{Binding FilePath}"
                                                                Click="ScreenshotDelete_Click"
                                                                Background="Transparent"
                                                                Foreground="#CC4444"
                                                                BorderThickness="0"
                                                                FontSize="10" Cursor="Hand"
                                                                Padding="4,2" />
                                                    </StackPanel>
                                                </DockPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </TabItem>

                    <!-- ===== Queue Tab ===== -->
                    <TabItem x:Name="QueueTab" Header="Queue">
                        <DockPanel>
                            <!-- Top bar -->
                            <Border DockPanel.Dock="Top" Padding="8,6"
                                    BorderBrush="#3C3C3C" BorderThickness="0,0,0,1">
                                <DockPanel>
                                    <Button Content="Clear" DockPanel.Dock="Right"
                                            Click="BtnClearQueue_Click"
                                            Background="Transparent" Foreground="#888888"
                                            BorderThickness="0" FontSize="11" Cursor="Hand"
                                            Padding="6,2" />
                                    <TextBlock x:Name="QueueCountText"
                                               Text="0 items"
                                               Foreground="#888888" FontSize="11"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                </DockPanel>
                            </Border>

                            <!-- Empty state -->
                            <TextBlock x:Name="QueueEmptyText"
                                       Text="No queued prompts"
                                       Foreground="#555555" FontSize="12"
                                       FontStyle="Italic"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />

                            <!-- Queue items list -->
                            <ListBox x:Name="QueueItemsList"
                                     Background="Transparent"
                                     Padding="4"
                                     IsVisible="False"
                                     DoubleTapped="QueueItemsList_DoubleTapped">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="6,4" Margin="0,1"
                                                Background="#2A2A2A" CornerRadius="2">
                                            <Grid ColumnDefinitions="20,*,Auto">
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Index}"
                                                           Foreground="#666666" FontSize="11"
                                                           VerticalAlignment="Top" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Preview}"
                                                           Foreground="#CCCCCC" FontSize="11"
                                                           TextWrapping="Wrap" MaxHeight="80"
                                                           TextTrimming="CharacterEllipsis" />
                                                <StackPanel Grid.Column="2"
                                                            Orientation="Vertical"
                                                            Spacing="1"
                                                            VerticalAlignment="Top">
                                                    <StackPanel Orientation="Horizontal" Spacing="2">
                                                        <Button Content="/\"
                                                                Tag="{Binding Id}"
                                                                Click="QueueItemMoveUp_Click"
                                                                Background="Transparent"
                                                                Foreground="#888888"
                                                                BorderThickness="0"
                                                                FontSize="9" Cursor="Hand"
                                                                Padding="3,1"
                                                                ToolTip.Tip="Move up" />
                                                        <Button Content="\/"
                                                                Tag="{Binding Id}"
                                                                Click="QueueItemMoveDown_Click"
                                                                Background="Transparent"
                                                                Foreground="#888888"
                                                                BorderThickness="0"
                                                                FontSize="9" Cursor="Hand"
                                                                Padding="3,1"
                                                                ToolTip.Tip="Move down" />
                                                        <Button Content="Pop"
                                                                Tag="{Binding Id}"
                                                                Click="QueueItemPop_Click"
                                                                Background="Transparent"
                                                                Foreground="#22C55E"
                                                                BorderThickness="0"
                                                                FontSize="10" Cursor="Hand"
                                                                Padding="4,2" />
                                                        <Button Content="X"
                                                                Tag="{Binding Id}"
                                                                Click="QueueItemRemove_Click"
                                                                Background="Transparent"
                                                                Foreground="#CC4444"
                                                                BorderThickness="0"
                                                                FontSize="10" FontWeight="Bold"
                                                                Cursor="Hand" Padding="4,2" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </TabItem>

                    <!-- ===== Sessions Tab (hidden for now) ===== -->
                    <TabItem Header="Sessions" IsVisible="False">
                        <controls:SessionBrowserView x:Name="SessionBrowserView" />
                    </TabItem>

                    <!-- ===== Usage Tab (hidden for now) ===== -->
                    <TabItem Header="Usage" IsVisible="False">
                        <controls:UsageDashboardView x:Name="UsageDashboardView" />
                    </TabItem>

                    <!-- ===== Manager Tab ===== -->
                    <TabItem Header="Manager" x:Name="TabItemManager">
                        <mgr:ManagerView x:Name="ManagerView" />
                    </TabItem>

                    <!-- ===== Hooks Tab (hidden for now) ===== -->
                    <TabItem Header="Hooks" IsVisible="False">
                        <DockPanel>
                            <!-- Top bar -->
                            <Border DockPanel.Dock="Top" Padding="8,6"
                                    BorderBrush="#3C3C3C" BorderThickness="0,0,0,1">
                                <DockPanel>
                                    <Button Content="Clear" DockPanel.Dock="Right"
                                            Click="BtnClearHookEvents_Click"
                                            Background="Transparent" Foreground="#888888"
                                            BorderThickness="0" FontSize="11" Cursor="Hand"
                                            Padding="6,2" />
                                    <TextBlock Text="HOOK EVENTS"
                                               Foreground="#888888" FontSize="11"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                </DockPanel>
                            </Border>

                            <!-- Empty state -->
                            <TextBlock x:Name="HookEventsEmptyText"
                                       Text="No hook events yet"
                                       Foreground="#555555" FontSize="12"
                                       FontStyle="Italic"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />

                            <!-- Hook events list -->
                            <ListBox x:Name="HookEventList"
                                     Background="Transparent"
                                     Padding="4"
                                     IsVisible="False">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="4,3">
                                            <DockPanel>
                                                <TextBlock Text="{Binding Timestamp}"
                                                           Foreground="#888888" FontSize="10"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding EventName}"
                                                           Foreground="{Binding EventBrush}"
                                                           FontSize="11" FontWeight="SemiBold"
                                                           Margin="8,0,0,0"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding SessionIdShort}"
                                                           Foreground="#666666" FontSize="10"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center" />
                                            </DockPanel>
                                            <TextBlock Text="{Binding Detail}"
                                                       Foreground="#AAAAAA" FontSize="10"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,2,0,0" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>

        <!-- ==================== COMMS OVERLAY (covers main + right panel) ==================== -->
        <Border x:Name="CommsOverlay"
                Grid.Row="0" Grid.RowSpan="2" Grid.Column="2"
                Background="{DynamicResource PanelBackground}"
                ZIndex="10"
                IsVisible="False">
            <DockPanel>
                <!-- Header bar -->
                <Border DockPanel.Dock="Top"
                        Background="{DynamicResource SidebarBackground}"
                        BorderBrush="#3C3C3C" BorderThickness="0,0,0,1"
                        Padding="12,8">
                    <DockPanel>
                        <Button x:Name="BtnCommsClose"
                                DockPanel.Dock="Right"
                                Content="[x] Close"
                                Click="BtnCommsClose_Click"
                                Background="Transparent"
                                Foreground="#888888"
                                BorderThickness="0"
                                Cursor="Hand"
                                Padding="8,4"
                                FontSize="12" />
                        <TextBlock Text="Communication Manager"
                                   Foreground="{DynamicResource TextForeground}"
                                   FontSize="16" FontWeight="Bold"
                                   VerticalAlignment="Center" />
                    </DockPanel>
                </Border>

                <!-- CommManagerView fills the rest -->
                <commMgr:CommManagerView x:Name="CommManagerView" />
            </DockPanel>
        </Border>

        <!-- ==================== CONNECTIONS OVERLAY (covers main + right panel) ==================== -->
        <Border x:Name="ConnectionsOverlay"
                Grid.Row="0" Grid.RowSpan="2" Grid.Column="2"
                Background="{DynamicResource PanelBackground}"
                ZIndex="10"
                IsVisible="False">
            <DockPanel>
                <!-- Header bar -->
                <Border DockPanel.Dock="Top"
                        Background="{DynamicResource SidebarBackground}"
                        BorderBrush="#3C3C3C" BorderThickness="0,0,0,1"
                        Padding="12,8">
                    <DockPanel>
                        <Button x:Name="BtnConnectionsClose"
                                DockPanel.Dock="Right"
                                Content="[x] Close"
                                Click="BtnConnectionsClose_Click"
                                Background="Transparent"
                                Foreground="#888888"
                                BorderThickness="0"
                                Cursor="Hand"
                                Padding="8,4"
                                FontSize="12" />
                        <TextBlock Text="Browser Connections"
                                   Foreground="{DynamicResource TextForeground}"
                                   FontSize="16" FontWeight="Bold"
                                   VerticalAlignment="Center" />
                    </DockPanel>
                </Border>

                <!-- ConnectionsView fills the rest -->
                <controls:ConnectionsView x:Name="ConnectionsView" />
            </DockPanel>
        </Border>

    </Grid>
</Window>
