<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:terminal="clr-namespace:CcDirector.Terminal.Avalonia;assembly=CcDirector.Terminal.Avalonia"
        xmlns:controls="clr-namespace:CcDirector.Avalonia.Controls"
        xmlns:commMgr="clr-namespace:CcDirector.Avalonia.Controls.CommManager"
        xmlns:mgr="clr-namespace:CcDirector.Avalonia.Controls.DirectorView"
        xmlns:md="https://github.com/whistyun/Markdown.Avalonia.Tight"
        x:Class="CcDirector.Avalonia.MainWindow"
        Title="Director"
        Width="1400" Height="900"
        MinWidth="800" MinHeight="500"
        Background="{DynamicResource PanelBackground}"
        Icon="avares://cc-director/app.ico">

    <Window.Styles>
        <!-- Toolbar buttons: flat, icon + label, subtle hover. The New Session
             button opts out (accent styling inline) since it is the primary action. -->
        <Style Selector="Button.toolbarBtn">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#CCCCCC" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Height" Value="30" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.toolbarBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#2D2D30" />
        </Style>

        <!-- Panel collapse/expand chevrons: a subtle vector chevron that brightens on
             hover. Replaces the old "&lt;&lt;"/"&gt;&gt;" text toggles. Each chevron points
             toward the edge its panel tucks into (left panel -> left, right panel -> right). -->
        <Style Selector="Button.panelToggle">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.panelToggle Path">
            <Setter Property="Stroke" Value="#888888" />
        </Style>
        <Style Selector="Button.panelToggle:pointerover Path">
            <Setter Property="Stroke" Value="#E0E0E0" />
        </Style>
        <Style Selector="Button.panelToggle:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#3A3A3A" />
            <Setter Property="CornerRadius" Value="4" />
        </Style>

        <!-- Collapsed-sidebar status dots: subtle border that brightens on hover. -->
        <Style Selector="Button.slimDot:pointerover Border">
            <Setter Property="BorderBrush" Value="#FFFFFF" />
        </Style>
    </Window.Styles>

    <!-- The menu bar and toolbar span the full window width above the sidebar and
         content. NativeMenuBar renders an in-window menu bar on Windows/Linux and
         lifts into the system menu bar on macOS automatically. The menu items are
         built in code-behind (BuildNativeMenu) and assigned via NativeMenu.SetMenu. -->
    <DockPanel>

        <!-- ==================== MENU BAR (full width) ==================== -->
        <NativeMenuBar DockPanel.Dock="Top" />

        <!-- ==================== TOOLBAR (full width) ====================
             High-frequency actions + the badge/pill bearers that cannot live inside
             a collapsed menu (Comms pending count, Scheduler LEADER pill). -->
        <Border x:Name="MainToolbar"
                DockPanel.Dock="Top"
                Background="{DynamicResource SidebarBackground}"
                BorderBrush="#3C3C3C" BorderThickness="0,0,0,1"
                Padding="8,4">
            <DockPanel>
                <!-- Right group: this Director's identity + global destinations + Settings -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            Spacing="2" VerticalAlignment="Center">
                    <!-- Director connection info (machine name + port + copy for agents).
                         This identifies the WHOLE application's Director (its Control API
                         address), so it belongs on the app-wide toolbar, not in the
                         per-session blue header. Always visible, even with no session. -->
                    <StackPanel x:Name="DirectorInfoPanel" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="0,0,4,0">
                        <TextBlock x:Name="DirectorInfoText"
                                   Text="..."
                                   Foreground="#CCCCCC"
                                   FontSize="11"
                                   FontFamily="Cascadia Mono,Consolas,monospace"
                                   VerticalAlignment="Center" />
                        <Button x:Name="BtnCopyDirectorInfo"
                                Content="Copy"
                                Click="BtnCopyDirectorInfo_Click"
                                Margin="8,0,0,0"
                                Padding="6,2"
                                FontSize="11"
                                Background="#2D2D30"
                                Foreground="White"
                                BorderThickness="0"
                                Cursor="Hand"
                                ToolTip.Tip="Copy Control API URL so other agents can reach this Director" />
                    </StackPanel>

                    <Border Width="1" Height="18" Background="#3C3C3C"
                            Margin="6,0" VerticalAlignment="Center" />

                    <!-- The Tools catalog button was retired: the tool status + repair now live in
                         Settings -> Tools (opened from the rail tools indicator). -->

                    <!-- Cockpit (asks the local gateway for the Tailscale URL, then opens it) -->
                    <Button x:Name="BtnCockpit" Classes="toolbarBtn"
                            Click="BtnCockpit_Click"
                            ToolTip.Tip="Open the Cockpit (single fleet UI) over Tailscale">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <Viewbox Width="15" Height="15">
                                <Path Stroke="#CCCCCC" StrokeThickness="1.3" Fill="Transparent"
                                      Data="M8,1 A7,7 0 1 1 7.99,1 M8,3 V8 L11.5,11.5 M3,8 H1 M15,8 H13 M8,3 V1" />
                            </Viewbox>
                            <TextBlock Text="Cockpit" FontSize="12" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- Learn (opens the Cockpit Learning page over Tailscale; reuses the same
                         gateway resolution + "is the Gateway running?" hint as the Cockpit button) -->
                    <Button x:Name="BtnLearn" Classes="toolbarBtn"
                            Click="BtnLearn_Click"
                            ToolTip.Tip="Learn about DevThrottle (opens the Cockpit Learning page)">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <Viewbox Width="15" Height="15">
                                <!-- Graduation cap (mortarboard): cap diamond + tassel + base. -->
                                <Path Stroke="#CCCCCC" StrokeThickness="1.3" Fill="Transparent"
                                      Data="M8,2 L15,5.5 L8,9 L1,5.5 Z M4,7 V11 C4,12 12,12 12,11 V7 M15,5.5 V9" />
                            </Viewbox>
                            <TextBlock Text="Learn" FontSize="12" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Border Width="1" Height="18" Background="#3C3C3C"
                            Margin="6,0" VerticalAlignment="Center" />

                    <!-- Settings -->
                    <Button x:Name="BtnSettings" Classes="toolbarBtn"
                            Click="BtnSettings_Click"
                            ToolTip.Tip="Director settings">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <Viewbox Width="15" Height="15">
                                <Path Fill="#CCCCCC"
                                      Data="M19.14,12.94c0.04-0.3,0.06-0.61,0.06-0.94c0-0.32-0.02-0.64-0.07-0.94l2.03-1.58c0.18-0.14,0.23-0.41,0.12-0.61l-1.92-3.32c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39,0.96c-0.5-0.38-1.03-0.7-1.62-0.94L14.4,2.81c-0.04-0.24-0.24-0.41-0.48-0.41h-3.84c-0.24,0-0.43,0.17-0.47,0.41L9.25,5.35C8.66,5.59,8.12,5.92,7.63,6.29L5.24,5.33c-0.22-0.08-0.47,0-0.59,0.22L2.74,8.87C2.62,9.08,2.66,9.34,2.86,9.48l2.03,1.58C4.84,11.36,4.8,11.69,4.8,12s0.02,0.64,0.07,0.94l-2.03,1.58c-0.18,0.14-0.23,0.41-0.12,0.61l1.92,3.32c0.12,0.22,0.37,0.29,0.59,0.22l2.39-0.96c0.5,0.38,1.03,0.7,1.62,0.94l0.36,2.54c0.05,0.24,0.24,0.41,0.48,0.41h3.84c0.24,0,0.44-0.17,0.47-0.41l0.36-2.54c0.59-0.24,1.13-0.56,1.62-0.94l2.39,0.96c0.22,0.08,0.47,0,0.59-0.22l1.92-3.32c0.12-0.22,0.07-0.47-0.12-0.61L19.14,12.94z M12,15.6c-1.98,0-3.6-1.62-3.6-3.6s1.62-3.6,3.6-3.6s3.6,1.62,3.6,3.6S13.98,15.6,12,15.6z" />
                            </Viewbox>
                            <TextBlock Text="Settings" FontSize="12" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Left group: primary session actions -->
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <Button x:Name="BtnNewSession"
                            Click="BtnNewSession_Click"
                            Background="{DynamicResource AccentBrush}"
                            Foreground="White"
                            BorderThickness="0"
                            CornerRadius="3"
                            Padding="10,4"
                            Height="30"
                            Cursor="Hand"
                            VerticalContentAlignment="Center"
                            ToolTip.Tip="Create a new session">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <Viewbox Width="13" Height="13">
                                <Path Fill="White" Data="M6,0 H8 V6 H14 V8 H8 V14 H6 V8 H0 V6 H6 Z" />
                            </Viewbox>
                            <TextBlock Text="New Session" FontSize="12" FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnStartFifo" Classes="toolbarBtn"
                            Click="BtnFifo_Click"
                            ToolTip.Tip="Start FIFO -- step through every session that needs you">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <Viewbox Width="14" Height="12">
                                <Path Fill="#CCCCCC" Data="M0,0 L7,6 L0,12 Z M7,0 L14,6 L7,12 Z" />
                            </Viewbox>
                            <TextBlock Text="Start FIFO" FontSize="12" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

    <Grid x:Name="MainLayoutGrid" ColumnDefinitions="264,Auto,*" RowDefinitions="Auto,*">

        <!-- ==================== SIDEBAR (spans both rows) ==================== -->
        <Border Grid.Column="0" Grid.RowSpan="2"
                Background="{DynamicResource SidebarBackground}"
                BorderBrush="#3C3C3C" BorderThickness="0,0,1,0">
            <Grid>
            <DockPanel x:Name="SidebarFullPanel">
                <!-- Sidebar header: title + needs-you count + collapse toggle. The
                     application menu moved to the window menu bar; New Session moved
                     to the toolbar. -->
                <Border DockPanel.Dock="Top" Padding="8,6">
                    <DockPanel>
                        <!-- Collapse the sidebar to the slim status strip. Chevron points
                             left, toward the edge the panel tucks into. -->
                        <Button DockPanel.Dock="Right"
                                Click="SidebarCollapse_Click"
                                Focusable="False"
                                VerticalAlignment="Center"
                                ToolTip.Tip="Collapse the session panel"
                                Classes="panelToggle">
                            <Viewbox Width="8" Height="12">
                                <Path Data="M 7,2 L 3,7 L 7,12"
                                      StrokeThickness="1.6"
                                      StrokeLineCap="Round" StrokeJoin="Round" />
                            </Viewbox>
                        </Button>
                        <TextBlock Text="SESSIONS"
                                   Foreground="{DynamicResource TextForeground}"
                                   FontSize="12" FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   Margin="0" />
                        <!-- At-a-glance "do I need to act?" count: how many sessions are red
                             (needs you). Amber, hidden when zero. Updated from the session timer. -->
                        <TextBlock x:Name="SessionsNeedYouText"
                                   Foreground="#F0B848" FontSize="11" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="8,0,0,0"
                                   IsVisible="False" />
                    </DockPanel>
                </Border>

                <!-- New Session and Start FIFO moved to the top toolbar. -->

                <!-- Version footer (very bottom): "v0.6.3 (1cc1abd)", build time in tooltip. -->
                <Border DockPanel.Dock="Bottom" Padding="8,4">
                    <TextBlock x:Name="BuildInfoText"
                               Text=""
                               Foreground="#555555"
                               FontSize="10"
                               HorizontalAlignment="Center" />
                </Border>

                <!-- Gateway two-way connection indicator (issues #223/#224), above the
                     version footer. GREEN is EARNED by the nonce handshake (both legs
                     proven) - heartbeats alone never paint it; YELLOW = verifying;
                     RED = a leg failed (click opens the troubleshooter); AMBER = no
                     gateway configured - a needs-attention state (a Gateway URL is
                     required, issue #442) whose click opens Settings on the Gateway tab.
                     All colors/text set from code-behind off GatewayConnectionMonitor. -->
                <Border x:Name="GatewayIndicator" DockPanel.Dock="Bottom"
                        Margin="8,0,8,4" Padding="10,8" CornerRadius="4"
                        Background="#3A331B" BorderBrush="#F0B848" BorderThickness="1"
                        Cursor="Hand"
                        PointerPressed="GatewayIndicator_PointerPressed">
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <Viewbox Width="22" Height="22" VerticalAlignment="Center">
                            <Path x:Name="GatewayIndicatorIcon"
                                  Fill="#F0B848"
                                  Data="M8,1 A7,7 0 1 0 8,15 A7,7 0 1 0 8,1 Z M8,3 A5,5 0 1 1 8,13 A5,5 0 1 1 8,3 Z" />
                        </Viewbox>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="GatewayIndicatorLabel"
                                       Text="GATEWAY NOT SET"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="#F0B848" />
                            <TextBlock x:Name="GatewayIndicatorSub"
                                       Text="click to set the Gateway URL in Settings"
                                       FontSize="10" Foreground="#666666"
                                       TextWrapping="Wrap" MaxWidth="186"
                                       MaxLines="3" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- cc-* tools health indicator (sits directly above the Gateway indicator).
                     Visible ONLY when a tool is failing or not built - hidden when every tool
                     passes - and shows the SAME message as the status screen's tools row (text
                     set from the same readiness check in code-behind). Click opens Settings on the
                     Tools tab, where one big button downloads and repairs the whole toolset. -->
                <Border x:Name="ToolsIndicator" DockPanel.Dock="Bottom"
                        Margin="8,0,8,4" Padding="10,8" CornerRadius="4"
                        Background="#3A331B" BorderBrush="#F0B848" BorderThickness="1"
                        Cursor="Hand" IsVisible="False"
                        PointerPressed="ToolsIndicator_PointerPressed">
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <Grid Width="22" Height="22" VerticalAlignment="Center">
                            <Ellipse Fill="#F0B848" />
                            <TextBlock Text="!" Foreground="#1E1E1E" FontWeight="Bold" FontSize="14"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="ToolsIndicatorLabel"
                                       Text="cc-* tools"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="#F0B848" />
                            <TextBlock x:Name="ToolsIndicatorSub"
                                       Text="click to download and repair the tools"
                                       FontSize="10" Foreground="#B59868"
                                       TextWrapping="Wrap" MaxWidth="186"
                                       MaxLines="3" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Auto-update status indicator. Mirrors the Gateway indicator above.
                     Hidden when there is nothing to report; surfaces checking /
                     downloading (with %) / ready / failed so updates are never silent.
                     Click = check now. All colors/text set from code-behind off
                     UpdateService.ProgressChanged. -->
                <Border x:Name="UpdateIndicator" DockPanel.Dock="Bottom"
                        Margin="8,0,8,4" Padding="10,8" CornerRadius="4"
                        Background="#2A2A2A" BorderBrush="#3C3C3C" BorderThickness="1"
                        Cursor="Hand" IsVisible="False"
                        PointerPressed="UpdateIndicator_PointerPressed">
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <Viewbox Width="22" Height="22" VerticalAlignment="Center">
                            <Path x:Name="UpdateIndicatorIcon"
                                  Fill="#777777"
                                  Data="M8,1 A7,7 0 1 0 8,15 A7,7 0 1 0 8,1 Z M8,3 A5,5 0 1 1 8,13 A5,5 0 1 1 8,3 Z" />
                        </Viewbox>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="UpdateIndicatorLabel"
                                       Text="UP TO DATE"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="#777777" />
                            <TextBlock x:Name="UpdateIndicatorSub"
                                       Text=""
                                       FontSize="10" Foreground="#666666"
                                       TextWrapping="Wrap" MaxWidth="186"
                                       MaxLines="2" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Control API status indicator. Mirrors the Gateway/Update indicators.
                     Hidden while the Control API is healthy; turns RED "CONTROL API DOWN"
                     when StartAsync could not bind (e.g. all ports in [7879..7898] busy), so
                     a degraded Director is never silently invisible to the fleet. Click =
                     show remediation guidance. Painted from code-behind off
                     ControlApiHost.StartupStatusChanged. -->
                <Border x:Name="ControlApiIndicator" DockPanel.Dock="Bottom"
                        Margin="8,0,8,4" Padding="10,8" CornerRadius="4"
                        Background="#3A1B1B" BorderBrush="#DC2626" BorderThickness="1"
                        Cursor="Hand" IsVisible="False"
                        PointerPressed="ControlApiIndicator_PointerPressed">
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <Viewbox Width="22" Height="22" VerticalAlignment="Center">
                            <Path x:Name="ControlApiIndicatorIcon"
                                  Fill="#EF4444"
                                  Data="M8,1 A7,7 0 1 0 8,15 A7,7 0 1 0 8,1 Z M7,4 H9 V9 H7 Z M7,10.5 H9 V12.5 H7 Z" />
                        </Viewbox>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="ControlApiIndicatorLabel"
                                       Text="CONTROL API DOWN"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="#EF4444" />
                            <TextBlock x:Name="ControlApiIndicatorSub"
                                       Text=""
                                       FontSize="10" Foreground="#C08080"
                                       TextWrapping="Wrap" MaxWidth="186"
                                       MaxLines="3" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Communications / Connections / Scheduler moved to the top toolbar
                     (their pending-count badge and LEADER pill ride along with them). -->

                <!-- Session list -->
                <ListBox x:Name="SessionList"
                         Background="Transparent"
                         Padding="4"
                         SelectionChanged="SessionList_SelectionChanged"
                         DragDrop.AllowDrop="True">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                        <Style Selector="Button.sessionMenuBtn:pointerover /template/ ContentPresenter">
                            <Setter Property="Foreground" Value="#CCCCCC" />
                            <Setter Property="Background" Value="Transparent" />
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,1">
                                <!-- Group header (issue #225): rendered above the FIRST member
                                     of a group only. Doubles as the group drag handle - grab it
                                     to move every member as one unit. -->
                                <Border IsVisible="{Binding ShowGroupHeader}"
                                        Background="#243049"
                                        BorderBrush="#3A4A63" BorderThickness="1,1,1,0"
                                        CornerRadius="6,6,0,0"
                                        Padding="9,4" Margin="0,3,0,0"
                                        Cursor="SizeAll"
                                        PointerPressed="ColorSquare_PointerPressed">
                                    <StackPanel Orientation="Horizontal" Spacing="7">
                                        <TextBlock Text="&#9776;" Foreground="#6F86B3" FontSize="11" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding GroupHeaderText}"
                                                   Foreground="#9DB4DD" FontSize="10" FontWeight="Bold"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <!-- Row body: a left accent stripe + subtle tint when this is a
                                     group member, so members read as one tied block. -->
                                <Border Background="{Binding GroupRowBackground}">
                                <Grid ColumnDefinitions="Auto,*">
                                    <Border Grid.Column="0" Width="3"
                                            Background="{Binding GroupAccent}"
                                            IsVisible="{Binding IsGroupMember}" />
                                <!-- Session row content: up to four stacked lines, each
                                     element with a guaranteed slot so nothing is ever
                                     pushed out of the panel by something else growing:
                                       1. status dot | title (trims) | queue | kebab
                                       2. agent badge + type badge
                                       3. activity + waiting | changes (right-anchored)
                                       4. wingman headline (only when present) -->
                                <StackPanel Grid.Column="1" Margin="8,6">
                                    <!-- LINE 1: the title sits in the star column, so
                                         TextTrimming actually engages and a long name
                                         can never run under the kebab menu. -->
                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                                        <!-- Live wingman status indicator. Reads
                                             Session.StatusColor (written by the
                                             SessionStatusWingman) so the same
                                             session shows the same color on Desktop
                                             and Gateway. Doubles as the drag handle
                                             for reordering the session list. -->
                                        <Border Grid.Column="0"
                                                Width="14" Height="14"
                                                CornerRadius="3"
                                                Background="{Binding StatusColorBrush}"
                                                ToolTip.Tip="{Binding StatusReason}"
                                                Margin="0,0,6,0"
                                                VerticalAlignment="Center"
                                                Cursor="SizeAll"
                                                PointerPressed="ColorSquare_PointerPressed" />
                                        <!-- Issue #820: three-digit session number as a muted
                                             prefix (tertiary #888888), separate from the name so a
                                             rename never affects it. -->
                                        <Grid Grid.Column="1" ColumnDefinitions="Auto,*">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding NumberBadge}"
                                                       IsVisible="{Binding HasNumber}"
                                                       ToolTip.Tip="Session number"
                                                       Foreground="#888888"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,6,0"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding DisplayName}"
                                                       ToolTip.Tip="{Binding DisplayName}"
                                                       Foreground="{DynamicResource TextForeground}"
                                                       FontSize="13"
                                                       FontWeight="Medium"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                        <!-- Queue count badge (click to preview queued prompts) -->
                                        <Button Grid.Column="2"
                                                IsVisible="{Binding HasQueuedItems}"
                                                Click="QueuePreview_Click"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Padding="0"
                                                Margin="4,0,2,0"
                                                VerticalAlignment="Center"
                                                Cursor="Hand"
                                                ToolTip.Tip="Preview queued prompts (text + images)">
                                            <Border Background="#EF4444"
                                                    CornerRadius="9"
                                                    MinWidth="18" Height="18"
                                                    Padding="5,0"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding QueueCount}"
                                                           Foreground="White"
                                                           FontSize="11"
                                                           FontWeight="Bold"
                                                           TextAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                        </Button>
                                        <Button Grid.Column="3"
                                                Content="..."
                                                Click="SessionMenuButton_Click"
                                                Focusable="False"
                                                VerticalAlignment="Center"
                                                Padding="6,2"
                                                Margin="0"
                                                MinWidth="24"
                                                Background="Transparent"
                                                Foreground="#AAAAAA"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                FontWeight="Bold"
                                                FontSize="12"
                                                ToolTip.Tip="Session options"
                                                Classes="sessionMenuBtn" />
                                    </Grid>
                                    <!-- LINE 2: identity badges only - the wide items.
                                         Alone on their own line they always fit. -->
                                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                        <!-- In-voice-mode ear indicator (issue #554): shown only
                                             while a phone is watching this session through the Voice
                                             (in-car) tab. A vector ear (outer fold + inner canal),
                                             never a glyph, tinted with the active-icon foreground so
                                             it reads as an indicator, not a status color. -->
                                        <Viewbox Width="14" Height="14"
                                                 IsVisible="{Binding IsVoiceMode}"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,6,0"
                                                 ToolTip.Tip="In voice mode - a phone is driving this session by voice">
                                            <Canvas Width="24" Height="24">
                                                <Path Stroke="{DynamicResource TextForeground}"
                                                      StrokeThickness="2"
                                                      StrokeLineCap="Round"
                                                      StrokeJoin="Round"
                                                      Fill="Transparent"
                                                      Data="M7 11 C7 6.6 10.1 4 12.5 4 C15.5 4 18 6.4 18 9.5 C18 12.4 16 13.7 14.7 14.7 C13.7 15.5 13 16.1 13 17.2 C13 18.7 11.9 19.9 10.4 19.9 C9 19.9 7.9 18.8 7.9 17.4" />
                                                <Path Stroke="{DynamicResource TextForeground}"
                                                      StrokeThickness="2"
                                                      StrokeLineCap="Round"
                                                      StrokeJoin="Round"
                                                      Fill="Transparent"
                                                      Data="M10.2 10.4 C10.2 9.1 11.2 8.1 12.5 8.1 C13.8 8.1 14.8 9.1 14.8 10.4 C14.8 11.6 13.9 12.1 13.2 12.7" />
                                            </Canvas>
                                        </Viewbox>
                                        <!-- Agent badge: shows which CLI this session is running -->
                                        <Border Background="{Binding AgentBadgeBrush}"
                                                CornerRadius="6"
                                                Padding="6,1"
                                                VerticalAlignment="Center"
                                                Margin="0,0,6,0"
                                                ToolTip.Tip="Agent running in this session">
                                            <TextBlock Text="{Binding AgentLabel}"
                                                       Foreground="White"
                                                       FontSize="9"
                                                       FontWeight="SemiBold" />
                                        </Border>
                                        <!-- Session-type badge (issue #211): OUTLINED chip
                                             (transparent fill + colored border) so type-as-
                                             identity never reads as a status color. Hidden
                                             for the default Developer type. -->
                                        <Border Background="Transparent"
                                                BorderBrush="{Binding SessionTypeBadgeBrush}"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Padding="6,0"
                                                VerticalAlignment="Center"
                                                Margin="0,0,6,0"
                                                IsVisible="{Binding ShowSessionTypeBadge}"
                                                ToolTip.Tip="{Binding SessionTypeTooltip}">
                                            <TextBlock Text="{Binding SessionTypeLabel}"
                                                       Foreground="{Binding SessionTypeBadgeBrush}"
                                                       FontSize="9"
                                                       FontWeight="SemiBold" />
                                        </Border>
                                    </StackPanel>
                                    <!-- LINE 3: live state. The changes badge is anchored
                                         to the RIGHT edge so it is always visible even if
                                         activity/waiting text grows. -->
                                    <Grid ColumnDefinitions="*,Auto" Margin="0,2,0,0">
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <TextBlock Text="{Binding ActivityLabel}"
                                                       Foreground="#888888"
                                                       FontSize="11"
                                                       VerticalAlignment="Center" />
                                            <!-- How long a needs-you session has been waiting,
                                                 so you can triage the most stale one first.
                                                 Only shown when red. -->
                                            <TextBlock Text="{Binding WaitingDurationLabel}"
                                                       IsVisible="{Binding HasWaitingDuration}"
                                                       Foreground="#E0883C"
                                                       FontSize="11"
                                                       Margin="6,0,0,0"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                        <Border Grid.Column="1"
                                                IsVisible="{Binding HasUncommittedChanges}"
                                                Background="#6B4C00"
                                                CornerRadius="6"
                                                Padding="4,0"
                                                Margin="6,0,0,0"
                                                VerticalAlignment="Center">
                                            <TextBlock Foreground="#F5D060" FontSize="9"
                                                       FontWeight="SemiBold">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}{0} chg">
                                                        <Binding Path="UncommittedCount" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </Border>
                                    </Grid>
                                    <!-- LINE 4: wingman headline - at-a-glance "what this
                                         session is about / needs" so the list is scannable
                                         without opening the Wingman tab. Hidden until a
                                         briefing exists. One line, ellipsized. -->
                                    <TextBlock Text="{Binding WingmanHeadline}"
                                               IsVisible="{Binding HasWingmanHeadline}"
                                               Foreground="{Binding WingmanHeadlineBrush}"
                                               FontSize="11"
                                               TextWrapping="NoWrap"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,3,0,0" />
                                </StackPanel>
                                </Grid>
                                </Border>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <!-- Collapsed sidebar: a slim strip that keeps the at-a-glance status
                 dots (clickable, tooltip = session name) and the expand button.
                 Toggled with SidebarFullPanel from code-behind. -->
            <DockPanel x:Name="SidebarSlimPanel" IsVisible="False">
                <!-- Expand back to the full panel. Chevron points right, pulling the
                     panel out from the left edge. -->
                <Button DockPanel.Dock="Top"
                        Click="SidebarExpand_Click"
                        Focusable="False"
                        Margin="2,6,2,4"
                        HorizontalAlignment="Stretch"
                        ToolTip.Tip="Expand the session panel"
                        Classes="panelToggle">
                    <Viewbox Width="8" Height="12">
                        <Path Data="M 3,2 L 7,7 L 3,12"
                              StrokeThickness="1.6"
                              StrokeLineCap="Round" StrokeJoin="Round" />
                    </Viewbox>
                </Button>
                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="SlimSessionList" Margin="0,2">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Click="SlimSessionDot_Click"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="0"
                                        Margin="0,3"
                                        HorizontalAlignment="Center"
                                        Cursor="Hand"
                                        Classes="slimDot"
                                        ToolTip.Tip="{Binding DisplayName}">
                                    <Border Width="18" Height="18"
                                            CornerRadius="5"
                                            BorderThickness="1"
                                            BorderBrush="Transparent"
                                            Background="{Binding StatusColorBrush}" />
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
            </Grid>
        </Border>

        <!-- Grid splitter (disabled while the sidebar is collapsed) -->
        <GridSplitter x:Name="SidebarSplitter"
                      Grid.Column="1" Grid.RowSpan="2"
                      Width="3"
                      Background="#3C3C3C"
                      ResizeDirection="Columns" />

        <!-- ==================== TOP BAR (unified, always visible) ====================
             One bar holds BOTH the global tools (right) and the per-session identity
             (fill). These used to be two separate, overlapping borders in the same
             grid cell, so the opaque blue session banner painted right over the
             Settings button. Now the global tools always render; only the identity
             grid toggles. The blue accent background is applied in code-behind when a
             session is active (SetSessionHeaderVisible). -->
        <Border x:Name="TopBar"
                Grid.Row="0" Grid.Column="2"
                Background="{DynamicResource SidebarBackground}"
                BorderBrush="#3C3C3C" BorderThickness="0,0,0,1"
                MinHeight="36">
            <DockPanel Margin="12,6">
                <!-- Global tools (Settings, Claude/MCP/Agents config, Help) moved to
                     the window menu bar and toolbar. This bar now carries only the
                     per-session identity. -->

                <!-- Per-session identity (fill). Toggled via SessionHeaderBanner in code.
                     The Director address moved to the app-wide toolbar (it identifies the
                     whole application, not the selected session). -->
                <Grid x:Name="SessionHeaderBanner"
                      RowDefinitions="Auto,Auto"
                      IsVisible="False">
                <!-- Row 0: Session name + badges + buttons -->
                <DockPanel Grid.Row="0">
                    <!-- Right-aligned buttons -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                VerticalAlignment="Center" Spacing="4">
                        <!-- Activity label -->
                        <TextBlock x:Name="HeaderActivityLabel"
                                   Text=""
                                   Foreground="#FFFFFFCC"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   IsVisible="False"
                                   Margin="0,0,8,0" />
                    </StackPanel>

                    <!-- Session name -->
                    <TextBlock x:Name="HeaderSessionName"
                               Text=""
                               Foreground="White"
                               FontSize="16" FontWeight="Bold"
                               VerticalAlignment="Center" />
                    <!-- Message count badge -->
                    <Border x:Name="HeaderMessageCountBadge"
                            Background="#1E40AF"
                            CornerRadius="4"
                            Padding="8,3"
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            IsVisible="False">
                        <TextBlock x:Name="HeaderMessageCountText"
                                   Text="0 msgs"
                                   Foreground="White"
                                   FontSize="11"
                                   FontWeight="SemiBold" />
                    </Border>
                </DockPanel>

                <!-- Row 1: GitHub remote links (only for GitHub Actions sessions) -->
                <StackPanel x:Name="HeaderRemoteLinks" Grid.Row="1"
                            Orientation="Horizontal"
                            Margin="0,4,0,0"
                            IsVisible="False">
                    <TextBlock Text="Remote:"
                               Foreground="#87CEFA" FontSize="10"
                               VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBlock x:Name="HeaderRemoteRepo"
                               Text=""
                               Foreground="#E0E0E0" FontSize="10"
                               FontFamily="Cascadia Mono,Consolas,monospace"
                               VerticalAlignment="Center" Margin="0,0,10,0" />
                    <Button x:Name="BtnOpenRemoteThread"
                            Content="Open thread"
                            Click="BtnOpenRemoteThread_Click"
                            Padding="6,2" FontSize="10"
                            Background="#005A9E" Foreground="#E0E0E0"
                            BorderThickness="0" Cursor="Hand" Margin="0,0,6,0"
                            ToolTip.Tip="Open the GitHub issue/PR thread driving this session" />
                    <Button x:Name="BtnOpenRemoteActions"
                            Content="Open Actions"
                            Click="BtnOpenRemoteActions_Click"
                            Padding="6,2" FontSize="10"
                            Background="#005A9E" Foreground="#E0E0E0"
                            BorderThickness="0" Cursor="Hand"
                            ToolTip.Tip="Open the repository's GitHub Actions runs" />
                </StackPanel>
                </Grid>
            </DockPanel>
        </Border>

        <!-- ==================== MAIN CONTENT + RIGHT PANEL ==================== -->
        <Grid Grid.Row="1" Grid.Column="2" ColumnDefinitions="*,Auto">

            <!-- Left: Terminal + Prompt -->
            <Grid Grid.Column="0" RowDefinitions="Auto,*,Auto,Auto">

                <!-- Left tab bar -->
                <Border Grid.Row="0"
                        Background="{DynamicResource SidebarBackground}"
                        Padding="8,0"
                        Height="36">
                    <DockPanel>
                        <!-- Right-aligned open-wingman + capture + refresh buttons -->
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                    VerticalAlignment="Center" Spacing="2">
                            <Button x:Name="TabBarOpenWingmanButton"
                                    Content="Open Wingman"
                                    Click="BtnOpenInBrowser_Click"
                                    Background="Transparent"
                                    Foreground="#888888"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Padding="8,4"
                                    FontSize="11"
                                    ToolTip.Tip="Open this session's wingman / voice view in your default browser"
                                    IsVisible="False" />
                            <Button x:Name="TabBarCaptureButton"
                                    Content="Capture"
                                    Click="TabBarCaptureButton_Click"
                                    Background="Transparent"
                                    Foreground="#888888"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Padding="8,4"
                                    FontSize="11"
                                    ToolTip.Tip="Capture terminal diagnostic snapshot (Ctrl+Shift+F12)"
                                    IsVisible="False" />
                            <Button x:Name="TabBarRefreshButton"
                                    Content="Reset View"
                                    Click="TabBarRefreshButton_Click"
                                    Background="Transparent"
                                    Foreground="#888888"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Padding="8,4"
                                    FontSize="11"
                                    ToolTip.Tip="Rebuild terminal and scrollbar from PTY buffer"
                                    IsVisible="False" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Spacing="2">
                            <Button x:Name="TerminalTabButton"
                                    Content="Terminal"
                                    Background="{DynamicResource AccentBrush}"
                                    Foreground="White"
                                    Padding="12,4"
                                    FontSize="12"
                                    Click="TerminalTabButton_Click" />
                            <Button x:Name="SourceControlTabButton"
                                    Content="Source Control"
                                    Background="Transparent"
                                    Foreground="#888888"
                                    Padding="12,4"
                                    FontSize="12"
                                    Click="SourceControlTabButton_Click" />
                            <Button x:Name="VoiceTabButton"
                                    Content="Voice"
                                    IsVisible="False"
                                    Background="Transparent"
                                    Foreground="#888888"
                                    Padding="12,4"
                                    FontSize="12"
                                    Click="VoiceTabButton_Click" />
                            <Button x:Name="WingmanTabButton"
                                    Content="Wingman"
                                    IsVisible="False"
                                    Background="Transparent"
                                    Foreground="#888888"
                                    Padding="12,4"
                                    FontSize="12"
                                    Click="WingmanTabButton_Click" />
                            <Button x:Name="HistoryTabButton"
                                    Content="History"
                                    Background="Transparent"
                                    Foreground="#888888"
                                    Padding="12,4"
                                    FontSize="12"
                                    Click="HistoryTabButton_Click" />
                            <!-- Separator between fixed tabs and document tabs -->
                            <Border x:Name="DocTabSeparator"
                                    Width="1" Height="16"
                                    Background="#3C3C3C"
                                    Margin="4,0"
                                    IsVisible="False" />

                            <!-- Dynamic document tab buttons inserted here -->
                            <ItemsControl x:Name="DocumentTabBar"
                                          IsVisible="False">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="2" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>

                            <!-- Close All document tabs button -->
                            <Button x:Name="CloseAllDocsButton"
                                    Content="x"
                                    Background="Transparent"
                                    Foreground="#666666"
                                    Padding="6,4"
                                    FontSize="10"
                                    ToolTip.Tip="Close all document tabs"
                                    IsVisible="False"
                                    Click="CloseAllDocsButton_Click" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Left tab content area -->
                <Panel Grid.Row="1" Background="#1E1E1E">

                    <!-- Terminal panel -->
                    <Panel x:Name="TerminalPanel" IsVisible="True">
                        <!-- Placeholder when no session -->
                        <TextBlock x:Name="PlaceholderText"
                                   Text="Select or create a session to begin"
                                   Foreground="#555555"
                                   FontSize="16"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />

                        <Grid x:Name="TerminalDock" IsVisible="False">
                            <!-- Terminal + scrollbar fill the whole area -->
                            <Grid x:Name="TerminalGrid">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <terminal:TerminalControl x:Name="TerminalHost"
                                                          Grid.Column="0" />
                                <ScrollBar x:Name="TerminalScrollBar" Grid.Column="1"
                                           Orientation="Vertical"
                                           Width="14"
                                           Background="#1E1E1E"
                                           Foreground="#5A5A5A"
                                           AllowAutoHide="False"
                                           Opacity="1" />
                            </Grid>
                        </Grid>
                    </Panel>

                    <!-- Source Control panel -->
                    <Panel x:Name="SourceControlPanel" IsVisible="False">
                        <controls:GitChangesView x:Name="GitChangesView" />
                    </Panel>

                    <!-- Voice panel (eyes-free: Ask Agent / Ask Wingman) -->
                    <Panel x:Name="VoicePanel" IsVisible="False">
                        <controls:VoiceView x:Name="VoiceView" />
                    </Panel>

                    <!-- Wingman panel: the clean output of the session (the agent's
                         replies render here, de-noised) plus a Speak/Send bar that
                         talks to the agent. The top section is a structured briefing
                         from the ProactiveExplainService - title, what happened (quick +
                         longer), what Claude wants next, and the spoken-version preview
                         with a button to TTS-play it for QA. The whole top section is a
                         testing surface so we can iterate on how good the Wingman is at
                         explaining a session. -->
                    <Panel x:Name="WingmanPanel" IsVisible="False">
                        <DockPanel>
                            <!-- ===== Structured briefing banner =====
                                 Passive viewer of Session.Cached*; refreshed via
                                 OnCachedExplainChanged whenever the ProactiveExplainService
                                 stores a new briefing. -->
                            <Border DockPanel.Dock="Top"
                                    Background="#16241B"
                                    BorderBrush="#2D7D46" BorderThickness="0,0,0,1"
                                    Padding="12,10">
                                <StackPanel Spacing="10">
                                    <!-- Empty/loading state: shown until the first cached briefing arrives. -->
                                    <TextBlock x:Name="WingmanEmptyText"
                                               Text="No briefing yet. The Wingman will write here at the next turn-end."
                                               Foreground="#B7C0D4" FontSize="13" FontStyle="Italic"
                                               TextWrapping="Wrap" IsVisible="True" />

                                    <!-- Header row: WINGMAN label + a QA toggle for the voice
                                         preview + model / generated-at info -->
                                    <DockPanel x:Name="WingmanHeaderRow" IsVisible="False">
                                        <TextBlock Text="WINGMAN"
                                                   Foreground="#5FD08A" FontSize="11" FontWeight="Bold"
                                                   VerticalAlignment="Center" />
                                        <!-- Voice-preview toggle. The preview is a QA surface (read
                                             what TTS would say, Play it); off by default so the tab
                                             stays clean. Flips WingmanVoiceSection visibility. -->
                                        <ToggleButton x:Name="WingmanVoicePreviewToggle"
                                                      DockPanel.Dock="Right"
                                                      Content="Voice preview"
                                                      IsChecked="False"
                                                      Margin="8,0,0,0" Padding="8,2"
                                                      FontSize="10"
                                                      VerticalAlignment="Center"
                                                      IsCheckedChanged="WingmanVoicePreviewToggle_Changed"
                                                      ToolTip.Tip="Show the spoken-version preview (QA). Off keeps the tab clean." />
                                        <TextBlock x:Name="WingmanMetaText"
                                                   DockPanel.Dock="Right"
                                                   Foreground="#888888" FontSize="10"
                                                   FontFamily="Cascadia Mono, Consolas, monospace"
                                                   VerticalAlignment="Center"
                                                   Text="" />
                                    </DockPanel>

                                    <!-- TITLE / headline: one-line "what's going on right now" -->
                                    <TextBlock x:Name="WingmanTitleText"
                                               Foreground="#FFFFFF" FontSize="18" FontWeight="Bold"
                                               TextWrapping="Wrap" IsVisible="False"
                                               Text="" />

                                    <!-- WHAT CLAUDE WANTS YOU TO DO NEXT - the decision the user
                                         must act on, so it sits directly under the headline and is
                                         highlighted to be impossible to miss. -->
                                    <Border x:Name="WingmanWhatNextSection" IsVisible="False"
                                            Background="#3A2A1B"
                                            BorderBrush="#D97706" BorderThickness="2"
                                            CornerRadius="4" Padding="10,8">
                                        <StackPanel Spacing="4">
                                            <!-- CLAUDE SAID: the trust anchor - Claude's decisive
                                                 line VERBATIM (validated against the terminal),
                                                 shown above the synthesized line so a drifting
                                                 summary is immediately visible. Hidden when no
                                                 verbatim line was validated. -->
                                            <TextBlock x:Name="WingmanClaudeSaidLabel"
                                                       Text="CLAUDE SAID" IsVisible="False"
                                                       Foreground="#9FB4D8" FontSize="11" FontWeight="Bold" />
                                            <TextBlock x:Name="WingmanClaudeVerbatimText" IsVisible="False"
                                                       Foreground="#E8F0FF" FontSize="14"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="WHAT CLAUDE WANTS YOU TO DO NEXT"
                                                       Foreground="#F59E0B" FontSize="11" FontWeight="Bold"
                                                       Margin="0,4,0,0" />
                                            <TextBlock x:Name="WingmanWhatNextText"
                                                       Foreground="#FFFFFF" FontSize="14"
                                                       TextWrapping="Wrap" />
                                            <!-- Tap-to-answer buttons. The briefing's `actions`
                                                 (Session.CachedQuickReplies) are the literal replies
                                                 the user can send back; clicking one routes through
                                                 the normal send path. Populated in code-behind;
                                                 hidden when there are no clear short answers. -->
                                            <WrapPanel x:Name="WingmanActionsPanel"
                                                       Orientation="Horizontal"
                                                       Margin="0,6,0,0" IsVisible="False" />
                                            <!-- "If you do nothing" - the single most triage-relevant
                                                 fact, from the gateway brief's NeedsYou.IfIgnored.
                                                 Hidden for the local explain (which has no such field). -->
                                            <TextBlock x:Name="WingmanIfIgnoredText" IsVisible="False"
                                                       Foreground="#C9B58A" FontSize="12" FontStyle="Italic"
                                                       TextWrapping="Wrap" Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Border>

                                    <!-- WHAT HAPPENED is intentionally NOT rendered on the desktop
                                         Wingman tab. The Opus "what happened" paraphrase exists for
                                         surfaces that cannot show Claude's reply (phone, voice mode),
                                         where it is the only content. On the desktop the verbatim
                                         final answer renders in full in the CleanView below, so a
                                         paraphrase on top of it is pure duplication. The briefing
                                         fields (CachedExplainWhatHappened / LongDescription) are still
                                         generated and consumed by the phone; they are just not drawn
                                         here. Headline + WHAT CLAUDE WANTS + the verbatim answer are
                                         the desktop's three layers: glance, action, substance. -->

                                    <!-- VOICE PREVIEW - shown for testing so we can read what
                                         TTS would say AND hear it on demand via the Speak button.
                                         Normally this content would be hidden behind voice mode. -->
                                    <Border x:Name="WingmanVoiceSection" IsVisible="False"
                                            Background="#1B2A3A"
                                            BorderBrush="#3B82F6" BorderThickness="1"
                                            CornerRadius="4" Padding="10,8">
                                        <StackPanel Spacing="6">
                                            <DockPanel>
                                                <TextBlock Text="VOICE PREVIEW (what Play reads aloud)"
                                                           Foreground="#3B82F6" FontSize="11" FontWeight="Bold"
                                                           VerticalAlignment="Center" />
                                                <!-- Playback control. Distinct from the green "Speak"
                                                     (dictation) button in the input bar: this one is a
                                                     blue play triangle that reads the briefing aloud and
                                                     opens a modal you can Stop. -->
                                                <Button x:Name="WingmanSpeakVoiceButton"
                                                        DockPanel.Dock="Right"
                                                        Padding="10,3"
                                                        Background="#3B82F6" Foreground="White"
                                                        FontSize="11" FontWeight="SemiBold"
                                                        BorderThickness="0" CornerRadius="3"
                                                        Cursor="Hand"
                                                        Click="WingmanSpeakVoiceButton_Click"
                                                        ToolTip.Tip="Play the briefing aloud. Opens a player with a Stop button.">
                                                    <StackPanel Orientation="Horizontal" Spacing="6"
                                                                VerticalAlignment="Center">
                                                        <Path Data="M0,0 L8,5 L0,10 Z" Fill="White"
                                                              VerticalAlignment="Center" />
                                                        <TextBlock Text="Play" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </Button>
                                            </DockPanel>
                                            <TextBlock x:Name="WingmanVoiceText"
                                                       Foreground="#CCCCCC" FontSize="13" FontStyle="Italic"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <Border DockPanel.Dock="Bottom"
                                    Background="{DynamicResource SidebarBackground}"
                                    BorderBrush="#3C3C3C" BorderThickness="0,1,0,0"
                                    Padding="8,6">
                                <Grid ColumnDefinitions="*,Auto,Auto">
                                    <TextBox x:Name="WingmanInput" Grid.Column="0"
                                             Watermark="Type or Speak to the agent..."
                                             AcceptsReturn="True" TextWrapping="Wrap"
                                             MinHeight="48" MaxHeight="120"
                                             Background="#1E1E1E"
                                             Foreground="{DynamicResource TextForeground}"
                                             BorderBrush="#3C3C3C" Padding="8,6"
                                             FontFamily="Cascadia Mono,Consolas,monospace"
                                             FontSize="13" />
                                    <Button x:Name="WingmanSpeakButton" Grid.Column="1"
                                            Content="Speak" Width="80" Height="32"
                                            Margin="8,0,4,0" VerticalAlignment="Bottom"
                                            Background="#16A34A" Foreground="White"
                                            HorizontalContentAlignment="Center" FontSize="13"
                                            Click="WingmanSpeakButton_Click" />
                                    <Button x:Name="WingmanSendButton" Grid.Column="2"
                                            Content="Send" Width="80" Height="32"
                                            VerticalAlignment="Bottom"
                                            Background="{DynamicResource AccentBrush}" Foreground="White"
                                            HorizontalContentAlignment="Center" FontSize="13"
                                            Click="WingmanSendButton_Click" />
                                </Grid>
                            </Border>
                            <controls:CleanView x:Name="CleanView" />
                        </DockPanel>
                    </Panel>

                    <Panel x:Name="HistoryPanel" IsVisible="False">
                        <controls:HistoryView x:Name="HistoryView" />
                    </Panel>

                    <!-- Document viewer panel (dynamic content swapped per tab) -->
                    <Panel x:Name="DocumentPanel" IsVisible="False" />
                </Panel>

                <!-- ==================== NOTIFICATION BAR ==================== -->
                <Border x:Name="NotificationBar" Grid.Row="2"
                        Background="{DynamicResource SidebarBackground}"
                        BorderBrush="#3C3C3C" BorderThickness="0,1,0,0"
                        Padding="8,4"
                        IsVisible="False">
                    <StackPanel Spacing="5">
                        <DockPanel>
                            <TextBlock x:Name="NotificationIcon" DockPanel.Dock="Left"
                                       Text="(i)"
                                       Foreground="#3B82F6"
                                       FontSize="12" FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"
                                       IsVisible="False" />
                            <TextBlock x:Name="NotificationText"
                                       Text=""
                                       Foreground="{DynamicResource TextForeground}"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" />
                        </DockPanel>
                        <!-- Download progress (auto-update). Hidden for plain notifications. -->
                        <ProgressBar x:Name="NotificationProgress"
                                     Height="6" Minimum="0" Maximum="100" Value="0"
                                     Foreground="{DynamicResource AccentBrush}"
                                     Background="#1E1E1E"
                                     IsVisible="False" />
                        <TextBlock x:Name="NotificationProgressMeta"
                                   Text=""
                                   FontSize="10" Foreground="#888888"
                                   FontFamily="Cascadia Mono,Consolas,monospace"
                                   IsVisible="False" />
                    </StackPanel>
                </Border>

                <!-- ==================== PROMPT BAR ==================== -->
                <Border Grid.Row="3"
                        x:Name="PromptBarBorder"
                        Background="{DynamicResource SidebarBackground}"
                        BorderBrush="#3C3C3C" BorderThickness="0,1,0,0"
                        Padding="8,6"
                        IsVisible="False">
                  <StackPanel Spacing="6">
                    <!-- Driver-capability action buttons (Stop / Interrupt / Clear
                         context / History) - rendered from the active session's
                         agent-driver flags, see Controls/SessionActionBar. -->
                    <controls:SessionActionBar x:Name="ActionBar" />
                    <Panel>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox x:Name="PromptInput"
                                     Grid.Column="0"
                                     Watermark="Type a message..."
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MinHeight="98"
                                     MaxHeight="200"
                                     Background="#1E1E1E"
                                     Foreground="{DynamicResource TextForeground}"
                                     BorderBrush="#3C3C3C"
                                     Padding="8,6"
                                     FontFamily="Cascadia Mono,Consolas,monospace"
                                     FontSize="13"
                                     DragDrop.AllowDrop="True" />

                            <!-- Expand into the large editor + image preview. Overlaid in the
                                 top-right corner of the input so it adds no button-bar clutter. -->
                            <Button x:Name="PromptExpandButton"
                                    Grid.Column="0"
                                    Content="Expand"
                                    Click="PromptExpand_Click"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="0,4,6,0"
                                    Padding="6,2"
                                    FontSize="10"
                                    Background="#2D2D30"
                                    Foreground="#AAAAAA"
                                    BorderThickness="0"
                                    Opacity="0.85"
                                    Cursor="Hand"
                                    ToolTip.Tip="Open the large editor with image preview (text + pictures)" />

                            <!-- Ask the Wingman to read this session and explain, in plain
                                 language, what happened and what the agent wants. Overlaid in
                                 the bottom-left corner of the input so it stays clear of the
                                 Speak/Send cluster. Same read-only briefing the FIFO uses. -->
                            <Button x:Name="BtnExplain"
                                    Grid.Column="0"
                                    Content="Explain"
                                    IsVisible="False"
                                    Click="BtnExplain_Click"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Bottom"
                                    Margin="6,0,0,4"
                                    Padding="8,2"
                                    FontSize="10"
                                    Background="#0E7C6B"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Opacity="0.9"
                                    Cursor="Hand"
                                    ToolTip.Tip="Have the Wingman read this session and explain what's happening" />

                            <!-- Vertical action stack: Send (primary) on top, then
                                 Speak, then Queue. Handover is alpha-gated and stays
                                 collapsed unless enabled, so the visible stack is three
                                 buttons tall - matching PromptInput's height. Fixed
                                 width/height per button so the bar can't grow when
                                 PromptInput expands. -->
                            <StackPanel Grid.Column="1"
                                        VerticalAlignment="Bottom"
                                        Margin="8,0,0,0"
                                        Spacing="4">
                                <Button x:Name="BtnSend"
                                        Content="Send"
                                        Width="80" Height="30"
                                        Background="{DynamicResource AccentBrush}"
                                        Foreground="White"
                                        HorizontalContentAlignment="Center"
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        Click="BtnSend_Click" />
                                <Button x:Name="BtnSpeak"
                                        Content="Speak"
                                        Width="80" Height="30"
                                        Background="#16A34A"
                                        Foreground="White"
                                        HorizontalContentAlignment="Center"
                                        FontSize="13"
                                        Click="BtnSpeak_Click"
                                        ToolTip.Tip="Dictate (Ctrl+H from anywhere on the Terminal tab)" />
                                <Button x:Name="BtnQueuePrompt"
                                        Content="Queue"
                                        Width="80" Height="30"
                                        Background="{DynamicResource ButtonBackground}"
                                        Foreground="{DynamicResource TextForeground}"
                                        HorizontalContentAlignment="Center"
                                        FontSize="13"
                                        Click="BtnQueuePrompt_Click"
                                        ToolTip.Tip="Add to prompt queue (Ctrl+Shift+Enter)" />
                                <Button x:Name="BtnHandover"
                                        Content="Handover"
                                        Width="80" Height="30"
                                        Background="#2D2D30"
                                        Foreground="#AAAAAA"
                                        HorizontalContentAlignment="Center"
                                        FontSize="13"
                                        Click="BtnHandover_Click"
                                        ToolTip.Tip="Create a handover document for this session" />
                            </StackPanel>
                        </Grid>

                        <!-- Slash command autocomplete popup -->
                        <Popup x:Name="SlashCommandPopup"
                               PlacementTarget="{Binding #PromptInput}"
                               Placement="Top"
                               IsLightDismissEnabled="False">
                            <Border Background="#252526"
                                    BorderBrush="#3C3C3C"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    MinWidth="700"
                                    MaxWidth="900"
                                    MaxHeight="420">
                                <Grid ColumnDefinitions="260,1,*">

                                    <!-- Command list -->
                                    <ListBox x:Name="SlashCommandList"
                                             Grid.Column="0"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             MaxHeight="410"
                                             Tapped="SlashCommandList_Tapped"
                                             SelectionChanged="SlashCommandList_SelectionChanged">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="4,2">
                                                    <TextBlock Text="{Binding Name, StringFormat=/\{0\}}"
                                                               Foreground="White"
                                                               FontFamily="Cascadia Mono,Consolas,monospace"
                                                               FontSize="13" />
                                                    <TextBlock Text="{Binding Description}"
                                                               Foreground="#888888"
                                                               FontSize="11"
                                                               TextTrimming="CharacterEllipsis"
                                                               Margin="0,1,0,0" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <!-- Divider -->
                                    <Border Grid.Column="1" Background="#3C3C3C" />

                                    <!-- Documentation panel -->
                                    <ScrollViewer Grid.Column="2"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <StackPanel x:Name="SlashCommandDocPanel" Margin="12,8"
                                                    IsVisible="False">
                                            <TextBlock x:Name="SlashCommandDocTitle"
                                                       Foreground="White"
                                                       FontFamily="Cascadia Mono,Consolas,monospace"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Margin="0,0,0,4" />
                                            <TextBlock x:Name="SlashCommandDocSource"
                                                       Foreground="#4EC9B0"
                                                       FontSize="11"
                                                       Margin="0,0,0,6" />
                                            <TextBlock x:Name="SlashCommandDocDesc"
                                                       Foreground="{DynamicResource TextForeground}"
                                                       FontSize="12" TextWrapping="Wrap"
                                                       Margin="0,0,0,8" />
                                            <Border Background="#1E1E1E"
                                                    CornerRadius="3"
                                                    Padding="10,8">
                                                <TextBlock x:Name="SlashCommandDocBody"
                                                           Foreground="#D4D4D4"
                                                           FontFamily="Cascadia Mono,Consolas,monospace"
                                                           FontSize="11.5" TextWrapping="Wrap" />
                                            </Border>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </Popup>
                    </Panel>
                  </StackPanel>
                </Border>
            </Grid>

            <!-- ==================== RIGHT PANEL ==================== -->
            <Border x:Name="RightPanel"
                    Grid.Column="1"
                    Width="280"
                    Background="{DynamicResource SidebarBackground}"
                    BorderBrush="#3C3C3C" BorderThickness="1,0,0,0">

              <Grid>
                <!-- Collapse chevron at the TOP-RIGHT of the panel header, mirroring the
                     session rail's toggle. Points right (tuck into the right edge). -->
                <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,3,6,0"
                        ZIndex="5"
                        Classes="panelToggle"
                        Click="RightPanelToggle_Click"
                        ToolTip.Tip="Collapse the right panel">
                    <Viewbox Width="8" Height="12">
                        <Path Data="M 3,2 L 7,7 L 3,12"
                              StrokeThickness="1.6"
                              StrokeLineCap="Round" StrokeJoin="Round" />
                    </Viewbox>
                </Button>

                <TabControl x:Name="RightPanelTabs"
                            Background="Transparent"
                            Padding="0"
                            FontSize="11">
                    <TabControl.Styles>
                        <Style Selector="TabItem">
                            <Setter Property="FontSize" Value="12" />
                            <Setter Property="Padding" Value="8,4" />
                            <Setter Property="MinHeight" Value="28" />
                        </Style>
                    </TabControl.Styles>

                    <!-- ===== Screenshots Tab ===== -->
                    <TabItem Header="Screenshots">
                        <DockPanel>
                            <!-- Top bar -->
                            <Border DockPanel.Dock="Top" Padding="8,6"
                                    BorderBrush="#3C3C3C" BorderThickness="0,0,0,1">
                                <DockPanel>
                                    <Button Content="Clear All" DockPanel.Dock="Right"
                                            Click="BtnClearScreenshots_Click"
                                            Background="Transparent" Foreground="#888888"
                                            BorderThickness="0" FontSize="11" Cursor="Hand"
                                            Padding="6,2" Margin="4,0,0,0" />
                                    <Button Content="Refresh" DockPanel.Dock="Right"
                                            Click="BtnRefreshScreenshots_Click"
                                            Background="Transparent" Foreground="#888888"
                                            BorderThickness="0" FontSize="11" Cursor="Hand"
                                            Padding="6,2" />
                                    <TextBlock Text="SCREENSHOTS"
                                               Foreground="#888888" FontSize="11"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                </DockPanel>
                            </Border>

                            <!-- Screenshot list -->
                            <ListBox x:Name="ScreenshotList"
                                     Background="Transparent"
                                     Padding="4">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="4" Margin="0,2"
                                                Background="#2A2A2A" CornerRadius="4"
                                                PointerPressed="ScreenshotItem_PointerPressed">
                                            <StackPanel>
                                                <Image Source="{Binding Thumbnail}"
                                                       MaxHeight="160"
                                                       Stretch="Uniform" />
                                                <DockPanel Margin="0,4,0,0">
                                                    <TextBlock Text="{Binding TimeLabel}"
                                                               Foreground="#888888" FontSize="10"
                                                               VerticalAlignment="Center" />
                                                    <StackPanel Orientation="Horizontal"
                                                                HorizontalAlignment="Right"
                                                                Spacing="4">
                                                        <Button Content="View"
                                                                Tag="{Binding FilePath}"
                                                                Click="ScreenshotView_Click"
                                                                Background="Transparent"
                                                                Foreground="#CCCCCC"
                                                                BorderThickness="0"
                                                                FontSize="10" Cursor="Hand"
                                                                Padding="4,2" />
                                                        <Button Content="Copy"
                                                                Tag="{Binding FilePath}"
                                                                Click="ScreenshotCopy_Click"
                                                                ToolTip.Tip="Copy image to clipboard"
                                                                Background="Transparent"
                                                                Foreground="#CCCCCC"
                                                                BorderThickness="0"
                                                                FontSize="10" Cursor="Hand"
                                                                Padding="4,2" />
                                                        <Button Content="Issue"
                                                                Tag="{Binding FilePath}"
                                                                Click="ScreenshotCreateIssue_Click"
                                                                ToolTip.Tip="Create GitHub issue with this screenshot"
                                                                Background="Transparent"
                                                                Foreground="#CCCCCC"
                                                                BorderThickness="0"
                                                                FontSize="10" Cursor="Hand"
                                                                Padding="4,2" />
                                                        <Button Content="Del"
                                                                Tag="{Binding FilePath}"
                                                                Click="ScreenshotDelete_Click"
                                                                Background="Transparent"
                                                                Foreground="#CC4444"
                                                                BorderThickness="0"
                                                                FontSize="10" Cursor="Hand"
                                                                Padding="4,2" />
                                                    </StackPanel>
                                                </DockPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </TabItem>

                    <!-- ===== Queue Tab ===== -->
                    <TabItem x:Name="QueueTab" Header="Queue">
                        <DockPanel>
                            <!-- Top bar -->
                            <Border DockPanel.Dock="Top" Padding="8,6"
                                    BorderBrush="#3C3C3C" BorderThickness="0,0,0,1">
                                <DockPanel>
                                    <Button Content="Clear" DockPanel.Dock="Right"
                                            Click="BtnClearQueue_Click"
                                            Background="Transparent" Foreground="#888888"
                                            BorderThickness="0" FontSize="11" Cursor="Hand"
                                            Padding="6,2" />
                                    <TextBlock x:Name="QueueCountText"
                                               Text="0 items"
                                               Foreground="#888888" FontSize="11"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                </DockPanel>
                            </Border>

                            <!-- Empty state -->
                            <TextBlock x:Name="QueueEmptyText"
                                       Text="No queued prompts"
                                       Foreground="#555555" FontSize="12"
                                       FontStyle="Italic"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />

                            <!-- Queue items list -->
                            <ListBox x:Name="QueueItemsList"
                                     Background="Transparent"
                                     Padding="4"
                                     IsVisible="False"
                                     DoubleTapped="QueueItemsList_DoubleTapped">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="6,4" Margin="0,1"
                                                Background="#2A2A2A" CornerRadius="2">
                                            <Grid ColumnDefinitions="20,*,Auto">
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Index}"
                                                           Foreground="#666666" FontSize="11"
                                                           VerticalAlignment="Top" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Preview}"
                                                           Foreground="#CCCCCC" FontSize="11"
                                                           TextWrapping="Wrap" MaxHeight="80"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip.Tip="{Binding FullText}"
                                                           ToolTip.ShowDelay="300"
                                                           ToolTip.Placement="Left" />
                                                <StackPanel Grid.Column="2"
                                                            Orientation="Vertical"
                                                            Spacing="1"
                                                            VerticalAlignment="Top">
                                                    <StackPanel Orientation="Horizontal" Spacing="2">
                                                        <Button Content="/\"
                                                                Tag="{Binding Id}"
                                                                Click="QueueItemMoveUp_Click"
                                                                Background="Transparent"
                                                                Foreground="#888888"
                                                                BorderThickness="0"
                                                                FontSize="9" Cursor="Hand"
                                                                Padding="3,1"
                                                                ToolTip.Tip="Move up" />
                                                        <Button Content="\/"
                                                                Tag="{Binding Id}"
                                                                Click="QueueItemMoveDown_Click"
                                                                Background="Transparent"
                                                                Foreground="#888888"
                                                                BorderThickness="0"
                                                                FontSize="9" Cursor="Hand"
                                                                Padding="3,1"
                                                                ToolTip.Tip="Move down" />
                                                        <Button Content="Edit"
                                                                Tag="{Binding Id}"
                                                                Click="QueueItemEdit_Click"
                                                                Background="Transparent"
                                                                Foreground="#3B82F6"
                                                                BorderThickness="0"
                                                                FontSize="10" Cursor="Hand"
                                                                Padding="4,2"
                                                                ToolTip.Tip="Open in the review editor (text + image preview)" />
                                                        <Button Content="Pop"
                                                                Tag="{Binding Id}"
                                                                Click="QueueItemPop_Click"
                                                                Background="Transparent"
                                                                Foreground="#22C55E"
                                                                BorderThickness="0"
                                                                FontSize="10" Cursor="Hand"
                                                                Padding="4,2" />
                                                        <Button Content="X"
                                                                Tag="{Binding Id}"
                                                                Click="QueueItemRemove_Click"
                                                                Background="Transparent"
                                                                Foreground="#CC4444"
                                                                BorderThickness="0"
                                                                FontSize="10" FontWeight="Bold"
                                                                Cursor="Hand" Padding="4,2" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </TabItem>

                </TabControl>
              </Grid>
            </Border>

            <!-- Collapsed right panel: a thin strip on the right edge with the expand
                 chevron at the TOP (mirrors the session rail's slim strip). Shown instead
                 of the full panel when collapsed; the Auto column sizes to whichever is up. -->
            <Border x:Name="RightPanelCollapsedStrip"
                    Grid.Column="1"
                    Width="22"
                    IsVisible="False"
                    Background="{DynamicResource SidebarBackground}"
                    BorderBrush="#3C3C3C" BorderThickness="1,0,0,0">
                <Button VerticalAlignment="Top" HorizontalAlignment="Center"
                        Margin="0,8,0,0"
                        Classes="panelToggle"
                        Click="RightPanelToggle_Click"
                        ToolTip.Tip="Expand the right panel">
                    <Viewbox Width="8" Height="12">
                        <Path Data="M 7,2 L 3,7 L 7,12"
                              StrokeThickness="1.6"
                              StrokeLineCap="Round" StrokeJoin="Round" />
                    </Viewbox>
                </Button>
            </Border>
        </Grid>

        <!-- ==================== COMMS OVERLAY (covers main + right panel) ==================== -->
        <Border x:Name="CommsOverlay"
                Grid.Row="0" Grid.RowSpan="2" Grid.Column="2"
                Background="{DynamicResource PanelBackground}"
                ZIndex="10"
                IsVisible="False">
            <DockPanel>
                <!-- Header bar -->
                <Border DockPanel.Dock="Top"
                        Background="{DynamicResource SidebarBackground}"
                        BorderBrush="#3C3C3C" BorderThickness="0,0,0,1"
                        Padding="12,8">
                    <DockPanel>
                        <Button x:Name="BtnCommsClose"
                                DockPanel.Dock="Right"
                                Content="[x] Close"
                                Click="BtnCommsClose_Click"
                                Background="Transparent"
                                Foreground="#888888"
                                BorderThickness="0"
                                Cursor="Hand"
                                Padding="8,4"
                                FontSize="12" />
                        <TextBlock Text="Communication Manager"
                                   Foreground="{DynamicResource TextForeground}"
                                   FontSize="16" FontWeight="Bold"
                                   VerticalAlignment="Center" />
                    </DockPanel>
                </Border>

                <!-- CommManagerView fills the rest -->
                <commMgr:CommManagerView x:Name="CommManagerView" />
            </DockPanel>
        </Border>

        <!-- ==================== CONNECTIONS OVERLAY (covers main + right panel) ==================== -->
        <Border x:Name="ConnectionsOverlay"
                Grid.Row="0" Grid.RowSpan="2" Grid.Column="2"
                Background="{DynamicResource PanelBackground}"
                ZIndex="10"
                IsVisible="False">
            <DockPanel>
                <!-- Header bar -->
                <Border DockPanel.Dock="Top"
                        Background="{DynamicResource SidebarBackground}"
                        BorderBrush="#3C3C3C" BorderThickness="0,0,0,1"
                        Padding="12,8">
                    <DockPanel>
                        <Button x:Name="BtnConnectionsClose"
                                DockPanel.Dock="Right"
                                Content="[x] Close"
                                Click="BtnConnectionsClose_Click"
                                Background="Transparent"
                                Foreground="#888888"
                                BorderThickness="0"
                                Cursor="Hand"
                                Padding="8,4"
                                FontSize="12" />
                        <TextBlock Text="Browser Connections"
                                   Foreground="{DynamicResource TextForeground}"
                                   FontSize="16" FontWeight="Bold"
                                   VerticalAlignment="Center" />
                    </DockPanel>
                </Border>

                <!-- ConnectionsView fills the rest -->
                <controls:ConnectionsView x:Name="ConnectionsView" />
            </DockPanel>
        </Border>

        <!-- ==================== SCHEDULER OVERLAY (covers main + right panel) ==================== -->
        <Border x:Name="SchedulerOverlay"
                Grid.Row="0" Grid.RowSpan="2" Grid.Column="2"
                Background="{DynamicResource PanelBackground}"
                ZIndex="10"
                IsVisible="False">
            <DockPanel>
                <Border DockPanel.Dock="Top"
                        Background="{DynamicResource SidebarBackground}"
                        BorderBrush="#3C3C3C" BorderThickness="0,0,0,1"
                        Padding="12,8">
                    <DockPanel>
                        <Button x:Name="BtnSchedulerClose"
                                DockPanel.Dock="Right"
                                Content="[x] Close"
                                Click="BtnSchedulerClose_Click"
                                Background="Transparent"
                                Foreground="#888888"
                                BorderThickness="0"
                                Cursor="Hand"
                                Padding="8,4"
                                FontSize="12" />
                        <TextBlock Text="Scheduler"
                                   Foreground="{DynamicResource TextForeground}"
                                   FontSize="16" FontWeight="Bold"
                                   VerticalAlignment="Center" />
                    </DockPanel>
                </Border>

                <controls:SchedulerView x:Name="SchedulerView" />
            </DockPanel>
        </Border>

        <!-- The Tools catalog is no longer a standalone in-window overlay: it now lives as the
             Tools tab inside the Settings dialog (one screen, status + repair together). The
             toolbar "Tools" button and the rail tools indicator both open Settings on that tab. -->

        <!-- ==================== PASTE-REMINDER CARD ====================
             Floating card shown after "create GitHub issue from screenshot" opens
             the browser: the screenshot is waiting on the clipboard for a manual
             Ctrl+V (no application is allowed to paste into a browser page itself,
             so this is the unavoidable manual step). Auto-hides after a while;
             the X dismisses it immediately. -->
        <Border x:Name="PasteCard"
                Grid.Row="1" Grid.Column="2"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0,0,24,24"
                MaxWidth="400"
                Background="#252526"
                BorderBrush="#007ACC" BorderThickness="1"
                CornerRadius="6"
                ZIndex="20"
                IsVisible="False">
            <DockPanel Margin="14,10,8,12">
                <Button DockPanel.Dock="Right"
                        Content="X"
                        Click="PasteCardClose_Click"
                        VerticalAlignment="Top"
                        Background="Transparent"
                        Foreground="#888888"
                        BorderThickness="0"
                        FontSize="11" Cursor="Hand"
                        Padding="6,2" />
                <StackPanel Spacing="4" Margin="0,0,8,0">
                    <TextBlock x:Name="PasteCardTitle"
                               Foreground="#CCCCCC"
                               FontSize="13" FontWeight="Bold" />
                    <TextBlock x:Name="PasteCardBody"
                               Foreground="#AAAAAA"
                               FontSize="12"
                               TextWrapping="Wrap" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ==================== STATUS / HOME ====================
             Status screen shown in the MAIN CONTENT cell (row 1, column 2) when no session
             is selected, or on demand via View > Status. The window chrome - toolbar and the
             session rail (with the gateway light at its bottom) - stays visible around it.
             It overlays the terminal content (higher ZIndex) and has an opaque background. -->
        <controls:HomeView x:Name="HomeView"
                           Grid.Row="1" Grid.Column="2"
                           ZIndex="30"
                           IsVisible="False" />

    </Grid>
    </DockPanel>
</Window>
