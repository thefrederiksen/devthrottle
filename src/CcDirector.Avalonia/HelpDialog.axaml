<Window x:Class="CcDirector.Avalonia.HelpDialog"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About CC Director"
        Width="600" Height="560"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="#252526">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="About CC Director"
                   Foreground="#CCCCCC"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12" />

        <!-- Scrollable content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- About This Instance Section -->
                <TextBlock Text="ABOUT THIS INSTANCE"
                           Foreground="#007ACC"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8" />

                <!-- Rows are populated from code-behind (HelpDialog.RenderRows) so the
                     displayed values and the "Copy info" text are built from one source. -->
                <StackPanel x:Name="AboutPanel" Margin="0,0,0,4" />

                <!-- Separator -->
                <Border BorderBrush="#3C3C3C" BorderThickness="0,1,0,0" Margin="0,12,0,12" />

                <!-- Slash Commands Section -->
                <TextBlock Text="SLASH COMMANDS"
                           Foreground="#007ACC"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8" />

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="/help" Foreground="#CCCCCC" FontSize="12"
                               FontFamily="Cascadia Mono, Consolas" />
                    <TextBlock Grid.Column="1" Text="Show help" Foreground="#AAAAAA" FontSize="12" />
                </Grid>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="/config" Foreground="#CCCCCC" FontSize="12"
                               FontFamily="Cascadia Mono, Consolas" />
                    <TextBlock Grid.Column="1" Text="Open settings" Foreground="#AAAAAA" FontSize="12" />
                </Grid>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="/status" Foreground="#CCCCCC" FontSize="12"
                               FontFamily="Cascadia Mono, Consolas" />
                    <TextBlock Grid.Column="1" Text="Show status info" Foreground="#AAAAAA" FontSize="12" />
                </Grid>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="/model" Foreground="#CCCCCC" FontSize="12"
                               FontFamily="Cascadia Mono, Consolas" />
                    <TextBlock Grid.Column="1" Text="Change AI model" Foreground="#AAAAAA" FontSize="12" />
                </Grid>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="/theme" Foreground="#CCCCCC" FontSize="12"
                               FontFamily="Cascadia Mono, Consolas" />
                    <TextBlock Grid.Column="1" Text="Change color theme" Foreground="#AAAAAA" FontSize="12" />
                </Grid>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="/memory" Foreground="#CCCCCC" FontSize="12"
                               FontFamily="Cascadia Mono, Consolas" />
                    <TextBlock Grid.Column="1" Text="Edit CLAUDE.md files" Foreground="#AAAAAA" FontSize="12" />
                </Grid>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="/stats" Foreground="#CCCCCC" FontSize="12"
                               FontFamily="Cascadia Mono, Consolas" />
                    <TextBlock Grid.Column="1" Text="View usage statistics" Foreground="#AAAAAA" FontSize="12" />
                </Grid>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="/context" Foreground="#CCCCCC" FontSize="12"
                               FontFamily="Cascadia Mono, Consolas" />
                    <TextBlock Grid.Column="1" Text="Show token usage (Terminal only)" Foreground="#888888" FontSize="12" />
                </Grid>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="/copy" Foreground="#CCCCCC" FontSize="12"
                               FontFamily="Cascadia Mono, Consolas" />
                    <TextBlock Grid.Column="1" Text="Copy code blocks (Terminal only)" Foreground="#888888" FontSize="12" />
                </Grid>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="/diff" Foreground="#CCCCCC" FontSize="12"
                               FontFamily="Cascadia Mono, Consolas" />
                    <TextBlock Grid.Column="1" Text="View pending changes (Terminal only)" Foreground="#888888" FontSize="12" />
                </Grid>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="/rewind" Foreground="#CCCCCC" FontSize="12"
                               FontFamily="Cascadia Mono, Consolas" />
                    <TextBlock Grid.Column="1" Text="Rewind conversation (Terminal only)" Foreground="#888888" FontSize="12" />
                </Grid>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="/export" Foreground="#CCCCCC" FontSize="12"
                               FontFamily="Cascadia Mono, Consolas" />
                    <TextBlock Grid.Column="1" Text="Export conversation (Terminal only)" Foreground="#888888" FontSize="12" />
                </Grid>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="/resume" Foreground="#CCCCCC" FontSize="12"
                               FontFamily="Cascadia Mono, Consolas" />
                    <TextBlock Grid.Column="1" Text="Resume a previous session" Foreground="#AAAAAA" FontSize="12" />
                </Grid>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="/permissions" Foreground="#CCCCCC" FontSize="12"
                               FontFamily="Cascadia Mono, Consolas" />
                    <TextBlock Grid.Column="1" Text="Manage tool permissions" Foreground="#AAAAAA" FontSize="12" />
                </Grid>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="/hooks" Foreground="#CCCCCC" FontSize="12"
                               FontFamily="Cascadia Mono, Consolas" />
                    <TextBlock Grid.Column="1" Text="View configured hooks" Foreground="#AAAAAA" FontSize="12" />
                </Grid>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="/plugin" Foreground="#CCCCCC" FontSize="12"
                               FontFamily="Cascadia Mono, Consolas" />
                    <TextBlock Grid.Column="1" Text="Toggle plugins" Foreground="#AAAAAA" FontSize="12" />
                </Grid>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="/mcp" Foreground="#CCCCCC" FontSize="12"
                               FontFamily="Cascadia Mono, Consolas" />
                    <TextBlock Grid.Column="1" Text="MCP server status (Terminal only)" Foreground="#888888" FontSize="12" />
                </Grid>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="/agents" Foreground="#CCCCCC" FontSize="12"
                               FontFamily="Cascadia Mono, Consolas" />
                    <TextBlock Grid.Column="1" Text="Agent configuration (Terminal only)" Foreground="#888888" FontSize="12" />
                </Grid>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="/output-style" Foreground="#CCCCCC" FontSize="12"
                               FontFamily="Cascadia Mono, Consolas" />
                    <TextBlock Grid.Column="1" Text="Change output style" Foreground="#AAAAAA" FontSize="12" />
                </Grid>

                <!-- Separator -->
                <Border BorderBrush="#3C3C3C" BorderThickness="0,1,0,0" Margin="0,12,0,12" />

                <!-- Keyboard Shortcuts Section -->
                <TextBlock Text="KEYBOARD SHORTCUTS"
                           Foreground="#007ACC"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8" />

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Ctrl+C" Foreground="#CCCCCC" FontSize="12"
                               FontFamily="Cascadia Mono, Consolas" />
                    <TextBlock Grid.Column="1" Text="Interrupt current operation" Foreground="#AAAAAA" FontSize="12" />
                </Grid>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Escape (x2)" Foreground="#CCCCCC" FontSize="12"
                               FontFamily="Cascadia Mono, Consolas" />
                    <TextBlock Grid.Column="1" Text="Force quit / new conversation" Foreground="#AAAAAA" FontSize="12" />
                </Grid>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Tab" Foreground="#CCCCCC" FontSize="12"
                               FontFamily="Cascadia Mono, Consolas" />
                    <TextBlock Grid.Column="1" Text="Accept autocomplete suggestion" Foreground="#AAAAAA" FontSize="12" />
                </Grid>

            </StackPanel>
        </ScrollViewer>

        <!-- Action buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="BtnCopyInfo" Content="Copy info" Width="110" Height="28"
                    Background="#3C3C3C" Foreground="#CCCCCC"
                    BorderThickness="0" Cursor="Hand"
                    Margin="0,0,8,0"
                    Click="BtnCopyInfo_Click" />
            <Button Content="Close" Width="80" Height="28"
                    Background="#3C3C3C" Foreground="#CCCCCC"
                    BorderThickness="0" Cursor="Hand"
                    Click="BtnClose_Click" />
        </StackPanel>
    </Grid>
</Window>
