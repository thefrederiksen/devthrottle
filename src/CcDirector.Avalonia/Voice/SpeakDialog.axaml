<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CcDirector.Avalonia.Voice.SpeakDialog"
        Title="Dictate"
        Width="640" Height="560"
        MinWidth="540" MinHeight="416"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        ShowInTaskbar="False"
        Background="#1E1E1E">

    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="16">

        <!-- Microphone selector. Shows the active capture device by name and
             lets the user switch mics (e.g. when the default one is silent).
             The list is populated in code; selection changes restart capture
             on the chosen device. -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="0,0,0,12" VerticalAlignment="Center">
            <TextBlock Grid.Column="0" Text="Mic"
                       Foreground="#888888"
                       FontFamily="Cascadia Mono,Consolas,monospace"
                       FontSize="12"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0" />
            <ComboBox x:Name="MicSelector" Grid.Column="1"
                      HorizontalAlignment="Stretch"
                      FontSize="12"
                      SelectionChanged="MicSelector_SelectionChanged">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </Grid>

        <!-- Status row -->
        <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,12">
            <!-- Opens in the CONNECTING state (yellow): the mic is already
                 capturing (capture-first pipeline) but the transcription
                 backend is not connected yet. SwitchToRecording flips these
                 red once the session is live. -->
            <TextBlock x:Name="StatusLabel" Grid.Column="0"
                       Text="CONNECTING"
                       FontFamily="Cascadia Mono,Consolas,monospace"
                       FontSize="20" FontWeight="Bold"
                       Foreground="#DCDCAA"
                       VerticalAlignment="Center" />
            <TextBlock x:Name="TimerLabel" Grid.Column="2"
                       Text="0:00.0"
                       FontFamily="Cascadia Mono,Consolas,monospace"
                       FontSize="22" FontWeight="SemiBold"
                       Foreground="#DCDCAA"
                       VerticalAlignment="Center" />
        </Grid>

        <!-- Center stage: equalizer + low-level hint + transcript area -->
        <Grid Grid.Row="2" RowDefinitions="Auto,Auto,*">
            <!-- 9-bar equalizer. Each red bar sits inside a fixed-height gray
                 "track well" so the full range (floor to ceiling) is always
                 visible; the red bar fills the well from the bottom. The well
                 height (92) matches the maxH used in OnAudioBands. -->
            <StackPanel Grid.Row="0" Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="6"
                        Height="100"
                        Margin="0,0,0,4">
                <Border Width="12" Height="92" Background="#33333A" CornerRadius="3" VerticalAlignment="Center">
                    <Border x:Name="Bar0" Height="8" Background="#F44747" CornerRadius="3" VerticalAlignment="Bottom" />
                </Border>
                <Border Width="12" Height="92" Background="#33333A" CornerRadius="3" VerticalAlignment="Center">
                    <Border x:Name="Bar1" Height="8" Background="#F44747" CornerRadius="3" VerticalAlignment="Bottom" />
                </Border>
                <Border Width="12" Height="92" Background="#33333A" CornerRadius="3" VerticalAlignment="Center">
                    <Border x:Name="Bar2" Height="8" Background="#F44747" CornerRadius="3" VerticalAlignment="Bottom" />
                </Border>
                <Border Width="12" Height="92" Background="#33333A" CornerRadius="3" VerticalAlignment="Center">
                    <Border x:Name="Bar3" Height="8" Background="#F44747" CornerRadius="3" VerticalAlignment="Bottom" />
                </Border>
                <Border Width="12" Height="92" Background="#33333A" CornerRadius="3" VerticalAlignment="Center">
                    <Border x:Name="Bar4" Height="8" Background="#F44747" CornerRadius="3" VerticalAlignment="Bottom" />
                </Border>
                <Border Width="12" Height="92" Background="#33333A" CornerRadius="3" VerticalAlignment="Center">
                    <Border x:Name="Bar5" Height="8" Background="#F44747" CornerRadius="3" VerticalAlignment="Bottom" />
                </Border>
                <Border Width="12" Height="92" Background="#33333A" CornerRadius="3" VerticalAlignment="Center">
                    <Border x:Name="Bar6" Height="8" Background="#F44747" CornerRadius="3" VerticalAlignment="Bottom" />
                </Border>
                <Border Width="12" Height="92" Background="#33333A" CornerRadius="3" VerticalAlignment="Center">
                    <Border x:Name="Bar7" Height="8" Background="#F44747" CornerRadius="3" VerticalAlignment="Bottom" />
                </Border>
                <Border Width="12" Height="92" Background="#33333A" CornerRadius="3" VerticalAlignment="Center">
                    <Border x:Name="Bar8" Height="8" Background="#F44747" CornerRadius="3" VerticalAlignment="Bottom" />
                </Border>
            </StackPanel>

            <!-- Low-level hint. Shown (amber) only while recording when the
                 input is voice-present but too quiet for clean capture. The
                 row keeps a reserved height (empty text when healthy) so the
                 layout does not jump when it toggles. -->
            <TextBlock x:Name="LevelHint" Grid.Row="1"
                       Text=""
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="#DCDCAA"
                       FontFamily="Cascadia Mono,Consolas,monospace"
                       FontSize="12"
                       MinHeight="18"
                       Margin="0,0,0,8" />

            <!-- Transcript area. Whole-audio batch (issue #589): NO live preview,
                 so the box stays blank while recording (its watermark shows
                 through) and only fills in when the user reaches a checkpoint -
                 Pause, Insert, or Send. It is read-only while recording and
                 transcribing, and editable in the PAUSED stage so the user can
                 fix mis-heard words before committing or resuming. The watermark
                 explains the batch model so the empty box does not read as
                 broken. AllowAutoHide="False" keeps the scrollbar pinned on
                 overflow instead of Avalonia's collapsing overlay bar. -->
            <TextBox x:Name="TranscriptText"
                     Grid.Row="2"
                     Watermark="Speak naturally - your words are turned into text when you pause or finish, not while you talk (it is more accurate that way). Press Pause any time to see what you have said so far."
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     Background="#252526"
                     Foreground="#DDDDDD"
                     BorderBrush="#3C3C3C" BorderThickness="1"
                     CornerRadius="6"
                     Padding="12,8"
                     FontFamily="Cascadia Mono,Consolas,monospace"
                     FontSize="13"
                     VerticalContentAlignment="Top"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.AllowAutoHide="False" />
        </Grid>

        <!-- Action bar. Split into two groups: recording controls / back-out
             on the LEFT (Cancel, Pause/Resume) and commit actions on the RIGHT
             (Insert, Send). The distance keeps Pause away from Send to avoid
             mis-clicks. State signalling comes from the StatusLabel + equalizer
             color (Recording->Transcribing->Paused), so we don't carry a
             separate hint TextBlock down here. -->
        <Grid Grid.Row="3" ColumnDefinitions="Auto,*,Auto" Margin="0,16,0,0">
            <!-- Left group: control the recording / back out -->
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Left"
                        Spacing="10">
                <Button x:Name="CancelButton"
                        Content="Cancel"
                        Width="84" Height="32"
                        Background="#2D2D30"
                        Foreground="#CCCCCC"
                        HorizontalContentAlignment="Center"
                        Click="CancelButton_Click" />
                <!-- Pause / Resume: a batch checkpoint. Pause stops the mic,
                     transcribes the current segment, appends it to the
                     transcript, and shows it (editable) without ending the turn;
                     it is disabled while transcribing ("you cannot resume until
                     it has been transcribed"). Resume starts a fresh segment that
                     appends to the (possibly edited) text. Neutral chrome, the
                     two-bar pause glyph built from Rectangles to avoid Unicode;
                     PauseButton.Content is rebuilt in code (BuildPauseIcon /
                     "Resume" text) as the state changes. -->
                <Button x:Name="PauseButton"
                        Width="100" Height="32"
                        Background="#2D2D30"
                        Foreground="#CCCCCC"
                        HorizontalContentAlignment="Center"
                        Click="PauseButton_Click">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="5">
                        <Rectangle Width="4" Height="14" Fill="#CCCCCC" />
                        <Rectangle Width="4" Height="14" Fill="#CCCCCC" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- Right group: commit -->
            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="10">
                <!-- Stop button kept its x:Name so existing code-behind references
                     still resolve; the visible label is "Insert" (inserts the
                     transcript at the caret without auto-submitting). -->
                <Button x:Name="StopButton"
                        Content="Insert"
                        Width="84" Height="32"
                        Background="#16A34A"
                        Foreground="White"
                        FontWeight="SemiBold"
                        HorizontalContentAlignment="Center"
                        Click="StopButton_Click" />
                <Button x:Name="PrimaryButton"
                        Content="Send"
                        Width="100" Height="32"
                        Background="#007ACC"
                        Foreground="White"
                        FontWeight="SemiBold"
                        HorizontalContentAlignment="Center"
                        Click="PrimaryButton_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
