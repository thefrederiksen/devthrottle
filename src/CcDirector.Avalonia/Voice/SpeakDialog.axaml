<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CcDirector.Avalonia.Voice.SpeakDialog"
        Title="Dictate"
        Width="540" Height="320"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False"
        Background="#1E1E1E">

    <Grid RowDefinitions="Auto,*,Auto" Margin="16">

        <!-- Status row -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,12">
            <TextBlock x:Name="StatusLabel" Grid.Column="0"
                       Text="RECORDING"
                       FontFamily="Cascadia Mono,Consolas,monospace"
                       FontSize="20" FontWeight="Bold"
                       Foreground="#F44747"
                       VerticalAlignment="Center" />
            <TextBlock x:Name="TimerLabel" Grid.Column="2"
                       Text="0:00.0"
                       FontFamily="Cascadia Mono,Consolas,monospace"
                       FontSize="22" FontWeight="SemiBold"
                       Foreground="#F44747"
                       VerticalAlignment="Center" />
        </Grid>

        <!-- Center stage: equalizer + transcript area -->
        <Grid Grid.Row="1" RowDefinitions="Auto,*">
            <!-- 9-bar equalizer -->
            <StackPanel Grid.Row="0" Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="6"
                        Height="64"
                        Margin="0,0,0,12">
                <Border x:Name="Bar0" Width="10" Height="6" Background="#F44747" CornerRadius="3" VerticalAlignment="Bottom" />
                <Border x:Name="Bar1" Width="10" Height="6" Background="#F44747" CornerRadius="3" VerticalAlignment="Bottom" />
                <Border x:Name="Bar2" Width="10" Height="6" Background="#F44747" CornerRadius="3" VerticalAlignment="Bottom" />
                <Border x:Name="Bar3" Width="10" Height="6" Background="#F44747" CornerRadius="3" VerticalAlignment="Bottom" />
                <Border x:Name="Bar4" Width="10" Height="6" Background="#F44747" CornerRadius="3" VerticalAlignment="Bottom" />
                <Border x:Name="Bar5" Width="10" Height="6" Background="#F44747" CornerRadius="3" VerticalAlignment="Bottom" />
                <Border x:Name="Bar6" Width="10" Height="6" Background="#F44747" CornerRadius="3" VerticalAlignment="Bottom" />
                <Border x:Name="Bar7" Width="10" Height="6" Background="#F44747" CornerRadius="3" VerticalAlignment="Bottom" />
                <Border x:Name="Bar8" Width="10" Height="6" Background="#F44747" CornerRadius="3" VerticalAlignment="Bottom" />
            </StackPanel>

            <!-- Transcript area (used both for live partials during recording AND
                 final cleaned text after stop). -->
            <Border Grid.Row="1"
                    Background="#252526"
                    BorderBrush="#3C3C3C" BorderThickness="1"
                    CornerRadius="6"
                    Padding="12,8">
                <ScrollViewer>
                    <TextBlock x:Name="TranscriptText"
                               Text="(your words will appear here)"
                               Foreground="#888888"
                               FontFamily="Cascadia Mono,Consolas,monospace"
                               FontSize="13"
                               TextWrapping="Wrap" />
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Action bar. State signalling comes from the StatusLabel + equalizer
             dots up top (color shift Recording->Transcribing->Paused), so we
             don't carry a separate hint TextBlock down here; it just cramped
             the buttons. -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0"
                    Spacing="10">
            <Button x:Name="CancelButton"
                    Content="Cancel"
                    Width="84" Height="32"
                    Background="#2D2D30"
                    Foreground="#CCCCCC"
                    HorizontalContentAlignment="Center"
                    Click="CancelButton_Click" />
            <!-- Pause: neutral chrome, two-bar pause glyph built from Rectangles
                 so we avoid Unicode. PauseButton.Content is rebuilt in code
                 (BuildPauseIcon / "Resume" text) when state changes. -->
            <Button x:Name="PauseButton"
                    Width="84" Height="32"
                    Background="#2D2D30"
                    Foreground="#CCCCCC"
                    HorizontalContentAlignment="Center"
                    Click="PauseButton_Click">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="5">
                    <Rectangle Width="4" Height="14" Fill="#CCCCCC" />
                    <Rectangle Width="4" Height="14" Fill="#CCCCCC" />
                </StackPanel>
            </Button>
            <!-- Stop button kept its x:Name so existing code-behind references
                 still resolve; the visible label is "Insert" (inserts the
                 transcript at the caret without auto-submitting). -->
            <Button x:Name="StopButton"
                    Content="Insert"
                    Width="84" Height="32"
                    Background="#16A34A"
                    Foreground="White"
                    FontWeight="SemiBold"
                    HorizontalContentAlignment="Center"
                    Click="StopButton_Click" />
            <Button x:Name="PrimaryButton"
                    Content="Send"
                    Width="100" Height="32"
                    Background="#007ACC"
                    Foreground="White"
                    FontWeight="SemiBold"
                    HorizontalContentAlignment="Center"
                    Click="PrimaryButton_Click" />
        </StackPanel>
    </Grid>
</Window>
