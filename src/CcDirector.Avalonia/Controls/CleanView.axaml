<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:CcDirector.Avalonia.Controls"
             x:Class="CcDirector.Avalonia.Controls.CleanView"
             Background="#1E1E1E">
    <UserControl.Styles>
        <!-- Custom Expander style with text chevron instead of default arrow -->
        <Style Selector="Expander.tool-expander /template/ ToggleButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="Expander.tool-expander">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <!-- Chevron text: "v" when collapsed, "^" when expanded -->
        <Style Selector="Expander.tool-expander TextBlock.chevron">
            <Setter Property="Text" Value="v" />
        </Style>
        <Style Selector="Expander.tool-expander:expanded TextBlock.chevron">
            <Setter Property="Text" Value="^" />
        </Style>
        <!-- Chevron hover: brighten on hover -->
        <Style Selector="Expander.tool-expander:pointerover TextBlock.chevron">
            <Setter Property="Foreground" Value="#AAAAAA" />
        </Style>
    </UserControl.Styles>

    <UserControl.Resources>

        <!-- ===== TEXT WIDGET - Assistant text messages ===== -->
        <DataTemplate x:Key="TextWidgetTemplate" DataType="controls:CleanWidgetViewModel">
            <Border Background="{Binding CardBackground}"
                    BorderBrush="{Binding CardBorderBrush}"
                    BorderThickness="1" CornerRadius="6"
                    Margin="{Binding CardMargin}" Padding="12,10">
                <StackPanel>
                    <!-- Header -->
                    <StackPanel Orientation="Horizontal">
                        <Border Background="{Binding IconBackground}"
                                CornerRadius="4" Width="26" Height="26"
                                Margin="0,0,8,0">
                            <TextBlock Text="{Binding IconText}" Foreground="White"
                                       FontFamily="Cascadia Mono,Consolas,monospace" FontSize="11"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="{Binding Header}"
                                   Foreground="#E0E0E0" FontSize="12" FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <!-- Content (plain text) -->
                    <TextBlock Text="{Binding Content}"
                               Foreground="#CCCCCC"
                               FontSize="13" TextWrapping="Wrap"
                               Margin="0,8,0,0" LineHeight="20" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- ===== THINKING WIDGET - Collapsible thinking block ===== -->
        <DataTemplate x:Key="ThinkingWidgetTemplate" DataType="controls:CleanWidgetViewModel">
            <Border Background="{Binding CardBackground}"
                    BorderBrush="{Binding CardBorderBrush}"
                    BorderThickness="1" CornerRadius="6"
                    Margin="{Binding CardMargin}" Padding="12,10"
                    Opacity="0.6">
                <Expander Classes="tool-expander" IsExpanded="False">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="v"
                                       Foreground="#666666"
                                       FontFamily="Cascadia Mono,Consolas,monospace"
                                       FontSize="11" VerticalAlignment="Center"
                                       Margin="0,0,8,0"
                                       Classes="chevron" />
                            <Border Background="{Binding IconBackground}"
                                    CornerRadius="4" Width="26" Height="26"
                                    Margin="0,0,8,0">
                                <TextBlock Text="{Binding IconText}" Foreground="White"
                                           FontFamily="Cascadia Mono,Consolas,monospace" FontSize="9"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="{Binding Header}"
                                       Foreground="#888888" FontSize="12" FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Expander.Header>
                    <TextBlock Text="{Binding Content}"
                               Foreground="#666666"
                               FontSize="11" TextWrapping="Wrap"
                               Margin="34,4,0,0" FontStyle="Italic" />
                </Expander>
            </Border>
        </DataTemplate>

        <!-- ===== BASH WIDGET - Terminal commands ===== -->
        <DataTemplate x:Key="BashWidgetTemplate" DataType="controls:CleanWidgetViewModel">
            <Border Background="{Binding CardBackground}"
                    BorderBrush="{Binding CardBorderBrush}"
                    BorderThickness="1" CornerRadius="6"
                    Margin="{Binding CardMargin}" Padding="12,10">
                <Expander Classes="tool-expander" IsExpanded="False">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="v"
                                       Foreground="#666666"
                                       FontFamily="Cascadia Mono,Consolas,monospace"
                                       FontSize="11" VerticalAlignment="Center"
                                       Margin="0,0,8,0"
                                       Classes="chevron" />
                            <Border Background="{Binding IconBackground}"
                                    CornerRadius="4" Width="26" Height="26"
                                    Margin="0,0,8,0">
                                <TextBlock Text="{Binding IconText}" Foreground="White"
                                           FontFamily="Cascadia Mono,Consolas,monospace"
                                           FontSize="13" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="{Binding Header}"
                                       Foreground="#E0E0E0" FontSize="12" FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Subheader}"
                                       Foreground="#888888" FontSize="11"
                                       VerticalAlignment="Center" Margin="8,0,0,0"
                                       IsVisible="{Binding HasSubheader}"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel>
                        <!-- Command -->
                        <Border Background="#0C0C0C" CornerRadius="4" Padding="8,6" Margin="0,4,0,0">
                            <TextBlock Text="{Binding Content}"
                                       Foreground="#22C55E"
                                       FontFamily="Cascadia Mono,Consolas,monospace"
                                       FontSize="12" TextWrapping="Wrap" MaxHeight="300" />
                        </Border>
                        <!-- Result -->
                        <Border Background="#1E1E1E" CornerRadius="4" Padding="8,6" Margin="0,6,0,0"
                                IsVisible="{Binding HasResult}">
                            <TextBlock Text="{Binding Result}"
                                       Foreground="{Binding ResultForeground}"
                                       FontFamily="Cascadia Mono,Consolas,monospace"
                                       FontSize="11" TextWrapping="Wrap" MaxHeight="300" />
                        </Border>
                        <!-- Pending -->
                        <TextBlock Text="Running..."
                                   Foreground="#D97706" FontSize="11" FontStyle="Italic"
                                   Margin="0,6,0,0"
                                   IsVisible="{Binding IsPending}" />
                    </StackPanel>
                </Expander>
            </Border>
        </DataTemplate>

        <!-- ===== TOOL WIDGET - File/Search/Todo/Skill/Agent/Generic tools ===== -->
        <DataTemplate x:Key="ToolWidgetTemplate" DataType="controls:CleanWidgetViewModel">
            <Border Background="{Binding CardBackground}"
                    BorderBrush="{Binding CardBorderBrush}"
                    BorderThickness="1" CornerRadius="6"
                    Margin="{Binding CardMargin}" Padding="12,10">
                <Expander Classes="tool-expander" IsExpanded="False">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="v"
                                       Foreground="#666666"
                                       FontFamily="Cascadia Mono,Consolas,monospace"
                                       FontSize="11" VerticalAlignment="Center"
                                       Margin="0,0,8,0"
                                       Classes="chevron" />
                            <Border Background="{Binding IconBackground}"
                                    CornerRadius="4" Width="26" Height="26"
                                    Margin="0,0,8,0">
                                <TextBlock Text="{Binding IconText}" Foreground="White"
                                           FontFamily="Cascadia Mono,Consolas,monospace"
                                           FontSize="13" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="{Binding Header}"
                                       Foreground="#E0E0E0" FontSize="12" FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Subheader}"
                                       Foreground="#888888" FontSize="11"
                                       VerticalAlignment="Center" Margin="8,0,0,0"
                                       IsVisible="{Binding HasSubheader}"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel>
                        <!-- Content -->
                        <Border Background="#1E1E1E" CornerRadius="4" Padding="8,6" Margin="0,4,0,0"
                                IsVisible="{Binding HasContent}">
                            <TextBlock Text="{Binding Content}"
                                       Foreground="#D4D4D4"
                                       FontFamily="Cascadia Mono,Consolas,monospace"
                                       FontSize="11" TextWrapping="Wrap" MaxHeight="300" />
                        </Border>
                        <!-- Result -->
                        <Border Background="#1E1E1E" CornerRadius="4" Padding="8,6" Margin="0,6,0,0"
                                IsVisible="{Binding HasResult}">
                            <TextBlock Text="{Binding Result}"
                                       Foreground="{Binding ResultForeground}"
                                       FontFamily="Cascadia Mono,Consolas,monospace"
                                       FontSize="11" TextWrapping="Wrap" MaxHeight="300" />
                        </Border>
                        <!-- Pending -->
                        <TextBlock Text="Running..."
                                   Foreground="#D97706" FontSize="11" FontStyle="Italic"
                                   Margin="0,6,0,0"
                                   IsVisible="{Binding IsPending}" />
                    </StackPanel>
                </Expander>
            </Border>
        </DataTemplate>

        <!-- ===== USER MESSAGE WIDGET ===== -->
        <DataTemplate x:Key="UserWidgetTemplate" DataType="controls:CleanWidgetViewModel">
            <Grid Margin="60,4,8,4" HorizontalAlignment="Right">
                <Border Padding="12,10"
                        Background="#094771" CornerRadius="6">
                    <DockPanel>
                        <!-- Rewind button -->
                        <Button DockPanel.Dock="Right"
                                Content="X"
                                Tag="{Binding SnapshotEntryNumber}"
                                IsVisible="{Binding IsRewindVisible}"
                                Click="RewindButton_Click"
                                VerticalAlignment="Top"
                                Margin="8,0,0,0"
                                Padding="4,2"
                                MinWidth="20" MinHeight="20"
                                Background="Transparent"
                                Foreground="#EF4444"
                                BorderThickness="0"
                                FontSize="11" FontWeight="Bold"
                                Cursor="Hand"
                                Opacity="0.4"
                                ToolTip.Tip="Rewind to before this prompt" />
                        <TextBlock Text="{Binding Content}"
                                   Foreground="White"
                                   FontSize="13" TextWrapping="Wrap"
                                   MaxWidth="600" />
                    </DockPanel>
                </Border>
            </Grid>
        </DataTemplate>

        <!-- Template Selector -->
        <controls:WidgetTemplateSelector x:Key="WidgetSelector"
                                         TextTemplate="{StaticResource TextWidgetTemplate}"
                                         ThinkingTemplate="{StaticResource ThinkingWidgetTemplate}"
                                         BashTemplate="{StaticResource BashWidgetTemplate}"
                                         ToolTemplate="{StaticResource ToolWidgetTemplate}"
                                         UserTemplate="{StaticResource UserWidgetTemplate}" />

    </UserControl.Resources>

    <Grid RowDefinitions="*,Auto">

        <!-- Widget cards -->
        <ScrollViewer x:Name="WidgetScroller" Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="WidgetItems"
                          ItemTemplate="{StaticResource WidgetSelector}"
                          Margin="4" />
        </ScrollViewer>

        <!-- Empty / new-session state. Shown when the session has no widgets
             yet - typically a brand-new session that hasn't started Claude or
             whose JSONL file does not exist on disk yet. Replaces the old
             "Loading session output..." placeholder, which felt broken because
             new sessions never have anything to load. -->
        <TextBlock x:Name="EmptyText" Grid.Row="0"
                   Text="New session. Type a message below to start."
                   Foreground="#888888" FontSize="13"
                   HorizontalAlignment="Center" VerticalAlignment="Center" />

        <!-- Loading state (only shown briefly when re-parsing an existing
             JSONL file). For brand-new sessions we leave EmptyText visible
             instead so the user sees an invitation, not a spinner. -->
        <TextBlock x:Name="LoadingText" Grid.Row="0"
                   Text="Loading..."
                   Foreground="#888888" FontSize="13" FontStyle="Italic"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   IsVisible="False" />

        <!-- Status bar -->
        <Border x:Name="StatusArea" Grid.Row="1" Padding="12,6">
            <Grid ColumnDefinitions="Auto,*">

                <!-- Message filter dropdown (kept in tree so code-behind keeps
                     compiling; hidden because it added cognitive load with no
                     payoff for the simplified Session view). -->
                <ComboBox x:Name="FilterCombo"
                          Grid.Column="0"
                          SelectedIndex="0"
                          IsVisible="False">
                    <ComboBoxItem Content="All Messages" Tag="All" />
                    <ComboBoxItem Content="My Messages" Tag="UserOnly" />
                    <ComboBoxItem Content="Conversation" Tag="Conversation" />
                </ComboBox>

                <!-- Status indicators -->
                <Grid Grid.Column="1">
                    <!-- Working state -->
                    <StackPanel x:Name="ProgressArea" IsVisible="False">
                        <ProgressBar IsIndeterminate="True"
                                     Height="3"
                                     Background="#3C3C3C"
                                     Foreground="#007ACC" />
                        <TextBlock x:Name="ProgressText"
                                   Text="Claude is working..."
                                   Foreground="#888888" FontSize="10"
                                   FontStyle="Italic" Margin="0,4,0,0" />
                    </StackPanel>
                    <!-- Your Turn state -->
                    <TextBlock x:Name="YourTurnText"
                               Text="Your Turn"
                               Foreground="#22C55E"
                               FontSize="11" FontWeight="SemiBold"
                               IsVisible="False"
                               HorizontalAlignment="Left" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
