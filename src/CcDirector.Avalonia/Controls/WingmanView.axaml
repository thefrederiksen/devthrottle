<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="CcDirector.Avalonia.Controls.WingmanView"
             Background="#1E1E1E">
    <DockPanel>
        <!-- ===== Header: title + status row ===== -->
        <Border DockPanel.Dock="Top" Padding="8,6"
                BorderBrush="#3C3C3C" BorderThickness="0,0,0,1">
            <StackPanel Spacing="6">
                <TextBlock Text="WINGMAN" Foreground="#888888" FontSize="11"
                           FontWeight="SemiBold" VerticalAlignment="Center" />

                <!-- Current colour the wingman has written -->
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Border x:Name="CurrentSwatch" Width="10" Height="10" CornerRadius="5"
                            Background="#6A6A6A" VerticalAlignment="Center" />
                    <TextBlock x:Name="CurrentStateText" Foreground="#CCCCCC" FontSize="12"
                               FontWeight="SemiBold" VerticalAlignment="Center"
                               Text="no session selected" />
                    <TextBlock x:Name="CurrentReasonText" Foreground="#AAAAAA" FontSize="11"
                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                </StackPanel>

                <!-- The silence clock the detector runs on: time since the terminal last
                     moved + the current activity state. Past QuietThreshold -> red. -->
                <DockPanel>
                    <Border x:Name="GateBadge" DockPanel.Dock="Right" CornerRadius="3"
                            Padding="6,1" Background="#2A2D2E" VerticalAlignment="Center">
                        <TextBlock x:Name="GateText" Foreground="#AAAAAA" FontSize="10"
                                   FontFamily="Cascadia Mono, Consolas, Courier New"
                                   Text="--" />
                    </Border>
                    <TextBlock x:Name="MovedAgoText" Foreground="#888888" FontSize="11"
                               FontFamily="Cascadia Mono, Consolas, Courier New"
                               VerticalAlignment="Center"
                               Text="Terminal moved: --" />
                </DockPanel>
            </StackPanel>
        </Border>

        <!-- Empty-state hint -->
        <TextBlock x:Name="EmptyText" DockPanel.Dock="Top"
                   Text="No state changes yet. Each row below is a transition: blue while output is flowing, red once the terminal goes quiet."
                   Foreground="#666666" FontSize="11" FontStyle="Italic"
                   TextWrapping="Wrap" Margin="10,12" IsVisible="False" />

        <!-- ===== State-change timeline (newest first) ===== -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="ChangeItems" Padding="4">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="6,5" Margin="0,2" Background="#252526" CornerRadius="4">
                            <DockPanel>
                                <Border DockPanel.Dock="Left" Width="8" Height="8" CornerRadius="4"
                                        Background="{Binding Swatch}" VerticalAlignment="Center"
                                        Margin="0,0,6,0" />
                                <TextBlock DockPanel.Dock="Right" Text="{Binding TimeLabel}"
                                           Foreground="#888888" FontSize="10"
                                           FontFamily="Cascadia Mono, Consolas, Courier New"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="{Binding TransitionLabel}" Foreground="{Binding Swatch}"
                                           FontSize="11" FontWeight="SemiBold"
                                           FontFamily="Cascadia Mono, Consolas, Courier New"
                                           VerticalAlignment="Center" />
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
