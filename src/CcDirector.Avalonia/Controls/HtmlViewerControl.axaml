<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="CcDirector.Avalonia.Controls.HtmlViewerControl"
             Background="#1E1E1E">

    <Grid RowDefinitions="Auto,*">

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#252526" Padding="8,4"
                BorderBrush="#3C3C3C" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto">

                <TextBlock x:Name="FilePathText" Grid.Column="0"
                           Foreground="#888888" FontSize="11"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                    <Button x:Name="ReloadButton" Content="Reload"
                            FontSize="11" Padding="8,2"
                            Background="#3C3C3C" Foreground="#CCCCCC"
                            BorderThickness="0" Cursor="Hand"
                            Click="ReloadButton_Click" />
                    <Button x:Name="OpenExternalButton" Content="Open in Browser"
                            FontSize="11" Padding="8,2"
                            Background="#3C3C3C" Foreground="#CCCCCC"
                            BorderThickness="0" Cursor="Hand"
                            Click="OpenExternalButton_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <TextBlock x:Name="LoadingText" Text="Loading..."
                       Foreground="#888888" FontSize="13"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />

            <WebView x:Name="WebViewHost" />
        </Grid>
    </Grid>
</UserControl>
