<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="CcDirector.Avalonia.Controls.SupervisorView"
             Background="#1E1E1E">
  <DockPanel Margin="14">

    <!-- Banner: current supervisor verdict for the bound session. -->
    <Border DockPanel.Dock="Top" Padding="14" CornerRadius="10"
            Background="#252526" BorderBrush="#3C3C3C" BorderThickness="1"
            Margin="0,0,0,12">
      <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto" >
        <Ellipse x:Name="SupDot" Grid.Column="0" Grid.RowSpan="2"
                 Width="28" Height="28"
                 Fill="#6A6A6A"
                 VerticalAlignment="Center"
                 Margin="0,0,14,0" />
        <TextBlock x:Name="SupReason" Grid.Row="0" Grid.Column="1"
                   Text="loading..."
                   FontSize="16" FontWeight="SemiBold"
                   Foreground="#DDDDDD"
                   TextWrapping="Wrap" />
        <TextBlock x:Name="SupSubtitle" Grid.Row="1" Grid.Column="1"
                   Margin="0,2,0,0"
                   Foreground="#888888" FontSize="12"
                   Text="" />
        <Button Grid.Column="2" Grid.RowSpan="2"
                Content="Refresh"
                Background="Transparent" Foreground="#888888"
                Padding="10,4" Click="RefreshButton_Click" />
      </Grid>
    </Border>

    <!-- Ask input: at the bottom. -->
    <Grid DockPanel.Dock="Bottom" ColumnDefinitions="*,Auto" Margin="0,12,0,0">
      <TextBox x:Name="QuestionBox"
               Grid.Column="0"
               Watermark="Ask the supervisor about this session..."
               KeyDown="QuestionBox_KeyDown"
               Padding="10" />
      <Button x:Name="AskButton"
              Grid.Column="1"
              Content="Ask"
              Padding="18,8"
              Margin="8,0,0,0"
              Background="#0E639C" Foreground="White"
              Click="AskButton_Click" />
    </Grid>

    <!-- Context-the-supervisor-sees footer (collapsible). -->
    <Expander DockPanel.Dock="Bottom"
              x:Name="ContextExpander"
              Header="Context the supervisor sees"
              Margin="0,8,0,0"
              IsExpanded="False">
      <TextBlock x:Name="ContextDigestText"
                 Foreground="#888888" FontSize="11"
                 TextWrapping="Wrap"
                 Text="(no answers yet)"
                 Margin="0,4,0,0" />
    </Expander>

    <!-- Ask history (fills the middle). -->
    <ScrollViewer x:Name="HistoryScroller">
      <ItemsControl x:Name="HistoryList">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <StackPanel Margin="0,0,0,14">
              <Border Background="#2D2D2E" CornerRadius="8" Padding="12">
                <StackPanel>
                  <TextBlock Text="Q" Foreground="#0E639C" FontWeight="Bold" FontSize="11" />
                  <TextBlock Text="{Binding Question}"
                             Foreground="#DDDDDD" TextWrapping="Wrap"
                             Margin="0,2,0,0" />
                </StackPanel>
              </Border>
              <Border Background="#1F2937" CornerRadius="8" Padding="12" Margin="20,8,0,0">
                <StackPanel>
                  <TextBlock Text="SUPERVISOR" Foreground="#888888" FontWeight="Bold" FontSize="10" />
                  <TextBlock Text="{Binding Answer}"
                             Foreground="#DDDDDD" TextWrapping="Wrap"
                             Margin="0,4,0,0" />
                  <TextBlock Text="{Binding Footer}"
                             Foreground="#6A6A6A" FontSize="10"
                             Margin="0,6,0,0" />
                </StackPanel>
              </Border>
            </StackPanel>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

  </DockPanel>
</UserControl>
