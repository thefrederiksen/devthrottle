<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CcDirector.Avalonia.GatewayTroubleshootDialog"
        Title="Gateway connection troubleshooter"
        Width="640" Height="580"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        Background="#252526">

    <Grid Margin="16" RowDefinitions="Auto,Auto,*,Auto">

        <TextBlock Grid.Row="0" Text="Gateway connection troubleshooter"
                   Foreground="#CCCCCC" FontSize="16" FontWeight="SemiBold"
                   Margin="0,0,0,12" />

        <!-- Handshake verdict: colored per result, names the failing LEG verbatim. -->
        <Border x:Name="VerdictBorder" Grid.Row="1"
                CornerRadius="4" Padding="12,10"
                Background="#2A2A2A" BorderBrush="#3C3C3C" BorderThickness="1"
                Margin="0,0,0,12">
            <StackPanel>
                <TextBlock x:Name="VerdictText"
                           Text="Running two-way handshake..."
                           Foreground="#CCCCCC" FontSize="12" FontWeight="SemiBold"
                           TextWrapping="Wrap" />
                <TextBlock x:Name="VerdictLegs"
                           Text="" IsVisible="False"
                           Foreground="#888888" FontSize="11"
                           Margin="0,5,0,0" TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <!-- The ladder: rungs fill in live as each check completes. -->
        <ScrollViewer Grid.Row="2">
            <StackPanel x:Name="RungsPanel">
                <TextBlock x:Name="RungsPlaceholder"
                           Text="Running checks..."
                           Foreground="#888888" FontSize="12" FontStyle="Italic"
                           Margin="4,4,0,0" />
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
            <Button x:Name="BtnCopyReport" Content="Copy report"
                    Height="28" Padding="14,0"
                    Background="#3C3C3C" Foreground="#CCCCCC"
                    BorderThickness="0" Cursor="Hand"
                    Click="BtnCopyReport_Click" />
            <Button x:Name="BtnRetest" Content="Re-test"
                    Height="28" Padding="14,0"
                    Background="#007ACC" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Click="BtnRetest_Click" />
            <Button Content="Close"
                    Height="28" Padding="14,0"
                    Background="#3C3C3C" Foreground="#CCCCCC"
                    BorderThickness="0" Cursor="Hand"
                    Click="BtnClose_Click" />
        </StackPanel>
    </Grid>
</Window>
