<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CcDirector.Avalonia.SettingsDialog"
        Title="CC Director Settings"
        Width="1040" Height="1010"
        MinWidth="760" MinHeight="560"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        Background="#252526">

    <Window.Styles>
        <Style Selector="TextBlock.sectionTitle">
            <Setter Property="Foreground" Value="#CCCCCC" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>
        <Style Selector="TextBlock.hint">
            <Setter Property="Foreground" Value="#888888" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style Selector="TextBlock.fieldLabel">
            <Setter Property="Foreground" Value="#AAAAAA" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>
        <Style Selector="TextBox.settingsInput">
            <Setter Property="Background" Value="#1E1E1E" />
            <Setter Property="Foreground" Value="#CCCCCC" />
            <Setter Property="CaretBrush" Value="#CCCCCC" />
            <Setter Property="BorderBrush" Value="#3C3C3C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
        </Style>
        <!-- Read-only monospace "this is what launches" preview strip (issue #436). -->
        <Style Selector="TextBox.previewStrip">
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="Background" Value="#252526" />
            <Setter Property="Foreground" Value="#CCCCCC" />
            <Setter Property="BorderBrush" Value="#3C3C3C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, Courier New" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style Selector="Button.dialogButton">
            <Setter Property="Height" Value="30" />
            <Setter Property="MinWidth" Value="76" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="#3C3C3C" />
            <Setter Property="Foreground" Value="#CCCCCC" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <!-- Compact square icon button for the list's reorder arrows and trash (issue #494). -->
        <Style Selector="Button.iconButton">
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="26" />
            <Setter Property="MinWidth" Value="26" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#3C3C3C" />
            <Setter Property="Foreground" Value="#CCCCCC" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.primaryButton">
            <Setter Property="Height" Value="30" />
            <Setter Property="MinWidth" Value="140" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="#007ACC" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </Window.Styles>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="CC Director Settings"
                   Foreground="#CCCCCC" FontSize="16" FontWeight="SemiBold"
                   Margin="0,0,0,8" />

        <TextBlock x:Name="LoadingText" Grid.Row="1"
                   Text="Loading..."
                   Foreground="#888888" FontSize="12" FontStyle="Italic"
                   Margin="0,0,0,8" />

        <TabControl Grid.Row="2" x:Name="SettingsTabs" IsVisible="False">
            <TabItem Header="Gateway">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,14,0">
                    <StackPanel Spacing="8" Margin="0,4,0,0">
                        <TextBlock Classes="sectionTitle" Text="Gateway" />
                        <TextBlock Classes="hint" Text="Connect this Director to a central gateway so it shows up there. Leave the URL blank to run local-only. Works on any network, not just a tailnet." />

                        <TextBlock Classes="fieldLabel" Text="Gateway URL" />
                        <Grid ColumnDefinitions="*,Auto,Auto">
                            <TextBox x:Name="GatewayUrlBox" Grid.Column="0" Classes="settingsInput"
                                     Watermark="e.g. http://gateway-host:7878" />
                            <Button x:Name="DetectGatewayButton" Grid.Column="1" Classes="dialogButton"
                                    Content="Detect" Margin="8,0,0,0"
                                    ToolTip.Tip="Look for a gateway running on this machine"
                                    Click="BtnDetectGateway_Click" />
                            <Button x:Name="TestGatewayButton" Grid.Column="2" Classes="dialogButton"
                                    Content="Test" Margin="8,0,0,0"
                                    ToolTip.Tip="Check the gateway URL is reachable"
                                    Click="BtnTestGateway_Click" />
                        </Grid>

                        <TextBlock Classes="fieldLabel" Text="Director public URL (any network)" />
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox x:Name="GatewayAdvertisedBox" Grid.Column="0" Classes="settingsInput"
                                     Watermark="how the gateway reaches THIS Director, e.g. http://this-host:7879" />
                            <Button x:Name="DetectPublicUrlButton" Grid.Column="1" Classes="dialogButton"
                                    Content="Detect" Margin="8,0,0,0"
                                    ToolTip.Tip="Fill from this machine's network address + control port"
                                    Click="BtnDetectPublicUrl_Click" />
                        </Grid>
                        <TextBlock Classes="hint" Text="Required when the gateway runs on a different machine. The gateway calls back to this URL, so it must be reachable from the gateway." />

                        <TextBlock x:Name="GatewayTestStatus" Text="" Foreground="#888888"
                                   FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0" IsVisible="False" />

                        <TextBlock Classes="fieldLabel" Text="Gateway token (optional)" />
                        <TextBox x:Name="GatewayTokenBox" Classes="settingsInput"
                                 Watermark="only if the gateway requires one" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Agents">
                <Grid RowDefinitions="Auto,*,Auto">
                    <StackPanel Grid.Row="0" Spacing="8" Margin="0,4,14,8">
                        <TextBlock Classes="sectionTitle" Text="Agents" />
                        <TextBlock Classes="hint" Text="Your agents, in the order they appear in New Session. Each entry is a configured agent CLI - you can add several of the same type (e.g. two Claude entries with different presets). Use the Up/Down arrows to reorder, Add Agent to create one, and Edit to set the executable, command-line preset, model, and arguments. The Detection wizard can scan this machine for known tools." />
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                            <Button x:Name="AddAgentButton" Classes="dialogButton" Content="+ Add Agent"
                                    Width="120" Click="BtnAddAgent_Click"
                                    ToolTip.Tip="Add a new agent entry to the list" />
                            <Button x:Name="RunWizardButton" Classes="dialogButton" Content="Detection wizard..."
                                    Width="150" Click="BtnRunWizard_Click"
                                    ToolTip.Tip="Scan this machine for known tools and add the ones it finds with their recommended settings" />
                            <TextBlock x:Name="AgentToolsStatus" Text="" Foreground="#888888"
                                       FontSize="11" TextWrapping="Wrap" VerticalAlignment="Center"
                                       IsVisible="False" />
                        </StackPanel>
                    </StackPanel>

                    <!-- CRUD list of agent entries (issue #489, polished #494). Columns: Order
                         (compact up/down arrows), Display name, Type, Enabled, Status pill, and a
                         fixed-width right-aligned Actions cell (Edit + trash). The shared column
                         definition is reused by the header and rows so they stay aligned, and the
                         outer ScrollViewer disables horizontal scroll so the grid is constrained to
                         the panel width - nothing clips at the right edge (AC1). -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,14,0">
                        <StackPanel Spacing="4">
                            <!-- Header row. Actions column is a fixed 96px with an 8px right margin so
                                 the Edit/trash controls always sit inside the panel. -->
                            <Grid ColumnDefinitions="56,*,100,64,86,96" Margin="8,0,16,2">
                                <TextBlock Grid.Column="0" Classes="fieldLabel" Text="Order" />
                                <TextBlock Grid.Column="1" Classes="fieldLabel" Text="Display name" />
                                <TextBlock Grid.Column="2" Classes="fieldLabel" Text="Type" />
                                <TextBlock Grid.Column="3" Classes="fieldLabel" Text="Enabled" />
                                <TextBlock Grid.Column="4" Classes="fieldLabel" Text="Status" />
                                <TextBlock Grid.Column="5" Classes="fieldLabel" Text="Actions" HorizontalAlignment="Right" />
                            </Grid>

                            <ItemsControl x:Name="AgentEntriesList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#1E1E1E" BorderBrush="#3C3C3C" BorderThickness="1" Padding="8,6" Margin="0,0,8,2">
                                            <Grid ColumnDefinitions="56,*,100,64,86,96" VerticalAlignment="Center">
                                                <!-- Compact up/down arrow controls in one tight cell (AC3).
                                                     Vector Path glyphs (no font/emoji dependency). -->
                                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="2">
                                                    <Button Classes="iconButton"
                                                            Tag="{Binding Id}" Click="BtnMoveUp_Click"
                                                            ToolTip.Tip="Move this agent up">
                                                        <Path Data="M 0,5 L 5,0 L 10,5 Z" Fill="#CCCCCC"
                                                              HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Button>
                                                    <Button Classes="iconButton"
                                                            Tag="{Binding Id}" Click="BtnMoveDown_Click"
                                                            ToolTip.Tip="Move this agent down">
                                                        <Path Data="M 0,0 L 5,5 L 10,0 Z" Fill="#CCCCCC"
                                                              HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Button>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="{Binding DisplayName}" Foreground="#CCCCCC"
                                                           FontSize="13" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,8,0" />
                                                <TextBlock Grid.Column="2" Text="{Binding TypeLabel}" Foreground="#AAAAAA"
                                                           FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                <CheckBox Grid.Column="3" IsChecked="{Binding Enabled, Mode=TwoWay}"
                                                          Foreground="#CCCCCC" VerticalAlignment="Center"
                                                          ToolTip.Tip="Whether this agent is available for launching" />
                                                <!-- Status as a small colored pill (AC3). -->
                                                <Border Grid.Column="4" CornerRadius="8" Padding="8,2"
                                                        HorizontalAlignment="Left" VerticalAlignment="Center"
                                                        IsVisible="{Binding HasStatus}"
                                                        Background="{Binding StatusPillBackground}">
                                                    <TextBlock Text="{Binding StatusText}"
                                                               Foreground="{Binding StatusPillForeground}"
                                                               FontSize="10" FontWeight="SemiBold" />
                                                </Border>
                                                <!-- Fixed-width, right-aligned Actions cell: Edit + compact trash. -->
                                                <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                                                    <Button Classes="dialogButton" Content="Edit" MinWidth="44" Padding="8,0"
                                                            Tag="{Binding Id}" Click="BtnEditAgent_Click"
                                                            ToolTip.Tip="Edit this agent" />
                                                    <Button Classes="iconButton"
                                                            Tag="{Binding Id}" Click="BtnRemoveAgent_Click"
                                                            ToolTip.Tip="Remove this agent">
                                                        <!-- Trash-can icon as a vector Path (no emoji). -->
                                                        <Canvas Width="12" Height="13">
                                                            <Rectangle Canvas.Left="1" Canvas.Top="3" Width="10" Height="1.4" Fill="#CCCCCC" />
                                                            <Rectangle Canvas.Left="4" Canvas.Top="1" Width="4" Height="1.4" Fill="#CCCCCC" />
                                                            <Path Data="M 2,4 L 10,4 L 9,12 L 3,12 Z"
                                                                  Stroke="#CCCCCC" StrokeThickness="1.2" Fill="Transparent" />
                                                            <Rectangle Canvas.Left="4.6" Canvas.Top="5.5" Width="1" Height="5" Fill="#CCCCCC" />
                                                            <Rectangle Canvas.Left="6.4" Canvas.Top="5.5" Width="1" Height="5" Fill="#CCCCCC" />
                                                        </Canvas>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock x:Name="AgentEntriesEmpty" Text="No agents configured. Click + Add Agent to create one."
                                       Foreground="#888888" FontSize="12" FontStyle="Italic" Margin="8,8,0,0" IsVisible="False" />
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Add/Edit editor (issue #489; flow polished in #494): collapsed until Add/Edit
                         is clicked. Top-to-bottom order matches the decision order (AC4): (1) Type,
                         (2) auto-filled Display name, (3) prominent Detect. Manual path entry is a
                         fallback that stays collapsed when Detect succeeds (AC7), and the preset /
                         model / args live in a collapsed Advanced section (AC8). -->
                    <Border Grid.Row="2" x:Name="AgentEditorPanel" IsVisible="False"
                            Background="#252526" BorderBrush="#3C3C3C" BorderThickness="1" Padding="10" Margin="0,8,14,0">
                        <StackPanel Spacing="6">
                            <TextBlock x:Name="AgentEditorTitle" Text="Add Agent" Foreground="#CCCCCC" FontSize="13" FontWeight="SemiBold" />

                            <!-- 1. Agent type (first / at the top). -->
                            <TextBlock Classes="fieldLabel" Text="Agent type" />
                            <ComboBox x:Name="EditorTypeCombo" MinWidth="200" HorizontalAlignment="Left"
                                      Background="#1E1E1E" Foreground="#CCCCCC"
                                      SelectionChanged="EditorTypeCombo_Changed"
                                      ToolTip.Tip="Pick the tool first; the name below fills in automatically" />

                            <!-- 2. Display name (auto-filled from the type; stays editable). -->
                            <TextBlock Classes="fieldLabel" Text="Display name" />
                            <TextBox x:Name="EditorDisplayNameBox" Classes="settingsInput"
                                     Watermark="e.g. Claude (read-only)"
                                     TextChanged="EditorDisplayName_Changed"
                                     ToolTip.Tip="Auto-filled from the type; edit it for a custom name" />

                            <CheckBox x:Name="EditorEnabledCheck" Content="Enabled" IsChecked="True"
                                      Foreground="#CCCCCC" FontSize="12" Margin="0,2,0,0"
                                      ToolTip.Tip="Whether this agent is available for launching from this machine" />

                            <!-- 3. Detect is the prominent next action. -->
                            <Button x:Name="EditorDetectButton" Classes="primaryButton" Content="Detect this tool"
                                    HorizontalAlignment="Left" Margin="0,4,0,0" Click="BtnEditorDetect_Click"
                                    ToolTip.Tip="Scan this machine for the selected tool and fill in its path" />

                            <TextBlock x:Name="EditorStatus" Text="" Foreground="#888888" FontSize="11" TextWrapping="Wrap" IsVisible="False" />

                            <!-- Manual path entry: a fallback, collapsed when Detect succeeds and
                                 revealed when it fails or via "Enter the path manually" (AC7). -->
                            <Button x:Name="EditorShowManualButton" Classes="dialogButton" Content="Enter the path manually"
                                    HorizontalAlignment="Left" IsVisible="False" Click="BtnEditorShowManual_Click"
                                    ToolTip.Tip="Type or browse to the executable yourself" />

                            <StackPanel x:Name="EditorManualPanel" Spacing="6" IsVisible="False">
                                <TextBlock Classes="fieldLabel" Text="Executable" />
                                <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                                    <TextBox x:Name="EditorPathBox" Grid.Column="0" Classes="settingsInput"
                                             Watermark="executable path or bare command"
                                             TextChanged="EditorInput_Changed" />
                                    <Button x:Name="EditorBrowseButton" Grid.Column="1" Classes="dialogButton" Content="Browse..." Margin="8,0,0,0" Click="BtnEditorBrowse_Click" />
                                    <Button x:Name="EditorQuickCheckButton" Grid.Column="2" Classes="dialogButton" Content="Quick check" Margin="8,0,0,0"
                                            ToolTip.Tip="Run a safe version probe of this executable" Click="BtnEditorQuickCheck_Click" />
                                    <Button x:Name="EditorLaunchPreviewButton" Grid.Column="3" Classes="dialogButton" Content="Launch preview..." Margin="8,0,0,0"
                                            ToolTip.Tip="Open a throwaway terminal that starts the agent with the command line below (nothing is saved)" Click="BtnEditorLaunchPreview_Click" />
                                </Grid>
                            </StackPanel>

                            <!-- Advanced: preset / model / args, collapsed by default (AC8). -->
                            <ToggleButton x:Name="EditorAdvancedToggle" Content="Advanced"
                                          Background="Transparent" BorderThickness="0" Foreground="#3B82F6"
                                          Padding="0" Cursor="Hand" HorizontalAlignment="Left" Margin="0,2,0,0"
                                          IsCheckedChanged="EditorAdvancedToggle_Changed"
                                          ToolTip.Tip="Command-line preset, default model, and args override" />

                            <StackPanel x:Name="EditorAdvancedPanel" Spacing="6" IsVisible="False">
                                <Grid ColumnDefinitions="Auto,*,Auto,*">
                                    <TextBlock Grid.Column="0" Classes="fieldLabel" Text="Command line" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <ComboBox x:Name="EditorPresetCombo" Grid.Column="1"
                                              Background="#1E1E1E" Foreground="#CCCCCC" HorizontalAlignment="Stretch"
                                              SelectionChanged="EditorPreset_Changed"
                                              ToolTip.Tip="The command-line preset for this agent type" />
                                    <TextBlock Grid.Column="2" Classes="fieldLabel" Text="Default model" VerticalAlignment="Center" Margin="12,0,8,0" />
                                    <TextBox x:Name="EditorModelBox" Grid.Column="3" Classes="settingsInput"
                                             Watermark="(none - tool default)"
                                             TextChanged="EditorInput_Changed"
                                             ToolTip.Tip="Passed as --model when set; leave blank for the tool's own default" />
                                </Grid>

                                <TextBox x:Name="EditorArgsOverrideBox" Classes="settingsInput"
                                         Watermark="optional: free-text args that REPLACE the preset (advanced)"
                                         TextChanged="EditorInput_Changed"
                                         ToolTip.Tip="When set, these args replace the selected preset's arguments" />
                            </StackPanel>

                            <TextBlock Classes="fieldLabel" Text="This is what launches:" Margin="0,2,0,0" />
                            <TextBox x:Name="EditorPreviewStrip" Classes="previewStrip"
                                     ToolTip.Tip="The fully-resolved command line that will launch - updates live as you change the preset, model, or override" />

                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,4,0,0">
                                <Button x:Name="EditorSaveButton" Classes="primaryButton" Content="Save agent" MinWidth="110" Click="BtnEditorSave_Click" />
                                <Button Classes="dialogButton" Content="Cancel" Width="90" Click="BtnEditorCancel_Click" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Directories">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,14,0">
                    <StackPanel Spacing="8" Margin="0,4,0,0">
                        <TextBlock Classes="sectionTitle" Text="Screenshots" />
                        <TextBlock Classes="hint" Text="Where phone-uploaded images are filed so a session can read them by path. On a Mac this must be set explicitly." />
                        <Grid ColumnDefinitions="*,Auto,Auto">
                            <TextBox x:Name="ScreenshotsDirBox" Grid.Column="0" Classes="settingsInput"
                                     Watermark="e.g. /Users/username/Desktop" />
                            <Button x:Name="DetectScreenshotsButton" Grid.Column="1" Classes="dialogButton"
                                    Content="Detect" Margin="8,0,0,0"
                                    ToolTip.Tip="Find the folder where this OS saves screenshots"
                                    Click="BtnDetectScreenshots_Click" />
                            <Button x:Name="BrowseButton" Grid.Column="2" Classes="dialogButton"
                                    Content="Browse..." Margin="8,0,0,0"
                                    Click="BtnBrowse_Click" />
                        </Grid>
                        <TextBlock x:Name="ScreenshotsStatus" Text="" Foreground="#888888"
                                   FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0" IsVisible="False" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Features">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,14,0">
                    <StackPanel Spacing="8" Margin="0,4,0,0">
                        <TextBlock Classes="sectionTitle" Text="Alpha Features" />
                        <TextBlock Classes="hint" Text="Unfinished features we are still testing. They may break, change, or disappear without notice, and no support is provided while they are in alpha." />
                        <CheckBox x:Name="AlphaFeaturesCheck"
                                  Content="Enable alpha features"
                                  IsChecked="False"
                                  Foreground="#CCCCCC" FontSize="13"
                                  Margin="0,4,0,0"
                                  IsCheckedChanged="AlphaCheck_Changed"
                                  ToolTip.Tip="Default: off. Shows untested features - no guarantees they work." />
                        <TextBlock Classes="hint" Margin="24,0,0,0"
                                   Text="When enabled you get: unverified coding agents, session handover, FIFO voice mode, GitHub remote sessions, Assistant/Coach quick-launch, and the wake-word test below. Claude Code and Pi have verified drivers and are always available." />

                        <StackPanel x:Name="AlphaVoicePanel" Spacing="6" Margin="24,8,0,0" IsVisible="False">
                            <TextBlock Text="Voice wake-word test" Foreground="#CCCCCC" FontSize="12" FontWeight="SemiBold" />
                            <TextBlock Classes="hint" Text="Sandbox for tuning the hands-free wake-word grammar: say &quot;wingman&quot; to start, dictate, then &quot;wingman send&quot; or &quot;wingman cancel&quot;. Emits to an on-screen box only, never to a live session." />
                            <Button x:Name="WakeWordTestButton" Classes="dialogButton"
                                    Content="Open Wake-Word Test" Width="170" HorizontalAlignment="Left"
                                    Click="BtnWakeWordTest_Click" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <TextBlock x:Name="StatusText" Grid.Row="3"
                   Text="" Foreground="#888888" FontSize="11"
                   TextWrapping="Wrap" Margin="0,8,0,0" />

        <!-- Bottom row: Open config.json link on the left (replaces the old Advanced
             read-only dump); Save / Cancel on the right. -->
        <Grid Grid.Row="4" Margin="0,12,0,0" ColumnDefinitions="*,Auto">
            <Button Grid.Column="0" x:Name="OpenConfigButton"
                    Content="Open config.json"
                    Background="Transparent" BorderThickness="0"
                    Foreground="#3B82F6" Cursor="Hand"
                    Padding="0" HorizontalAlignment="Left" VerticalAlignment="Center"
                    ToolTip.Tip="Open the CC Director config.json in your default editor"
                    Click="BtnOpenConfig_Click" />
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="SaveButton" Classes="primaryButton" Content="Save and Close"
                        IsDefault="True" Click="BtnSave_Click" />
                <Button Content="Cancel" Classes="dialogButton" Width="100" Margin="8,0,0,0"
                        IsCancel="True" Click="BtnClose_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
