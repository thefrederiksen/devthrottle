<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:CcDirectorSetup.Converters"
             x:Class="CcDirectorSetup.Steps.PrerequisitesStep">
    <UserControl.Resources>
        <converters:HexColorToBrushConverter x:Key="HexToBrush" />
    </UserControl.Resources>

    <DockPanel>
        <StackPanel DockPanel.Dock="Top">
            <TextBlock Text="Prerequisites"
                       Foreground="White"
                       FontSize="22"
                       FontWeight="SemiBold" />
            <TextBlock x:Name="SubtitleText"
                       Text="Checking required software..."
                       Foreground="#CCCCCC"
                       FontSize="13"
                       Margin="0,8,0,16" />
        </StackPanel>

        <!-- Success banner (hidden by default) -->
        <Border x:Name="SuccessBanner"
                DockPanel.Dock="Bottom"
                Background="#1B3A2A"
                CornerRadius="6"
                Padding="16"
                Margin="0,16,0,0"
                IsVisible="False">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Border Width="32" Height="32" CornerRadius="16"
                        Background="#22C55E"
                        Margin="0,0,12,0">
                    <TextBlock Text="OK"
                               Foreground="White"
                               FontSize="12"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="All prerequisites met -- ready to install."
                           Foreground="#22C55E"
                           FontSize="15"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    Margin="0,12,0,0">
            <Button x:Name="RefreshButton" Content="Re-check"
                    Classes="setup"
                    Width="100"
                    VerticalAlignment="Top"
                    Click="RefreshButton_Click" />
            <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="Just installed one of these? Click Re-check -- it re-reads your PATH."
                           Foreground="#888888"
                           FontSize="11" />
                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                    <TextBlock Text="Still not found after a re-check?"
                               Foreground="#888888"
                               FontSize="11" />
                    <TextBlock Text="Setup help ->"
                               Foreground="#007ACC"
                               FontSize="11"
                               Margin="6,0,0,0"
                               Cursor="Hand"
                               Tag="https://github.com/thefrederiksen/devthrottle/blob/main/docs/public/getting-started/02-installation.md#if-a-tool-is-not-detected-after-installing-it"
                               PointerPressed="InstallLink_PointerPressed">
                        <TextBlock.TextDecorations>
                            <TextDecorationCollection>
                                <TextDecoration Location="Underline" />
                            </TextDecorationCollection>
                        </TextBlock.TextDecorations>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <ItemsControl x:Name="PrereqList">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="#2A2D2E"
                            CornerRadius="4"
                            Padding="14,10"
                            Margin="0,0,0,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="White"
                                               FontSize="14"
                                               FontWeight="SemiBold" />
                                    <Border CornerRadius="3"
                                            Padding="6,1"
                                            Margin="8,0,0,0"
                                            Background="#3A1B1B"
                                            VerticalAlignment="Center"
                                            IsVisible="{Binding IsRequired}">
                                        <TextBlock Text="Required"
                                                   Foreground="#CC4444"
                                                   FontSize="10"
                                                   FontWeight="SemiBold" />
                                    </Border>
                                    <Border CornerRadius="3"
                                            Padding="6,1"
                                            Margin="8,0,0,0"
                                            Background="#2A2F38"
                                            VerticalAlignment="Center"
                                            IsVisible="{Binding !IsRequired}">
                                        <TextBlock Text="Optional"
                                                   Foreground="#8AA0B8"
                                                   FontSize="10"
                                                   FontWeight="SemiBold" />
                                    </Border>
                                </StackPanel>

                                <TextBlock Text="{Binding Description}"
                                           Foreground="#888888"
                                           FontSize="11"
                                           Margin="0,2,0,0" />

                                <TextBlock Text="{Binding Version}"
                                           Foreground="#AAAAAA"
                                           FontSize="11"
                                           Margin="0,2,0,0"
                                           IsVisible="{Binding Version, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                                <!-- Install + setup-help links (shown when prerequisite is not found) -->
                                <StackPanel Orientation="Horizontal"
                                            Margin="0,4,0,0"
                                            IsVisible="{Binding !IsFound}">
                                    <TextBlock Text="Download and install ->"
                                               Foreground="#007ACC"
                                               FontSize="11"
                                               Cursor="Hand"
                                               Tag="{Binding InstallUrl}"
                                               PointerPressed="InstallLink_PointerPressed">
                                        <TextBlock.TextDecorations>
                                            <TextDecorationCollection>
                                                <TextDecoration Location="Underline" />
                                            </TextDecorationCollection>
                                        </TextBlock.TextDecorations>
                                    </TextBlock>
                                    <TextBlock Text="Setup help ->"
                                               Foreground="#007ACC"
                                               FontSize="11"
                                               Margin="16,0,0,0"
                                               Cursor="Hand"
                                               Tag="{Binding DocsUrl}"
                                               PointerPressed="InstallLink_PointerPressed">
                                        <TextBlock.TextDecorations>
                                            <TextDecorationCollection>
                                                <TextDecoration Location="Underline" />
                                            </TextDecorationCollection>
                                        </TextBlock.TextDecorations>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>

                            <TextBlock Grid.Column="1"
                                       Text="{Binding Status}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0"
                                       Foreground="{Binding StatusColor, Converter={StaticResource HexToBrush}}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </DockPanel>
</UserControl>
