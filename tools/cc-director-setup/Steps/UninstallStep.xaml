<UserControl x:Class="CcDirectorSetup.Steps.UninstallStep"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <!-- ===================== CONFIRM ===================== -->
        <DockPanel x:Name="ConfirmView">
            <StackPanel DockPanel.Dock="Top">
                <TextBlock Text="Uninstall CC Director"
                           Foreground="White" FontSize="22" FontWeight="SemiBold" />
                <TextBlock x:Name="ConfirmSubtitle"
                           Text="This removes CC Director and its integration from this PC."
                           Foreground="{StaticResource TextForeground}" FontSize="13"
                           Margin="0,8,0,0" />
            </StackPanel>

            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                        HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button x:Name="ConfirmCancelButton" Content="Cancel" Width="100"
                        Click="ConfirmCancelButton_Click" />
                <Button x:Name="ConfirmUninstallButton" Content="Uninstall" Width="120" Margin="8,0,0,0"
                        Style="{StaticResource DangerButton}"
                        Click="ConfirmUninstallButton_Click" />
            </StackPanel>

            <StackPanel Margin="0,20,0,0">
                <Border Background="#2A2D2E" CornerRadius="6" Padding="16">
                    <StackPanel>
                        <TextBlock Text="What gets removed"
                                   Foreground="White" FontSize="14" FontWeight="SemiBold" />
                        <ItemsControl x:Name="RemoveList" Margin="0,8,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                        <Ellipse Width="5" Height="5" Fill="#888888"
                                                 VerticalAlignment="Center" Margin="2,0,10,0" />
                                        <TextBlock Text="{Binding}" Foreground="#CCCCCC" FontSize="13" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border x:Name="DataKeptCard" Background="#1B2A3A" CornerRadius="6" Padding="14" Margin="0,12,0,0">
                    <TextBlock x:Name="DataKeptText"
                               Foreground="#AACCEE" FontSize="12.5" TextWrapping="Wrap" />
                </Border>

                <CheckBox x:Name="DeleteDataCheckbox" Margin="2,14,0,0"
                          Foreground="#CCCCCC"
                          Checked="DeleteDataCheckbox_Changed"
                          Unchecked="DeleteDataCheckbox_Changed">
                    <TextBlock TextWrapping="Wrap" Margin="4,0,0,0">
                        <Run Text="Also delete my data" FontWeight="SemiBold" Foreground="#E5A100" /><LineBreak />
                        <Run Text="Permanently remove config, vault secrets, signed-in browser sessions, and recordings. This cannot be undone."
                             Foreground="#999999" FontSize="11.5" />
                    </TextBlock>
                </CheckBox>
            </StackPanel>
        </DockPanel>

        <!-- ===================== PROGRESS ===================== -->
        <DockPanel x:Name="ProgressView" Visibility="Collapsed">
            <StackPanel DockPanel.Dock="Top">
                <TextBlock Text="Uninstalling"
                           Foreground="White" FontSize="22" FontWeight="SemiBold" />
                <TextBlock x:Name="ProgressStatus" Text="Preparing..."
                           Foreground="{StaticResource TextForeground}" FontSize="13" Margin="0,8,0,4" />
                <ProgressBar IsIndeterminate="True" Height="3" Margin="0,8,0,16"
                             Background="#3C3C3C" Foreground="#007ACC" BorderThickness="0" />
            </StackPanel>

            <Border Background="#2A2D2E" CornerRadius="6" Padding="16">
                <ScrollViewer x:Name="StepScroller" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="StepList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,3">
                                    <Ellipse Width="8" Height="8" Fill="#22C55E"
                                             VerticalAlignment="Center" Margin="0,0,10,0" />
                                    <TextBlock Text="{Binding}" Foreground="#AAAAAA" FontSize="13" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </DockPanel>

        <!-- ===================== COMPLETE ===================== -->
        <DockPanel x:Name="CompleteView" Visibility="Collapsed">
            <StackPanel DockPanel.Dock="Top">
                <StackPanel Orientation="Horizontal">
                    <Ellipse x:Name="CompleteDot" Width="12" Height="12" Fill="#22C55E"
                             VerticalAlignment="Center" Margin="0,0,10,0" />
                    <TextBlock x:Name="CompleteHeading" Text="Uninstall complete"
                               Foreground="White" FontSize="22" FontWeight="SemiBold" />
                </StackPanel>
                <TextBlock x:Name="CompleteSummary"
                           Foreground="{StaticResource TextForeground}" FontSize="13"
                           Margin="0,8,0,0" TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                        HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button x:Name="CompleteCloseButton" Content="Close" Width="100"
                        Style="{StaticResource PrimaryButton}"
                        Click="CompleteCloseButton_Click" />
            </StackPanel>

            <StackPanel Margin="0,20,0,0">
                <Border x:Name="ErrorCard" Background="#2A2D2E" CornerRadius="6" Padding="16"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Some items could not be removed"
                                   Foreground="#E5A100" FontSize="14" FontWeight="SemiBold" />
                        <ItemsControl x:Name="ErrorList" Margin="0,8,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#CCCCCC" FontSize="12.5"
                                               TextWrapping="Wrap" Margin="0,2" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Background="#1B2A3A" CornerRadius="6" Padding="14" Margin="0,12,0,0">
                    <TextBlock x:Name="CompleteDataKept"
                               Foreground="#AACCEE" FontSize="12.5" TextWrapping="Wrap" />
                </Border>
            </StackPanel>
        </DockPanel>
    </Grid>
</UserControl>
