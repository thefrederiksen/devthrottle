<UserControl x:Class="CcDirectorSetup.Steps.SignInStep"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel>
        <StackPanel DockPanel.Dock="Top">
            <TextBlock Text="Sign in to DevThrottle"
                       Foreground="White"
                       FontSize="22"
                       FontWeight="SemiBold" />
            <TextBlock Text="An account is required to use DevThrottle. You sign in once, here, before we finish."
                       Foreground="{StaticResource TextForeground}"
                       FontSize="13"
                       TextWrapping="Wrap"
                       Margin="0,8,0,0" />
        </StackPanel>

        <!-- Centered sign-in card -->
        <Border Background="#252526"
                CornerRadius="6"
                Padding="32"
                Margin="0,32,0,0"
                VerticalAlignment="Top"
                HorizontalAlignment="Center"
                MinWidth="420">
            <StackPanel HorizontalAlignment="Center">

                <!-- The one button -->
                <Button x:Name="SignInButton"
                        Content="Sign in to DevThrottle"
                        Width="240"
                        Height="40"
                        FontSize="15"
                        Style="{StaticResource PrimaryButton}"
                        Click="SignInButton_Click" />

                <TextBlock Text="A browser opens to sign in."
                           Foreground="{StaticResource DimText}"
                           FontSize="12"
                           HorizontalAlignment="Center"
                           Margin="0,12,0,0" />

                <!-- Waiting state (hidden until the browser is opened) -->
                <StackPanel x:Name="WaitingPanel"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,20,0,0"
                            Visibility="Collapsed">
                    <TextBlock Text="Waiting for sign-in..."
                               Foreground="{StaticResource AccentBrush}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <Button x:Name="CancelButton"
                            Content="Cancel"
                            Width="90"
                            Margin="16,0,0,0"
                            Click="CancelButton_Click" />
                </StackPanel>

                <!-- Status message (cancel / timeout / failure / success) -->
                <TextBlock x:Name="StatusText"
                           FontSize="13"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Foreground="{StaticResource TextForeground}"
                           HorizontalAlignment="Center"
                           Margin="0,20,0,0"
                           Visibility="Collapsed" />

                <!-- Success banner -->
                <StackPanel x:Name="SuccessPanel"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,20,0,0"
                            Visibility="Collapsed">
                    <Border Width="28" Height="28" CornerRadius="14"
                            Background="{StaticResource SuccessBrush}"
                            Margin="0,0,10,0">
                        <TextBlock Text="OK"
                                   Foreground="White"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Signed in. Click Next to continue."
                               Foreground="{StaticResource SuccessBrush}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </StackPanel>
            </StackPanel>
        </Border>
    </DockPanel>
</UserControl>
