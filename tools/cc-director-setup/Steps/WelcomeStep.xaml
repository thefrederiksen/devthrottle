<UserControl x:Class="CcDirectorSetup.Steps.WelcomeStep"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <Image Source="pack://application:,,,/app.ico"
               Width="96"
               Height="96"
               HorizontalAlignment="Center"
               Margin="0,8,0,16"
               RenderOptions.BitmapScalingMode="HighQuality" />

        <TextBlock x:Name="TitleText"
                   Text="Welcome to CC Director"
                   Foreground="White"
                   FontSize="24"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center" />

        <TextBlock Text="A Windows-first toolkit for Claude Code developers"
                   Foreground="{StaticResource AccentBrush}"
                   FontSize="14"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center"
                   Margin="0,6,0,0" />

        <TextBlock x:Name="DescriptionText"
                   Text="CC Director runs and manages multiple Claude Code sessions side by side, with a full suite of CLI tools for documents, browser automation, email, media, and more. Built for Windows developers who live in the terminal and want Claude Code to fit into a real day of shipping software."
                   Foreground="{StaticResource TextForeground}"
                   FontSize="13"
                   TextWrapping="Wrap"
                   TextAlignment="Center"
                   Margin="40,20,40,0"
                   LineHeight="20" />

        <TextBlock x:Name="VersionInfoText"
                   Foreground="{StaticResource DimText}"
                   FontSize="12"
                   HorizontalAlignment="Center"
                   Margin="0,16,0,0"
                   Visibility="Collapsed" />

        <Border x:Name="RolePanel"
                Margin="40,24,40,0"
                Padding="16,12"
                Background="#1A000000"
                CornerRadius="6">
            <StackPanel>
                <TextBlock Text="Install type"
                           Foreground="White"
                           FontSize="13"
                           FontWeight="SemiBold" />
                <RadioButton x:Name="WorkstationRadio"
                             GroupName="role"
                             IsChecked="True"
                             Margin="0,10,0,0"
                             Foreground="{StaticResource TextForeground}">
                    <TextBlock TextWrapping="Wrap">
                        <Run Text="Workstation" FontWeight="SemiBold" Foreground="White" /><LineBreak />
                        <Run Text="CC Director app + all CLI tools. Per-user, no administrator rights." FontSize="12" />
                    </TextBlock>
                </RadioButton>
                <RadioButton x:Name="GatewayRadio"
                             GroupName="role"
                             Margin="0,10,0,0"
                             Foreground="{StaticResource TextForeground}">
                    <TextBlock TextWrapping="Wrap">
                        <Run Text="Gateway" FontWeight="SemiBold" Foreground="White" /><LineBreak />
                        <Run Text="Everything above, plus the Gateway tray app (starts at logon) and the Cockpit web UI. Per-user, no administrator rights." FontSize="12" />
                    </TextBlock>
                </RadioButton>
            </StackPanel>
        </Border>

        <TextBlock Text="Click Next to continue."
                   Foreground="{StaticResource DimText}"
                   FontSize="12"
                   HorizontalAlignment="Center"
                   Margin="0,28,0,0" />
    </StackPanel>
</UserControl>
