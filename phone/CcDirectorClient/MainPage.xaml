<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CcDirectorClient.MainPage"
             BackgroundColor="#0B1020"
             Shell.NavBarIsVisible="False"
             Title="CC Director Client">

    <Grid>
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <Label Text="Notes"
                   FontSize="26" FontAttributes="Bold" TextColor="#E6EAF2" />
            <Label Text="Quick notes, kept on your phone."
                   FontSize="13" TextColor="#8A93A6" />

            <Entry x:Name="TitleEntry" Placeholder="Title (optional)"
                   TextColor="#E6EAF2" PlaceholderColor="#8A93A6" BackgroundColor="#141B2E" />

            <Button x:Name="RecordButton" Text="Start"
                    BackgroundColor="#2B6CB0" TextColor="White"
                    FontSize="18" FontAttributes="Bold" HeightRequest="64"
                    CornerRadius="12" Clicked="OnRecordClicked" />

            <Button x:Name="PauseButton" Text="Pause" IsVisible="False"
                    BackgroundColor="#2B6CB0" TextColor="White" HeightRequest="50"
                    CornerRadius="12" Clicked="OnPauseClicked" />

            <!-- Discreet running indicator: small + muted, shown only while active,
                 so a glance does not reveal audio capture. No red, no "recording"
                 wording, no live mic meter. -->
            <HorizontalStackLayout Spacing="8" HorizontalOptions="Center" Margin="0,2,0,0">
                <Border x:Name="StatusDot" WidthRequest="9" HeightRequest="9"
                        StrokeShape="RoundRectangle 5" BackgroundColor="#5B8DEF"
                        VerticalOptions="Center" IsVisible="False" />
                <Label x:Name="TimerLabel" Text="" FontSize="13" TextColor="#5A6378" VerticalOptions="Center" />
                <Label x:Name="StateLabel" Text="" FontSize="13" TextColor="#5A6378" IsVisible="False" />
                <Label x:Name="SegmentLabel" Text="" FontSize="12" TextColor="#5A6378" IsVisible="False" />
            </HorizontalStackLayout>
            <ProgressBar x:Name="LevelMeter" Progress="0" HeightRequest="1"
                         ProgressColor="#0B1020" IsVisible="False" />

            <!-- Notes -->
            <Label Text="Notes" FontSize="15" FontAttributes="Bold" TextColor="#E6EAF2" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Entry x:Name="NoteEntry" Grid.Column="0" Placeholder="Type a note, hit Add"
                       TextColor="#E6EAF2" PlaceholderColor="#5A6378" BackgroundColor="#141B2E" />
                <Button x:Name="AddNoteButton" Grid.Column="1" Text="Add"
                        BackgroundColor="#2B6CB0" TextColor="White" Clicked="OnAddNoteClicked" />
            </Grid>
            <CollectionView x:Name="NotesList" HeightRequest="120">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Label Text="{Binding}" TextColor="#B7C0D4" FontSize="13" Padding="0,2" />
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Recordings list: per-row upload progress lives here, out of the
                 way of the recording controls above. -->
            <Label Text="Saved" FontSize="15" FontAttributes="Bold" TextColor="#E6EAF2" />
            <Label Text="Kept on your phone."
                   FontSize="12" TextColor="#8A93A6" />
            <CollectionView x:Name="LibraryList" HeightRequest="320"
                            SelectionMode="Single" SelectionChanged="OnRecordingSelected">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="#141B2E" StrokeShape="RoundRectangle 8" Padding="10" Margin="0,3">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding Title}" TextColor="#E6EAF2" FontAttributes="Bold" />
                                <Label Text="{Binding Subtitle}" TextColor="#8A93A6" FontSize="12" />
                                <ProgressBar Progress="{Binding Progress}" ProgressColor="#5FD08A"
                                             HeightRequest="6" IsVisible="{Binding IsUploading}" />
                                <!-- Two independent status checkmarks: upload + transcription -->
                                <HorizontalStackLayout Spacing="18" Margin="0,2,0,0">
                                    <HorizontalStackLayout Spacing="5" VerticalOptions="Center">
                                        <Path Data="M0,5 L4,9 L11,0"
                                              Stroke="{Binding UploadStroke}" StrokeThickness="2.5"
                                              WidthRequest="13" HeightRequest="11" VerticalOptions="Center" />
                                        <Label Text="Saved" FontSize="11" TextColor="#8A93A6" VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                    <HorizontalStackLayout Spacing="5" VerticalOptions="Center">
                                        <Path Data="M0,5 L4,9 L11,0"
                                              Stroke="{Binding TransCheckStroke}" StrokeThickness="2.5"
                                              WidthRequest="13" HeightRequest="11" VerticalOptions="Center"
                                              IsVisible="{Binding TransShowCheck}" />
                                        <Path Data="M0,0 L10,10 M10,0 L0,10"
                                              Stroke="#E8B339" StrokeThickness="2.5"
                                              WidthRequest="11" HeightRequest="11" VerticalOptions="Center"
                                              IsVisible="{Binding TransShowX}" />
                                        <Label Text="Synced" FontSize="11" TextColor="#8A93A6" VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Server settings (out of the way; pre-filled) -->
            <Label Text="Server settings" FontSize="13" FontAttributes="Bold" TextColor="#5A6378" Margin="0,12,0,0" />
            <Entry x:Name="ServerEntry" Placeholder="https://gateway-host.ts.net"
                   TextColor="#A9B4C8" PlaceholderColor="#5A6378" BackgroundColor="#0F1626"
                   Unfocused="OnCredsChanged" />
            <Entry x:Name="TokenEntry" Placeholder="Gateway token" IsPassword="True"
                   TextColor="#A9B4C8" PlaceholderColor="#5A6378" BackgroundColor="#0F1626"
                   Unfocused="OnCredsChanged" />

        </VerticalStackLayout>
    </ScrollView>

        <!-- Top-right burger menu: switch between Talk and Recorder. -->
        <Border x:Name="NavMenuButton"
                HorizontalOptions="End" VerticalOptions="Start"
                Margin="0,14,16,0" Padding="11,9"
                BackgroundColor="#141B2E" Stroke="#2A3550"
                StrokeShape="RoundRectangle 8">
            <VerticalStackLayout Spacing="4" WidthRequest="22">
                <BoxView HeightRequest="2" Color="#E6EAF2" />
                <BoxView HeightRequest="2" Color="#E6EAF2" />
                <BoxView HeightRequest="2" Color="#E6EAF2" />
            </VerticalStackLayout>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnNavMenuClicked" />
            </Border.GestureRecognizers>
        </Border>
    </Grid>
</ContentPage>
