<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CcDirectorClient.TalkPage"
             BackgroundColor="#0B1020"
             Shell.NavBarIsVisible="False"
             Title="Talk">

    <Grid>
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <Label Text="CC Director Client"
                   FontSize="26" FontAttributes="Bold" TextColor="#E6EAF2" />
            <Label Text="Talk to a Claude Code session by voice. Push to talk, push to send, hear the reply."
                   FontSize="13" TextColor="#8A93A6" />

            <!-- ===== Session list (roster) ===== -->
            <VerticalStackLayout x:Name="ListPanel" Spacing="12">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <Label Grid.Column="0" Text="Sessions" FontSize="18" FontAttributes="Bold"
                           TextColor="#E6EAF2" VerticalOptions="Center" />
                    <Button Grid.Column="1" x:Name="RefreshButton" Text="Refresh"
                            BackgroundColor="#2B6CB0" TextColor="White" Clicked="OnRefreshClicked" />
                </Grid>
                <Label x:Name="ListStatusLabel" Text="Loading sessions..." FontSize="13" TextColor="#8A93A6" />

                <Button x:Name="ConductorButton" Text="Talk to all sessions that need me"
                        BackgroundColor="#6B46C1" TextColor="White" HeightRequest="50"
                        CornerRadius="12" Clicked="OnConductorClicked" />

                <CollectionView x:Name="SessionsList" SelectionMode="Single"
                                SelectionChanged="OnSessionSelected" HeightRequest="420">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="#141B2E" StrokeShape="RoundRectangle 10" Padding="12" Margin="0,3">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                    <Border Grid.Column="0" WidthRequest="14" HeightRequest="14"
                                            StrokeShape="RoundRectangle 7" BackgroundColor="{Binding Dot}"
                                            VerticalOptions="Center" />
                                    <VerticalStackLayout Grid.Column="1" Spacing="2">
                                        <Label Text="{Binding Name}" TextColor="#E6EAF2" FontAttributes="Bold" />
                                        <Label Text="{Binding Subtitle}" TextColor="#8A93A6" FontSize="12" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Gateway settings (out of the way; pre-filled) -->
                <Label Text="Gateway settings" FontSize="13" FontAttributes="Bold" TextColor="#5A6378" Margin="0,12,0,0" />
                <Entry x:Name="ServerEntry" Placeholder="https://gateway-host.ts.net"
                       TextColor="#A9B4C8" PlaceholderColor="#5A6378" BackgroundColor="#0F1626"
                       Unfocused="OnCredsChanged" />
                <Entry x:Name="TokenEntry" Placeholder="Gateway token (optional)" IsPassword="True"
                       TextColor="#A9B4C8" PlaceholderColor="#5A6378" BackgroundColor="#0F1626"
                       Unfocused="OnCredsChanged" />
            </VerticalStackLayout>

            <!-- ===== Single-session panel: three tabs (Voice / Wingman / Terminal) ===== -->
            <VerticalStackLayout x:Name="TalkPanel" Spacing="16" IsVisible="False">
                <Button x:Name="BackButton" Text="&lt; Back to sessions"
                        BackgroundColor="Transparent" TextColor="#8A93A6"
                        HorizontalOptions="Start" Clicked="OnBackClicked" />

                <Border BackgroundColor="#141B2E" StrokeShape="RoundRectangle 14" Padding="18">
                    <VerticalStackLayout Spacing="6">
                        <Label x:Name="TalkSessionName" Text="" FontSize="22"
                               FontAttributes="Bold" TextColor="#E6EAF2" />
                        <Label x:Name="TalkSessionState" Text="" FontSize="13" TextColor="#8A93A6" />
                    </VerticalStackLayout>
                </Border>

                <!-- Tab switcher: Voice | Wingman | Terminal. A simple three-button
                     segmented control; the selected tab is highlighted and swaps the
                     content section below. Kept at the top so it works one-handed. -->
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="6">
                    <Button Grid.Column="0" x:Name="VoiceTabButton" Text="Voice"
                            BackgroundColor="#2B6CB0" TextColor="White" HeightRequest="44"
                            CornerRadius="10" FontAttributes="Bold" Clicked="OnVoiceTabClicked" />
                    <Button Grid.Column="1" x:Name="WingmanTabButton" Text="Wingman"
                            BackgroundColor="#1A2236" TextColor="#8A93A6" HeightRequest="44"
                            CornerRadius="10" Clicked="OnWingmanTabClicked" />
                    <Button Grid.Column="2" x:Name="TerminalTabButton" Text="Terminal"
                            BackgroundColor="#1A2236" TextColor="#8A93A6" HeightRequest="44"
                            CornerRadius="10" Clicked="OnTerminalTabClicked" />
                </Grid>

                <!-- ========== VOICE SECTION (eyes-free, spoken replies) ========== -->
                <VerticalStackLayout x:Name="VoiceSection" Spacing="16">
                    <!-- Big, always-present status so you always know where we are. -->
                    <Label x:Name="VoiceStatusLabel" Text="Ready" FontSize="17"
                           FontAttributes="Bold" TextColor="#5FD08A" HorizontalOptions="Center" />

                    <!-- Ask Agent: the primary push-to-talk. Bigger than Ask Wingman.
                         Talks to the working agent and speaks the reply. -->
                    <Button x:Name="TalkButton" Text="Ask Agent"
                            BackgroundColor="#5FD08A" TextColor="#06210F"
                            FontSize="22" FontAttributes="Bold" HeightRequest="110"
                            CornerRadius="18" Clicked="OnTalkClicked" />

                    <!-- Recording view: shows the live mic level so you can see your
                         voice is being captured, plus elapsed time and the send hint. -->
                    <Border x:Name="RecordingCard" IsVisible="False"
                            BackgroundColor="#21121A" Stroke="#E5484D" StrokeThickness="1"
                            StrokeShape="RoundRectangle 14" Padding="16">
                        <VerticalStackLayout Spacing="12">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                <Border Grid.Column="0" WidthRequest="12" HeightRequest="12"
                                        StrokeShape="RoundRectangle 6" BackgroundColor="#E5484D"
                                        VerticalOptions="Center" />
                                <Label Grid.Column="1" Text="Recording - tap Send when done"
                                       TextColor="#E6EAF2" FontAttributes="Bold" VerticalOptions="Center" />
                                <Label Grid.Column="2" x:Name="RecElapsedLabel" Text="00:00"
                                       TextColor="#8A93A6" VerticalOptions="Center" />
                            </Grid>
                            <ProgressBar x:Name="LevelMeter" Progress="0" ProgressColor="#5FD08A"
                                         HeightRequest="10" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Ask Wingman: a bit smaller than Ask Agent. Read-only observer. -->
                    <Button x:Name="AskWingmanButton" Text="Ask Wingman"
                            BackgroundColor="#0E7C6B" TextColor="White" HeightRequest="62"
                            CornerRadius="14" FontSize="16" Clicked="OnAskWingmanClicked" />

                    <Button x:Name="NextButton" Text="Next session" IsVisible="False"
                            BackgroundColor="#6B46C1" TextColor="White" HeightRequest="54"
                            CornerRadius="12" Clicked="OnNextClicked" />

                    <Border BackgroundColor="#0F1626" StrokeShape="RoundRectangle 12" Padding="14">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="You said" FontSize="12" FontAttributes="Bold" TextColor="#5A6378" />
                            <Label x:Name="TranscriptLabel" Text="-" TextColor="#B7C0D4" FontSize="14" />
                            <Label Text="Reply" FontSize="12" FontAttributes="Bold" TextColor="#5A6378" Margin="0,8,0,0" />
                            <Label x:Name="ReplyLabel" Text="-" TextColor="#E6EAF2" FontSize="14" />
                        </VerticalStackLayout>
                    </Border>

                    <Label x:Name="TurnStatusLabel" Text="" FontSize="13" TextColor="#E8B339"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>

                <!-- ========== WINGMAN SECTION (clean text output, text replies) ========== -->
                <VerticalStackLayout x:Name="WingmanSection" Spacing="12" IsVisible="False">
                    <Label x:Name="WingmanStatusLabel" Text="" FontSize="13" TextColor="#8A93A6"
                           HorizontalOptions="Center" />

                    <!-- Wingman annotation: plain-language "what just happened / what it is
                         waiting on" from the read-only observer, atop the clean output. -->
                    <Border BackgroundColor="#15233B" Stroke="#0E7C6B" StrokeThickness="1"
                            StrokeShape="RoundRectangle 12" Padding="14">
                        <VerticalStackLayout Spacing="8">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <Label Grid.Column="0" Text="Wingman" FontSize="12" FontAttributes="Bold"
                                       TextColor="#5FD08A" VerticalOptions="Center" />
                                <Button Grid.Column="1" x:Name="WingmanRefreshButton" Text="Refresh"
                                        BackgroundColor="#0E7C6B" TextColor="White" HeightRequest="36"
                                        Padding="12,0" CornerRadius="8" FontSize="13"
                                        Clicked="OnWingmanRefreshClicked" />
                            </Grid>
                            <Label x:Name="WingmanNoteLabel" Text="Tap Refresh for a read on this session."
                                   TextColor="#E6EAF2" FontSize="14" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Clean, de-noised conversation. Monospace-ish readable text. -->
                    <Border BackgroundColor="#0F1626" StrokeShape="RoundRectangle 12" Padding="14">
                        <Label x:Name="WingmanOutputLabel" Text="Loading clean output..."
                               TextColor="#B7C0D4" FontSize="13" />
                    </Border>

                    <!-- Input bar: type or Speak, Send -> agent. Replies render as TEXT
                         in the clean output above (this tab never speaks). -->
                    <Entry x:Name="WingmanInput" Placeholder="type a message..."
                           TextColor="#E6EAF2" PlaceholderColor="#5A6378" BackgroundColor="#0F1626" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <Button Grid.Column="0" x:Name="WingmanSpeakButton" Text="Speak"
                                BackgroundColor="#0E7C6B" TextColor="White" HeightRequest="50"
                                CornerRadius="12" Clicked="OnWingmanSpeakClicked" />
                        <Button Grid.Column="1" x:Name="WingmanSendButton" Text="Send"
                                BackgroundColor="#2B6CB0" TextColor="White" HeightRequest="50"
                                CornerRadius="12" Clicked="OnWingmanSendClicked" />
                    </Grid>
                </VerticalStackLayout>

                <!-- ========== TERMINAL SECTION (read-only mirror + control buttons) ========== -->
                <VerticalStackLayout x:Name="TerminalSection" Spacing="12" IsVisible="False">
                    <Label x:Name="TerminalStatusLabel" Text="" FontSize="13" TextColor="#8A93A6"
                           HorizontalOptions="Center" />

                    <!-- Read-only raw terminal: a real xterm.js emulator hosted in a
                         WebView, fed by the session's raw PTY byte stream over
                         /sessions/{sid}/stream (the same path the web client uses). A
                         byte stream applied in order renders coherently, unlike the old
                         poll-the-grid-into-a-Label approach which stacked half-drawn
                         repaint frames as overlapping ghost lines. -->
                    <Border BackgroundColor="#06090F" StrokeShape="RoundRectangle 8" Padding="0">
                        <WebView x:Name="TerminalWebView" HeightRequest="440"
                                 BackgroundColor="#1E1E1E" />
                    </Border>

                    <!-- Structured input: type a line + Send. This writes to the PTY. -->
                    <Entry x:Name="TerminalInput" Placeholder="type / send..."
                           TextColor="#E6EAF2" PlaceholderColor="#5A6378" BackgroundColor="#0F1626" />
                    <Button x:Name="TerminalSendButton" Text="Send"
                            BackgroundColor="#2B6CB0" TextColor="White" HeightRequest="48"
                            CornerRadius="12" Clicked="OnTerminalSendClicked" />

                    <!-- Control buttons: Enter, Esc, Stop, and the four arrows. -->
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8" RowSpacing="8">
                        <Button Grid.Column="0" x:Name="TerminalEnterButton" Text="Enter"
                                BackgroundColor="#5FD08A" TextColor="#06210F" HeightRequest="46"
                                CornerRadius="10" FontAttributes="Bold" Clicked="OnTerminalEnterClicked" />
                        <Button Grid.Column="1" x:Name="TerminalEscButton" Text="Esc"
                                BackgroundColor="#E8B339" TextColor="#221A06" HeightRequest="46"
                                CornerRadius="10" FontAttributes="Bold" Clicked="OnTerminalEscClicked" />
                        <Button Grid.Column="2" x:Name="TerminalStopButton" Text="Stop"
                                BackgroundColor="#E5484D" TextColor="White" HeightRequest="46"
                                CornerRadius="10" FontAttributes="Bold" Clicked="OnTerminalStopClicked" />
                    </Grid>
                    <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8">
                        <Button Grid.Column="0" x:Name="TerminalUpButton" Text="Up"
                                BackgroundColor="#1A2236" TextColor="#E6EAF2" HeightRequest="46"
                                CornerRadius="10" Clicked="OnTerminalUpClicked" />
                        <Button Grid.Column="1" x:Name="TerminalDownButton" Text="Down"
                                BackgroundColor="#1A2236" TextColor="#E6EAF2" HeightRequest="46"
                                CornerRadius="10" Clicked="OnTerminalDownClicked" />
                        <Button Grid.Column="2" x:Name="TerminalLeftButton" Text="Left"
                                BackgroundColor="#1A2236" TextColor="#E6EAF2" HeightRequest="46"
                                CornerRadius="10" Clicked="OnTerminalLeftClicked" />
                        <Button Grid.Column="3" x:Name="TerminalRightButton" Text="Right"
                                BackgroundColor="#1A2236" TextColor="#E6EAF2" HeightRequest="46"
                                CornerRadius="10" Clicked="OnTerminalRightClicked" />
                    </Grid>
                </VerticalStackLayout>

            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

        <!-- Top-right burger menu: switch between Talk and Recorder. -->
        <Border x:Name="NavMenuButton"
                HorizontalOptions="End" VerticalOptions="Start"
                Margin="0,14,16,0" Padding="11,9"
                BackgroundColor="#141B2E" Stroke="#2A3550"
                StrokeShape="RoundRectangle 8">
            <VerticalStackLayout Spacing="4" WidthRequest="22">
                <BoxView HeightRequest="2" Color="#E6EAF2" />
                <BoxView HeightRequest="2" Color="#E6EAF2" />
                <BoxView HeightRequest="2" Color="#E6EAF2" />
            </VerticalStackLayout>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnNavMenuClicked" />
            </Border.GestureRecognizers>
        </Border>
    </Grid>
</ContentPage>
