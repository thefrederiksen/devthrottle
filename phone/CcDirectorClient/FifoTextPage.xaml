<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CcDirectorClient.FifoTextPage"
             BackgroundColor="#0B1020"
             Shell.NavBarIsVisible="False"
             Title="FIFO Text">

    <Grid>
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <Label Text="FIFO text mode"
                   FontSize="26" FontAttributes="Bold" TextColor="#E6EAF2" />
            <Label Text="Go through every session that needs you, one at a time - by typing. Read what's happening, type your answer, and it moves straight to the next. No waiting for the agent to respond."
                   FontSize="13" TextColor="#8A93A6" />

            <!-- ===== Start panel ===== -->
            <VerticalStackLayout x:Name="StartPanel" Spacing="12">
                <Label x:Name="StartStatusLabel" Text="Loading sessions..." FontSize="15" TextColor="#E6EAF2" />

                <Button x:Name="StartButton" Text="Start"
                        BackgroundColor="#6B46C1" TextColor="White" HeightRequest="64"
                        FontSize="20" FontAttributes="Bold" CornerRadius="14"
                        Clicked="OnStartClicked" />
                <Button x:Name="RescanButton" Text="Refresh count"
                        BackgroundColor="#2B6CB0" TextColor="White" HeightRequest="46"
                        CornerRadius="10" Clicked="OnRescanClicked" />

                <!-- Gateway settings (shared with the other screens via the same prefs) -->
                <Label Text="Gateway settings" FontSize="13" FontAttributes="Bold" TextColor="#5A6378" Margin="0,12,0,0" />
                <Entry x:Name="ServerEntry" Placeholder="https://gateway-host.ts.net"
                       TextColor="#A9B4C8" PlaceholderColor="#5A6378" BackgroundColor="#0F1626"
                       Unfocused="OnCredsChanged" />
                <Entry x:Name="TokenEntry" Placeholder="Gateway token (optional)" IsPassword="True"
                       TextColor="#A9B4C8" PlaceholderColor="#5A6378" BackgroundColor="#0F1626"
                       Unfocused="OnCredsChanged" />
            </VerticalStackLayout>

            <!-- ===== Active panel: one session at a time ===== -->
            <VerticalStackLayout x:Name="FifoPanel" Spacing="16" IsVisible="False">
                <Button x:Name="ExitButton" Text="&lt; Exit FIFO"
                        BackgroundColor="Transparent" TextColor="#8A93A6"
                        HorizontalOptions="Start" Clicked="OnExitClicked" />

                <Border BackgroundColor="#141B2E" StrokeShape="RoundRectangle 14" Padding="18">
                    <VerticalStackLayout Spacing="6">
                        <Label x:Name="FifoSessionName" Text="" FontSize="22"
                               FontAttributes="Bold" TextColor="#E6EAF2" />
                        <Label x:Name="FifoSessionState" Text="" FontSize="13" TextColor="#8A93A6" />
                    </VerticalStackLayout>
                </Border>

                <Label x:Name="FifoStatusLabel" Text="Ready" FontSize="17"
                       FontAttributes="Bold" TextColor="#5FD08A" HorizontalOptions="Center" />

                <!-- What's happening: the wingman's briefing, shown as text to read. -->
                <Border BackgroundColor="#15233B" Stroke="#0E7C6B" StrokeThickness="1"
                        StrokeShape="RoundRectangle 12" Padding="14">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="What's happening" FontSize="12" FontAttributes="Bold" TextColor="#5FD08A" />
                        <Label x:Name="BriefingLabel" Text="-" TextColor="#E6EAF2" FontSize="14" />
                    </VerticalStackLayout>
                </Border>

                <!-- One input box; the action buttons decide where the text goes. -->
                <Editor x:Name="InputEditor" Placeholder="type your answer, or a question / command for the wingman..."
                        TextColor="#E6EAF2" PlaceholderColor="#5A6378" BackgroundColor="#0F1626"
                        AutoSize="TextChanges" MinimumHeightRequest="90" />

                <!-- Primary: send the typed text to the session, then auto-advance. -->
                <Button x:Name="SendButton" Text="Send to session"
                        BackgroundColor="#5FD08A" TextColor="#06210F"
                        FontSize="18" FontAttributes="Bold" HeightRequest="64"
                        CornerRadius="14" Clicked="OnSendClicked" />

                <!-- Ask the wingman with the typed text: a question is answered as text below;
                     "skip"/"hold" are acted on, just like the spoken FIFO mode. -->
                <Button x:Name="AskWingmanButton" Text="Ask Wingman"
                        BackgroundColor="#0E7C6B" TextColor="White" HeightRequest="56"
                        CornerRadius="14" FontSize="16" Clicked="OnAskWingmanClicked" />

                <!-- Skip / Hold: steer the queue. -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <Button Grid.Column="0" x:Name="SkipButton" Text="Skip"
                            BackgroundColor="#2B6CB0" TextColor="White" HeightRequest="56"
                            CornerRadius="12" FontSize="16" Clicked="OnSkipClicked" />
                    <Button Grid.Column="1" x:Name="HoldButton" Text="Hold"
                            BackgroundColor="#8A5A1A" TextColor="White" HeightRequest="56"
                            CornerRadius="12" FontSize="16" Clicked="OnHoldClicked" />
                </Grid>

                <!-- Read area: the wingman's answers and send confirmations. -->
                <Border BackgroundColor="#0F1626" StrokeShape="RoundRectangle 12" Padding="14">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Wingman / status" FontSize="12" FontAttributes="Bold" TextColor="#5A6378" />
                        <Label x:Name="ReplyLabel" Text="-" TextColor="#E6EAF2" FontSize="14" />
                    </VerticalStackLayout>
                </Border>

                <Label x:Name="TurnStatusLabel" Text="" FontSize="13" TextColor="#E8B339"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

        <!-- Top-right burger menu: switch between pages. -->
        <Border x:Name="NavMenuButton"
                HorizontalOptions="End" VerticalOptions="Start"
                Margin="0,14,16,0" Padding="11,9"
                BackgroundColor="#141B2E" Stroke="#2A3550"
                StrokeShape="RoundRectangle 8">
            <VerticalStackLayout Spacing="4" WidthRequest="22">
                <BoxView HeightRequest="2" Color="#E6EAF2" />
                <BoxView HeightRequest="2" Color="#E6EAF2" />
                <BoxView HeightRequest="2" Color="#E6EAF2" />
            </VerticalStackLayout>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnNavMenuClicked" />
            </Border.GestureRecognizers>
        </Border>
    </Grid>
</ContentPage>
