<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:CcDirectorClient.Controls"
             x:Class="CcDirectorClient.FifoPage"
             BackgroundColor="#0B1020"
             Shell.NavBarIsVisible="False"
             Title="FIFO">

    <Grid>
    <!-- Start + Idle states scroll normally. The ACTIVE FIFO experience is the
         shared VoiceSessionView below; FIFO just walks the queue and hands each
         session to that control. -->
    <ScrollView x:Name="MainScroll">
        <VerticalStackLayout Padding="20" Spacing="16">

            <Label Text="FIFO voice mode"
                   FontSize="26" FontAttributes="Bold" TextColor="#E6EAF2" />
            <Label Text="Go through every session that needs you, one at a time. Hear what's happening, speak your answer, and it moves straight to the next - no waiting for the agent to respond."
                   FontSize="13" TextColor="#8A93A6" />

            <!-- ===== Start panel: shows how many need you, then Start ===== -->
            <VerticalStackLayout x:Name="StartPanel" Spacing="12">
                <Label x:Name="StartStatusLabel" Text="Loading sessions..." FontSize="15" TextColor="#E6EAF2" />

                <Button x:Name="StartButton" Text="Start"
                        BackgroundColor="#6B46C1" TextColor="White" HeightRequest="64"
                        FontSize="20" FontAttributes="Bold" CornerRadius="14"
                        Clicked="OnStartClicked" />
                <Button x:Name="RescanButton" Text="Refresh count"
                        BackgroundColor="#2B6CB0" TextColor="White" HeightRequest="46"
                        CornerRadius="10" Clicked="OnRescanClicked" />

                <!-- Gateway settings (shared with the Talk screen via the same prefs) -->
                <Label Text="Gateway settings" FontSize="13" FontAttributes="Bold" TextColor="#5A6378" Margin="0,12,0,0" />
                <Entry x:Name="ServerEntry" Placeholder="https://gateway-host.ts.net"
                       TextColor="#A9B4C8" PlaceholderColor="#5A6378" BackgroundColor="#0F1626"
                       Unfocused="OnCredsChanged" />
                <Entry x:Name="TokenEntry" Placeholder="Gateway token (optional)" IsPassword="True"
                       TextColor="#A9B4C8" PlaceholderColor="#5A6378" BackgroundColor="#0F1626"
                       Unfocused="OnCredsChanged" />
            </VerticalStackLayout>

            <!-- ===== Idle panel: caught up, auto-rechecking every 5 minutes ===== -->
            <VerticalStackLayout x:Name="IdlePanel" Spacing="16" IsVisible="False">
                <Button Text="&lt; Exit FIFO"
                        BackgroundColor="Transparent" TextColor="#8A93A6"
                        HorizontalOptions="Start" Clicked="OnExitFromIdleClicked" />

                <Border BackgroundColor="#141B2E" StrokeShape="RoundRectangle 14" Padding="22">
                    <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                        <Label Text="All caught up" FontSize="24" FontAttributes="Bold"
                               TextColor="#5FD08A" HorizontalOptions="Center" />
                        <Label Text="Nothing to do right now."
                               FontSize="15" TextColor="#E6EAF2" HorizontalOptions="Center" />
                        <Label x:Name="IdleCountdownLabel" Text="Checking again soon..."
                               FontSize="14" TextColor="#8A93A6" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Border>

                <Button x:Name="CheckNowButton" Text="Check now"
                        BackgroundColor="#2B6CB0" TextColor="White" HeightRequest="60"
                        CornerRadius="12" FontSize="16" Clicked="OnCheckNowClicked" />
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

        <!-- ===== Active panel: the shared VoiceSessionView, hidden until the queue
             starts. FifoPage drives it via LoadSessionAsync (each queue entry) and
             listens to AnswerDelivered/SkipRequested/HoldRequested to advance. -->
        <controls:VoiceSessionView x:Name="Voice" IsVisible="False" />

        <!-- Top-right burger menu: switch between pages. -->
        <Border x:Name="NavMenuButton"
                HorizontalOptions="End" VerticalOptions="Start"
                Margin="0,14,16,0" Padding="11,9"
                BackgroundColor="#141B2E" Stroke="#2A3550"
                StrokeShape="RoundRectangle 8">
            <VerticalStackLayout Spacing="4" WidthRequest="22">
                <BoxView HeightRequest="2" Color="#E6EAF2" />
                <BoxView HeightRequest="2" Color="#E6EAF2" />
                <BoxView HeightRequest="2" Color="#E6EAF2" />
            </VerticalStackLayout>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnNavMenuClicked" />
            </Border.GestureRecognizers>
        </Border>
    </Grid>
</ContentPage>
