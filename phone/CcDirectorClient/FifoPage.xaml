<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CcDirectorClient.FifoPage"
             BackgroundColor="#0B1020"
             Shell.NavBarIsVisible="False"
             Title="FIFO">

    <Grid>
    <!-- Start + Idle states scroll normally. The ACTIVE FIFO experience is a
         separate fixed-layout panel below so its action buttons never scroll. -->
    <ScrollView x:Name="MainScroll">
        <VerticalStackLayout Padding="20" Spacing="16">

            <Label Text="FIFO voice mode"
                   FontSize="26" FontAttributes="Bold" TextColor="#E6EAF2" />
            <Label Text="Go through every session that needs you, one at a time. Hear what's happening, speak your answer, and it moves straight to the next - no waiting for the agent to respond."
                   FontSize="13" TextColor="#8A93A6" />

            <!-- ===== Start panel: shows how many need you, then Start ===== -->
            <VerticalStackLayout x:Name="StartPanel" Spacing="12">
                <Label x:Name="StartStatusLabel" Text="Loading sessions..." FontSize="15" TextColor="#E6EAF2" />

                <Button x:Name="StartButton" Text="Start"
                        BackgroundColor="#6B46C1" TextColor="White" HeightRequest="64"
                        FontSize="20" FontAttributes="Bold" CornerRadius="14"
                        Clicked="OnStartClicked" />
                <Button x:Name="RescanButton" Text="Refresh count"
                        BackgroundColor="#2B6CB0" TextColor="White" HeightRequest="46"
                        CornerRadius="10" Clicked="OnRescanClicked" />

                <!-- Gateway settings (shared with the Talk screen via the same prefs) -->
                <Label Text="Gateway settings" FontSize="13" FontAttributes="Bold" TextColor="#5A6378" Margin="0,12,0,0" />
                <Entry x:Name="ServerEntry" Placeholder="https://gateway-host.ts.net"
                       TextColor="#A9B4C8" PlaceholderColor="#5A6378" BackgroundColor="#0F1626"
                       Unfocused="OnCredsChanged" />
                <Entry x:Name="TokenEntry" Placeholder="Gateway token (optional)" IsPassword="True"
                       TextColor="#A9B4C8" PlaceholderColor="#5A6378" BackgroundColor="#0F1626"
                       Unfocused="OnCredsChanged" />
            </VerticalStackLayout>

            <!-- ===== Idle panel: caught up, auto-rechecking every 5 minutes ===== -->
            <VerticalStackLayout x:Name="IdlePanel" Spacing="16" IsVisible="False">
                <Button Text="&lt; Exit FIFO"
                        BackgroundColor="Transparent" TextColor="#8A93A6"
                        HorizontalOptions="Start" Clicked="OnExitClicked" />

                <Border BackgroundColor="#141B2E" StrokeShape="RoundRectangle 14" Padding="22">
                    <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                        <Label Text="All caught up" FontSize="24" FontAttributes="Bold"
                               TextColor="#5FD08A" HorizontalOptions="Center" />
                        <Label Text="Nothing to do right now."
                               FontSize="15" TextColor="#E6EAF2" HorizontalOptions="Center" />
                        <Label x:Name="IdleCountdownLabel" Text="Checking again soon..."
                               FontSize="14" TextColor="#8A93A6" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Border>

                <Button x:Name="CheckNowButton" Text="Check now"
                        BackgroundColor="#2B6CB0" TextColor="White" HeightRequest="60"
                        CornerRadius="12" FontSize="16" Clicked="OnCheckNowClicked" />
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

        <!-- ===== Active panel: one session at a time =====
             Driving-safety layout (issue #143): the action buttons are PINNED in a
             fixed top region and never move or scroll; the per-session output
             (status, briefing, recording, transcript, reply) scrolls underneath. -->
        <Grid x:Name="FifoPanel" IsVisible="False" BackgroundColor="#0B1020"
              RowDefinitions="Auto,*">

            <!-- Fixed action header: never scrolls, always reachable while driving. -->
            <VerticalStackLayout Grid.Row="0" Padding="20,12,20,12" Spacing="10"
                                 BackgroundColor="#0B1020">
                <Button x:Name="ExitButton" Text="&lt; Exit FIFO"
                        BackgroundColor="Transparent" TextColor="#8A93A6"
                        HorizontalOptions="Start" Padding="0" Clicked="OnExitClicked" />

                <!-- Which session you're acting on, compact so the buttons stay reachable. -->
                <Label x:Name="FifoSessionName" Text="" FontSize="19"
                       FontAttributes="Bold" TextColor="#E6EAF2" />
                <Label x:Name="FifoSessionState" Text="" FontSize="12" TextColor="#8A93A6" />

                <!-- Primary actions read as "Ask X" so it is instantly obvious which one
                     talks to the agent vs. the wingman. Ask Agent records your answer and
                     advances; its WORD never changes (state is shown by colour only). -->
                <Button x:Name="AnswerButton" Text="Ask Agent"
                        BackgroundColor="#5FD08A" TextColor="#06210F"
                        FontSize="22" FontAttributes="Bold" HeightRequest="96"
                        CornerRadius="18" Clicked="OnAnswerClicked" />

                <!-- Ask the read-only wingman about this session (stays on it). -->
                <Button x:Name="AskWingmanButton" Text="Ask Wingman"
                        BackgroundColor="#0E7C6B" TextColor="White" HeightRequest="56"
                        CornerRadius="14" FontSize="16" Clicked="OnAskWingmanClicked" />

                <!-- Replay (issue #148): re-hear the last thing said for this session (its
                     briefing, or the wingman's last answer). Shown only when a clip is cached;
                     hidden once the session starts working again so stale audio never replays. -->
                <Button x:Name="ReplayButton" Text="Replay" IsVisible="False"
                        BackgroundColor="#2B6CB0" TextColor="White" HeightRequest="56"
                        CornerRadius="14" FontSize="16" Clicked="OnReplayClicked" />

                <!-- Skip / Hold: steer the queue. Skip = move on, come back later.
                     Hold = park this one out of the rotation until you bring it back. -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <Button Grid.Column="0" x:Name="SkipButton" Text="Skip"
                            BackgroundColor="#2B6CB0" TextColor="White" HeightRequest="56"
                            CornerRadius="12" FontSize="16" Clicked="OnSkipClicked" />
                    <Button Grid.Column="1" x:Name="HoldButton" Text="Hold"
                            BackgroundColor="#8A5A1A" TextColor="White" HeightRequest="56"
                            CornerRadius="12" FontSize="16" Clicked="OnHoldClicked" />
                </Grid>
            </VerticalStackLayout>

            <!-- Scrollable output: everything being answered for this session. -->
            <ScrollView Grid.Row="1" Padding="20,4,20,20">
                <VerticalStackLayout Spacing="14">

                    <!-- Big, always-present status so you always know where we are. -->
                    <Label x:Name="FifoStatusLabel" Text="Ready" FontSize="17"
                           FontAttributes="Bold" TextColor="#5FD08A" HorizontalOptions="Center" />

                    <!-- What's happening: the wingman's spoken briefing, also shown as text. -->
                    <Border BackgroundColor="#15233B" Stroke="#0E7C6B" StrokeThickness="1"
                            StrokeShape="RoundRectangle 12" Padding="14">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="What's happening" FontSize="12" FontAttributes="Bold" TextColor="#5FD08A" />
                            <Label x:Name="BriefingLabel" Text="-" TextColor="#E6EAF2" FontSize="14" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Recording view: live mic level + elapsed, identical to the Talk screen. -->
                    <Border x:Name="RecordingCard" IsVisible="False"
                            BackgroundColor="#21121A" Stroke="#E5484D" StrokeThickness="1"
                            StrokeShape="RoundRectangle 14" Padding="16">
                        <VerticalStackLayout Spacing="12">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                <Border Grid.Column="0" WidthRequest="12" HeightRequest="12"
                                        StrokeShape="RoundRectangle 6" BackgroundColor="#E5484D"
                                        VerticalOptions="Center" />
                                <Label Grid.Column="1" x:Name="RecordingHintLabel" Text="Recording - tap Ask Agent to send"
                                       TextColor="#E6EAF2" FontAttributes="Bold" VerticalOptions="Center" />
                                <Label Grid.Column="2" x:Name="RecElapsedLabel" Text="00:00"
                                       TextColor="#8A93A6" VerticalOptions="Center" />
                            </Grid>
                            <ProgressBar x:Name="LevelMeter" Progress="0" ProgressColor="#5FD08A"
                                         HeightRequest="10" />
                            <!-- Always able to bail out of a recording (e.g. started by mistake):
                                 discards the clip without transcribing or sending. -->
                            <Button x:Name="CancelRecordingButton" Text="Cancel"
                                    BackgroundColor="#3A2230" TextColor="#E6EAF2" HeightRequest="48"
                                    CornerRadius="10" FontSize="15" Clicked="OnCancelRecordingClicked" />
                        </VerticalStackLayout>
                    </Border>

                    <Border BackgroundColor="#0F1626" StrokeShape="RoundRectangle 12" Padding="14">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="You said" FontSize="12" FontAttributes="Bold" TextColor="#5A6378" />
                            <Label x:Name="TranscriptLabel" Text="-" TextColor="#B7C0D4" FontSize="14" />
                            <Label Text="Reply" FontSize="12" FontAttributes="Bold" TextColor="#5A6378" Margin="0,8,0,0" />
                            <Label x:Name="ReplyLabel" Text="-" TextColor="#E6EAF2" FontSize="14" />
                        </VerticalStackLayout>
                    </Border>

                    <Label x:Name="TurnStatusLabel" Text="" FontSize="13" TextColor="#E8B339"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </ScrollView>
        </Grid>

        <!-- Floating Stop-talking pill (issue #146): pinned to the top, reachable without
             scrolling, shown only while the wingman/briefing is speaking. One tap silences
             the read immediately. Centered so it never collides with the burger menu. -->
        <Button x:Name="StopTalkingButton" Text="Stop talking"
                IsVisible="False" Clicked="OnStopTalkingClicked"
                HorizontalOptions="Center" VerticalOptions="Start" Margin="0,12,0,0"
                Padding="22,0" HeightRequest="52" CornerRadius="26"
                BackgroundColor="#E5484D" TextColor="White"
                FontSize="16" FontAttributes="Bold" />

        <!-- Top-right burger menu: switch between pages. -->
        <Border x:Name="NavMenuButton"
                HorizontalOptions="End" VerticalOptions="Start"
                Margin="0,14,16,0" Padding="11,9"
                BackgroundColor="#141B2E" Stroke="#2A3550"
                StrokeShape="RoundRectangle 8">
            <VerticalStackLayout Spacing="4" WidthRequest="22">
                <BoxView HeightRequest="2" Color="#E6EAF2" />
                <BoxView HeightRequest="2" Color="#E6EAF2" />
                <BoxView HeightRequest="2" Color="#E6EAF2" />
            </VerticalStackLayout>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnNavMenuClicked" />
            </Border.GestureRecognizers>
        </Border>
    </Grid>
</ContentPage>
