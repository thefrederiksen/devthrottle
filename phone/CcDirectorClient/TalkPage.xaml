<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:CcDirectorClient.Controls"
             x:Class="CcDirectorClient.TalkPage"
             BackgroundColor="#0B1020"
             Shell.NavBarIsVisible="False"
             Title="Sessions">

    <Grid>

        <!-- ===== Session list (roster). Stays in a ScrollView; toggled with TalkPanel. -->
        <ScrollView x:Name="ListPanel">
            <VerticalStackLayout Padding="20" Spacing="16">

                <Label Text="Sessions"
                       FontSize="26" FontAttributes="Bold" TextColor="#E6EAF2" />
                <Label Text="Pick a session to talk to one-on-one, or start FIFO to go through everything that needs you."
                       FontSize="13" TextColor="#8A93A6" />

                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <Label Grid.Column="0" Text="Sessions" FontSize="18" FontAttributes="Bold"
                           TextColor="#E6EAF2" VerticalOptions="Center" />
                    <Button Grid.Column="1" x:Name="RefreshButton" Text="Refresh"
                            BackgroundColor="#2B6CB0" TextColor="White" Clicked="OnRefreshClicked" />
                </Grid>
                <Label x:Name="ListStatusLabel" Text="Loading sessions..." FontSize="13" TextColor="#8A93A6" />

                <Button x:Name="NewSessionButton" Text="+ New session"
                        BackgroundColor="#5FD08A" TextColor="#06210F" HeightRequest="50"
                        CornerRadius="12" FontAttributes="Bold" Clicked="OnNewSessionClicked" />

                <Button x:Name="FifoButton" Text="FIFO - go through everything that needs me"
                        BackgroundColor="#6B46C1" TextColor="White" HeightRequest="50"
                        CornerRadius="12" Clicked="OnFifoClicked" />

                <CollectionView x:Name="SessionsList" SelectionMode="Single"
                                SelectionChanged="OnSessionSelected" HeightRequest="420">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="#141B2E" StrokeShape="RoundRectangle 10" Padding="12" Margin="0,3">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                    <Border Grid.Column="0" WidthRequest="14" HeightRequest="14"
                                            StrokeShape="RoundRectangle 7" BackgroundColor="{Binding Dot}"
                                            VerticalOptions="Center" />
                                    <VerticalStackLayout Grid.Column="1" Spacing="2">
                                        <Label Text="{Binding Name}" TextColor="#E6EAF2" FontAttributes="Bold" />
                                        <Label Text="{Binding Subtitle}" TextColor="#8A93A6" FontSize="12" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Gateway settings (out of the way; pre-filled) -->
                <Label Text="Gateway settings" FontSize="13" FontAttributes="Bold" TextColor="#5A6378" Margin="0,12,0,0" />

                <!-- Scan the Cockpit "Connect a phone" QR to fill both fields in one tap (issue
                     #386). The manual Entry fields below stay as a fallback. -->
                <Button x:Name="ScanQrButton" Text="Scan QR to connect"
                        BackgroundColor="#2B6CB0" TextColor="White" HeightRequest="48"
                        CornerRadius="12" FontAttributes="Bold" Clicked="OnScanQrClicked" />
                <Label x:Name="ScanStatusLabel" Text="" FontSize="12" TextColor="#8A93A6" IsVisible="False" />

                <Entry x:Name="ServerEntry" Placeholder="https://gateway-host.ts.net"
                       TextColor="#A9B4C8" PlaceholderColor="#5A6378" BackgroundColor="#0F1626"
                       Unfocused="OnCredsChanged" />
                <Entry x:Name="TokenEntry" Placeholder="Gateway token (optional)" IsPassword="True"
                       TextColor="#A9B4C8" PlaceholderColor="#5A6378" BackgroundColor="#0F1626"
                       Unfocused="OnCredsChanged" />
            </VerticalStackLayout>
        </ScrollView>

        <!-- ===== Single-session detail. Grid Auto,* so the tab content area has a
             bounded height: that lets the Voice tab's VoiceSessionView use its own
             pinned-top driving-safety layout (Grid Auto,* inside Grid Auto,*) instead
             of having its buttons scroll. -->
        <Grid x:Name="TalkPanel" IsVisible="False" RowDefinitions="Auto,*">

            <!-- Header: back, session card, tab switcher. Fixed at the top. -->
            <VerticalStackLayout Grid.Row="0" Padding="20,20,20,8" Spacing="12">
                <Button x:Name="BackButton" Text="&lt; Back to sessions"
                        BackgroundColor="Transparent" TextColor="#8A93A6"
                        HorizontalOptions="Start" Padding="0" Clicked="OnBackClicked" />

                <Border BackgroundColor="#141B2E" StrokeShape="RoundRectangle 14" Padding="14">
                    <VerticalStackLayout Spacing="4">
                        <Label x:Name="TalkSessionName" Text="" FontSize="20"
                               FontAttributes="Bold" TextColor="#E6EAF2" />
                        <Label x:Name="TalkSessionState" Text="" FontSize="12" TextColor="#8A93A6" />
                    </VerticalStackLayout>
                </Border>

                <!-- Tab switcher: Voice / Wingman / Terminal. All three swap inline content
                     below; Voice IS the shared FIFO voice control, just hosted in this tab.
                     The Voice column collapses to width 0 on wingman-off sessions (Voice is
                     hidden there), so Wingman + Terminal fill the bar with no empty gap. -->
                <Grid x:Name="TabSwitcher" ColumnDefinitions="*,*,*" ColumnSpacing="6">
                    <Button Grid.Column="0" x:Name="VoiceTabButton" Text="Voice"
                            BackgroundColor="#2B6CB0" TextColor="White" HeightRequest="44"
                            CornerRadius="10" FontAttributes="Bold" Clicked="OnVoiceTabClicked" />
                    <Button Grid.Column="1" x:Name="WingmanTabButton" Text="Wingman"
                            BackgroundColor="#1A2236" TextColor="#8A93A6" HeightRequest="44"
                            CornerRadius="10" Clicked="OnWingmanTabClicked" />
                    <Button Grid.Column="2" x:Name="TerminalTabButton" Text="Terminal"
                            BackgroundColor="#1A2236" TextColor="#8A93A6" HeightRequest="44"
                            CornerRadius="10" Clicked="OnTerminalTabClicked" />
                </Grid>
            </VerticalStackLayout>

            <!-- Tab content area: all three sections share Row 1 and toggle IsVisible. -->
            <Grid Grid.Row="1">

                <!-- ========== VOICE SECTION: walkie-talkie. Tap Record, talk, tap Submit;
                     the words are transcribed and sent to the agent, then the agent's reply
                     is spoken aloud (OpenAI voice) and shown. Rows: status (Auto), the
                     you-said / agent-reply transcript (*), and the record controls (Auto). -->
                <Grid x:Name="VoiceSection" IsVisible="True"
                      RowDefinitions="Auto,Auto,*,Auto" Padding="20,8,20,16" RowSpacing="12">

                    <Label Grid.Row="0" x:Name="VoiceStatusLabel"
                           Text="Tap Record and talk to the agent." FontSize="14"
                           TextColor="#8A93A6" HorizontalOptions="Center" HorizontalTextAlignment="Center" />

                    <!-- Recording state indicators: visible only while mic is open. -->
                    <VerticalStackLayout Grid.Row="1" x:Name="RecordingIndicatorPanel"
                                         IsVisible="False" Spacing="10" HorizontalOptions="Center">
                        <Grid ColumnDefinitions="Auto,Auto,Auto" ColumnSpacing="14"
                              HorizontalOptions="Center" VerticalOptions="Center">
                            <!-- Pulsing red dot -->
                            <BoxView x:Name="RecordPulseDot" Grid.Column="0"
                                     WidthRequest="18" HeightRequest="18" CornerRadius="9"
                                     Color="#F44747" VerticalOptions="Center" />
                            <!-- RECORDING label -->
                            <Label x:Name="RecordingLabel" Grid.Column="1"
                                   Text="RECORDING" FontSize="26" FontAttributes="Bold"
                                   TextColor="#F44747" VerticalOptions="Center" />
                            <!-- Elapsed timer -->
                            <Label x:Name="RecordTimerLabel" Grid.Column="2"
                                   Text="0:00" FontFamily="Consolas" FontSize="16"
                                   TextColor="#8A93A6" VerticalOptions="Center" />
                        </Grid>
                    </VerticalStackLayout>

                    <ScrollView Grid.Row="2">
                        <VerticalStackLayout Spacing="12">
                            <Border x:Name="VoiceYouCard" IsVisible="False" BackgroundColor="#0F1626"
                                    StrokeShape="RoundRectangle 12" Padding="14">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="YOU SAID" FontSize="11" FontAttributes="Bold" TextColor="#37C2B6" />
                                    <Label x:Name="VoiceYouLabel" Text="" TextColor="#E6EAF2" FontSize="15" />
                                </VerticalStackLayout>
                            </Border>
                            <Border x:Name="VoiceReplyCard" IsVisible="False" BackgroundColor="#0F1626"
                                    StrokeShape="RoundRectangle 12" Padding="14">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="AGENT" FontSize="11" FontAttributes="Bold" TextColor="#5FD08A" />
                                    <Label x:Name="VoiceReplyLabel" Text="" TextColor="#E6EAF2" FontSize="15" />
                                </VerticalStackLayout>
                            </Border>
                        </VerticalStackLayout>
                    </ScrollView>

                    <VerticalStackLayout Grid.Row="3" Spacing="8">
                        <!-- Shown only while the reply is playing (issue #146 parity). -->
                        <Button x:Name="VoiceStopSpeakingButton" Text="Stop talking" IsVisible="False"
                                BackgroundColor="#E5484D" TextColor="White" HeightRequest="44"
                                CornerRadius="10" Clicked="OnVoiceStopSpeakingClicked" />
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <!-- Toggles Record (green) <-> Submit (red) for walkie-talkie capture. -->
                            <Button Grid.Column="0" x:Name="VoiceRecordButton" Text="Record"
                                    BackgroundColor="#5FD08A" TextColor="#06210F" HeightRequest="64"
                                    CornerRadius="14" FontSize="18" FontAttributes="Bold"
                                    Clicked="OnVoiceRecordClicked" />
                            <Button Grid.Column="1" x:Name="VoiceCancelButton" Text="Cancel" IsVisible="False"
                                    BackgroundColor="#1A2236" TextColor="#8A93A6" HeightRequest="64"
                                    Padding="20,0" CornerRadius="14" Clicked="OnVoiceCancelClicked" />
                        </Grid>
                    </VerticalStackLayout>
                </Grid>

                <!-- ========== WINGMAN SECTION: the structured turn brief =============
                     Renders the Gateway's latest TurnBriefDto verbatim (headline / you're
                     doing / you asked / NEEDS YOU with tappable options / ALL CLEAR / CLAUDE
                     DID / mission-complete), the same brief the desktop BriefPane shows. The
                     brief cards are built in code into WingmanBriefContainer because their
                     content is variable; the status header and the Speak/Send composer are
                     fixed. -->
                <ScrollView x:Name="WingmanSection" IsVisible="False" Padding="16,4,16,16">
                    <VerticalStackLayout Spacing="11">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <Label Grid.Column="0" x:Name="WingmanStatusLabel" Text="" FontSize="12"
                                   TextColor="#8A93A6" VerticalOptions="Center" />
                            <Button Grid.Column="1" x:Name="WingmanRefreshButton" Text="Refresh"
                                    BackgroundColor="#1A2236" TextColor="#8A93A6" HeightRequest="34"
                                    Padding="12,0" CornerRadius="8" FontSize="12"
                                    Clicked="OnWingmanRefreshClicked" />
                        </Grid>

                        <!-- Brief cards are inserted here at runtime by RenderBrief(). -->
                        <VerticalStackLayout x:Name="WingmanBriefContainer" Spacing="11" />

                        <Entry x:Name="WingmanInput" Placeholder="reply or ask..."
                               TextColor="#E6EAF2" PlaceholderColor="#5A6378" BackgroundColor="#0F1626" />
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                            <Button Grid.Column="0" x:Name="WingmanSpeakButton" Text="Speak"
                                    BackgroundColor="#0E7C6B" TextColor="White" HeightRequest="50"
                                    CornerRadius="12" Clicked="OnWingmanSpeakClicked" />
                            <Button Grid.Column="1" x:Name="WingmanSendButton" Text="Send"
                                    BackgroundColor="#2B6CB0" TextColor="White" HeightRequest="50"
                                    CornerRadius="12" Clicked="OnWingmanSendClicked" />
                        </Grid>
                    </VerticalStackLayout>
                </ScrollView>

                <!-- ========== TERMINAL SECTION (read-only mirror + control buttons) ==========
                     Issue #244: NO outer ScrollView and NO fixed WebView height. The WebView
                     is the only scroll container (it owns both axes: xterm vertical scrollback
                     + #wrap horizontal pan, with an in-page Fit-width toggle). Rows: status bar
                     (Auto), the terminal filling all remaining space (*), and a collapsible
                     controls panel (Auto) so the terminal is maximized by default. -->
                <Grid x:Name="TerminalSection" IsVisible="False"
                      RowDefinitions="Auto,*,Auto" Padding="12,4,12,12" RowSpacing="8">

                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Label Grid.Column="0" x:Name="TerminalStatusLabel" Text="" FontSize="13"
                               TextColor="#8A93A6" VerticalOptions="Center" />
                        <Button Grid.Column="1" x:Name="TerminalKeysToggle" Text="Keys"
                                BackgroundColor="#1A2236" TextColor="#8A93A6" HeightRequest="34"
                                Padding="12,0" CornerRadius="8" FontSize="12"
                                Clicked="OnTerminalKeysToggleClicked" />
                    </Grid>

                    <!-- Terminal fills all remaining vertical space (parent row is '*'). -->
                    <Border Grid.Row="1" BackgroundColor="#06090F" StrokeShape="RoundRectangle 8" Padding="0">
                        <WebView x:Name="TerminalWebView" BackgroundColor="#1E1E1E"
                                 VerticalOptions="Fill" HorizontalOptions="Fill" />
                    </Border>

                    <!-- Collapsible controls: hidden by default so the terminal is maximized.
                         The Keys button toggles this whole panel. -->
                    <VerticalStackLayout Grid.Row="2" x:Name="TerminalControls" IsVisible="False" Spacing="8">
                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                            <Entry Grid.Column="0" x:Name="TerminalInput" Placeholder="type / send..."
                                   TextColor="#E6EAF2" PlaceholderColor="#5A6378" BackgroundColor="#0F1626" />
                            <Button Grid.Column="1" x:Name="TerminalSpeakButton" Text="Speak"
                                    BackgroundColor="#0E7C6B" TextColor="White" HeightRequest="46"
                                    Padding="16,0" CornerRadius="10" Clicked="OnTerminalSpeakClicked" />
                            <Button Grid.Column="2" x:Name="TerminalSendButton" Text="Send"
                                    BackgroundColor="#2B6CB0" TextColor="White" HeightRequest="46"
                                    Padding="16,0" CornerRadius="10" Clicked="OnTerminalSendClicked" />
                        </Grid>

                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8" RowSpacing="8">
                            <Button Grid.Column="0" x:Name="TerminalEnterButton" Text="Enter"
                                    BackgroundColor="#5FD08A" TextColor="#06210F" HeightRequest="44"
                                    CornerRadius="10" FontAttributes="Bold" Clicked="OnTerminalEnterClicked" />
                            <Button Grid.Column="1" x:Name="TerminalEscButton" Text="Esc"
                                    BackgroundColor="#E8B339" TextColor="#221A06" HeightRequest="44"
                                    CornerRadius="10" FontAttributes="Bold" Clicked="OnTerminalEscClicked" />
                            <Button Grid.Column="2" x:Name="TerminalStopButton" Text="Stop"
                                    BackgroundColor="#E5484D" TextColor="White" HeightRequest="44"
                                    CornerRadius="10" FontAttributes="Bold" Clicked="OnTerminalStopClicked" />
                        </Grid>
                        <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8">
                            <Button Grid.Column="0" x:Name="TerminalUpButton" Text="Up"
                                    BackgroundColor="#1A2236" TextColor="#E6EAF2" HeightRequest="44"
                                    CornerRadius="10" Clicked="OnTerminalUpClicked" />
                            <Button Grid.Column="1" x:Name="TerminalDownButton" Text="Down"
                                    BackgroundColor="#1A2236" TextColor="#E6EAF2" HeightRequest="44"
                                    CornerRadius="10" Clicked="OnTerminalDownClicked" />
                            <Button Grid.Column="2" x:Name="TerminalLeftButton" Text="Left"
                                    BackgroundColor="#1A2236" TextColor="#E6EAF2" HeightRequest="44"
                                    CornerRadius="10" Clicked="OnTerminalLeftClicked" />
                            <Button Grid.Column="3" x:Name="TerminalRightButton" Text="Right"
                                    BackgroundColor="#1A2236" TextColor="#E6EAF2" HeightRequest="44"
                                    CornerRadius="10" Clicked="OnTerminalRightClicked" />
                        </Grid>
                    </VerticalStackLayout>
                </Grid>
            </Grid>
        </Grid>

        <!-- ===== New-session flow (issue #245): pick a fleet Director, then a recent
             repo, then create. Header fixed (Auto), the two pickers scroll (*). -->
        <Grid x:Name="NewSessionPanel" IsVisible="False" RowDefinitions="Auto,*">

            <VerticalStackLayout Grid.Row="0" Padding="20,20,20,8" Spacing="8">
                <Button x:Name="NewSessionBackButton" Text="&lt; Back to sessions"
                        BackgroundColor="Transparent" TextColor="#8A93A6"
                        HorizontalOptions="Start" Padding="0" Clicked="OnNewSessionBackClicked" />
                <Label Text="Start a new session" FontSize="24" FontAttributes="Bold" TextColor="#E6EAF2" />
                <Label x:Name="NewSessionStatusLabel" Text="" FontSize="13" TextColor="#8A93A6" />
            </VerticalStackLayout>

            <ScrollView Grid.Row="1" Padding="20,0,20,20">
                <VerticalStackLayout Spacing="12">

                    <!-- Step 1: machine -->
                    <Label Text="1. Machine" FontSize="16" FontAttributes="Bold" TextColor="#E6EAF2" />
                    <Label x:Name="DirectorsStatusLabel" Text="Loading machines..."
                           FontSize="12" TextColor="#8A93A6" />
                    <CollectionView x:Name="DirectorsList" SelectionMode="Single"
                                    SelectionChanged="OnDirectorSelected" HeightRequest="150">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border BackgroundColor="#141B2E" StrokeShape="RoundRectangle 10" Padding="12" Margin="0,3">
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="{Binding Name}" TextColor="#E6EAF2" FontAttributes="Bold" />
                                        <Label Text="{Binding Subtitle}" TextColor="#8A93A6" FontSize="12" />
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- Step 2: repo -->
                    <Label Text="2. Repository" FontSize="16" FontAttributes="Bold" TextColor="#E6EAF2" Margin="0,6,0,0" />
                    <Label x:Name="ReposStatusLabel" Text="Pick a machine first."
                           FontSize="12" TextColor="#8A93A6" />
                    <CollectionView x:Name="ReposList" SelectionMode="Single"
                                    SelectionChanged="OnRepoSelected" HeightRequest="240">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border BackgroundColor="#141B2E" StrokeShape="RoundRectangle 10" Padding="12" Margin="0,3">
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="{Binding Name}" TextColor="#E6EAF2" FontAttributes="Bold" />
                                        <Label Text="{Binding Subtitle}" TextColor="#8A93A6" FontSize="12" />
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- Or a path not in the recent list -->
                    <Label Text="Or enter a path" FontSize="13" FontAttributes="Bold" TextColor="#5A6378" Margin="0,6,0,0" />
                    <Entry x:Name="NewSessionPathEntry" Placeholder="D:\Repos\my-project"
                           TextColor="#E6EAF2" PlaceholderColor="#5A6378" BackgroundColor="#0F1626" />
                    <Button x:Name="NewSessionCreateButton" Text="Create session"
                            BackgroundColor="#5FD08A" TextColor="#06210F" HeightRequest="50"
                            CornerRadius="12" FontAttributes="Bold" Clicked="OnCreateSessionClicked" />
                </VerticalStackLayout>
            </ScrollView>
        </Grid>

        <!-- Top-right burger menu: switch between pages. The Stop-talking pill is owned
             by the VoiceSessionView itself (only voice playback needs it). -->
        <Border x:Name="NavMenuButton"
                HorizontalOptions="End" VerticalOptions="Start"
                Margin="0,14,16,0" Padding="11,9"
                BackgroundColor="#141B2E" Stroke="#2A3550"
                StrokeShape="RoundRectangle 8">
            <VerticalStackLayout Spacing="4" WidthRequest="22">
                <BoxView HeightRequest="2" Color="#E6EAF2" />
                <BoxView HeightRequest="2" Color="#E6EAF2" />
                <BoxView HeightRequest="2" Color="#E6EAF2" />
            </VerticalStackLayout>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnNavMenuClicked" />
            </Border.GestureRecognizers>
        </Border>
    </Grid>
</ContentPage>
